<Window x:Class="MBColumn.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        xmlns:views="clr-namespace:MBColumn.Presentation.Wpf.Views"
        Title="{Binding WindowTitle}"
        Icon="Resources/desktop-icon.png"
        Height="900" Width="1460" MinHeight="780" MinWidth="1280">
    <Window.Resources>
        <Style x:Key="EmptyStateCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="Padding" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ExplorerStatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="6,1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Calculated}">
                    <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Outdated}">
                    <Setter Property="Background" Value="#FFF7E6" />
                    <Setter Property="BorderBrush" Value="#C98600" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Error}">
                    <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentRedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{DynamicResource PrimaryNavyBrush}" Padding="16,10">
            <DockPanel>
                <TextBlock Text="MBColumn" Style="{StaticResource AppTitleTextStyle}" VerticalAlignment="Center" />
                <TextBlock Text="Reinforced concrete column design"
                           Style="{StaticResource AppSubtitleTextStyle}"
                           VerticalAlignment="Center"
                           Margin="14,4,0,0" />
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding NewProjectCommand}"
                        ToolTip="New Project (Ctrl+N)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="New" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenProjectCommand}"
                        ToolTip="Open Project (Ctrl+O)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Open" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveProjectCommand}"
                        ToolTip="Save Project (Ctrl+S)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Save" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveProjectAsCommand}"
                        ToolTip="Save Project As…"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Save As" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Button>
                <Separator Margin="0,4,12,4" />
                <Button Click="CalculateButton_Click"
                        IsEnabled="{Binding HasCurrentSection}"
                        ToolTip="Choose calculation scope"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinHeight="30" Padding="14,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Calculate This Section" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="8,1,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Calculate This Section"
                                      Command="{Binding Path=PlacementTarget.DataContext.CalculateCurrentColumnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="Calculate All Sections"
                                      Command="{Binding Path=PlacementTarget.DataContext.CalculateAllColumnsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Width="130"
                                 Height="12"
                                 IsIndeterminate="True"
                                 VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CalculationStatus}"
                               FontSize="12"
                               Foreground="{DynamicResource TextDarkBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content: sidebar + tabs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="320" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Project Explorer -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Explorer header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource PrimaryNavyBrush}"
                            Padding="10,6">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding Explorer.AddColumnCommand}"
                                    ToolTip="Add Section"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    MinHeight="0"
                                    Cursor="Hand">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                            <TextBlock Text="{Binding Explorer.ProjectName}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Border>

                    <!-- Section list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Explorer.Columns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6"
                                            Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}" />
                                        </Border.InputBindings>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename Section"
                                                          Command="{Binding Path=PlacementTarget.DataContext.BeginRenameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Separator />
                                                <MenuItem Header="Duplicate Section"
                                                          Command="{Binding Path=PlacementTarget.DataContext.DuplicateCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="Delete Section"
                                                          Command="{Binding Path=PlacementTarget.DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <!-- Normal label -->
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="Right-click for section actions"
                                                       Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="White" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border Grid.Row="1"
                                                    Style="{StaticResource ExplorerStatusBadgeStyle}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,5,0,0"
                                                    Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                            </Border>
                                            <!-- Inline rename TextBox -->
                                            <TextBox Grid.RowSpan="2"
                                                     Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="12"
                                                     Padding="2,1"
                                                     Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibilityConverter}}"
                                                     KeyDown="ColumnRenameBox_KeyDown"
                                                     LostFocus="ColumnRenameBox_LostFocus"
                                                     IsVisibleChanged="RenameBox_IsVisibleChanged" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderGreyBrush}" />

            <!-- Tabs -->
            <TabControl Grid.Column="2" Margin="14,14,18,18"
                        SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}"
                        Background="{DynamicResource LightBackgroundBrush}"
                        Foreground="{DynamicResource TextDarkBrush}">
                <TabItem Header="Input"
                         Background="{DynamicResource PanelBackgroundBrush}"
                         Foreground="{DynamicResource TextDarkBrush}">
                    <Grid Margin="0,12,0,0">
                        <views:InputTabView DataContext="{Binding Input}"
                                            Visibility="{Binding DataContext.HasCurrentSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowInputEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="No section selected."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center" />
                                <TextBlock Text="Create or select a section from the Project Explorer to begin."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Add Section"
                                        Command="{Binding Explorer.AddColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Results"
                         IsEnabled="{Binding IsResultsTabAvailable}"
                         Background="{DynamicResource PanelBackgroundBrush}"
                         Foreground="{DynamicResource TextDarkBrush}">
                    <Grid Margin="0,12,0,0">
                        <views:ResultTabView DataContext="{Binding Result}"
                                             Visibility="{Binding DataContext.ShowResultContent, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowNoSectionResultEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="No section selected."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center" />
                                <TextBlock Text="Create or select a section from the Project Explorer to review results."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Add Section"
                                        Command="{Binding Explorer.AddColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowNoResultEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="No calculation result yet."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center" />
                                <TextBlock Text="Click Calculate to generate the PMM capacity surface and demand/capacity ratio."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Calculate This Section"
                                        Command="{Binding CalculateCurrentColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowOutdatedResultEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Input has changed after the last calculation."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Recalculate to update the result."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Recalculate"
                                        Command="{Binding CalculateCurrentColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
        <StatusBar Grid.Row="3"
                   Background="{DynamicResource PanelBackgroundBrush}"
                   BorderBrush="{DynamicResource BorderGreyBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="10,2">
            <TextBlock Text="{Binding AppStatusText}" />
            <Separator />
            <TextBlock Text="{Binding ProjectStatusText}" />
            <Separator />
            <TextBlock Text="{Binding CurrentSectionStatusText}" />
            <Separator />
            <TextBlock Text="{Binding ModifiedStatusText}" />
            <Separator />
            <TextBlock Text="{Binding ResultFreshnessStatusText}" />
        </StatusBar>
    </Grid>
</Window>
