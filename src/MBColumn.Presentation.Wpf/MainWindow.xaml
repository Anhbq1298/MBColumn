<Window x:Class="MBColumn.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        xmlns:views="clr-namespace:MBColumn.Presentation.Wpf.Views"
        Title="MBColumn"
        Icon="Resources/desktop-icon.png"
        Height="900" Width="1360" MinHeight="780" MinWidth="1180">
    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="66" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Background="{DynamicResource PrimaryNavyBrush}" Padding="24,12">
            <DockPanel>
                <TextBlock Text="MBColumn" Style="{StaticResource AppTitleTextStyle}" VerticalAlignment="Center" />
                <TextBlock Text="Strain compatibility capacity check"
                           Style="{StaticResource AppSubtitleTextStyle}"
                           VerticalAlignment="Center"
                           Margin="18,5,0,0" />
            </DockPanel>
        </Border>
        <TabControl Grid.Row="1" Margin="18,16,18,18"
                    Background="{DynamicResource LightBackgroundBrush}"
                    Foreground="{DynamicResource TextDarkBrush}">
            <TabItem Header="Input"
                     Background="{DynamicResource PanelBackgroundBrush}"
                     Foreground="{DynamicResource TextDarkBrush}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <views:InputTabView Grid.Row="0" DataContext="{Binding Input}" />
                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <Button Content="Calculate PMM Capacity"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CalculateCommand}"
                                HorizontalAlignment="Left"
                                MinWidth="210" />
                        <TextBlock Text="{Binding ValidationMessage}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Results"
                     IsEnabled="{Binding Result.HasResult}"
                     Background="{DynamicResource PanelBackgroundBrush}"
                     Foreground="{DynamicResource TextDarkBrush}">
                <views:ResultTabView DataContext="{Binding Result}" Margin="0,12,0,0" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>

