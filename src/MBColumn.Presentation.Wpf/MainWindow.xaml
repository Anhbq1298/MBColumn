<Window x:Class="MBColumn.Presentation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        xmlns:views="clr-namespace:MBColumn.Presentation.Wpf.Views"
        Title="{Binding WindowTitle}"
        Icon="Resources/desktop-icon.png"
        Height="960" Width="1680" MinHeight="800" MinWidth="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="EmptyStateCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="MaxWidth" Value="520" />
            <Setter Property="Padding" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ExplorerStatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="6,1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Calculated}">
                    <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Outdated}">
                    <Setter Property="Background" Value="#FFF7E6" />
                    <Setter Property="BorderBrush" Value="#C98600" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Error}">
                    <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentRedBrush}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Calculated}" />
                        <Condition Binding="{Binding OverallStatus}" Value="FAIL" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentRedBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Status}" Value="{x:Static vm:SectionStatus.Calculated}" />
                        <Condition Binding="{Binding OverallStatus}" Value="WARNING" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFF7E6" />
                    <Setter Property="BorderBrush" Value="#C98600" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{DynamicResource PrimaryNavyBrush}" Padding="16,10">
            <DockPanel>
                <TextBlock Text="MBColumn" Style="{DynamicResource AppTitleTextStyle}" VerticalAlignment="Center" />
                <TextBlock Text="Reinforced concrete column design"
                           Style="{DynamicResource AppSubtitleTextStyle}"
                           VerticalAlignment="Center"
                           Margin="14,4,0,0" />
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding NewProjectCommand}"
                        ToolTip="New Project (Ctrl+N)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="New" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenProjectCommand}"
                        ToolTip="Open Project (Ctrl+O)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Open" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveProjectCommand}"
                        ToolTip="Save Project (Ctrl+S)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Save" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveProjectAsCommand}"
                        ToolTip="Save Project As…"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Save As" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding BatchPrintCommand}"
                        ToolTip="Batch print PDF reports for multiple sections"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="30" Padding="10,4"
                        Margin="4,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Batch Print" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </Button>
                <Separator Margin="0,4,12,4" />
                <Button Click="CalculateButton_Click"
                        IsEnabled="{Binding HasSections}"
                        ToolTip="Choose calculation scope"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinHeight="30" Padding="14,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <TextBlock Text="Calculate" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="8,1,0,0" VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                             <MenuItem Header="Calculate This Section"
                                       Command="{Binding Path=PlacementTarget.DataContext.CalculateCurrentColumnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                             <MenuItem Header="Calculate Selected Sections"
                                       Command="{Binding Path=PlacementTarget.DataContext.CalculateSelectedColumnsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                             <MenuItem Header="Calculate All Sections"
                                       Command="{Binding Path=PlacementTarget.DataContext.CalculateAllColumnsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Width="130"
                                 Height="12"
                                 IsIndeterminate="True"
                                 VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CalculationStatus}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextDarkBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content: sidebar + tabs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <!-- Project Explorer -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Explorer header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource PrimaryNavyBrush}"
                            Padding="10,6">
                        <DockPanel>
                            <!-- + Section button -->
                            <Button DockPanel.Dock="Right"
                                    Click="AddSectionButton_Click"
                                    ToolTip="Add Section"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    MinHeight="0"
                                    Cursor="Hand">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Add Manually"
                                                  Command="{Binding Path=PlacementTarget.DataContext.Explorer.AddColumnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Import from ETABS"
                                                  Command="{Binding Path=PlacementTarget.DataContext.ImportFromEtabsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <!-- + Group button -->
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding Explorer.AddGroupCommand}"
                                    ToolTip="Add Group"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    MinHeight="0"
                                    Cursor="Hand">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                            <TextBlock Text="{Binding Explorer.ProjectName}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeBody}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Border>

                    <!-- Section list -->
                    <TreeView ItemsSource="{Binding Explorer.Nodes}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              BorderThickness="0" Background="Transparent"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                        <TreeView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </TreeView.ItemsPanel>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="4,4" />
                                <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
                                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <!-- Group Template -->
                                <HierarchicalDataTemplate DataType="{x:Type vm:GroupItemViewModel}" ItemsSource="{Binding Columns}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,2" Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsThreeState="True" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="📁 " VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <StackPanel.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rename" Command="{Binding BeginRenameCommand}" />
                                                    <MenuItem Header="Add New Section" Command="{Binding AddSectionCommand}" />
                                                    <MenuItem Header="Add Existing Sections..." Command="{Binding AddExistingSectionsCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Print Group Reports..." 
                                                              Command="{Binding Path=PlacementTarget.DataContext.PrintGroupReportsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" Foreground="{DynamicResource AccentRedBrush}" />
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                        </StackPanel>
                                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 KeyDown="NodeRenameBox_KeyDown"
                                                 LostFocus="NodeRenameBox_LostFocus"
                                                 IsVisibleChanged="RenameBox_IsVisibleChanged" />
                                    </Grid>
                                </HierarchicalDataTemplate>

                                <!-- Column Template -->
                                <DataTemplate DataType="{x:Type vm:ColumnItemViewModel}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,2" Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsThreeState="False" VerticalAlignment="Top" Margin="0,3,6,0" />
                                            <StackPanel Orientation="Vertical">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📄 " VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <Border Margin="0,2,0,0"
                                                        HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource ExplorerStatusBadgeStyle}" />
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextDarkBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel.ContextMenu>
                                                <ContextMenu Opened="ColumnContextMenu_Opened">
                                                    <MenuItem Header="Rename" Command="{Binding BeginRenameCommand}" />
                                                    <MenuItem Header="Duplicate" Command="{Binding DuplicateCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="Print Report as PDF..."
                                                              Command="{Binding Path=PlacementTarget.DataContext.PrintSingleReportCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}" />
                                                    <Separator />
                                                    <MenuItem Header="Move to Group..." ItemsSource="{Binding MoveToGroupOptions}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding Name}" />
                                                                <Setter Property="Command" Value="{Binding Command}" />
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                    <Separator />
                                                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" Foreground="{DynamicResource AccentRedBrush}" />
                                                </ContextMenu>
                                            </StackPanel.ContextMenu>
                                        </StackPanel>
                                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 KeyDown="NodeRenameBox_KeyDown"
                                                 LostFocus="NodeRenameBox_LostFocus"
                                                 IsVisibleChanged="RenameBox_IsVisibleChanged" />
                                    </Grid>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                </DockPanel>
            </Border>

            <!-- Divider (non-resizable) -->
            <Border Grid.Column="1" Background="{DynamicResource BorderGreyBrush}" />

            <!-- Tabs -->
            <TabControl Grid.Column="2" Margin="14,14,18,18"
                        SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}"
                        Background="{DynamicResource LightBackgroundBrush}"
                        Foreground="{DynamicResource TextDarkBrush}">
                <TabItem Header="Input"
                         Background="{DynamicResource PanelBackgroundBrush}"
                         Foreground="{DynamicResource TextDarkBrush}">
                    <Grid Margin="0,12,0,0">
                        <views:InputTabView DataContext="{Binding Input}"
                                            Visibility="{Binding DataContext.HasCurrentSection, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowInputEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="No section selected."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center" />
                                <TextBlock Text="Create or select a section from the Project Explorer to begin."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Add Section"
                                        Command="{Binding Explorer.AddColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Results"
                         IsEnabled="{Binding IsResultsTabAvailable}"
                         Background="{DynamicResource PanelBackgroundBrush}"
                         Foreground="{DynamicResource TextDarkBrush}">
                    <Grid Margin="0,12,0,0">
                        <!-- Combined Results summary + Report side-by-side (30 / 50 / 20) -->
                        <Grid Visibility="{Binding ShowResultContent, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" MinWidth="240" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="7*" MinWidth="480" />
                            </Grid.ColumnDefinitions>
                            <views:ResultTabView Grid.Column="0"
                                                 DataContext="{Binding Result}" />
                            <GridSplitter Grid.Column="1"
                                          Width="8"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource LightBackgroundBrush}" />
                            <views:ReportTabView Grid.Column="2"
                                                 DataContext="{Binding Report}" />

                            <!-- PMM details overlay — phủ toàn bộ Results tab -->
                            <Border Grid.Column="0" Grid.ColumnSpan="3"
                                    Background="#990B1220"
                                    Visibility="{Binding Result.IsPmmDetailsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="True">
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Margin="16">
                                    <views:PmmInteractionWindow DataContext="{Binding Result}" />
                                </Border>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowNoSectionResultEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="No section selected."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center" />
                                <TextBlock Text="Create or select a section from the Project Explorer to review results."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Add Section"
                                        Command="{Binding Explorer.AddColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowNoResultEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="No calculation result yet."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center" />
                                <TextBlock Text="Click Calculate to generate the PMM capacity surface and demand/capacity ratio."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Calculate This Section"
                                        Command="{Binding CalculateCurrentColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource EmptyStateCardStyle}"
                                Visibility="{Binding ShowOutdatedResultEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Input has changed after the last calculation."
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Recalculate to update the result."
                                           Style="{StaticResource HelperTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,18" />
                                <Button Content="Recalculate"
                                        Command="{Binding CalculateCurrentColumnCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
        <StatusBar Grid.Row="3"
                   Background="{DynamicResource PanelBackgroundBrush}"
                   BorderBrush="{DynamicResource BorderGreyBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="10,2">
            <TextBlock Text="{Binding AppStatusText}" />
            <Separator />
            <TextBlock Text="{Binding ProjectStatusText}" />
            <Separator />
            <TextBlock Text="{Binding CurrentSectionStatusText}" />
            <Separator />
            <TextBlock Text="{Binding ModifiedStatusText}" />
            <Separator />
            <TextBlock Text="{Binding ResultFreshnessStatusText}" />
        </StatusBar>

        <!-- Save Notification Toast Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,52,24,0"
                Visibility="{Binding IsSaveNotificationVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                IsHitTestVisible="False">
            <Border x:Name="SaveToastBorder"
                    CornerRadius="10"
                    Padding="16,12,20,12"
                    MinWidth="260"
                    Effect="{StaticResource CardElevationEffect}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B8A4E" Offset="0" />
                        <GradientStop Color="#1F8A55" Offset="0.5" />
                        <GradientStop Color="#178A46" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                    <TranslateTransform Y="0" />
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Border.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.25"
                                                 EasingFunction="{StaticResource SmoothEase}" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="-20" To="0" Duration="0:0:0.3"
                                                 EasingFunction="{StaticResource SmoothEase}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <StackPanel Orientation="Horizontal">
                    <!-- Animated checkmark circle -->
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="#FFFFFF" Opacity="0.22"
                            VerticalAlignment="Center" />
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="16" Foreground="White"
                               VerticalAlignment="Center"
                               Margin="-22,0,0,0"
                               Width="16" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SaveNotificationText}"
                                   Foreground="White"
                                   FontSize="{StaticResource FontSizeSection}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="All changes are persisted to disk."
                                   Foreground="#C8F0D8"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Saving Spinner Overlay (subtle top bar) -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,52,24,0"
                Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}"
                IsHitTestVisible="False">
            <Border CornerRadius="10"
                    Padding="16,12,20,12"
                    MinWidth="200"
                    Background="{DynamicResource PrimaryNavyBrush}"
                    Effect="{StaticResource CardElevationEffect}">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="18" Height="18"
                                 IsIndeterminate="True"
                                 VerticalAlignment="Center"
                                 Foreground="White"
                                 Background="Transparent"
                                 BorderBrush="Transparent" />
                    <TextBlock Text="Saving project…"
                               Foreground="White"
                               FontSize="{StaticResource FontSizeSection}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </StackPanel>
            </Border>
        </Border>

        <!-- Importing Spinner Overlay (subtle top bar) -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,52,24,0"
                Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibilityConverter}}"
                IsHitTestVisible="False">
            <Border CornerRadius="10"
                    Padding="16,12,20,12"
                    MinWidth="260"
                    Background="{DynamicResource PrimaryNavyBrush}"
                    Effect="{StaticResource CardElevationEffect}">
                <StackPanel>
                    <TextBlock Text="{Binding ImportStatusText}"
                               Foreground="White"
                               FontSize="{StaticResource FontSizeSection}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <ProgressBar Height="6"
                                 Minimum="0"
                                 Maximum="{Binding ImportProgressMax, Mode=OneWay}"
                                 Value="{Binding ImportProgressValue, Mode=OneWay}"
                                 Foreground="{DynamicResource AccentBlueBrush}"
                                 Background="{DynamicResource PanelBackgroundBrush}"
                                 BorderThickness="0" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
