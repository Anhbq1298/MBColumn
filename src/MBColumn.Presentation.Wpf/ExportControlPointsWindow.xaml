<Window x:Class="MBColumn.Presentation.Wpf.ExportControlPointsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Control Points"
        Icon="Resources/desktop-icon.png"
        Width="1280"
        Height="680"
        MinWidth="1040"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SidebarCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Export Settings"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Theta Selection"
                                   Style="{StaticResource GroupTitleTextStyle}"
                                   Margin="0,0,0,8" />

                        <RadioButton GroupName="ThetaSelection"
                                     IsChecked="{Binding IsCurrentViewSelected}"
                                     Margin="0,0,0,4">
                            <TextBlock Text="Current View" />
                        </RadioButton>
                        <TextBlock Text="{Binding CurrentViewDescription}"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="24,0,0,0" />
                        <TextBlock Text="{Binding CurrentViewScopeDescription}"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="24,2,0,10" />

                        <RadioButton GroupName="ThetaSelection"
                                     IsChecked="{Binding IsCustomThetaSelected}"
                                     Margin="0,0,0,4">
                            <TextBlock Text="Custom Theta" />
                        </RadioButton>
                        <Grid Margin="24,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding CustomThetaText, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsCustomThetaInputEnabled}"
                                     HorizontalContentAlignment="Right" />
                            <TextBlock Grid.Column="1"
                                       Text="deg"
                                       Style="{StaticResource UnitTextStyle}"
                                       Margin="6,0,0,0" />
                        </Grid>
                        <TextBlock Text="{Binding ThetaValidationMessage}"
                                   Style="{StaticResource HelperTextStyle}"
                                   Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="24,0,0,10" />

                        <RadioButton GroupName="ThetaSelection"
                                     IsChecked="{Binding IsAllThetaSelected}"
                                     Margin="0,0,0,4">
                            <TextBlock Text="All Theta" />
                        </RadioButton>
                        <TextBlock Text="Export all available theta datasets."
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="24,0,0,14" />

                        <Separator Margin="0,0,0,12" />

                        <TextBlock Text="Preview"
                                   Style="{StaticResource GroupTitleTextStyle}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding PreviewSummary}"
                                   Style="{StaticResource HelperTextStyle}" />
                        <TextBlock Text="{Binding StrainSignConventionNote}"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ColumnHeaderNote}"
                                   Style="{StaticResource HelperTextStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="14,14,14,10">
                        <Button DockPanel.Dock="Right"
                                Content="Refresh Preview"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshPreviewCommand}" />
                        <TextBlock Text="Control Point Preview"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="14,0,14,14">
                        <DataGrid ItemsSource="{Binding PreviewRows}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="True"
                                  ClipboardCopyMode="IncludeHeader"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ColumnWidth="Auto"
                                  ColumnHeaderHeight="50"
                                  IsReadOnly="True">
                            <DataGrid.Resources>
                                <Style x:Key="PreviewHeaderTitleText" TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                    <Setter Property="TextAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="LineHeight" Value="13" />
                                </Style>
                                <Style x:Key="PreviewHeaderUnitText" TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="10" />
                                    <Setter Property="FontWeight" Value="Normal" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Setter Property="Margin" Value="0,2,0,0" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                                    Binding="{Binding ThetaDeg, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="34">
                                                <TextBlock Text="&#x03B8;" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.AngleUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding PointIndex}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="34">
                                                <TextBlock Text="Pt." Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding P, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="P" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.ForceUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding MxPositive, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="Mx+" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.MomentUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding MyPositive, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="My+" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.MomentUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding MThetaPositive, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="M&#x03B8;+" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.MomentUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding MxNegative, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="Mx-" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.MomentUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding MyNegative, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="My-" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.MomentUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding MThetaNegative, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="M&#x03B8;-" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.MomentUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding NeutralAxisDepth, StringFormat=F1}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="76">
                                                <TextBlock Text="Neutral Axis Depth" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.LengthUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding SteelStrainMax, StringFormat=F5}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="&#x03B5;t" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.StrainUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding ConcreteStrainMax, StringFormat=F5}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="58">
                                                <TextBlock Text="&#x03B5;c" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.StrainUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding PhiFactor, StringFormat=F2}"
                                                    Width="Auto"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="56">
                                                <TextBlock Text="&#x03C6;" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="{Binding DataContext.PhiUnitHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn
                                                    Binding="{Binding Remarks}"
                                                    Width="170"
                                                    MinWidth="140"
                                                    ElementStyle="{StaticResource LeftAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel MinWidth="82">
                                                <TextBlock Text="Remarks" Style="{StaticResource PreviewHeaderTitleText}" />
                                                <TextBlock Text="" Style="{StaticResource PreviewHeaderUnitText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="#CCFFFFFF"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="18,12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding EmptyStateMessage}"
                                       Style="{StaticResource HelperTextStyle}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Active Design Strain Limits -->
                    <Border Grid.Row="2" Margin="14,0,14,14" Padding="12,8"
                            Background="#06000000" BorderBrush="{DynamicResource BorderSoftBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <DockPanel>
                            <TextBlock Text="Active Design Strain Limits:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryNavyBrush}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Background="#103B82F6" CornerRadius="4" Padding="8,4" Margin="6,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Concrete Limit (" Style="{StaticResource HelperTextStyle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ConcreteUltimateStrainLabel}" Style="{StaticResource HelperTextStyle}" FontWeight="SemiBold" />
                                        <TextBlock Text="): " Style="{StaticResource HelperTextStyle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding EpsilonCu2, StringFormat=F5}" FontWeight="SemiBold" Foreground="#FF3B82F6" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#1010B981" CornerRadius="4" Padding="8,4" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Steel Yield (&#x03B5;yd): " Style="{StaticResource HelperTextStyle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding EpsilonYd, StringFormat=F5}" FontWeight="SemiBold" Foreground="#FF10B981" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#10F59E0B" CornerRadius="4" Padding="8,4" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Steel Max Tension (&#x03B5;ud): " Style="{StaticResource HelperTextStyle}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding EpsilonUd, StringFormat=F5}" FontWeight="SemiBold" Foreground="#FFF59E0B" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="1" Margin="0,16,0,0">
            <Button DockPanel.Dock="Right"
                    Content="Close"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="10,0,0,0"
                    Command="{Binding CloseCommand}" />
            <Button DockPanel.Dock="Right"
                    Content="Export CSV"
                    Command="{Binding ExportCsvCommand}" />
        </DockPanel>
    </Grid>
</Window>
