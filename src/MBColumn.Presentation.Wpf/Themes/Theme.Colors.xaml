<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="PrimaryNavyColor">#1565C0</Color>
    <Color x:Key="DarkNavyColor">#0D47A1</Color>
    <Color x:Key="AccentBlueColor">#1E88E5</Color>
    <Color x:Key="AccentBlueSoftColor">#EAF4FF</Color>
    <Color x:Key="AccentRedColor">#EF4444</Color>
    <Color x:Key="SuccessGreenColor">#10B981</Color>
    <Color x:Key="SuccessGreenSoftColor">#E8F8F2</Color>
    <Color x:Key="DangerRedSoftColor">#FDECEC</Color>
    <Color x:Key="LightBackgroundColor">#F5F7FA</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="PanelBackgroundColor">#FFFFFF</Color>
    <Color x:Key="BorderGreyColor">#D9E2EC</Color>
    <Color x:Key="BorderSoftColor">#EAF0F6</Color>
    <Color x:Key="TextDarkColor">#1E293B</Color>
    <Color x:Key="TextMutedColor">#64748B</Color>

    <SolidColorBrush x:Key="PrimaryNavyBrush" Color="{DynamicResource PrimaryNavyColor}" />
    <SolidColorBrush x:Key="DarkNavyBrush" Color="{DynamicResource DarkNavyColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{DynamicResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentBlueSoftBrush" Color="{DynamicResource AccentBlueSoftColor}" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="{DynamicResource AccentRedColor}" />
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{DynamicResource SuccessGreenColor}" />
    <SolidColorBrush x:Key="SuccessGreenSoftBrush" Color="{DynamicResource SuccessGreenSoftColor}" />
    <SolidColorBrush x:Key="DangerRedSoftBrush" Color="{DynamicResource DangerRedSoftColor}" />
    <SolidColorBrush x:Key="LightBackgroundBrush" Color="{DynamicResource LightBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{DynamicResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="BorderGreyBrush" Color="{DynamicResource BorderGreyColor}" />
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{DynamicResource BorderSoftColor}" />
    <SolidColorBrush x:Key="TextDarkBrush" Color="{DynamicResource TextDarkColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
</ResourceDictionary>
