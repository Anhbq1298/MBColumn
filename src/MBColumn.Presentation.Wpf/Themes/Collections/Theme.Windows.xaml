<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="DialogWindowStyle" TargetType="Window">
        <Setter Property="WindowStartupLocation" Value="CenterOwner" />
        <Setter Property="ResizeMode" Value="NoResize" />
        <Setter Property="ShowInTaskbar" Value="False" />
        <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="DialogRootGridStyle" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
    </Style>

    <Style x:Key="DialogHeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
        <Setter Property="Padding" Value="18,12" />
    </Style>

    <!-- Inlined from DialogTitleTextStyle to avoid cross-dictionary StaticResource -->
    <Style x:Key="DialogHeaderTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeDialogTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Inlined from DialogSubtitleTextStyle to avoid cross-dictionary StaticResource -->
    <Style x:Key="DialogHeaderSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeHelper}" />
        <Setter Property="Foreground" Value="{DynamicResource DialogHeaderSubtitleBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="DialogBodyBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="DialogFooterBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <!-- Inlined from CardBorderStyle to avoid cross-dictionary StaticResource -->
    <Style x:Key="DialogPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="DialogActionPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>
</ResourceDictionary>
