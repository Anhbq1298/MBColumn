        <ResourceDictionary Source="Theme.Controls.xaml" />
        <ResourceDictionary Source="Theme.DataGrid.xaml" />
        <ResourceDictionary Source="Theme.Cards.xaml" />
        <ResourceDictionary Source="Collections/Theme.Windows.xaml" />
