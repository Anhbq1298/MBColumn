<Window x:Class="MBColumn.Presentation.Wpf.Views.ProjectNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project"
        Width="360" SizeToContent="Height"
        Style="{StaticResource DialogWindowStyle}">
    <Grid Style="{StaticResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="New Project" Style="{StaticResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Name the project file before creating sections."
                           Style="{StaticResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DialogBodyBorderStyle}">
            <StackPanel>
                <TextBlock x:Name="NameLabel"
                           Text="Project name"
                           Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox x:Name="NameBox"
                         MinWidth="280"
                         KeyDown="NameBox_KeyDown" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterBarStyle}">
            <StackPanel Style="{StaticResource DialogActionPanelStyle}">
                <Button Content="Cancel"
                        Width="88"
                        IsCancel="True"
                        Click="Cancel_Click"
                        Style="{StaticResource DialogActionButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="OK"
                        Width="88"
                        IsDefault="True"
                        Click="OK_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
