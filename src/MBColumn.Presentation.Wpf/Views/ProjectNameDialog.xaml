<Window x:Class="MBColumn.Presentation.Wpf.Views.ProjectNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="Project name:" Margin="0,0,0,6" />
        <TextBox x:Name="NameBox" MinWidth="280" Padding="6,4"
                 KeyDown="NameBox_KeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="OK_Click" Margin="0,0,8,0" />
            <Button Content="Cancel" Width="80" IsCancel="True" Click="Cancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
