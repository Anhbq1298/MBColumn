<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.SectionRebarInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:views="clr-namespace:MBColumn.Presentation.Wpf.Views"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
            <Grid Margin="4,6,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18*" MinWidth="200" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="32*" MinWidth="250" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="50*" MinWidth="400" />
                </Grid.ColumnDefinitions>

                <views:GeneralMaterialInputView Grid.Column="0" />
                <views:SectionPreviewInputView Grid.Column="2" />
                <views:SectionGeometryRebarInputView Grid.Column="4" />
            </Grid>
</UserControl>
