<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsPreloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Import from ETABS"
        Width="420"
        SizeToContent="Height"
        MinHeight="240"
        MaxHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{DynamicResource DialogWindowStyle}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Import from ETABS"
                           Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Loading ETABS data — please wait…"
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <!-- Progress steps -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Steps}"
                      Margin="28,18,28,10"
                      VerticalAlignment="Top">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:EtabsPreloadStep}">
                    <DockPanel Margin="0,5">
                        <!-- Status circle -->
                        <Border DockPanel.Dock="Left"
                                CornerRadius="10"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Width"      Value="22" />
                                    <Setter Property="Height"     Value="22" />
                                    <Setter Property="Background" Value="{DynamicResource BorderGreyBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Background" Value="#2196F3" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                            <Setter Property="Background" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                            <Setter Property="Background" Value="#FF9800" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="·" />
                                        <Setter Property="FontSize"   Value="11" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text"       Value="…" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                <Setter Property="Text"       Value="✓" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Text"       Value="!" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Label + detail -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="{Binding Label}" />
                                        <Setter Property="FontSize"   Value="12" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding Detail}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,1,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Bottom bar -->
        <Grid Grid.Row="2">
            <Border Style="{DynamicResource DialogFooterBarStyle}">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,5"
                            MinHeight="30" />
                    <Button DockPanel.Dock="Right"
                            Content="Next"
                            Command="{Binding NextCommand}"
                            Padding="14,5"
                            Margin="0,0,6,0"
                            MinHeight="30"
                            Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <!-- Progress bar -->
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Maximum="100"
                         Height="3"
                         VerticalAlignment="Top"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource PrimaryNavyBrush}" />
        </Grid>
    </Grid>
</Window>
