<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsPreloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Import from ETABS"
        Width="460"
        SizeToContent="Height"
        MinHeight="320"
        MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DialogWindowStyle}"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">

    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Style="{StaticResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Import from ETABS"
                           Style="{StaticResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Loading ETABS data — please wait…"
                           Style="{StaticResource DialogHeaderSubtitleTextStyle}"
                           Visibility="{Binding IsAwaitingComboSelection, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                <TextBlock Text="Select the load combinations you want to import."
                           Style="{StaticResource DialogHeaderSubtitleTextStyle}"
                           Visibility="{Binding IsAwaitingComboSelection, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <!-- Steps + Combo selection -->
        <StackPanel Grid.Row="1" Margin="22,18,22,10">

            <!-- Progress steps -->
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EtabsPreloadStep}">
                        <DockPanel>
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Margin" Value="0,5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSubStep}" Value="True">
                                            <Setter Property="Margin" Value="26,3,0,3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                            <!-- Status circle -->
                            <Border DockPanel.Dock="Left"
                                    CornerRadius="10"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Width"      Value="22" />
                                        <Setter Property="Height"     Value="22" />
                                        <Setter Property="Background" Value="{DynamicResource BorderGreyBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSubStep}" Value="True">
                                                <Setter Property="Width"  Value="16" />
                                                <Setter Property="Height" Value="16" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Background" Value="#2196F3" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                <Setter Property="Background" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Background" Value="#FF9800" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="·" />
                                            <Setter Property="FontSize"   Value="11" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSubStep}" Value="True">
                                                    <Setter Property="FontSize" Value="9" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Text"       Value="…" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                    <Setter Property="Text"       Value="✓" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                    <Setter Property="Text"       Value="!" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Label + detail -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding Label}" />
                                            <Setter Property="FontSize"   Value="12" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSubStep}" Value="True">
                                                    <Setter Property="FontSize" Value="11" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Detail}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,1,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDetail}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Combo selection panel — visible after steps 1-3 complete -->
            <Border Visibility="{Binding IsAwaitingComboSelection, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,14,0,0"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,12,0,0">
                <StackPanel>
                    <!-- Header row -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding SelectedComboCount, Mode=OneWay}" />
                            <Run Text=" selected" />
                        </TextBlock>
                        <TextBlock Text="Select load combinations:"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDarkBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Filter box -->
                    <TextBox Text="{Binding LoadComboFilterText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Search…"
                             Margin="0,0,0,6"
                             FontSize="11" />

                    <!-- Select All / Clear All -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Select All"
                                Command="{Binding SelectAllCombosCommand}"
                                Padding="8,3"
                                Margin="0,0,6,0" />
                        <Button Content="Clear All"
                                Command="{Binding ClearAllCombosCommand}"
                                Padding="8,3" />
                    </StackPanel>

                    <!-- Combo list — Shift+click range, Ctrl+click toggle -->
                    <ListBox ItemsSource="{Binding FilteredCombinations}"
                             SelectionMode="Extended"
                             MaxHeight="210"
                             FontSize="11"
                             BorderBrush="{DynamicResource BorderGreyBrush}"
                             BorderThickness="1"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="False">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="Padding"    Value="8,3" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:EtabsLoadCombinationViewModel}">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Bottom bar -->
        <Grid Grid.Row="2">
            <Border Style="{StaticResource DialogFooterBarStyle}">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,5"
                            MinHeight="30" />
                    <Button DockPanel.Dock="Right"
                            Content="Next"
                            Command="{Binding NextCommand}"
                            Padding="14,5"
                            Margin="0,0,6,0"
                            MinHeight="30"
                            Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button DockPanel.Dock="Right"
                            Content="Proceed"
                            Command="{Binding ProceedCommand}"
                            Padding="14,5"
                            Margin="0,0,6,0"
                            MinHeight="30"
                            Visibility="{Binding IsAwaitingComboSelection, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ComboSelectionCountText}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   Margin="6,0,0,0"
                                   Visibility="{Binding IsAwaitingComboSelection, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Progress bar -->
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Maximum="100"
                         Height="3"
                         VerticalAlignment="Top"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource PrimaryNavyBrush}"
                         Visibility="{Binding IsAwaitingComboSelection, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</Window>
