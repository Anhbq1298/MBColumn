<Window x:Class="MBColumn.Presentation.Wpf.Views.StartUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MBColumn — Start" Height="450" Width="680" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        MinWidth="760"
        Background="{DynamicResource LightBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Banner -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{DynamicResource DarkNavyColor}" Offset="0.0" />
                    <GradientStop Color="{DynamicResource AccentBlueColor}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Decorative SVG-like path on the right -->
                <Canvas HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="300" ClipToBounds="True" Opacity="0.12">
                    <Path Fill="Transparent" Stroke="White" StrokeThickness="2" StrokeDashArray="4 4" 
                          Data="M 150,15 L 250,15 L 250,75 L 150,75 Z" />
                    <Path Fill="Transparent" Stroke="White" StrokeThickness="4" 
                          Data="M 160,25 L 240,25 L 240,65 L 160,65 Z" />
                    <Ellipse Fill="White" Width="10" Height="10" Canvas.Left="155" Canvas.Top="20" />
                    <Ellipse Fill="White" Width="10" Height="10" Canvas.Left="235" Canvas.Top="20" />
                    <Ellipse Fill="White" Width="10" Height="10" Canvas.Left="155" Canvas.Top="60" />
                    <Ellipse Fill="White" Width="10" Height="10" Canvas.Left="235" Canvas.Top="60" />
                </Canvas>

                <Button x:Name="BtnInfo"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="24"
                        Height="24"
                        Margin="0,10,12,0"
                        Padding="0"
                        MinWidth="0"
                        MinHeight="0"
                        Background="Transparent"
                        BorderBrush="#DCEAF5"
                        ToolTip="Developer information">
                    <TextBlock Text="i"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>

                <StackPanel VerticalAlignment="Center" Margin="24,0,0,0">
                    <TextBlock Text="MBColumn" FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Reinforced Concrete Column Design" FontSize="12.5" Foreground="#DCEAF5" Margin="2,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Recent Projects -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="4,0,0,8">
                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Recent Projects" FontWeight="SemiBold" FontSize="13.5" Foreground="{DynamicResource TextDarkBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="1" Background="White" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="RecentList" BorderThickness="0" Background="Transparent" SelectionChanged="RecentList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xEC50;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" Margin="4,0,12,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="12.5" Foreground="{DynamicResource TextDarkBrush}"/>
                                            <TextBlock Text="{Binding FolderPath}" FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Right Column: Preview & Actions -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Project Preview Card -->
                <Border Grid.Row="0" Background="White" BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                    <Grid>
                        <TextBlock x:Name="NoSelectionText" 
                                   Text="Select a recent project to preview its details and sections." 
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontStyle="Italic"/>

                        <Grid x:Name="PreviewPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Project Preview" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>

                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <TextBlock x:Name="TxtPreviewProjName" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryNavyBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="TxtPreviewFileName" FontSize="11.5" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Grid Grid.Row="3" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Last Modified" FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPreviewLastModified" FontSize="11.5" Foreground="{DynamicResource TextDarkBrush}" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="File Size" FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBlock x:Name="TxtPreviewFileSize" FontSize="11.5" Foreground="{DynamicResource TextDarkBrush}" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TxtPreviewColCount" Text="Sections (0)" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource DarkNavyBrush}" Margin="0,0,0,8"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="PreviewColumnsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource AccentBlueSoftBrush}" 
                                                        BorderBrush="{DynamicResource AccentBlueBrush}" BorderThickness="1" 
                                                        CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource DarkNavyBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2">
                    <Button x:Name="BtnNew" Style="{StaticResource PrimaryButtonStyle}" MinHeight="36" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="New Project..." Margin="8,0,0,0" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="BtnOpen" Grid.Column="0" MinHeight="32">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Open Project..." Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="BtnCancel" Grid.Column="2" MinHeight="32">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="Exit" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
