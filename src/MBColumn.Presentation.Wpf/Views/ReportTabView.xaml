<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ReportTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
             MinHeight="560">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" MinWidth="300"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="2*" MinWidth="220" MaxWidth="440"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Right: control panel ═══════════════════════════════════ -->
        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <DockPanel>

                <!-- Top: title + actions -->
                <StackPanel DockPanel.Dock="Top" Margin="14,14,14,0">

                    <TextBlock Text="Report"
                               Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="{StaticResource FontSizeSection}"/>

                    <!-- Outdated warning -->
                    <Border Background="#FFF7E6" BorderBrush="#C98600" BorderThickness="1"
                            CornerRadius="2" Padding="7,5" Margin="0,10,0,0"
                            Visibility="{Binding IsOutdated,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock TextWrapping="Wrap" FontSize="10"
                                   Text="Result outdated — recalculate before exporting."/>
                    </Border>

                    <!-- "Generate Report" — shown when report not yet built -->
                    <Button Content="Generate Report"
                            Command="{Binding RevealReportPreviewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,12,0,0"
                            Visibility="{Binding ShowRevealReportPreviewButton,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Generating spinner text -->
                    <TextBlock Text="Rendering report…"
                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,12,0,0"
                               Visibility="{Binding IsGeneratingReport,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- No-result placeholder -->
                    <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,10,0,0"
                               Text="{Binding ReportPreviewStatusText}"
                               Visibility="{Binding ShowReportPreviewPlaceholder,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Sections header row -->
                    <DockPanel Margin="0,18,0,6"
                               Visibility="{Binding HasSectionToggles,
                                   Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Sections"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="All"
                                    Command="{Binding SelectAllSectionsCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Padding="6,1" FontSize="10"
                                    Margin="0,0,4,0"/>
                            <Button Content="None"
                                    Command="{Binding DeselectAllSectionsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6,1" FontSize="10"/>
                        </StackPanel>
                    </DockPanel>

                </StackPanel>

                <!-- Section list (scrollable, fills remaining space) -->
                <TreeView x:Name="SectionTreeView"
                          ItemsSource="{Binding ReportTreeNodes}"
                          BorderThickness="0" Background="Transparent"
                          Margin="8,0,8,10"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          Visibility="{Binding HasSectionToggles,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True" />
                            <Setter Property="Padding" Value="2,1" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    
                    <TreeView.Resources>
                        <!-- HierarchicalDataTemplate for ReportTreeItemViewModel -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:ReportTreeItemViewModel}" ItemsSource="{Binding Children}">
                            <Grid Margin="2,1"
                                  MaxWidth="{Binding ActualWidth, ElementName=SectionTreeView}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsThreeState="{Binding HasChildren}"
                                          VerticalAlignment="Top"
                                          Margin="2,3,6,0"/>
                                          
                                <!-- Leaf node layout (Button) -->
                                <Button Grid.Column="1"
                                        x:Name="LeafButton"
                                        Command="{Binding DataContext.ScrollToSectionCommand,
                                            RelativeSource={RelativeSource AncestorType=TreeView}}"
                                        CommandParameter="{Binding SectionNumber}"
                                        BorderThickness="0" Padding="2,2"
                                        Cursor="Hand"
                                        HorizontalContentAlignment="Left"
                                        HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding HasChildren}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Title}"
                                               TextWrapping="Wrap"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource TextDarkBrush}"/>
                                </Button>
                                
                                <!-- Group/Folder node layout (TextBlock) -->
                                <TextBlock Grid.Column="1"
                                           x:Name="GroupText"
                                           Text="{Binding Title}"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource TextDarkBrush}"
                                           VerticalAlignment="Center"
                                           Padding="2,3">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>

            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource LightBackgroundBrush}" />

        <!-- ═══ Left: report preview ════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="#CCCCCC">

            <!-- Placeholder — shown when no report content -->
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding ShowReportPreviewPlaceholder,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ReportPreviewPlaceholderTitle}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,10,0,0" FontSize="{StaticResource FontSizeBody}"
                               Foreground="#888" HorizontalAlignment="Center"
                               Text="{Binding ReportPreviewPlaceholderText}"/>
                    <Button Content="Generate Report"
                            Command="{Binding RevealReportPreviewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Visibility="{Binding ShowRevealReportPreviewButton,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- WebView2 — renders the full KaTeX HTML report -->
            <wv2:WebView2 x:Name="ReportWebView"
                          Visibility="{Binding ShowReportContent,
                              Converter={StaticResource BoolToVisibilityConverter}}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

        </Grid>
    </Grid>
</UserControl>
