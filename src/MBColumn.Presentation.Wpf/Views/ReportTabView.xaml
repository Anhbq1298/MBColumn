<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ReportTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpfmath="clr-namespace:WpfMath.Controls;assembly=WpfMath"
             MinHeight="560">
    <UserControl.Resources>

        <!-- ── FormulaBlock item template ──────────────────────────────── -->
        <DataTemplate x:Key="FormulaBlockTemplate">
            <Border Background="#F8F9FA"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="12,8"
                    Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               FontSize="11"
                               Foreground="#555"
                               Margin="0,0,0,6" />

                    <!-- Symbolic formula -->
                    <wpfmath:FormulaControl Formula="{Binding LatexFormula}"
                                           Foreground="#1A1A2E"
                                           Background="Transparent"
                                           HorizontalAlignment="Left"
                                           Margin="4,0,0,6" />

                    <!-- Substitution -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="Sub: "
                                   FontSize="10"
                                   Foreground="#888"
                                   VerticalAlignment="Center" />
                        <wpfmath:FormulaControl Formula="{Binding SubstitutionLatex}"
                                               Foreground="#444"
                                               Background="Transparent"
                                               HorizontalAlignment="Left" />
                    </StackPanel>

                    <!-- Result (hidden when empty) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ResultLatex, Converter={StaticResource NullOrEmptyToCollapsedConverter}}">
                        <TextBlock Text="= "
                                   FontSize="10"
                                   Foreground="#888"
                                   VerticalAlignment="Center" />
                        <wpfmath:FormulaControl Formula="{Binding ResultLatex}"
                                               Foreground="#1A5276"
                                               Background="Transparent"
                                               HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ── Validation row item template ────────────────────────────── -->
        <DataTemplate x:Key="ValidationRowTemplate">
            <Border BorderBrush="#E8E8E8"
                    BorderThickness="0,0,0,1"
                    Padding="0,0,0,20"
                    Margin="0,0,0,20">
                <StackPanel>

                    <!-- Row header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="#1A5276" CornerRadius="3" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="{Binding ControlPointId}"
                                       Foreground="White" FontWeight="Bold" FontSize="12" />
                        </Border>
                        <TextBlock Text="{Binding ControlPointName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <!-- Status badge -->
                        <Border Margin="10,0,0,0" CornerRadius="3" Padding="8,3" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E0E0E0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="Pass">
                                            <Setter Property="Background" Value="#D5F5E3" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Warning">
                                            <Setter Property="Background" Value="#FEF9E7" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="Fail">
                                            <Setter Property="Background" Value="#FADBD8" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#666" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                <Setter Property="Foreground" Value="#1E8449" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                <Setter Property="Foreground" Value="#B7770D" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Fail">
                                                <Setter Property="Foreground" Value="#C0392B" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Assumption -->
                    <TextBlock Text="{Binding Assumption}"
                               TextWrapping="Wrap"
                               Foreground="#666" FontStyle="Italic" FontSize="11"
                               Margin="0,0,0,10" />

                    <!-- Formula blocks (only when supported) -->
                    <ItemsControl ItemsSource="{Binding FormulaBlocks}"
                                  ItemTemplate="{StaticResource FormulaBlockTemplate}"
                                  Visibility="{Binding IsSupported,
                                      Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- N/A placeholder -->
                    <TextBlock Text="Not applicable for this section shape or design code."
                               Foreground="#999" FontStyle="Italic" FontSize="11"
                               Visibility="{Binding IsSupported,
                                   Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <!-- Comparison table (only when supported) -->
                    <Border Background="#EBF5FB"
                            BorderBrush="#AED6F1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10"
                            Margin="0,10,0,0"
                            Visibility="{Binding IsSupported,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Comparison with solver surface"
                                       FontWeight="SemiBold" FontSize="11"
                                       Foreground="#1A5276"
                                       Margin="0,0,0,8" />

                            <!-- Column headers -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Quantity" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="Hand calc" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="2" Text="Solver" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="Diff %" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right" />
                            </Grid>
                            <Separator Margin="0,4,0,4" />

                            <!-- φPn row -->
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11">
                                    <Run Text="φPn  (" /><Run Text="{Binding ForceUnitLabel}" /><Run Text=")" />
                                </TextBlock>
                                <TextBlock Grid.Column="1" FontSize="11" HorizontalAlignment="Right"
                                           Text="{Binding HandPnDisplay, StringFormat={}{0:0.0}}" />
                                <TextBlock Grid.Column="2" FontSize="11" HorizontalAlignment="Right"
                                           Text="{Binding SolverPnDisplay, StringFormat={}{0:0.0}}" />
                                <TextBlock Grid.Column="3" FontSize="11" HorizontalAlignment="Right"
                                           Text="{Binding DifferencePPercent, StringFormat={}{0:0.00}%}" />
                            </Grid>

                            <!-- φMnx row (hidden when Mx = 0) -->
                            <Grid Margin="0,2,0,2"
                                  Visibility="{Binding HandMxDisplay,
                                      Converter={StaticResource NonZeroToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="11">
                                    <Run Text="φMnx  (" /><Run Text="{Binding MomentUnitLabel}" /><Run Text=")" />
                                </TextBlock>
                                <TextBlock Grid.Column="1" FontSize="11" HorizontalAlignment="Right"
                                           Text="{Binding HandMxDisplay, StringFormat={}{0:0.0}}" />
                                <TextBlock Grid.Column="2" FontSize="11" HorizontalAlignment="Right"
                                           Text="{Binding SolverMxDisplay, StringFormat={}{0:0.0}}" />
                                <TextBlock Grid.Column="3" FontSize="11" HorizontalAlignment="Right"
                                           Text="{Binding DifferenceMPercent, StringFormat={}{0:0.00}%}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Settings panel ──────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Report Settings"
                           Style="{StaticResource SectionTitleTextStyle}"
                           FontSize="16" />
                <CheckBox Content="Include Input Data"
                          IsChecked="{Binding IncludeInputData}"
                          Margin="0,14,0,0" />
                <CheckBox Content="Include Boundary Coordinates"
                          IsChecked="{Binding IncludeBoundaryCoordinates}"
                          Margin="0,8,0,0" />
                <CheckBox Content="Include Rebar Coordinates"
                          IsChecked="{Binding IncludeRebarCoordinates}"
                          Margin="0,8,0,0" />
                <CheckBox Content="Include Hand Calc Validation"
                          IsChecked="{Binding IncludeValidation}"
                          Margin="0,8,0,0" />
                <CheckBox Content="Include Demand Cases"
                          IsChecked="{Binding IncludeDemandCases}"
                          Margin="0,8,0,0" />
                <CheckBox Content="Include PM Charts"
                          IsChecked="{Binding IncludePmCharts}"
                          Margin="0,8,0,0" />

                <TextBlock Text="Chart Angle Step"
                           Style="{StaticResource FieldLabelTextStyle}"
                           Margin="0,18,0,4" />
                <TextBox Text="{Binding ChartAngleStepDegrees, UpdateSourceTrigger=PropertyChanged}"
                         Width="80"
                         HorizontalAlignment="Left" />

                <Button Content="Generate Preview"
                        Command="{Binding GeneratePreviewCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,18,0,0" />
                <Button Content="Print"
                        IsEnabled="False"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0" />
                <Button Content="Export PDF"
                        IsEnabled="False"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- ── Report preview ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="White"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="1"
                    Padding="28"
                    MaxWidth="960"
                    HorizontalAlignment="Left">
                <StackPanel>

                    <!-- Title -->
                    <TextBlock Text="MBColumn Design Report"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}" />
                    <TextBlock Text="{Binding ResultStatusText, StringFormat=Result status: {0}}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,4,0,0" />
                    <Border Background="#FFF7E6" BorderBrush="#C98600"
                            BorderThickness="1" Padding="10" Margin="0,12,0,0"
                            Visibility="{Binding IsOutdated, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock TextWrapping="Wrap"
                                   Text="Input or demand cases changed after the last calculation. Recalculate before generating the final report." />
                    </Border>

                    <!-- ════════════════════════════════════════════════════
                         I.  Input Data
                         ════════════════════════════════════════════════ -->
                    <TextBlock Text="I.  Input Data"
                               Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="16" Margin="0,22,0,8"
                               Visibility="{Binding IncludeInputData, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Grid Visibility="{Binding IncludeInputData, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Project" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding ProjectName}" />
                        <TextBlock Grid.Row="1" Text="Group" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GroupName}" />
                        <TextBlock Grid.Row="2" Text="Design Tier" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DesignTierName}" />
                        <TextBlock Grid.Row="3" Text="Section Shape" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SectionShape}" />
                        <TextBlock Grid.Row="4" Text="Design Code" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DesignCode}" />
                        <TextBlock Grid.Row="5" Text="Unit System" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding UnitSystem}" />
                        <TextBlock Grid.Row="6" Text="Material" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MaterialSummary}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="7" Text="Geometry" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding GeometrySummary}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="8" Text="Rebar" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding RebarSummary}" TextWrapping="Wrap" />
                    </Grid>

                    <!-- ════════════════════════════════════════════════════
                         II. Hand Calculation Validation
                         ════════════════════════════════════════════════ -->
                    <TextBlock Text="II.  Hand Calculation Validation"
                               Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="16" Margin="0,28,0,8"
                               Visibility="{Binding IncludeValidation, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <StackPanel Visibility="{Binding IncludeValidation, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- No result yet -->
                        <Border Background="#F8F8F8" BorderBrush="#DDD"
                                BorderThickness="1" Padding="16" Margin="0,0,0,12"
                                Visibility="{Binding HasValidationData,
                                    Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="Calculate the section first to generate hand calculation validation."
                                       Foreground="#888" FontStyle="Italic" />
                        </Border>

                        <!-- Supported validation -->
                        <StackPanel Visibility="{Binding HasSupportedValidation,
                                        Converter={StaticResource BoolToVisibilityConverter}}">

                            <!-- Conventions note -->
                            <Border Background="#EBF5FB" BorderBrush="#AED6F1"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="12" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding HandCalcValidation.DesignCodeNote}"
                                               FontWeight="SemiBold" FontSize="11"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding HandCalcValidation.AxisConvention}"
                                               TextWrapping="Wrap" FontSize="11"
                                               Margin="0,0,0,2" />
                                    <TextBlock Text="{Binding HandCalcValidation.SignConvention}"
                                               TextWrapping="Wrap" FontSize="11" Foreground="#666"
                                               Margin="0,0,0,4" />
                                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#999">
                                        Note: Hand calculations use the Whitney rectangular stress block.
                                        The solver uses fiber (parabolic-rectangular) integration.
                                        Differences of 1–5 % at the balanced / tension-controlled points are expected.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Control point rows -->
                            <ItemsControl ItemsSource="{Binding HandCalcValidation.Rows}"
                                          ItemTemplate="{StaticResource ValidationRowTemplate}" />
                        </StackPanel>

                        <!-- Not supported -->
                        <Border Background="#FFF8E1" BorderBrush="#FFD54F"
                                BorderThickness="1" Padding="16" Margin="0,0,0,12"
                                Visibility="{Binding HasUnsupportedValidation,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Hand calculation validation is not available for this configuration."
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding HandCalcValidation.NotSupportedReason}"
                                           TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#666" />
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- ════════════════════════════════════════════════════
                         III. Applied Demand Cases
                         ════════════════════════════════════════════════ -->
                    <TextBlock Text="III.  Applied Demand Cases"
                               Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="16" Margin="0,24,0,8"
                               Visibility="{Binding IncludeDemandCases, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <DataGrid ItemsSource="{Binding DemandCases}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="300"
                              Visibility="{Binding IncludeDemandCases, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Case Name" Binding="{Binding CaseName}" Width="150" />
                            <DataGridTextColumn Header="Original LC" Binding="{Binding OriginalLoadCase}" Width="110" />
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="80" />
                            <DataGridTextColumn Header="Story" Binding="{Binding Story}" Width="80" />
                            <DataGridTextColumn Header="Station" Binding="{Binding Station}" Width="80" />
                            <DataGridTextColumn Header="P" Binding="{Binding Pu, StringFormat={}{0:0.#}}" Width="80" />
                            <DataGridTextColumn Header="Mx" Binding="{Binding Mux, StringFormat={}{0:0.#}}" Width="80" />
                            <DataGridTextColumn Header="My" Binding="{Binding Muy, StringFormat={}{0:0.#}}" Width="80" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ════════════════════════════════════════════════════
                         IV. Capacity Charts
                         ════════════════════════════════════════════════ -->
                    <TextBlock Text="IV.  Capacity Charts"
                               Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="16" Margin="0,24,0,8"
                               Visibility="{Binding IncludePmCharts, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <ItemsControl ItemsSource="{Binding ChartPreviews}"
                                  Visibility="{Binding IncludePmCharts, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderGreyBrush}"
                                        BorderThickness="1"
                                        Margin="0,0,10,10" Padding="12"
                                        MinHeight="120">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="Capacity curve and demand points use the current MBColumn result."
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
