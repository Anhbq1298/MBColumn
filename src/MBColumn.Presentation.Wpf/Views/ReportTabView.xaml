<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ReportTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinHeight="560">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" MinWidth="300"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="2*" MinWidth="180" MaxWidth="340"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Right: control panel ═══════════════════════════════════ -->
        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
            <DockPanel>

                <!-- Top: title + actions -->
                <StackPanel DockPanel.Dock="Top" Margin="14,14,14,0">

                    <TextBlock Text="Report"
                               Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="{StaticResource FontSizeSection}"/>

                    <!-- Outdated warning -->
                    <Border Background="#FFF7E6" BorderBrush="#C98600" BorderThickness="1"
                            CornerRadius="2" Padding="7,5" Margin="0,10,0,0"
                            Visibility="{Binding IsOutdated,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock TextWrapping="Wrap" FontSize="10"
                                   Text="Result outdated — recalculate before exporting."/>
                    </Border>

                    <!-- "Generate Report" — shown when report not yet built -->
                    <Button Content="Generate Report"
                            Command="{Binding RevealReportPreviewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,12,0,0"
                            Visibility="{Binding ShowRevealReportPreviewButton,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Generating spinner text -->
                    <TextBlock Text="Rendering report…"
                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,12,0,0"
                               Visibility="{Binding IsGeneratingReport,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Export buttons — shown once report is ready -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding ShowReportContent,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Save as PDF"
                                Command="{Binding SaveAsPdfCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Save the full calculation report as PDF"/>
                        <Button Content="Save as HTML"
                                Command="{Binding SaveAsHtmlCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,6,0,0"
                                ToolTip="Save as a self-contained HTML file"/>
                    </StackPanel>

                    <!-- No-result placeholder -->
                    <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap" Margin="0,10,0,0"
                               Text="{Binding ReportPreviewStatusText}"
                               Visibility="{Binding ShowReportPreviewPlaceholder,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Sections header row -->
                    <DockPanel Margin="0,18,0,6"
                               Visibility="{Binding HasSectionToggles,
                                   Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Sections"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="All"
                                    Command="{Binding SelectAllSectionsCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Padding="6,1" FontSize="10"
                                    Margin="0,0,4,0"/>
                            <Button Content="None"
                                    Command="{Binding DeselectAllSectionsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6,1" FontSize="10"/>
                        </StackPanel>
                    </DockPanel>

                </StackPanel>

                <!-- Section list (scrollable, fills remaining space) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="8,0,8,10"
                              Visibility="{Binding HasSectionToggles,
                                  Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding SectionToggles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                              VerticalAlignment="Top"
                                              Margin="2,3,6,0"/>
                                    <Button Grid.Column="1"
                                            Command="{Binding DataContext.ScrollToSectionCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding SectionNumber}"
                                            BorderThickness="0" Padding="2,2"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Left"
                                            HorizontalAlignment="Stretch">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource TextDarkBrush}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource LightBackgroundBrush}" />

        <!-- ═══ Left: report preview ════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="#CCCCCC">

            <!-- Placeholder — shown when no report content -->
            <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding ShowReportPreviewPlaceholder,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ReportPreviewPlaceholderTitle}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,10,0,0" FontSize="{StaticResource FontSizeBody}"
                               Foreground="#888" HorizontalAlignment="Center"
                               Text="{Binding ReportPreviewPlaceholderText}"/>
                    <Button Content="Generate Report"
                            Command="{Binding RevealReportPreviewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Visibility="{Binding ShowRevealReportPreviewButton,
                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- WebView2 — renders the full KaTeX HTML report -->
            <wv2:WebView2 x:Name="ReportWebView"
                          Visibility="{Binding ShowReportContent,
                              Converter={StaticResource BoolToVisibilityConverter}}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

        </Grid>
    </Grid>
</UserControl>
