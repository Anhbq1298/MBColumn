<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ReportTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             MinHeight="560">

    <UserControl.Resources>

        <!-- A4 page border style ─────────────────────────────────────────── -->
        <Style x:Key="A4PageStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="Width" Value="794" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <!-- 0.1 inch = 9.6 dip margin on all sides -->
            <Setter Property="Padding" Value="9.6" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.18" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chapter heading ──────────────────────────────────────────────── -->
        <Style x:Key="ChapterHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,4,0,12" />
        </Style>

        <!-- Page number ──────────────────────────────────────────────────── -->
        <Style x:Key="PageNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <!-- Field label in 2-col grid ────────────────────────────────────── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Caption / note text ──────────────────────────────────────────── -->
        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontStyle" Value="Italic" />
        </Style>

        <!-- Inline placeholder (no data) ─────────────────────────────────── -->
        <Style x:Key="PlaceholderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F8F8" />
            <Setter Property="BorderBrush" Value="#DDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Settings panel
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Report Settings"
                           Style="{StaticResource SectionTitleTextStyle}"
                           FontSize="15" />

                <TextBlock Text="Sections"
                           Style="{StaticResource FieldLabelTextStyle}"
                           Margin="0,16,0,6" />
                <CheckBox Content="Input Data"
                          IsChecked="{Binding IncludeInputData}"
                          Margin="0,0,0,6" />
                <CheckBox Content="PM 7 Verification Points"
                          IsChecked="{Binding IncludePm7Table}"
                          Margin="0,0,0,6" />
                <CheckBox Content="Critical Chart"
                          IsChecked="{Binding IncludeGoverningChart}"
                          Margin="0,0,0,6" />
                <CheckBox Content="Demand Cases"
                          IsChecked="{Binding IncludeDemandCases}"
                          Margin="0,0,0,6" />

                <Button Content="Refresh"
                        Command="{Binding GeneratePreviewCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,18,0,0" />
                <Button Content="Print"
                        x:Name="PrintButton"
                        Click="PrintButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0" />

                <Button Content="Export PDF"
                        IsEnabled="False"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             Report preview – A4 pages
             ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="#CCCCCC">
            <StackPanel x:Name="ReportContent"
                        Margin="24,24,24,40"
                        HorizontalAlignment="Left">

                <!-- ┌────────────────────────────────────────────────┐
                     │  PAGE 1 – Report header + Input Data           │
                     └────────────────────────────────────────────────┘ -->
                <Border Style="{StaticResource A4PageStyle}">
                    <StackPanel>

                        <!-- Outdated banner -->
                        <Border Background="#FFF7E6" BorderBrush="#C98600"
                                BorderThickness="1" Padding="10" Margin="0,0,0,12"
                                Visibility="{Binding IsOutdated,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock TextWrapping="Wrap"
                                       Text="Input or demand cases changed after the last calculation. Recalculate before generating the final report."
                                       FontSize="11" />
                        </Border>

                        <!-- Report title -->
                        <TextBlock Text="MB Column – Engineering Calculation Report"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}" />
                        <TextBlock Text="{Binding ResultStatusText, StringFormat='Result status: {0}'}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" Margin="0,4,0,0" />
                        <Separator Margin="0,12,0,12" />

                        <!-- ── I. Input Data ────────────────────────────── -->
                        <StackPanel Visibility="{Binding IncludeInputData,
                                        Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="I.  Input Data"
                                       Style="{StaticResource ChapterHeadingStyle}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Project" />
                                <TextBlock Grid.Column="1" Text="{Binding ProjectName}" FontSize="11" />

                                <TextBlock Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Text="Group" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GroupName}" FontSize="11" />

                                <TextBlock Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Text="Design Tier" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DesignTierName}" FontSize="11" />

                                <TextBlock Grid.Row="3" Style="{StaticResource FieldLabelStyle}" Text="Section Shape" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SectionShape}" FontSize="11" />

                                <TextBlock Grid.Row="4" Style="{StaticResource FieldLabelStyle}" Text="Design Code" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DesignCode}" FontSize="11" />

                                <TextBlock Grid.Row="5" Style="{StaticResource FieldLabelStyle}" Text="Unit System" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding UnitSystem}" FontSize="11" />

                                <TextBlock Grid.Row="6" Style="{StaticResource FieldLabelStyle}" Text="Material" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MaterialSummary}"
                                           TextWrapping="Wrap" FontSize="11" />

                                <TextBlock Grid.Row="7" Style="{StaticResource FieldLabelStyle}" Text="Geometry" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding GeometrySummary}"
                                           TextWrapping="Wrap" FontSize="11" />

                                <TextBlock Grid.Row="8" Style="{StaticResource FieldLabelStyle}" Text="Reinforcement" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding RebarSummary}"
                                           TextWrapping="Wrap" FontSize="11" />

                                <controls:SectionPreviewCanvas Grid.Column="2" Grid.RowSpan="9"
                                                               Height="160"
                                                               MinHeight="160"
                                                               HorizontalAlignment="Stretch"
                                                               VerticalAlignment="Top"
                                                               Margin="10,0,0,0"
                                                               SectionWidth="{Binding SectionWidth}"
                                                               SectionHeight="{Binding SectionHeight}"
                                                               BoundaryPoints="{Binding BoundaryPoints}"
                                                               Rebars="{Binding Rebars}"
                                                               Cover="{Binding ClearCover}" />
                            </Grid>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Boundary Points -->
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Boundary Coordinates" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />
                                    <DataGrid ItemsSource="{Binding BoundaryPoints}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              FontSize="10">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Pt" Binding="{Binding Index}" Width="*" />
                                            <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F2}" Width="*" />
                                            <DataGridTextColumn Header="Y" Binding="{Binding Y, StringFormat=F2}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>

                                <!-- Rebar Coordinates -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Rebar Coordinates" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />
                                    <DataGrid ItemsSource="{Binding Rebars}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              RowHeaderWidth="0"
                                              FontSize="10">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="*" />
                                            <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F2}" Width="*" />
                                            <DataGridTextColumn Header="Y" Binding="{Binding Y, StringFormat=F2}" Width="*" />
                                            <DataGridTextColumn Header="Size" Binding="{Binding Label}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <TextBlock Style="{StaticResource PageNumberStyle}" Text="— 1 —" />
                    </StackPanel>
                </Border>

                <!-- ┌────────────────────────────────────────────────┐
                     │  PAGE 2 – PM 7 Verification Points            │
                     └────────────────────────────────────────────────┘ -->
                <Border Style="{StaticResource A4PageStyle}"
                        Visibility="{Binding IncludePm7Table,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="II.  PM 7 Verification Points"
                                   Style="{StaticResource ChapterHeadingStyle}" />
                        <TextBlock Style="{StaticResource CaptionStyle}"
                                   Margin="0,0,0,10"
                                   Text="Seven PM control points derived from strain-compatibility analysis. Values are design (reduced) axial force φPn and uniaxial moment φMn at the governing bending direction." />

                        <!-- No data placeholder -->
                        <Border Style="{StaticResource PlaceholderStyle}"
                                Visibility="{Binding HasPm7Data,
                                    Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="PM 7 verification data not available. Calculate the section first."
                                       Foreground="#888888" FontStyle="Italic" FontSize="11" />
                        </Border>

                        <!-- PM 7 Table -->
                        <DataGrid ItemsSource="{Binding Pm7Rows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  FontSize="11"
                                  Visibility="{Binding HasPm7Data,
                                      Converter={StaticResource BoolToVisibilityConverter}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No."
                                                    Binding="{Binding Index}"
                                                    Width="36" />
                                <DataGridTextColumn Header="Code"
                                                    Binding="{Binding PointCode}"
                                                    Width="56" />
                                <DataGridTextColumn Header="Verification Point"
                                                    Binding="{Binding PointName}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Strain State"
                                                    Binding="{Binding StrainDescription}"
                                                    Width="*" />
                                <DataGridTextColumn Binding="{Binding SolverPDisplay}"
                                                    Width="90"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DataContext.ForceUnit, RelativeSource={RelativeSource AncestorType=DataGrid}, StringFormat='φPn ({0})'}"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding SolverMDisplay}"
                                                    Width="90"
                                                    ElementStyle="{StaticResource RightAlignText}">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DataContext.MomentUnit, RelativeSource={RelativeSource AncestorType=DataGrid}, StringFormat='φMn ({0})'}"/>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Units note -->
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource CaptionStyle}"
                                   Visibility="{Binding HasPm7Data,
                                       Converter={StaticResource BoolToVisibilityConverter}}">
                            <Run Text="Force units: " />
                            <Run Text="{Binding ForceUnit, Mode=OneWay}" />
                            <Run Text="  |  Moment units: " />
                            <Run Text="{Binding MomentUnit, Mode=OneWay}" />
                            <Run Text="  |  N/A = value not available from solver result." />
                        </TextBlock>

                        <TextBlock Style="{StaticResource PageNumberStyle}" Text="— 2 —" />
                    </StackPanel>
                </Border>

                <!-- ┌────────────────────────────────────────────────┐
                     │  PAGE 3 – Critical Chart Visualization        │
                     └────────────────────────────────────────────────┘ -->
                <Border Style="{StaticResource A4PageStyle}"
                        Visibility="{Binding IncludeGoverningChart,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="III.  Critical Utilization Slice"
                                   Style="{StaticResource ChapterHeadingStyle}" />

                        <!-- No governing data -->
                        <Border Style="{StaticResource PlaceholderStyle}"
                                Visibility="{Binding HasNoPmChartData,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Critical chart visualization is not available from the current solver result. Calculate the section first."
                                       Foreground="#888888" FontStyle="Italic" FontSize="11" />
                        </Border>

                        <!-- Governing chart content -->
                        <StackPanel Visibility="{Binding HasGoverningChart,
                                        Converter={StaticResource BoolToVisibilityConverter}}">

                            <!-- Caption -->
                            <Border Background="#EBF5FB" BorderBrush="#AED6F1"
                                    BorderThickness="1" CornerRadius="3"
                                    Padding="10" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding GoverningChart.Caption}"
                                               TextWrapping="Wrap" FontSize="11"
                                               Foreground="#1A5276" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                Visibility="{Binding GoverningChart.LoadCaseName,
                                                    Converter={StaticResource NullOrEmptyToCollapsedConverter}}">
                                        <TextBlock Text="Governing case: " FontSize="10" Foreground="#555" />
                                        <TextBlock Text="{Binding GoverningChart.LoadCaseName}"
                                                   FontSize="10" Foreground="#555" FontWeight="SemiBold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Two charts stacked vertically -->
                            <StackPanel>

                                <!-- 2D PM chart (governing θ slice) -->
                                <StackPanel Margin="0,0,0,16"
                                            Visibility="{Binding GoverningChart.HasPmChart,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="2D P-M Interaction (governing θ)"
                                               FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <controls:DiagramCanvas2D
                                        Height="340"
                                        Points="{Binding GoverningChart.PmAllPoints}"
                                        ReferenceLines="{Binding GoverningChart.PmReferenceLines}"
                                        XAxisLabel="{Binding GoverningChart.PmXAxisLabel}"
                                        YAxisLabel="{Binding GoverningChart.PmYAxisLabel}"
                                        HighlightedDemandLabel="{Binding GoverningChart.LoadCaseName}"
                                        ShowGrid="True"
                                        ShowLabels="True"
                                        ShowDemandPoint="True"
                                        ShowDemandLabel="False"
                                        ShowSpecialPoints="False"
                                        ShowGoverningPoint="True"
                                        ShowReferenceLines="True"
                                        ShowNominalCurve="True" />
                                    <!-- PM legend -->
                                    <Border Background="#FFF8F8" BorderBrush="#F5BEBE"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="8,5" Margin="0,4,0,0"
                                            Visibility="{Binding GoverningChart.HasDemandPoint,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="#E31B23"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock FontSize="10" VerticalAlignment="Center">
                                                <Run Text="{Binding GoverningChart.LoadCaseName, Mode=OneWay}" FontWeight="SemiBold" />
                                                <Run Text="  |  Mθ = " />
                                                <Run Text="{Binding GoverningChart.DemandMthetaDisplay, Mode=OneWay}" />
                                                <Run Text=",  P = " />
                                                <Run Text="{Binding GoverningChart.DemandPDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- PM chart not available placeholder -->
                                    <Border Style="{StaticResource PlaceholderStyle}"
                                            Visibility="{Binding GoverningChart.HasPmChart,
                                                Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="P-M slice not available from current solver result."
                                                   Foreground="#888888" FontStyle="Italic" FontSize="10" />
                                    </Border>
                                </StackPanel>

                                <!-- 2D MM chart -->
                                <StackPanel Visibility="{Binding GoverningChart.HasMmChart,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="2D M-M Contour (at governing P level)"
                                               FontSize="11" FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <controls:DiagramCanvas2D
                                        Height="340"
                                        Points="{Binding GoverningChart.MmAllPoints}"
                                        ReferenceLines="{Binding GoverningChart.MmReferenceLines}"
                                        XAxisLabel="{Binding GoverningChart.MmXAxisLabel}"
                                        YAxisLabel="{Binding GoverningChart.MmYAxisLabel}"
                                        HighlightedDemandLabel="{Binding GoverningChart.LoadCaseName}"
                                        ShowGrid="True"
                                        ShowLabels="True"
                                        ShowDemandPoint="True"
                                        ShowDemandLabel="False"
                                        ShowSpecialPoints="False"
                                        ShowGoverningPoint="False"
                                        ShowReferenceLines="True"
                                        ShowNominalCurve="True"
                                        UseEqualAspect="True" />
                                    <!-- MM legend -->
                                    <Border Background="#FFF8F8" BorderBrush="#F5BEBE"
                                            BorderThickness="1" CornerRadius="3"
                                            Padding="8,5" Margin="0,4,0,0"
                                            Visibility="{Binding GoverningChart.HasDemandPoint,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="#E31B23"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock FontSize="10" VerticalAlignment="Center">
                                                <Run Text="{Binding GoverningChart.LoadCaseName, Mode=OneWay}" FontWeight="SemiBold" />
                                                <Run Text="  |  Mx = " />
                                                <Run Text="{Binding GoverningChart.DemandMxDisplay, Mode=OneWay}" />
                                                <Run Text=",  My = " />
                                                <Run Text="{Binding GoverningChart.DemandMyDisplay, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- MM chart not available placeholder -->
                                    <Border Style="{StaticResource PlaceholderStyle}"
                                            Visibility="{Binding GoverningChart.HasMmChart,
                                                Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="M-M contour not available from current solver result."
                                                   Foreground="#888888" FontStyle="Italic" FontSize="10" />
                                    </Border>
                                </StackPanel>

                            </StackPanel>

                        </StackPanel>

                        <TextBlock Style="{StaticResource PageNumberStyle}" Text="— 3 —" />
                    </StackPanel>
                </Border>

                <!-- ┌────────────────────────────────────────────────┐
                     │  PAGE 4 – Applied Demand Cases                │
                     └────────────────────────────────────────────────┘ -->
                <Border Style="{StaticResource A4PageStyle}"
                        Visibility="{Binding IncludeDemandCases,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="IV.  Applied Demand Cases"
                                   Style="{StaticResource ChapterHeadingStyle}" />

                        <DataGrid ItemsSource="{Binding DemandCases}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  FontSize="11">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFailing}" Value="True">
                                            <Setter Property="Background" Value="#FFEBEB" />
                                            <Setter Property="Foreground" Value="#D32F2F" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Case Name"    Binding="{Binding CaseName}"      Width="140" />
                                <DataGridTextColumn Header="P"            Binding="{Binding Pu,  StringFormat={}{0:0.#}}" Width="70" ElementStyle="{StaticResource RightAlignText}" />
                                <DataGridTextColumn Header="Mx"           Binding="{Binding Mux, StringFormat={}{0:0.#}}" Width="70" ElementStyle="{StaticResource RightAlignText}" />
                                <DataGridTextColumn Header="My"           Binding="{Binding Muy, StringFormat={}{0:0.#}}" Width="70" ElementStyle="{StaticResource RightAlignText}" />
                                <DataGridTextColumn Header="PMM Ratio"    Binding="{Binding PmmRatio, StringFormat={}{0:0.###}}" Width="80" ElementStyle="{StaticResource RightAlignText}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Style="{StaticResource PageNumberStyle}" Text="— 4 —" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
