<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.DemandCasesInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="InputViewResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
                <!-- Left Column: Demand Cases Table + Diagram -->
                <GroupBox Header="Demand Cases"
                          Grid.Column="0"
                          Background="White"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="14"
                          Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Moment sign convention diagram -->
                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6"
                                VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Moment Sign Convention"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Margin="0,0,0,4"
                                           HorizontalAlignment="Center" />
                                <Viewbox Stretch="Uniform"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center">
                                    <Canvas Width="900" Height="1100">
                                        <Canvas.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Arial, Helvetica, sans-serif"/>
                                                <Setter Property="Foreground" Value="#0046d5"/>
                                            </Style>
                                        </Canvas.Resources>

                                        <Rectangle Width="900" Height="1100" Fill="White"/>

                                        <!-- Column faces -->
                                        <Polygon Points="170.0,860.0 480.0,860.0 480.0,110.0 170.0,110.0" Fill="#dcecff" Opacity="0.45" />
                                        <Polygon Points="480.0,860.0 625.0,765.0 625.0,15.0 480.0,110.0" Fill="#dcecff" Opacity="0.65" />
                                        <Polygon Points="170.0,110.0 480.0,110.0 625.0,15.0 315.0,15.0" Fill="#dcecff" Opacity="0.55" />

                                        <!-- Main prism outline -->
                                        <Polyline Points="170.0,860.0 480.0,860.0 625.0,765.0 315.0,765.0 170.0,860.0" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                        <Polyline Points="170.0,110.0 480.0,110.0 625.0,15.0 315.0,15.0 170.0,110.0" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                        <Line X1="170" Y1="860" X2="170" Y2="110" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                        <Line X1="480" Y1="860" X2="480" Y2="110" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                        <Line X1="625" Y1="765" X2="625" Y2="15" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                        <Line X1="315" Y1="765" X2="315" Y2="15" Stroke="#0046d5" StrokeThickness="1.6" StrokeDashArray="7 7"/>

                                        <!-- Mid section -->
                                        <Polygon Points="170.0,445.0 480.0,445.0 625.0,350.0 315.0,350.0" Fill="White" Opacity="0.45" Stroke="#0046d5" StrokeThickness="2.4"/>
                                        <Line X1="170" Y1="445" X2="625" Y2="350" Stroke="#0046d5" StrokeThickness="1.6" StrokeDashArray="7 7"/>
                                        <Line X1="480" Y1="445" X2="315" Y2="350" Stroke="#0046d5" StrokeThickness="1.6" StrokeDashArray="7 7"/>

                                        <!-- Centroid marker -->
                                        <Ellipse Canvas.Left="381.5" Canvas.Top="381.5" Width="32" Height="32" Fill="White" Stroke="#0046d5" StrokeThickness="2.2"/>
                                        <Ellipse Canvas.Left="392.5" Canvas.Top="392.5" Width="10" Height="10" Fill="#0046d5"/>

                                        <!-- Axial load P -->
                                        <Line X1="397.5" Y1="147.5" X2="397.5" Y2="373.5" Stroke="#0046d5" StrokeThickness="3" />
                                        <Polygon Points="382.5,343.5 397.5,373.5 412.5,343.5" Fill="#0046d5" />
                                        <TextBlock Canvas.Left="415.5" Canvas.Top="157" Text="P" FontSize="58" />

                                        <!-- MX -->
                                        <Line X1="397.5" Y1="397.5" X2="647.5" Y2="397.5" Stroke="#0046d5" StrokeThickness="3"/>
                                        <Path Data="M 642.5 384.5 L 669.5 397.5 L 642.5 410.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                        <Path Data="M 667.5 384.5 L 694.5 397.5 L 667.5 410.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                        <TextBlock Canvas.Left="723" Canvas.Top="374" Text="MX" FontSize="58" />

                                        <!-- MY -->
                                        <Line X1="397.5" Y1="397.5" X2="517.5" Y2="304.5" Stroke="#0046d5" StrokeThickness="3"/>
                                        <Path Data="M 507.5 287.5 L 535.5 285.5 L 520.5 310.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                        <Path Data="M 528.5 270.5 L 556.5 268.5 L 541.5 293.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                        <TextBlock Canvas.Left="587" Canvas.Top="243" Text="MY" FontSize="58" />

                                        <!-- Coordinate triad (enlarged, shifted down) -->
                                        <Line X1="620" Y1="1040" X2="850" Y2="1040" Stroke="#0046d5" StrokeThickness="2.8" />
                                        <Path Data="M 822 1025 L 850 1040 L 822 1055" Stroke="#0046d5" StrokeThickness="2.2" Fill="Transparent" />
                                        <Line X1="620" Y1="1040" X2="770" Y2="920" Stroke="#0046d5" StrokeThickness="2.8" />
                                        <Path Data="M 755 947 L 770 920 L 740 928" Stroke="#0046d5" StrokeThickness="2.2" Fill="Transparent" />
                                        <Line X1="620" Y1="1040" X2="620" Y2="830" Stroke="#0046d5" StrokeThickness="2.8" />
                                        <Path Data="M 606 860 L 620 830 L 634 860" Stroke="#0046d5" StrokeThickness="2.2" Fill="Transparent" />
                                        <TextBlock Canvas.Left="858" Canvas.Top="1022" Text="X" FontSize="42" FontWeight="SemiBold" />
                                        <TextBlock Canvas.Left="778" Canvas.Top="895" Text="Y" FontSize="42" FontWeight="SemiBold" />
                                        <TextBlock Canvas.Left="598" Canvas.Top="790" Text="Z" FontSize="42" FontWeight="SemiBold" />
                                    </Canvas>
                                </Viewbox>
                            </StackPanel>
                        </Border>

                        <!-- Right: DataGrid + buttons -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                                <CheckBox Content="Include EC2 slenderness amplification"
                                          IsChecked="{Binding IncludeEc2Slenderness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          FontWeight="SemiBold"
                                          Margin="0,0,12,6" />
                                <TextBlock Text="Method: EC2 Nominal Curvature"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="0,2,12,6"
                                           Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="{Binding DemandInputModeText}"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="0,2,16,6" />
                                 <Button Content="Re-import Forces"
                                         Command="{Binding DataContext.ReimportForcesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Style="{StaticResource PrimaryButtonStyle}"
                                         Padding="12,4"
                                         FontSize="{StaticResource FontSizeBody}"
                                         Margin="0,0,0,6" />
                             </WrapPanel>

                            <Border Grid.Row="1"
                                    Style="{StaticResource CardBorderStyle}"
                                    Padding="10"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}">
                                <WrapPanel>
                                    <StackPanel Width="120" Margin="0,0,10,6">
                                        <DockPanel>
                                            <TextBlock Text="L" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MemberLengthLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBox Style="{StaticResource ComputedTextBoxStyle}"
                                                 Text="{Binding MemberLengthDisplay, Mode=OneWay, TargetNullValue=''}" />
                                    </StackPanel>

                                    <StackPanel Width="95" Margin="0,0,10,6">
                                        <TextBlock Text="kx" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Text="{Binding Kx, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </StackPanel>

                                    <StackPanel Width="95" Margin="0,0,10,6">
                                        <TextBlock Text="ky" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Text="{Binding Ky, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </StackPanel>

                                    <StackPanel Width="110" Margin="0,0,10,6">
                                        <DockPanel>
                                            <TextBlock Text="l&#x2080;x" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MemberLengthLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBox Style="{StaticResource ComputedTextBoxStyle}"
                                                 Text="{Binding L0xText, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Width="110" Margin="0,0,10,6">
                                        <DockPanel>
                                            <TextBlock Text="l&#x2080;y" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MemberLengthLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBox Style="{StaticResource ComputedTextBoxStyle}"
                                                 Text="{Binding L0yText, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Width="200" Margin="0,0,10,6">
                                        <TextBlock Style="{StaticResource FieldLabelTextStyle}">
                                            <Run Text="&#x03C6;" /><Run Text="eff" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=" — Effective creep ratio" />
                                        </TextBlock>
                                        <TextBox Text="{Binding PhiEff, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"
                                                 ToolTip="&#x03C6;eff = &#x03C6;(&#x221E;,t&#x2080;) &#x00D7; M&#x2080;EQP / M&#x2080;Ed (EC2 &#x00A7;5.8.4).&#x0A;Typical range: 0.5 &#x2013; 2.5.&#x0A;Leave blank to use default A = 0.7." />
                                        <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,3,0,0" Foreground="{DynamicResource TextMutedBrush}">Typical: 0.5 &#x2013; 2.5  (EC2 &#x00A7;5.8.4)</TextBlock>
                                    </StackPanel>

                                </WrapPanel>
                            </Border>

                             <Grid Grid.Row="2">
                                <DataGrid x:Name="LoadCasesGrid"
                                          ItemsSource="{Binding LoadCases}"
                                          SelectedItem="{Binding SelectedLoadCase, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeColumns="True"
                                          HeadersVisibility="Column"
                                          SelectionMode="Extended"
                                          SelectionUnit="CellOrRowHeader"
                                          ClipboardCopyMode="IncludeHeader"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          EnableRowVirtualization="True"
                                          Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                          PreviewKeyDown="DataGrid_PreviewKeyDown">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                            <Setter Property="FontSize" Value="11" />
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="View EC2 Moment Determination"
                                                                  Command="{Binding PlacementTarget.Tag.ShowSlendernessCalculationDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Separator />
                                                        <MenuItem Header="Duplicate"
                                                                  Command="{Binding PlacementTarget.Tag.DuplicateLoadCaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <MenuItem Header="Remove"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteLoadCaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Include"
                                                                Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="70" />
                                        <DataGridTextColumn Header="Case Name"
                                                            Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                            Width="110"
                                                            ElementStyle="{StaticResource LeftAlignText}" />
                                        <DataGridTextColumn Binding="{Binding MemberLengthOverrideDisplay, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F3}"
                                                            Width="65"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MemberLengthOverrideHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding NEd, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.DemandForceHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vx, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.ShearVuxHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vy, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.ShearVuyHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxTop, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxTopHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxBottomHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyTop, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyTopHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyBottomHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxUsed, TargetNullValue=auto, StringFormat=F1}"
                                                            Width="*"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyUsed, TargetNullValue=auto, StringFormat=F1}"
                                                            Width="*"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            Width="90"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource LeftAlignText}">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
 
                                <DataGrid x:Name="SlenderLoadCasesGrid"
                                          ItemsSource="{Binding LoadCases}"
                                          SelectedItem="{Binding SelectedLoadCase, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeColumns="True"
                                          HeadersVisibility="Column"
                                          SelectionMode="Extended"
                                          SelectionUnit="CellOrRowHeader"
                                          ClipboardCopyMode="IncludeHeader"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          EnableRowVirtualization="True"
                                          Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}"
                                          PreviewKeyDown="DataGrid_PreviewKeyDown">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                            <Setter Property="FontSize" Value="11" />
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="View EC2 Moment Determination"
                                                                  Command="{Binding PlacementTarget.Tag.ShowSlendernessCalculationDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Separator />
                                                        <MenuItem Header="Duplicate"
                                                                  Command="{Binding PlacementTarget.Tag.DuplicateLoadCaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <MenuItem Header="Remove"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteLoadCaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Include"
                                                                Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="70" />
                                        <DataGridTextColumn Header="Case Name"
                                                            Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                            Width="110"
                                                            ElementStyle="{StaticResource LeftAlignText}" />
                                        <DataGridTextColumn Binding="{Binding MemberLengthOverrideDisplay, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F3}"
                                                            Width="65"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MemberLengthOverrideHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding NEd, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.DemandForceHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vx, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.ShearVuxHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vy, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.ShearVuyHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxTop, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxTopHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxBottomHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyTop, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyTopHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyBottomHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="λx"
                                                            Binding="{Binding LambdaX, TargetNullValue='-', StringFormat=F2}"
                                                            Width="60" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Header="λlim,x"
                                                            Binding="{Binding LambdaLimitX, TargetNullValue='-', StringFormat=F2}"
                                                            Width="72" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Header="λy"
                                                            Binding="{Binding LambdaY, TargetNullValue='-', StringFormat=F2}"
                                                            Width="60" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Header="λlim,y"
                                                            Binding="{Binding LambdaLimitY, TargetNullValue='-', StringFormat=F2}"
                                                            Width="72" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Binding="{Binding MxUsed, TargetNullValue=auto, StringFormat=F1}"
                                                            Width="*"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyUsed, TargetNullValue=auto, StringFormat=F1}"
                                                            Width="*"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            Width="100"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource LeftAlignText}">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- Buttons below DataGrid -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="+ Add case"
                                        Command="{Binding AddLoadCaseCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Delete demand case"
                                        Command="{Binding DeleteSelectedLoadCasesCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=LoadCasesGrid}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                                        Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <Button Content="Delete demand case"
                                        Command="{Binding DeleteSelectedLoadCasesCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=SlenderLoadCasesGrid}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                                        Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Content="Import from CSV"
                                        Command="{Binding ImportLoadCasesCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0" />
                                <Button Content="Export to CSV"
                                        Command="{Binding ExportLoadCasesCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </GroupBox>
</UserControl>
