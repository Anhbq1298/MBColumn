<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.SectionPreviewInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
                <!-- Column 2: Section Preview -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Preview card -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Section Preview"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="SECTION PREVIEW"
                                           Style="{StaticResource OverlineTextStyle}"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="2D VIEW &#x00B7; GRID"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,0,0,4" />
                                <controls:SectionPreviewCanvas Height="240"
                                                               MinHeight="160"
                                                               HorizontalAlignment="Stretch"
                                                               SectionWidth="{Binding SectionWidth}"
                                                               SectionHeight="{Binding SectionHeight}"
                                                               Cover="{Binding Cover}"
                                                               UnitSystem="{Binding SelectedUnitSystem}"
                                                               SectionShape="{Binding SelectedSectionShape}"
                                                               Rebars="{Binding PreviewRebars}"
                                                               SectionLabel="{Binding SectionPreviewLabel}"
                                                               RebarLabel="{Binding RebarPreviewLabel}"
                                                               CoverLabel="{Binding CoverPreviewLabel}"
                                                               IsValid="{Binding IsSectionPreviewValid}"
                                                               ErrorMessage="{Binding SectionPreviewErrorMessage}"
                                                               BoundaryPoints="{Binding PreviewBoundaryPoints}"
                                                               StirrupDiameterMm="{Binding StirrupDiameterMm}"
                                                               InnerLegsX="{Binding InnerLegsX}"
                                                               InnerLegsY="{Binding InnerLegsY}" />
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,10">
                                    <Button Click="OpenCadEditor_Click"
                                            Style="{StaticResource CompactButtonStyle}"
                                            MinWidth="78"
                                            MinHeight="32"
                                            Padding="10,5"
                                            Margin="0,0,8,0"
                                            ToolTip="Open CAD Lite editor"
                                            Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE70F;"
                                                       FontFamily="{StaticResource IconFontFamily}"
                                                       FontSize="{StaticResource FontSizeSection}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Edit"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ImportDxfCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="96"
                                            MinHeight="32"
                                            Padding="10,5"
                                            Margin="0,0,8,0"
                                            ToolTip="Import .DXF">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 6,3 L 15,3 L 20,8 L 20,21 L 6,21 Z M 15,3 L 15,8 L 20,8"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                    <Path Data="M 12,9 L 12,16 M 8.8,13 L 12,16.2 L 15.2,13"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Import .dxf" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ExportDxfCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="96"
                                            MinHeight="32"
                                            Padding="10,5"
                                            ToolTip="Export current section as .DXF">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 6,3 L 15,3 L 20,8 L 20,21 L 6,21 Z M 15,3 L 15,8 L 20,8"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                    <Path Data="M 12,14 L 12,7 M 8.8,10 L 12,6.8 L 15.2,10"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Export .dxf" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Section properties (compact) -->
                                <Separator Background="{DynamicResource BorderGreyBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="SECTION PROPERTIES"
                                           Style="{StaticResource OverlineTextStyle}"
                                           Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Section" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewShapeSummaryText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Layout" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewRebarLayoutText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Cover" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CoverPreviewLabel}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="A" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewAreaText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Ixx" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PreviewIxxText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Iyy" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PreviewIyyText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource PreviewPropertyLabelTextStyle}">
                                        <Run Text="r"/>
                                        <Run Text="x" FontSize="{StaticResource FontSizeSubscript}" BaselineAlignment="Subscript"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PreviewIxText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource PreviewPropertyLabelTextStyle}">
                                        <Run Text="r"/>
                                        <Run Text="y" FontSize="{StaticResource FontSizeSubscript}" BaselineAlignment="Subscript"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding PreviewIyText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="9" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Rebars" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding RebarPreviewLabel}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="rho (&#x03C1;)" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding PreviewRebarPercentageText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="12" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="13" Grid.Column="0" Text="Concrete" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding PreviewConcreteQuantityText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="14" Grid.Column="0" Text="Steel" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding PreviewSteelQuantityText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>


</UserControl>
