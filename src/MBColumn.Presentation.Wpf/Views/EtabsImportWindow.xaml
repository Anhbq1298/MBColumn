<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        Title="Import from ETABS"
        Width="1200"
        Height="820"
        MinWidth="1060"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Loaded="OnWindowLoaded">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
        </Style>
        <Style x:Key="GroupCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="GroupNameNormalStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SmallIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StepCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="StepCircleActiveStyle" TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
        </Style>
        <Style x:Key="WarningBannerStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8E1" />
            <Setter Property="BorderBrush" Value="#FFC107" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="StepButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryNavyBrush}"
                Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Command="{Binding CancelCommand}"
                        Width="30"
                        Height="26"
                        Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <StackPanel>
                    <TextBlock Text="Import from ETABS"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="#DCEBFF"
                               FontSize="12"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ─── Step Indicator ─── -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Step 1 -->
                <Button Command="{Binding GoToFlow1Command}" Style="{StaticResource StepButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow1}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlow1}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Section Assignment" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow1}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Rectangle Width="50" Height="1" Fill="{DynamicResource BorderGreyBrush}"
                           VerticalAlignment="Center" Margin="14,0" />

                <!-- Step 2 -->
                <Button Command="{Binding GoToFlow2Command}" Style="{StaticResource StepButtonStyle}"
                        ToolTip="Connect to ETABS first to access Force Import">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow2}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlow2}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Force Import" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow2}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Rectangle Width="50" Height="1" Fill="{DynamicResource BorderGreyBrush}"
                           VerticalAlignment="Center" Margin="14,0" />

                <!-- Step 3 -->
                <Button Command="{Binding GoToFlow3Command}" Style="{StaticResource StepButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow3}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlow3}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Review &amp; Import" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow3}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             FLOW 1 — MB Column Section Assignment
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Margin="12,10,12,8"
              Visibility="{Binding IsFlow1, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.8*" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Connection + Filter + Available Items ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Connection -->
                <GroupBox Grid.Row="0"
                          Header="Connection"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="10"
                          Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="{Binding UnitConversionMessage}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Connect to running ETABS"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,5"
                                    MinHeight="30" />
                            <Button Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,5"
                                    MinHeight="30"
                                    Margin="8,0,0,0" />
                            <TextBlock Text="{Binding ModelName, StringFormat='  {0}'}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextDarkBrush}" />
                        </StackPanel>
                    </DockPanel>
                </GroupBox>

                <!-- Filter -->
                <GroupBox Grid.Row="1"
                          Header="Filter"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="10"
                          Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="85" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="85" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="ETABS Element"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding EtabsElementFilters}"
                                  SelectedItem="{Binding SelectedEtabsElementFilter}" />

                        <TextBlock Grid.Row="0" Grid.Column="3"
                                   Text="Section Type"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="4"
                                  ItemsSource="{Binding SectionTypeFilters}"
                                  SelectedItem="{Binding SelectedSectionTypeFilter}"
                                  IsEnabled="{Binding IsSectionTypeFilterEnabled}" />

                        <TextBlock Grid.Row="0" Grid.Column="6"
                                   Text="Unique Section"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="7"
                                  ItemsSource="{Binding UniqueSectionOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedUniqueSection}" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Story From"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  ItemsSource="{Binding StoryOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="StoryName"
                                  SelectedValue="{Binding StoryFrom, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   Text="Story To"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="2" Grid.Column="4"
                                  ItemsSource="{Binding StoryOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="StoryName"
                                  SelectedValue="{Binding StoryTo, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Grid.Column="6"
                                   Text="Label Filter"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="7"
                                 Text="{Binding LabelTextFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <!-- Available Items -->
                <GroupBox Grid.Row="2"
                          Header="Available Items"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="0">
                    <DataGrid ItemsSource="{Binding TierObjectCandidatesView}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              SelectionChanged="OnDataGridSelectionChanged"
                              ContextMenuOpening="OnAvailableItemsContextMenuOpening">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding SectionTypeDisplay}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="Section / Pier" Binding="{Binding EtabsSectionName}" Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="Story" Binding="{Binding Story}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Section" Binding="{Binding ImportGroupName}" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                        <Setter Property="FontStyle" Value="Italic" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>

            <!-- ── RIGHT: Section Preview + Summary + Import Groups ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="240" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section Preview (SectionPreviewCanvas style) -->
                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="6">
                    <controls:SectionPreviewCanvas
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        SectionWidth="{Binding BoundaryPreviewWidth}"
                        SectionHeight="{Binding BoundaryPreviewHeight}"
                        Cover="{Binding BoundaryPreviewCover}"
                        UnitSystem="{Binding TargetUnitSystem}"
                        SectionShape="{Binding BoundaryPreviewSectionShape}"
                        BoundaryPoints="{Binding BoundaryPreviewPoints}"
                        SectionLabel="{Binding BoundaryPreviewSectionLabel}"
                        IsValid="{Binding IsBoundaryPreviewValid}"
                        ErrorMessage="{Binding PreviewStatusText}" />
                </Border>

                <!-- Import Summary -->
                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Import Summary" Style="{StaticResource SectionHeaderStyle}" />
                        <UniformGrid Columns="3">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding UnassignedCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Unassigned" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AssignedCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Assigned" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MbColumnSectionsReadyCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Sections ready" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </UniformGrid>
                        <!-- Flow 1 validation warning -->
                        <Border Margin="0,8,0,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource WarningBannerStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFlow1Warning}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding Flow1ValidationMessage}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="#7B5E00" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Import Groups -->
                <Border Grid.Row="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,8,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Content="+ New Section"
                                    Command="{Binding CreateMbColumnSectionCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="26" />
                            <TextBlock Text="MB Column Sections"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="No sections yet. Select items on the left, then click + New Section."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MbColumnSections.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MbColumnSections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:MbColumnSectionViewModel}">
                                        <Border Style="{StaticResource GroupCardStyle}">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,4">
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{StaticResource SmallIconButtonStyle}"
                                                            ToolTip="Delete section"
                                                            Command="{Binding DataContext.DeleteMbColumnSectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{StaticResource SmallIconButtonStyle}"
                                                            ToolTip="Clear all items from section"
                                                            Command="{Binding ClearSectionCommand}"
                                                            Margin="0,0,4,0">
                                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <StackPanel DockPanel.Dock="Right"
                                                                Orientation="Horizontal"
                                                                Margin="0,0,4,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Content="✓"
                                                                Command="{Binding CommitRenameCommand}"
                                                                Style="{StaticResource SmallIconButtonStyle}"
                                                                ToolTip="Confirm rename" />
                                                        <Button Content="✕"
                                                                Command="{Binding CancelRenameCommand}"
                                                                Style="{StaticResource SmallIconButtonStyle}"
                                                                ToolTip="Cancel rename"
                                                                Margin="2,0,0,0" />
                                                    </StackPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            ToolTip="Rename section"
                                                            Command="{Binding BeginRenameCommand}"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource GroupNameNormalStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding SectionName, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding ItemCount, StringFormat=({0}), Mode=OneWay}"
                                                             Foreground="{DynamicResource TextMutedBrush}" />
                                                    </TextBlock>
                                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </DockPanel>

                                                <!-- Rename error message -->
                                                <TextBlock Text="{Binding RenameError}"
                                                           FontSize="10"
                                                           Foreground="#C62828"
                                                           Margin="0,2,0,0"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RenameError}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding RenameError}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Content="→ Assign selected items"
                                                        Command="{Binding DataContext.AssignToSectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="8,3"
                                                        MinHeight="24"
                                                        HorizontalAlignment="Left"
                                                        FontSize="11" />

                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="0,6,0,0">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ItemCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EtabsColumnImportRowViewModel}">
                                                            <DockPanel Margin="0,1">
                                                                <Button DockPanel.Dock="Right"
                                                                        Content="×"
                                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SmallIconButtonStyle}"
                                                                        FontSize="12"
                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                        ToolTip="Remove from section" />
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource TextDarkBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <Run Text="{Binding EtabsSectionName, Mode=OneWay}" />
                                                                    <Run Text=" | " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Story, Mode=OneWay}" />
                                                                    <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Label, Mode=OneWay}" />
                                                                </TextBlock>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             FLOW 2 — Force Import
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Margin="12,10,12,8"
              Visibility="{Binding IsFlow2, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <!-- Demand Cases (left) -->
            <GroupBox Grid.Column="0"
                      Header="Demand Cases"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SelectedLoadCombinationCount, StringFormat='{}{0} selected'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="All"
                                    Command="{Binding SelectAllCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="24"
                                    FontSize="11" />
                            <Button Content="None"
                                    Command="{Binding ClearAllCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="24"
                                    FontSize="11"
                                    Margin="4,0,0,0" />
                            <Button Content="⟳"
                                    Command="{Binding RefreshCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="24"
                                    FontSize="11"
                                    Margin="4,0,0,0"
                                    ToolTip="Refresh load combinations from ETABS" />
                        </StackPanel>
                    </DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBox Text="{Binding LoadCombinationFilterText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" />
                        <TextBlock Text="Search combinations..."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsHitTestVisible="False"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LoadCombinationFilterText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LoadCombinationFilterText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ListBox ItemsSource="{Binding FilteredLoadCombinations}"
                             BorderBrush="{DynamicResource BorderGreyBrush}"
                             FontSize="12"
                             SelectionMode="Extended"
                             SelectionChanged="OnListBoxSelectionChanged"
                             DisplayMemberPath="Name">
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- Selected Story/Label Items -->
            <GroupBox Grid.Column="2"
                      Header="Selected Items"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding AllAssignedItems.Count, StringFormat='{}{0} item(s)'}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,6" />
                    <DataGrid ItemsSource="{Binding AllAssignedItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              FontSize="11"
                              RowHeight="22"
                              BorderBrush="{DynamicResource BorderGreyBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Section"
                                                Binding="{Binding ImportGroupName}"
                                                Width="*" />
                            <DataGridTextColumn Header="Story"
                                                Binding="{Binding Story}"
                                                Width="65" />
                            <DataGridTextColumn Header="Label"
                                                Binding="{Binding Label}"
                                                Width="55" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <!-- Force Preview (middle) -->
            <GroupBox Grid.Column="4"
                      Header="Force Preview"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <DockPanel>
                    <!-- Force source status + selection -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource LightBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Design Forces -->
                            <StackPanel Grid.Column="0">
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock DockPanel.Dock="Right"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding DesignForcesStatusText}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDesignForcesImported}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Design Forces:" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <RadioButton Content="Use Design Forces"
                                             IsChecked="{Binding UseDesignForces, Mode=TwoWay}"
                                             IsEnabled="{Binding IsDesignForcesImported}"
                                             FontSize="11"
                                             Margin="0,2" />
                            </StackPanel>
                            <!-- Element Forces -->
                            <StackPanel Grid.Column="2">
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock DockPanel.Dock="Right"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding ElementForcesStatusText}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsElementForcesAvailable}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Element Forces:" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <RadioButton Content="Use Element Forces"
                                             IsChecked="{Binding UseElementForces, Mode=TwoWay}"
                                             IsEnabled="{Binding IsElementForcesAvailable}"
                                             FontSize="11"
                                             Margin="0,2" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Trigger bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Left"
                                Content="Load Forces"
                                Command="{Binding LoadForcesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="14,5"
                                MinHeight="28" />
                        <TextBlock Text="{Binding ForceCacheStatus}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="8,0,0,0" />
                    </DockPanel>

                    <!-- Flow 2 validation warning -->
                    <Border DockPanel.Dock="Top">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource WarningBannerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFlow2Warning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Flow2ValidationMessage}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="#7B5E00" />
                    </Border>

                    <!-- Force rows TabControl -->
                    <TabControl FontSize="11">
                        <!-- Tab 1: All Forces (raw preview) -->
                        <TabItem Header="All Forces">
                            <DataGrid ItemsSource="{Binding ForceRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Extended"
                                      FontSize="11"
                                      RowHeight="22"
                                      BorderBrush="{DynamicResource BorderGreyBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="LoadcaseMBname"
                                                        Binding="{Binding LoadcaseMBname}"
                                                        Width="180" />
                                    <DataGridTextColumn Header="LOADCASE"
                                                        Binding="{Binding LoadCombination}"
                                                        Width="120" />
                                    <DataGridTextColumn Header="STORY"
                                                        Binding="{Binding Story}"
                                                        Width="80" />
                                    <DataGridTextColumn Header="Col Label"
                                                        Binding="{Binding Label}"
                                                        Width="80" />
                                    <DataGridTextColumn Header="P"
                                                        Binding="{Binding P, StringFormat=N2}"
                                                        Width="70" />
                                    <DataGridTextColumn Header="Mx"
                                                        Binding="{Binding M2, StringFormat=N2}"
                                                        Width="70" />
                                    <DataGridTextColumn Header="My"
                                                        Binding="{Binding M3, StringFormat=N2}"
                                                        Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <!-- Tab 2: By Section (filtered by MB Column Section Story+Label) -->
                        <TabItem Header="By Section">
                            <DataGrid ItemsSource="{Binding MbColumnMappedForceRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      FontSize="11"
                                      RowHeight="22"
                                      BorderBrush="{DynamicResource BorderGreyBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Section"
                                                        Binding="{Binding MbColumnSectionName}"
                                                        Width="120" />
                                    <DataGridTextColumn Header="LoadCaseName"
                                                        Binding="{Binding LoadCaseName}"
                                                        Width="200" />
                                    <DataGridTextColumn Header="Story"
                                                        Binding="{Binding Story}"
                                                        Width="80" />
                                    <DataGridTextColumn Header="Label"
                                                        Binding="{Binding Label}"
                                                        Width="80" />
                                    <DataGridTextColumn Header="Location"
                                                        Binding="{Binding Location}"
                                                        Width="70" />
                                    <DataGridTextColumn Header="P"
                                                        Binding="{Binding P, StringFormat=N2}"
                                                        Width="70" />
                                    <DataGridTextColumn Header="Mx"
                                                        Binding="{Binding Mx, StringFormat=N2}"
                                                        Width="70" />
                                    <DataGridTextColumn Header="My"
                                                        Binding="{Binding My, StringFormat=N2}"
                                                        Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </GroupBox>

            <!-- Stations (right) -->
            <GroupBox Grid.Column="6"
                      Header="Stations"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <StackPanel>
                    <TextBlock Text="Include forces at:"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,8" />
                    <CheckBox Content="Top"
                              IsChecked="{Binding ImportTop, Mode=TwoWay}"
                              Margin="0,3"
                              FontSize="12" />
                    <CheckBox Content="Bottom"
                              IsChecked="{Binding ImportBottom, Mode=TwoWay}"
                              Margin="0,3"
                              FontSize="12" />
                    <CheckBox Content="Mid-height"
                              IsChecked="{Binding ImportMid, Mode=TwoWay}"
                              Margin="0,3"
                              FontSize="12" />
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             FLOW 3 — Review &amp; Import
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Margin="12,10,12,8"
              Visibility="{Binding IsFlow3, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- MB Column Sections Summary (left) -->
            <GroupBox Grid.Column="0"
                      Header="MB Column Sections Summary"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,10"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap">
                        <Run Text="{Binding MbColumnSectionsReadyCount, Mode=OneWay}" />
                        <Run Text=" section(s) ready to import. Each section becomes one MB Column design section." />
                    </TextBlock>

                    <TextBlock DockPanel.Dock="Top"
                               Text="No MB Column Sections defined. Go back to Step 1 and assign items to sections."
                               FontSize="11"
                               Foreground="{DynamicResource AccentRedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MbColumnSectionsReadyCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TabControl FontSize="11">
                        <!-- Tab 1: Section list with Project Group assignment -->
                        <TabItem Header="Sections">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MbColumnSections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:MbColumnSectionViewModel}">
                                            <Border Style="{StaticResource GroupCardStyle}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="Project Group:" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                                                            <ComboBox ItemsSource="{Binding DataContext.TargetGroups, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      DisplayMemberPath="DisplayName"
                                                                      SelectedItem="{Binding SelectedTargetGroup, Mode=TwoWay}"
                                                                      Width="130"
                                                                      Margin="6,0,0,0" />
                                                            <Button Content="+"
                                                                    Command="{Binding DataContext.AddTargetGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Margin="4,0,0,0" Padding="6,2" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding SectionName}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </DockPanel>
                                                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,4,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:EtabsColumnImportRowViewModel}">
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource TextDarkBrush}"
                                                                           Margin="0,1">
                                                                    <Run Text="{Binding EtabsSectionName, Mode=OneWay}" />
                                                                    <Run Text=" | " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Story, Mode=OneWay}" />
                                                                    <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Label, Mode=OneWay}" />
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        <!-- Tab 2: Force mapping summary -->
                        <TabItem Header="Force Summary">
                            <DataGrid ItemsSource="{Binding MbColumnSectionSummaryRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      FontSize="11"
                                      RowHeight="22"
                                      BorderBrush="{DynamicResource BorderGreyBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="140" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding ObjectType}" Width="70" />
                                    <DataGridTextColumn Header="Items" Binding="{Binding SelectedItems}" Width="55" />
                                    <DataGridTextColumn Header="Force Rows" Binding="{Binding MatchedForceRows}" Width="80" />
                                    <DataGridTextColumn Header="Missing" Binding="{Binding MissingItems}" Width="60" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MissingItems}" Value="0">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </GroupBox>

            <!-- Right panel: Target Group + Model Info -->
            <StackPanel Grid.Column="2">
                <!-- Model Info -->
                <GroupBox Header="Model"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="12"
                          Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModelName}" FontSize="11" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Units" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PresentUnits}" FontSize="11" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Stories" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Margin="0,0,0,4">
                            <Run Text="{Binding StoryCount, Mode=OneWay}" />
                            <Run Text=" stories / " />
                            <Run Text="{Binding PierCount, Mode=OneWay}" />
                            <Run Text=" piers" />
                        </TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Frames" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FrameObjectCount}" FontSize="11" />
                    </Grid>
                </GroupBox>

                <!-- Demand Cases Summary -->
                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Force Settings" Style="{StaticResource SectionHeaderStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Combos" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SelectedLoadCombinationCount, StringFormat='{}{0} selected'}"
                                       FontSize="11" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Text="Stations" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewStationsText}" FontSize="11" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ─── Bottom Navigation Bar ─── -->
        <Border Grid.Row="3"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Cancel (always) -->
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            MinHeight="32" />

                    <!-- Back (flows 2 and 3) -->
                    <Button Content="← Back"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsFlow1, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <!-- Flow 1 → Flow 2 -->
                    <Button Content="Force Import  →"
                            Command="{Binding GoToFlow2Command}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            ToolTip="Connect to ETABS first to proceed"
                            Visibility="{Binding IsFlow1, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- Flow 2 → Flow 3 -->
                    <Button Content="Review  →"
                            Command="{Binding GoToFlow3Command}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsFlow2, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- Flow 3: Import -->
                    <Button Content="Import  →"
                            Command="{Binding ApplyImportCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsFlow3, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <TextBlock Text="{Binding ConnectionStatus}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextDarkBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
