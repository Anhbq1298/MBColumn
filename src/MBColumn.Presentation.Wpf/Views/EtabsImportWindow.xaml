<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Import from ETABS"
        Width="1200"
        Height="800"
        MinWidth="1060"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
        </Style>
        <Style x:Key="GroupCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="GroupNameNormalStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SmallIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryNavyBrush}"
                Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="X"
                        Command="{Binding CancelCommand}"
                        Width="30"
                        Height="26"
                        Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <StackPanel>
                    <TextBlock Text="Import from ETABS"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="#DCEBFF"
                               FontSize="12"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ─── Main workspace ─── -->
        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.8*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Filters + Available Items ═══ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Connection -->
                <GroupBox Grid.Row="0"
                          Header="Connection"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="10"
                          Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="{Binding UnitConversionMessage}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Connect to running ETABS"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,5"
                                    MinHeight="30" />
                            <Button Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,5"
                                    MinHeight="30"
                                    Margin="8,0,0,0" />
                            <TextBlock Text="{Binding ModelName, StringFormat='  {0}'}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextDarkBrush}" />
                        </StackPanel>
                    </DockPanel>
                </GroupBox>

                <!-- Filters -->
                <GroupBox Grid.Row="1"
                          Header="Filter"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="10"
                          Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="85" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="85" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: ETABS Element | Section Type | Unique Section -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="ETABS Element"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding EtabsElementFilters}"
                                  SelectedItem="{Binding SelectedEtabsElementFilter}" />

                        <TextBlock Grid.Row="0" Grid.Column="3"
                                   Text="Section Type"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="4"
                                  ItemsSource="{Binding SectionTypeFilters}"
                                  SelectedItem="{Binding SelectedSectionTypeFilter}"
                                  IsEnabled="{Binding IsSectionTypeFilterEnabled}" />

                        <TextBlock Grid.Row="0" Grid.Column="6"
                                   Text="Unique Section"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="0" Grid.Column="7"
                                  ItemsSource="{Binding UniqueSectionOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedUniqueSection}" />

                        <!-- Row 2: Story From | Story To | Label -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Story From"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  ItemsSource="{Binding StoryOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="StoryName"
                                  SelectedValue="{Binding StoryFrom, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   Text="Story To"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Row="2" Grid.Column="4"
                                  ItemsSource="{Binding StoryOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="StoryName"
                                  SelectedValue="{Binding StoryTo, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Grid.Column="6"
                                   Text="Label Filter"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="7"
                                 Text="{Binding LabelTextFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <!-- Available Items -->
                <GroupBox Grid.Row="2"
                          Header="Available Items"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="0">
                    <DataGrid ItemsSource="{Binding TierObjectCandidatesView}"
                              SelectedItem="{Binding SelectedColumn, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              ContextMenuOpening="OnAvailableItemsContextMenuOpening">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓"
                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="36" />
                            <DataGridTextColumn Header="Type" Binding="{Binding SectionTypeDisplay}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="Section / Pier" Binding="{Binding EtabsSectionName}" Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="Story" Binding="{Binding Story}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Group" Binding="{Binding ImportGroupName}" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                        <Setter Property="FontStyle" Value="Italic" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>

            <!-- ═══ RIGHT: Preview + Summary + Import Groups ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section Boundary Preview -->
                <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <TextBlock Text="Boundary Preview" Style="{StaticResource SectionHeaderStyle}" />
                            <TextBlock Text="{Binding PreviewStatusText}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ColumnPreviewDimensions}"
                                       Foreground="{DynamicResource TextDarkBrush}"
                                       FontSize="11"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="4">
                            <Grid>
                                <TextBlock Text="No boundary"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11"
                                           Visibility="{Binding HasBoundaryPreview, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <Viewbox Stretch="Uniform"
                                         Visibility="{Binding HasBoundaryPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Canvas Width="{Binding PreviewCanvasWidth}"
                                            Height="{Binding PreviewCanvasHeight}">
                                        <Polygon Points="{Binding BoundaryPreviewPointCollection}"
                                                 Stroke="{DynamicResource AccentBlueBrush}"
                                                 Fill="#200070C0"
                                                 StrokeThickness="1.5" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Import Summary -->
                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Import Summary" Style="{StaticResource SectionHeaderStyle}" />
                        <UniformGrid Columns="3">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding UnassignedCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Unassigned" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AssignedCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Assigned" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ImportGroupsReadyCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Groups ready" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Import Groups -->
                <Border Grid.Row="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,8,0,0">
                    <DockPanel>
                        <!-- Header row -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Content="+ New Group"
                                    Command="{Binding CreateImportGroupCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="26" />
                            <TextBlock Text="Import Groups"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Empty state -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="No groups yet. Select items on the left, then click + New Group."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ImportGroups.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Groups list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ImportGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ImportGroupViewModel}">
                                        <Border Style="{StaticResource GroupCardStyle}">
                                            <StackPanel>
                                                <!-- Group header row -->
                                                <DockPanel Margin="0,0,0,4">
                                                    <!-- Delete button -->
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{StaticResource SmallIconButtonStyle}"
                                                            ToolTip="Delete group"
                                                            Command="{Binding DataContext.DeleteImportGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <!-- Clear button -->
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{StaticResource SmallIconButtonStyle}"
                                                            ToolTip="Clear all items from group"
                                                            Command="{Binding ClearGroupCommand}"
                                                            Margin="0,0,4,0">
                                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <!-- Rename button / commit / cancel -->
                                                    <StackPanel DockPanel.Dock="Right"
                                                                Orientation="Horizontal"
                                                                Margin="0,0,4,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Content="✓"
                                                                Command="{Binding CommitRenameCommand}"
                                                                Style="{StaticResource SmallIconButtonStyle}"
                                                                ToolTip="Confirm rename" />
                                                        <Button Content="✕"
                                                                Command="{Binding CancelRenameCommand}"
                                                                Style="{StaticResource SmallIconButtonStyle}"
                                                                ToolTip="Cancel rename"
                                                                Margin="2,0,0,0" />
                                                    </StackPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            ToolTip="Rename group"
                                                            Command="{Binding BeginRenameCommand}"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>

                                                    <!-- Group name / edit -->
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource GroupNameNormalStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding GroupName, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding ItemCount, StringFormat=({0}), Mode=OneWay}"
                                                             Foreground="{DynamicResource TextMutedBrush}" />
                                                    </TextBlock>
                                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </DockPanel>

                                                <!-- Assign selected items button -->
                                                <Button Content="→ Assign selected items"
                                                        Command="{Binding DataContext.AssignToGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="8,3"
                                                        MinHeight="24"
                                                        HorizontalAlignment="Left"
                                                        FontSize="11" />

                                                <!-- Items list -->
                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="0,6,0,0">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ItemCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EtabsColumnImportRowViewModel}">
                                                            <DockPanel Margin="0,1">
                                                                <Button DockPanel.Dock="Right"
                                                                        Content="×"
                                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SmallIconButtonStyle}"
                                                                        FontSize="12"
                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                        ToolTip="Remove from group" />
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource TextDarkBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <Run Text="{Binding EtabsSectionName, Mode=OneWay}" />
                                                                    <Run Text=" | " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Story, Mode=OneWay}" />
                                                                    <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Label, Mode=OneWay}" />
                                                                </TextBlock>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ─── Bottom Bar ─── -->
        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Load Combinations (compact) -->
                <DockPanel Grid.Column="0" Margin="0,0,10,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Demand Cases"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SelectedLoadCombinationCount, StringFormat=  ({0} selected)}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="All"
                                    Command="{Binding SelectAllCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6,2"
                                    MinHeight="22"
                                    FontSize="11" />
                            <Button Content="None"
                                    Command="{Binding ClearAllCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6,2"
                                    MinHeight="22"
                                    FontSize="11"
                                    Margin="4,0,0,0" />
                            <Button Content="⟳"
                                    Command="{Binding RefreshCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="6,2"
                                    MinHeight="22"
                                    FontSize="11"
                                    Margin="4,0,0,0"
                                    ToolTip="Refresh load combinations from ETABS" />
                        </StackPanel>
                    </DockPanel>
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding LoadCombinationFilterText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4"
                             FontSize="11" />
                    <ListBox ItemsSource="{Binding FilteredLoadCombinations}"
                             MaxHeight="72"
                             BorderBrush="{DynamicResource BorderGreyBrush}"
                             FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2,1" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Separator 1 -->
                <Rectangle Grid.Column="1"
                           Fill="{DynamicResource BorderGreyBrush}"
                           Width="1"
                           Margin="0,2" />

                <!-- Stations + Force Cache -->
                <StackPanel Grid.Column="2" Margin="10,0">
                    <TextBlock Text="Stations"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               Margin="0,0,0,4" />
                    <CheckBox Content="Top"
                              IsChecked="{Binding ImportTop, Mode=TwoWay}"
                              Margin="0,2"
                              FontSize="11" />
                    <CheckBox Content="Bottom"
                              IsChecked="{Binding ImportBottom, Mode=TwoWay}"
                              Margin="0,2"
                              FontSize="11" />
                    <CheckBox Content="Mid-height"
                              IsChecked="{Binding ImportMid, Mode=TwoWay}"
                              Margin="0,2"
                              FontSize="11" />
                    <TextBlock Text="Force Cache"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               Margin="0,8,0,4" />
                    <TextBlock Text="{Binding ForceCacheStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,4" />
                    <Button Content="Build Cache"
                            Command="{Binding BuildForceCacheCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="8,3"
                            MinHeight="24"
                            FontSize="11"
                            HorizontalAlignment="Left"
                            Visibility="{Binding IsForceCacheAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <!-- Separator 2 -->
                <Rectangle Grid.Column="3"
                           Fill="{DynamicResource BorderGreyBrush}"
                           Width="1"
                           Margin="0,2" />

                <!-- Model Info (compact) -->
                <StackPanel Grid.Column="4" Margin="10,0">
                    <TextBlock Text="Model"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Units" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding PresentUnits}" FontSize="11" />
                        <TextBlock Grid.Row="1" Text="Stories" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11">
                            <Run Text="{Binding StoryCount, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding PierCount, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Grid.Row="2" Text="Frames" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrameObjectCount}" FontSize="11" />
                    </Grid>
                </StackPanel>

                <!-- Separator 3 -->
                <Rectangle Grid.Column="5"
                           Fill="{DynamicResource BorderGreyBrush}"
                           Width="1"
                           Margin="0,2" />

                <!-- Target Group + Action Buttons -->
                <StackPanel Grid.Column="6" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Target Project Group"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right"
                                Content="+ New"
                                Command="{Binding AddTargetGroupCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,3"
                                MinHeight="26"
                                Margin="6,0,0,0" />
                        <ComboBox ItemsSource="{Binding TargetGroups}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedTargetGroup}"
                                  MinWidth="160" />
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Command="{Binding CancelCommand}"
                                IsCancel="True"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="14,6"
                                MinHeight="32"
                                Margin="0,0,8,0" />
                        <Button Content="Import →"
                                Command="{Binding ApplyImportCommand}"
                                IsDefault="True"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="18,6"
                                MinHeight="32" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
