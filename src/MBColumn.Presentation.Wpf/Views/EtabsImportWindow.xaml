<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        Title="Import from ETABS"
        Width="1300"
        Height="820"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Loaded="OnWindowLoaded">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
        </Style>
        <Style x:Key="GroupCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="GroupNameNormalStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SmallIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StepCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="StepCircleActiveStyle" TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
        </Style>
        <Style x:Key="WarningBannerStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8E1" />
            <Setter Property="BorderBrush" Value="#FFC107" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="StepButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BorderSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Style="{StaticResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Border Grid.Row="0"
                Style="{StaticResource DialogHeaderBorderStyle}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Command="{Binding CancelCommand}"
                        Width="30"
                        Height="26"
                        Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <TextBlock Text="Import from ETABS"
                           Style="{StaticResource DialogHeaderTitleTextStyle}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- ─── Step Indicator ─── -->
        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,6">
            <DockPanel VerticalAlignment="Center">

                <!-- Right: Connection controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Vertical"
                            VerticalAlignment="Center" Margin="0,0,4,0">

                    <!-- Row 1: Connect / Reconnect / Disconnect -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Connect"
                                Command="{Binding ConnectCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,3" MinHeight="26"
                                FontSize="{StaticResource FontSizeBody}"
                                ToolTip="{Binding UnitConversionMessage}" />
                        <Button Content="Reconnect"
                                Command="{Binding ReconnectCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,3" MinHeight="26"
                                FontSize="{StaticResource FontSizeBody}"
                                Margin="6,0,0,0"
                                ToolTip="Disconnect and reconnect to ETABS, reloading all model data" />
                        <Button Content="Disconnect"
                                Command="{Binding DisconnectCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,3" MinHeight="26"
                                FontSize="{StaticResource FontSizeBody}"
                                Margin="6,0,0,0" />
                    </StackPanel>

                    <!-- Row 2: Reload actions (only when connected) -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Content="Load Story Definition"
                                Command="{Binding ReloadStoryDefinitionsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,3" MinHeight="24"
                                FontSize="{StaticResource FontSizeBody}"
                                ToolTip="Reload story levels from the connected ETABS model" />
                        <Button Content="Load Column / Pier Connectivity"
                                Command="{Binding ReloadColumnConnectivityCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,3" MinHeight="24"
                                FontSize="{StaticResource FontSizeBody}"
                                Margin="6,0,0,0"
                                ToolTip="Reload frame columns and pier labels from the connected ETABS model" />
                    </StackPanel>
                </StackPanel>

                <!-- Model info strip (visible when connected) -->
                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource LightBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderGreyBrush}"
                        BorderThickness="1" CornerRadius="3"
                        Padding="8,4" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Model:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding ModelName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="4" Text="Units:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="{Binding PresentUnits}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="8" Text="Stories:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="10" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center">
                            <Run Text="{Binding StoryCount, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding PierCount, Mode=OneWay}" /><Run Text=" piers" />
                        </TextBlock>
                        <TextBlock Grid.Column="12" Text="Frames:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="14" Text="{Binding FrameObjectCount}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Center: Step buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                <!-- Step 1 -->
                <Button Command="{Binding GoToFlow1Command}" Style="{StaticResource StepButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow1}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlow1}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Section Assignment" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow1}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Rectangle Width="50" Height="1" Fill="{DynamicResource BorderGreyBrush}"
                           VerticalAlignment="Center" Margin="14,0" />

                <!-- Step 2 -->
                <Button Command="{Binding GoToFlow2Command}" Style="{StaticResource StepButtonStyle}"
                        ToolTip="Connect to ETABS first to access Force Import">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow2}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlow2}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Force Import" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow2}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Rectangle Width="50" Height="1" Fill="{DynamicResource BorderGreyBrush}"
                           VerticalAlignment="Center" Margin="14,0" />

                <!-- Step 3 -->
                <Button Command="{Binding GoToFlow3Command}" Style="{StaticResource StepButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,8,0">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepCircleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow3}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFlow3}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="Review &amp; Import" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFlow3}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             Content area: Model Info Sidebar + Flows
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── ETABS Model Info Sidebar ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                    </Grid.ColumnDefinitions>

                    <!-- Info content panel -->
                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Width="180" Margin="12,12,4,12" VerticalAlignment="Top">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModelInfoPanelOpen}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="ETABS Model"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource PrimaryNavyBrush}"
                                       Margin="0,0,0,10" />

                            <!-- Connection status badge -->
                            <Border CornerRadius="3" Padding="6,3" Margin="0,0,0,12"
                                    HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFEBEE" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="● Not connected" />
                                            <Setter Property="Foreground" Value="#C62828" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Text" Value="● Connected" />
                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Model fields — visible only when connected -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Name" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding ModelName}"
                                           FontSize="11" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ModelName}"
                                           Margin="0,1,0,8" />

                                <TextBlock Text="Units" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding PresentUnits}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="0,1,0,8" />

                                <TextBlock Text="Stories / Piers" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock FontSize="11" FontWeight="SemiBold" Margin="0,1,0,8">
                                    <Run Text="{Binding StoryCount, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding PierCount, Mode=OneWay}" />
                                </TextBlock>

                                <TextBlock Text="Frames" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding FrameObjectCount}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Margin="0,1,0,0" />
                            </StackPanel>

                            <!-- Status text -->
                            <Separator Margin="0,10,0,8" />
                            <TextBlock Text="{Binding ConnectionStatus}"
                                       FontSize="10" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Toggle button -->
                    <Button Grid.Column="1"
                            Command="{Binding ToggleModelInfoPanelCommand}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="1,0,0,0"
                            Padding="0"
                            MinHeight="0"
                            Cursor="Hand"
                            VerticalAlignment="Stretch"
                            ToolTip="Toggle model info">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="9"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE76C;" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModelInfoPanelOpen}" Value="True">
                                            <Setter Property="Text" Value="&#xE76B;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
            </Border>

        <!-- ═══════════════════════════════════════════════════════
             FLOW 1 — MB Column Section Assignment
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1"
              Margin="12,10,12,8"
              Visibility="{Binding IsFlow1, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="35*" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Filter bar + Stories sidebar + Available Items ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filter — single row: Element | Section Type | Label Filter -->
                <GroupBox Grid.Row="0"
                          Header="Filter"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="10"
                          Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="ETABS Element"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding EtabsElementFilters}"
                                  SelectedItem="{Binding SelectedEtabsElementFilter}" />

                        <TextBlock Grid.Column="3" Text="Section Type"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox Grid.Column="4"
                                  ItemsSource="{Binding SectionTypeFilters}"
                                  SelectedItem="{Binding SelectedSectionTypeFilter}"
                                  IsEnabled="{Binding IsSectionTypeFilterEnabled}" />

                        <TextBlock Grid.Column="6" Text="Label Filter"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Grid.Column="7"
                                 Text="{Binding LabelTextFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <!-- Stories sidebar + Unique Section + Available Items side by side -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="115" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Stories column -->
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Stories"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DarkNavyBrush}"
                                   Margin="0,0,0,4" />
                        <ListBox x:Name="StoryListBox"
                                 ItemsSource="{Binding StoryOptions}"
                                 SelectionMode="Extended"
                                 BorderBrush="{DynamicResource BorderGreyBrush}"
                                 BorderThickness="1"
                                 FontSize="{StaticResource FontSizeBody}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="OnStoryListBoxSelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,3" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Unique Section column -->
                    <DockPanel Grid.Column="2">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Unique Section"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DarkNavyBrush}"
                                   Margin="0,0,0,4" />
                        <ListBox x:Name="UniqueSectionListBox"
                                 ItemsSource="{Binding UniqueSectionOptions}"
                                 SelectedItem="{Binding SelectedUniqueSection}"
                                 SelectionMode="Extended"
                                 BorderBrush="{DynamicResource BorderGreyBrush}"
                                 BorderThickness="1"
                                 FontSize="{StaticResource FontSizeBody}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="OnUniqueSectionListBoxSelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,3" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Available Items -->
                    <GroupBox Grid.Column="4"
                              Header="Available Items"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              Padding="0">
                        <DataGrid ItemsSource="{Binding TierObjectCandidatesView}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserReorderColumns="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Extended"
                                  SelectionChanged="OnDataGridSelectionChanged"
                                  ContextMenuOpening="OnAvailableItemsContextMenuOpening"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  RowHeight="24"
                                  FontSize="{StaticResource FontSizeBody}"
                                  GridLinesVisibility="Horizontal"
                                  BorderBrush="{DynamicResource BorderGreyBrush}">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type" Binding="{Binding SectionTypeDisplay}" Width="85" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Section / Pier" Binding="{Binding EtabsSectionName}" Width="135" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Story" Binding="{Binding Story}" Width="75" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="70" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="80" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Length" Binding="{Binding LengthDisplay}" Width="90" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Assigned Section" Binding="{Binding ImportGroupName}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Padding" Value="4,0" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </Grid>

            <!-- ── RIGHT: MB Column Sections (top) + Summary + Section Preview (bottom) ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="170" />
                </Grid.RowDefinitions>

                <!-- MB Column Sections — prominent, at the top -->
                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Content="+ New Section"
                                    Command="{Binding CreateMbColumnSectionCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="26" />
                            <TextBlock Text="MB Column Sections"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="No sections yet. Select items on the left, then click + New Section."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MbColumnSections.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding MbColumnSections}"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:MbColumnSectionViewModel}">
                                        <Border Style="{StaticResource GroupCardStyle}">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,4">
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{StaticResource SmallIconButtonStyle}"
                                                            ToolTip="Delete section"
                                                            Command="{Binding DataContext.DeleteMbColumnSectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <Button DockPanel.Dock="Right"
                                                            Style="{StaticResource SmallIconButtonStyle}"
                                                            ToolTip="Clear all items from section"
                                                            Command="{Binding ClearSectionCommand}"
                                                            Margin="0,0,4,0">
                                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="{StaticResource FontSizeBody}"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <StackPanel DockPanel.Dock="Right"
                                                                Orientation="Horizontal"
                                                                Margin="0,0,4,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Content="✓"
                                                                Command="{Binding CommitRenameCommand}"
                                                                Style="{StaticResource SmallIconButtonStyle}"
                                                                ToolTip="Confirm rename" />
                                                        <Button Content="✕"
                                                                Command="{Binding CancelRenameCommand}"
                                                                Style="{StaticResource SmallIconButtonStyle}"
                                                                ToolTip="Cancel rename"
                                                                Margin="2,0,0,0" />
                                                    </StackPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            ToolTip="Rename section"
                                                            Command="{Binding BeginRenameCommand}"
                                                            Margin="0,0,4,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Button>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource GroupNameNormalStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding SectionName, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding ItemCount, StringFormat=({0}), Mode=OneWay}"
                                                             Foreground="{DynamicResource TextMutedBrush}" />
                                                    </TextBlock>
                                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </DockPanel>

                                                <!-- Rename error message -->
                                                <TextBlock Text="{Binding RenameError}"
                                                           FontSize="10"
                                                           Foreground="#C62828"
                                                           Margin="0,2,0,0"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RenameError}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding RenameError}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Content="→ Assign selected items"
                                                        Command="{Binding DataContext.AssignToSectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="8,3"
                                                        MinHeight="24"
                                                        HorizontalAlignment="Left"
                                                        FontSize="{StaticResource FontSizeBody}" />

                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="0,6,0,0">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ItemCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EtabsColumnImportRowViewModel}">
                                                            <DockPanel Margin="0,1">
                                                                <Button DockPanel.Dock="Right"
                                                                        Content="×"
                                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SmallIconButtonStyle}"
                                                                        FontSize="{StaticResource FontSizeBody}"
                                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                                        ToolTip="Remove from section" />
                                                                <TextBlock FontSize="{StaticResource FontSizeBody}"
                                                                           Foreground="{DynamicResource TextDarkBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <Run Text="{Binding EtabsSectionName, Mode=OneWay}" />
                                                                    <Run Text=" | " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Story, Mode=OneWay}" />
                                                                    <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                                                    <Run Text="{Binding Label, Mode=OneWay}" />
                                                                </TextBlock>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>


                <!-- Section Preview — secondary, smaller, at the bottom -->
                <Border Grid.Row="2"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="6"
                        Margin="0,8,0,0">
                    <controls:SectionPreviewCanvas
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        SectionWidth="{Binding BoundaryPreviewWidth}"
                        SectionHeight="{Binding BoundaryPreviewHeight}"
                        Cover="{Binding BoundaryPreviewCover}"
                        UnitSystem="{Binding TargetUnitSystem}"
                        SectionShape="{Binding BoundaryPreviewSectionShape}"
                        BoundaryPoints="{Binding BoundaryPreviewPoints}"
                        SectionLabel="{Binding BoundaryPreviewSectionLabel}"
                        IsValid="{Binding IsBoundaryPreviewValid}"
                        ErrorMessage="{Binding PreviewStatusText}" />
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             FLOW 2 — Force Import
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1"
              Margin="12,10,12,8"
              Visibility="{Binding IsFlow2, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Demand Cases (left) -->
            <GroupBox Grid.Column="0"
                      Header="Demand Cases"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SelectedLoadCombinationCount, StringFormat='{}{0} selected'}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="All"
                                    Command="{Binding SelectAllCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="24"
                                    FontSize="{StaticResource FontSizeBody}" />
                            <Button Content="None"
                                    Command="{Binding ClearAllCombosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,3"
                                    MinHeight="24"
                                    FontSize="{StaticResource FontSizeBody}"
                                    Margin="4,0,0,0" />
                        </StackPanel>
                    </DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBox Text="{Binding LoadCombinationFilterText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="{StaticResource FontSizeBody}" />
                        <TextBlock Text="Search combinations..."
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   IsHitTestVisible="False"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LoadCombinationFilterText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LoadCombinationFilterText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ListBox ItemsSource="{Binding FilteredLoadCombinations}"
                             BorderBrush="{DynamicResource BorderGreyBrush}"
                             FontSize="{StaticResource FontSizeBody}"
                             SelectionMode="Extended"
                             SelectionChanged="OnListBoxSelectionChanged"
                             DisplayMemberPath="Name">
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- MB Column Sections from Step 1 -->
            <GroupBox Grid.Column="2"
                      Header="MB Column Sections"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding MbColumnSections.Count, StringFormat='{}{0} section(s)'}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,6" />
                    <ListBox ItemsSource="{Binding MbColumnSections}"
                             BorderBrush="{DynamicResource BorderGreyBrush}"
                             BorderThickness="1"
                             FontSize="{StaticResource FontSizeBody}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MbColumnSectionViewModel}">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Items.Count, StringFormat='({0})'}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                    <TextBlock Text="{Binding SectionName}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <!-- Force Preview (middle) -->
            <GroupBox Grid.Column="4"
                      Header="Force Preview"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <DockPanel>
                    <!-- Force source status + selection -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource LightBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,6"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Design Forces -->
                            <StackPanel Grid.Column="0">
                                <RadioButton Content="Use Design Forces"
                                             IsChecked="{Binding UseDesignForces, Mode=TwoWay}"
                                             FontSize="{StaticResource FontSizeBody}"
                                             Margin="0,2" />
                            </StackPanel>
                            <!-- Element Forces -->
                            <StackPanel Grid.Column="2">
                                <RadioButton Content="Use Element Forces"
                                             IsChecked="{Binding UseElementForces, Mode=TwoWay}"
                                             FontSize="{StaticResource FontSizeBody}"
                                             Margin="0,2" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Trigger bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Left"
                                Content="Load Forces"
                                Command="{Binding LoadForcesCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="14,5"
                                MinHeight="28" />
                        <ProgressBar DockPanel.Dock="Left"
                                     IsIndeterminate="True"
                                     Width="80"
                                     Height="4"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource PrimaryNavyBrush}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Visibility="{Binding IsLoadingForces, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding ForceCacheStatus}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="8,0,0,0" />
                    </DockPanel>

                    <!-- Flow 2 validation warning -->
                    <Border DockPanel.Dock="Top">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource WarningBannerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFlow2Warning}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Flow2ValidationMessage}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   TextWrapping="Wrap"
                                   Foreground="#7B5E00" />
                    </Border>

                    <!-- Force rows TabControl -->
                    <TabControl FontSize="{StaticResource FontSizeBody}">
                        <!-- Tab 1: Column Forces -->
                        <TabItem Header="Column Forces">
                            <DataGrid ItemsSource="{Binding FilteredColumnMappedForceRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      FontSize="{StaticResource FontSizeBody}"
                                      RowHeight="22"
                                      BorderBrush="{DynamicResource BorderGreyBrush}"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Case Name"        Binding="{Binding CaseName}"                  Width="*" MinWidth="130" />
                                    <DataGridTextColumn Header="Col Label"        Binding="{Binding Label}"                     Width="62" />
                                    <DataGridTextColumn Header="Story"            Binding="{Binding Story}"                     Width="60" />
                                    <DataGridTextColumn Header="NEd (kN)"         Binding="{Binding NEd,      StringFormat=N2}" Width="74" />
                                    <DataGridTextColumn Header="Vx (kN)"          Binding="{Binding Vx,       StringFormat=N2}" Width="64" />
                                    <DataGridTextColumn Header="Vy (kN)"          Binding="{Binding Vy,       StringFormat=N2}" Width="64" />
                                    <DataGridTextColumn Header="Mx Top (kN·m)"    Binding="{Binding MxTop,    StringFormat=N2}" Width="86" />
                                    <DataGridTextColumn Header="Mx Bot (kN·m)"    Binding="{Binding MxBottom, StringFormat=N2}" Width="86" />
                                    <DataGridTextColumn Header="My Top (kN·m)"    Binding="{Binding MyTop,    StringFormat=N2}" Width="86" />
                                    <DataGridTextColumn Header="My Bot (kN·m)"    Binding="{Binding MyBottom, StringFormat=N2}" Width="86" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- Tab 2: Pier Forces -->
                        <TabItem Header="Pier Forces">
                            <DataGrid ItemsSource="{Binding FilteredPierMappedForceRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      FontSize="{StaticResource FontSizeBody}"
                                      RowHeight="22"
                                      BorderBrush="{DynamicResource BorderGreyBrush}"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Case Name"        Binding="{Binding CaseName}"                  Width="*" MinWidth="130" />
                                    <DataGridTextColumn Header="Pier Label"       Binding="{Binding Label}"                     Width="62" />
                                    <DataGridTextColumn Header="Story"            Binding="{Binding Story}"                     Width="60" />
                                    <DataGridTextColumn Header="NEd (kN)"         Binding="{Binding NEd,      StringFormat=N2}" Width="74" />
                                    <DataGridTextColumn Header="Vx (kN)"          Binding="{Binding Vx,       StringFormat=N2}" Width="64" />
                                    <DataGridTextColumn Header="Vy (kN)"          Binding="{Binding Vy,       StringFormat=N2}" Width="64" />
                                    <DataGridTextColumn Header="Mx Top (kN·m)"    Binding="{Binding MxTop,    StringFormat=N2}" Width="86" />
                                    <DataGridTextColumn Header="Mx Bot (kN·m)"    Binding="{Binding MxBottom, StringFormat=N2}" Width="86" />
                                    <DataGridTextColumn Header="My Top (kN·m)"    Binding="{Binding MyTop,    StringFormat=N2}" Width="86" />
                                    <DataGridTextColumn Header="My Bot (kN·m)"    Binding="{Binding MyBottom, StringFormat=N2}" Width="86" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </GroupBox>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             FLOW 3 — Review &amp; Import
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1"
              Margin="12,10,12,8"
              Visibility="{Binding IsFlow3, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- MB Column Sections Summary (left) -->
            <GroupBox Grid.Column="0"
                      Header="MB Column Sections Summary"
                      BorderBrush="{DynamicResource BorderGreyBrush}"
                      Foreground="{DynamicResource DarkNavyBrush}"
                      Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,10"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap">
                        <Run Text="{Binding MbColumnSectionsReadyCount, Mode=OneWay}" />
                        <Run Text=" section(s) ready to import. Each section becomes one MB Column design section." />
                    </TextBlock>

                    <TextBlock DockPanel.Dock="Top"
                               Text="No MB Column Sections defined. Go back to Step 1 and assign items to sections."
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource AccentRedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MbColumnSectionsReadyCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TabControl FontSize="{StaticResource FontSizeBody}">
                        <!-- Tab 1: Section list with Project Group assignment -->
                        <TabItem Header="Sections">
                            <ListBox ItemsSource="{Binding MbColumnSections}"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:MbColumnSectionViewModel}">
                                        <Border Style="{StaticResource GroupCardStyle}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="Project Group:" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextMutedBrush}" />
                                                        <ComboBox ItemsSource="{Binding DataContext.TargetGroups, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedItem="{Binding SelectedTargetGroup, Mode=TwoWay}"
                                                                  Width="130"
                                                                  Margin="6,0,0,0" />
                                                        <Button Content="+"
                                                                Command="{Binding DataContext.AddTargetGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Margin="4,0,0,0" Padding="6,2" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding SectionName}"
                                                               FontSize="{StaticResource FontSizeBody}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                                               VerticalAlignment="Center" />
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding Items}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:EtabsColumnImportRowViewModel}">
                                                            <TextBlock FontSize="{StaticResource FontSizeBody}"
                                                                       Foreground="{DynamicResource TextDarkBrush}"
                                                                       Margin="0,1">
                                                                <Run Text="{Binding EtabsSectionName, Mode=OneWay}" />
                                                                <Run Text=" | " Foreground="{DynamicResource TextMutedBrush}" />
                                                                <Run Text="{Binding Story, Mode=OneWay}" />
                                                                <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                                                <Run Text="{Binding Label, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <!-- Tab 2: Force mapping summary -->
                        <TabItem Header="Force Summary">
                            <DataGrid ItemsSource="{Binding MbColumnSectionSummaryRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      FontSize="{StaticResource FontSizeBody}"
                                      RowHeight="22"
                                      BorderBrush="{DynamicResource BorderGreyBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="140" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding ObjectType}" Width="70" />
                                    <DataGridTextColumn Header="Items" Binding="{Binding SelectedItems}" Width="55" />
                                    <DataGridTextColumn Header="Force Rows" Binding="{Binding MatchedForceRows}" Width="80" />
                                    <DataGridTextColumn Header="Missing" Binding="{Binding MissingItems}" Width="60" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MissingItems}" Value="0">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </GroupBox>

            <!-- Right panel: Target Group + Model Info -->
            <StackPanel Grid.Column="2">

                <!-- Import Summary -->
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Import Summary" Style="{StaticResource SectionHeaderStyle}" />
                        <UniformGrid Columns="3">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding UnassignedCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Unassigned" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AssignedCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Assigned" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MbColumnSectionsReadyCount}" Style="{StaticResource SummaryValueStyle}" HorizontalAlignment="Center" />
                                <TextBlock Text="Sections ready" Style="{StaticResource SummaryLabelStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Model Info -->
                <GroupBox Header="Model"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          Padding="12"
                          Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModelName}" FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Units" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PresentUnits}" FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Stories" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1" FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4">
                            <Run Text="{Binding StoryCount, Mode=OneWay}" />
                            <Run Text=" stories / " />
                            <Run Text="{Binding PierCount, Mode=OneWay}" />
                            <Run Text=" piers" />
                        </TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Frames" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FrameObjectCount}" FontSize="{StaticResource FontSizeBody}" />
                    </Grid>
                </GroupBox>

                <!-- Demand Cases Summary -->
                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Force Settings" Style="{StaticResource SectionHeaderStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Combos" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SelectedLoadCombinationCount, StringFormat='{}{0} selected'}"
                                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,4" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Design Settings -->
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Design Settings" Style="{StaticResource SectionHeaderStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Unit System -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Unit System"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,6" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding ImportUnitSystems}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="System"
                                      SelectedValue="{Binding SelectedImportUnitSystem, Mode=TwoWay}"
                                      FontSize="{StaticResource FontSizeBody}"
                                      Margin="0,0,0,6" />

                            <!-- Design Code -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Design Code"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,6" />
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding ImportDesignCodes}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding SelectedImportDesignCode, Mode=TwoWay}"
                                      FontSize="{StaticResource FontSizeBody}"
                                      Margin="0,0,0,6" />

                            <!-- Rebar Grade -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Rebar Grade"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,6" />
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{Binding AvailableImportRebarGrades}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedImportRebarGrade, Mode=TwoWay}"
                                      FontSize="{StaticResource FontSizeBody}"
                                      Margin="0,0,0,6" />

                            <!-- Slenderness check (EC2 only) -->
                            <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                      Content="Consider slenderness check"
                                      IsChecked="{Binding ImportIncludeSlenderness, Mode=TwoWay}"
                                      FontSize="{StaticResource FontSizeBody}"
                                      Margin="0,2,0,0">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImportDesignCodeEc2}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        </Grid><!-- /Content area -->

        <!-- ─── Bottom Navigation Bar ─── -->
        <Border Grid.Row="3"
                Style="{StaticResource DialogFooterBarStyle}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Cancel (always) -->
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            MinHeight="32" />

                    <!-- Back (flows 2 and 3) -->
                    <Button Content="← Back"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsFlow1, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                    <!-- Flow 1 → Flow 2 -->
                    <Button Content="Force Import  →"
                            Command="{Binding GoToFlow2Command}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            ToolTip="Connect to ETABS first to proceed"
                            Visibility="{Binding IsFlow1, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- Flow 2 → Flow 3 -->
                    <Button Content="Review  →"
                            Command="{Binding GoToFlow3Command}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsFlow2, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- Flow 3: Import -->
                    <Button Content="Import  →"
                            Command="{Binding ApplyImportCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="18,6"
                            MinHeight="32"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsFlow3, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
