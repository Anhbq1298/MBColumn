<Window x:Class="MBColumn.Presentation.Wpf.Views.BatchPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Batch Print PDF Reports" Height="580" Width="820"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">
    <Grid Style="{DynamicResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Batch Print PDF Reports" Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Configure calculation scope, file organization, and export checked section reports."
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="1" Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Project Explorer tree -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Project Structure" 
                           Style="{StaticResource FieldLabelTextStyle}"
                           Margin="0,0,0,6" />

                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderGreyBrush}"
                        BorderThickness="1" CornerRadius="3" Background="{DynamicResource PanelBackgroundBrush}">
                    <TreeView ItemsSource="{Binding Nodes}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding" Value="0,2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <!-- Group Item Template -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:GroupItemViewModel}" ItemsSource="{Binding Columns}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsThreeState="True" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="📁 " VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- Column Item Template -->
                            <DataTemplate DataType="{x:Type vm:ColumnItemViewModel}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsThreeState="False" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="📄 " VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}" />
                                    <Border Margin="6,0,0,0" VerticalAlignment="Center" Style="{StaticResource ExplorerStatusBadgeStyle}">
                                        <TextBlock Text="{Binding StatusText}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Border>

                <!-- Selection Shortcuts -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Select All" 
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource CompactButtonStyle}" 
                            Padding="8,3" FontSize="10" Margin="0,0,6,0" />
                    <Button Content="Clear All" 
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Padding="8,3" FontSize="10" />
                </StackPanel>
            </Grid>

            <!-- Right Panel: Export settings -->
            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                <!-- Folder selection -->
                <TextBlock Text="Destination Folder" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0" Height="28" Padding="6,4" VerticalContentAlignment="Center"
                             BorderBrush="{DynamicResource BorderGreyBrush}"
                             Background="White" />
                    <Button Content="Browse..." 
                            Command="{Binding BrowseFolderCommand}"
                            Grid.Column="1" Margin="8,0,0,0" Height="28" Padding="12,0"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <!-- PDF Organization -->
                <TextBlock Text="File Organization Options" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,6" />
                <Border BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Background="White">
                    <StackPanel>
                        <RadioButton IsChecked="{Binding KeepProjectStructure}" Content="Keep project structure" 
                                     GroupName="FileOrg" Foreground="{DynamicResource TextDarkBrush}"
                                     Margin="0,0,0,10"
                                     ToolTip="Creates subfolders representing groups and places the corresponding section reports within them." />
                        <RadioButton IsChecked="{Binding FlatFiles}" Content="Prints to individual flat files" 
                                     GroupName="FileOrg" Foreground="{DynamicResource TextDarkBrush}"
                                     Margin="0,0,0,10"
                                     ToolTip="Saves all PDF files directly in the selected folder, prefixing the group name to each file." />
                        <RadioButton IsChecked="{Binding CompiledReport}" Content="Compiled full report (Single PDF)" 
                                     GroupName="FileOrg" Foreground="{DynamicResource TextDarkBrush}"
                                     ToolTip="Combines all selected calculation reports into a single, compiled PDF file." />
                    </StackPanel>
                </Border>

                <!-- Help/Info message -->
                <Border Background="#F4F6F7" BorderBrush="#CCD6E0" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,20,0,0">
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#555555">
                        <Run Text="Note: " FontWeight="Bold" Foreground="{DynamicResource PrimaryNavyBrush}" />
                        <Run Text="If any checked section in the project has not been calculated or has outdated results, it will be calculated automatically in the background first before PDF generation starts." />
                    </TextBlock>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Style="{DynamicResource DialogFooterBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Cancel -->
                <Button Grid.Column="0" Content="Close" IsCancel="True" Width="88" Style="{DynamicResource DialogActionButtonStyle}" />

                <!-- Action Triggers -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Print All" 
                            Command="{Binding PrintAllCommand}"
                            Width="110" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="Print Selected" 
                            Command="{Binding PrintSelectedCommand}"
                            Width="130" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
