<Window x:Class="MBColumn.Presentation.Wpf.Views.BatchPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Batch Print — PDF Reports"
        Width="760" Height="560"
        MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource LightBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
            <!-- Progress bar -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ───────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryNavyBrush}" Padding="20,14">
            <StackPanel>
                <TextBlock Text="Batch Print PDF Reports"
                           FontSize="{StaticResource FontSizeDialogTitle}" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Select sections and choose an output format below."
                           FontSize="{StaticResource FontSizeCaption}" Foreground="#B0C4D8" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Two-column content area ────────────────────────────── -->
        <Grid Grid.Row="1" Margin="16,14,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left: project tree ────────────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel Margin="12">
                    <!-- Header row -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Sections"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="All"
                                    Command="{Binding SelectAllCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Padding="8,2" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,4,0"/>
                            <Button Content="None"
                                    Command="{Binding ClearAllCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,2" FontSize="{StaticResource FontSizeCaption}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Group / column tree -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:BatchGroupNode}">
                                    <StackPanel Margin="0,2">
                                        <!-- Group row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      IsThreeState="True"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                                            <TextBlock Text="📁 " VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{DynamicResource PrimaryNavyBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Column rows -->
                                        <ItemsControl ItemsSource="{Binding Columns}" Margin="20,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:BatchColumnNode}">
                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                  IsThreeState="False"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,6,0"/>
                                                        <TextBlock Text="📄 " VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="{StaticResource FontSizeBody}"
                                                                   Foreground="{DynamicResource TextDarkBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right: output settings ─────────────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel Margin="14">
                    <!-- Output folder -->
                    <TextBlock Text="Output Folder"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding OutputFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 Padding="6,0"/>
                        <Button Grid.Column="2"
                                Content="Browse…"
                                Command="{Binding BrowseFolderCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"/>
                    </Grid>

                    <!-- File organisation -->
                    <TextBlock Text="File Organisation"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Margin="0,18,0,8"/>

                    <RadioButton IsChecked="{Binding ModeKeepStructure, Mode=TwoWay}"
                                 GroupName="PrintMode"
                                 Margin="0,4">
                        <StackPanel>
                            <TextBlock Text="Keep project structure"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextDarkBrush}"/>
                            <TextBlock Text="Group subfolders inside the output folder."
                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton IsChecked="{Binding ModeFlat, Mode=TwoWay}"
                                 GroupName="PrintMode"
                                 Margin="0,4">
                        <StackPanel>
                            <TextBlock Text="Flat individual files"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextDarkBrush}"/>
                            <TextBlock Text="All PDFs placed directly in the output folder."
                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton IsChecked="{Binding ModeCompiled, Mode=TwoWay}"
                                 GroupName="PrintMode"
                                 Margin="0,4">
                        <StackPanel>
                            <TextBlock Text="Compiled single PDF"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextDarkBrush}"/>
                            <TextBlock Text="All reports merged into one PDF with bookmarks."
                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Status text -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,18,0,0"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Progress bar (visible while busy) ──────────────────── -->
        <ProgressBar Grid.Row="2"
                     Margin="16,10,16,0"
                     Height="4"
                     Minimum="0"
                     Maximum="{Binding ProgressMax, Mode=OneWay}"
                     Value="{Binding ProgressValue, Mode=OneWay}"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                     Foreground="{DynamicResource PrimaryNavyBrush}"
                     Background="#DDE6EF"/>

        <!-- ── Action buttons ─────────────────────────────────────── -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <DockPanel>
                <Button Content="Cancel"
                        DockPanel.Dock="Right"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="80" Padding="14,6"
                        Click="Cancel_Click"/>
                <Button Content="Print All"
                        DockPanel.Dock="Right"
                        Command="{Binding PrintAllCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="90" Padding="14,6"
                        Margin="0,0,8,0"/>
                <Button Content="Print Selected"
                        DockPanel.Dock="Right"
                        Command="{Binding PrintSelectedCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="110" Padding="14,6"
                        Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
