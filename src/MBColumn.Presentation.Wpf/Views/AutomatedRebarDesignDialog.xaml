<Window x:Class="MBColumn.Presentation.Wpf.Views.AutomatedRebarDesignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels.AutomatedRebarDesign"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain"
        Title="Automated Rebar Design"
        Width="1200" Height="760"
        MinWidth="950" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">

    <Window.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource DarkNavyBrush}" />
        </Style>
        <Style x:Key="StatusCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RebarSuggestionStatus.Failed}">
                    <Setter Property="Background" Value="#FFEBEE" />
                    <Setter Property="Foreground" Value="#C62828" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RebarSuggestionStatus.Warning}">
                    <Setter Property="Background" Value="#FFF8E1" />
                    <Setter Property="Foreground" Value="#E65100" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RebarSuggestionStatus.Valid}">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Setter Property="Foreground" Value="#2E7D32" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TagCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RecommendationTag}" Value="">
                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                    <Setter Property="FontWeight" Value="Normal" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ConditionCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Condition}" Value="Changed">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Condition}" Value="Frozen">
                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CheckPassCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPassAfter}" Value="True">
                    <Setter Property="Foreground" Value="#2E7D32" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPassAfter}" Value="False">
                    <Setter Property="Foreground" Value="#C62828" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Automated Rebar Design"
                           Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Spacing-first longitudinal layout + EC2 shear link auto-design. Corner bars fixed; count derived from spacing."
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <!-- Main body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="4*" MinWidth="320" MaxWidth="460" />
            </Grid.ColumnDefinitions>

            <!-- ════════════════ LEFT PANEL ════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!-- Before / After -->
                <TextBlock Grid.Row="0" Text="Before / After"
                           Style="{StaticResource SectionLabelStyle}" Margin="12,10,0,4" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ParameterRows}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserSortColumns="False" CanUserResizeRows="False"
                          BorderThickness="0,1,0,0" Margin="8,0,4,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="160" />
                        <DataGridTextColumn Header="Before"    Binding="{Binding Before}"    Width="80" />
                        <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="90"
                                            CellStyle="{StaticResource ConditionCellStyle}" />
                        <DataGridTextColumn Header="After"     Binding="{Binding After}"     Width="80" />
                        <DataGridTextColumn Header="Unit"      Binding="{Binding Unit}"      Width="50" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Design Check Summary -->
                <TextBlock Grid.Row="2" Text="Design Check Summary"
                           Style="{StaticResource SectionLabelStyle}" Margin="12,4,0,4" />
                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding CheckRows}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserSortColumns="False" CanUserResizeRows="False"
                          MaxHeight="220" BorderThickness="0,1,0,0" Margin="8,0,4,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Check"     Binding="{Binding CheckName}" Width="190" />
                        <DataGridTextColumn Header="Before"    Binding="{Binding Before}"    Width="65" />
                        <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="80"
                                            CellStyle="{StaticResource ConditionCellStyle}" />
                        <DataGridTextColumn Header="After"     Binding="{Binding After}"     Width="80"
                                            CellStyle="{StaticResource CheckPassCellStyle}" />
                        <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    Width="60"
                                            CellStyle="{StaticResource CheckPassCellStyle}" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Candidate Suggestions -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Candidate Suggestions"
                               Style="{StaticResource SectionLabelStyle}" Margin="12,4,0,4" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CandidateRows}"
                              SelectedItem="{Binding SelectedCandidate}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              SelectionMode="Single" CanUserSortColumns="True"
                              CanUserResizeRows="False" BorderThickness="0,1,0,0"
                              Margin="8,0,4,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"       Binding="{Binding Rank}"                Width="28" />
                            <DataGridTextColumn Header="Config"  Binding="{Binding Config}"              Width="65" />
                            <DataGridTextColumn Header="Layout"  Binding="{Binding LayoutTypeLabel}"     Width="45" />
                            <DataGridTextColumn Header="As mm²"  Binding="{Binding AsMm2Display}"        Width="60" />
                            <DataGridTextColumn Header="ρ %"     Binding="{Binding RhoDisplay}"          Width="50" />
                            <DataGridTextColumn Header="PMM"     Binding="{Binding PmmDisplay}"          Width="46" />
                            <DataGridTextColumn Header="Clr mm"  Binding="{Binding MinClearSpacingDisplay}" Width="50" />
                            <DataGridTextColumn Header="Link"    Binding="{Binding LinkLabel}"           Width="46" />
                            <DataGridTextColumn Header="Sv mm"   Binding="{Binding LinkSpacingDisplay}"  Width="46" />
                            <DataGridTextColumn Header="X-ties"  Binding="{Binding InternalLinksDisplay}" Width="46" />
                            <DataGridTextColumn Header="Status"  Binding="{Binding StatusLabel}"         Width="46"
                                                CellStyle="{StaticResource StatusCellStyle}" />
                            <DataGridTextColumn Header="Tag"     Binding="{Binding RecommendationTag}"   Width="150"
                                                CellStyle="{StaticResource TagCellStyle}" />
                            <DataGridTextColumn Header="Reason"  Binding="{Binding Reason}"              Width="*" MinWidth="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderGreyBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- ════════════════ RIGHT PANEL — 4 tabs ════════════════ -->
            <TabControl Grid.Column="2" Margin="4,8,8,4"
                        SelectedIndex="{Binding SelectedTabIndex}">

                <!-- ── Tab 0: Section Preview ── -->
                <TabItem Header="Section Preview">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <controls:SectionPreviewCanvas Grid.Row="0"
                            SectionWidth="{Binding PreviewSectionWidthMm}"
                            SectionHeight="{Binding PreviewSectionHeightMm}"
                            Cover="{Binding PreviewCoverMm}"
                            UnitSystem="Metric"
                            Rebars="{Binding PreviewRebars}"
                            SectionLabel="{Binding PreviewSectionLabel}"
                            RebarLabel="{Binding PreviewRebarLabel}"
                            CoverLabel="{Binding PreviewCoverLabel}"
                            IsValid="{Binding PreviewIsValid}"
                            StirrupDiameterMm="{Binding PreviewStirrupDiameterMm}"
                            Margin="8,8,8,4" />
                        <TextBlock Grid.Row="1"
                                   Text="{Binding PreviewStatusText}"
                                   Margin="10,0,10,10" FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Grid>
                </TabItem>

                <!-- ── Tab 1: Parameters (merged Target + Search Space) ── -->
                <TabItem Header="Parameters">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">

                            <!-- PMM Target -->
                            <TextBlock Text="PMM Target" Style="{StaticResource SectionLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Target PMM Ratio (0–1)"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center" Width="165" />
                                <TextBox Text="{Binding TargetPmmRatio, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" />
                            </StackPanel>
                            <TextBlock Text="Candidates with PMM &gt; target are rejected. Default: 1.00."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8" />

                            <!-- Longitudinal bar spacing -->
                            <TextBlock Text="Longitudinal bar spacing" Style="{StaticResource SectionLabelStyle}" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Initial spacing (mm)" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding InitialSpacingMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Reduction step (mm)" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding SpacingStepMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Min spacing limit (mm)" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MinSpacingLimitMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Max bar spacing (mm)" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MaxBarSpacingMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <!-- Longitudinal bar sizes -->
                            <TextBlock Text="Allowed longitudinal bar sizes" Style="{StaticResource SectionLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Min diameter (mm)"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center" Width="120" />
                                <TextBox Text="{Binding MinBarDiameterMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding AllowedBarToggles}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllowedBarToggleViewModel}">
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsEnabled}" Margin="0,0,12,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Shear link auto-design -->
                            <TextBlock Text="Shear link auto-design" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="EC2 §9.5.3 — link diameter and spacing calculated automatically. Set 0 to use EC2 limits."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding AllowedLinkToggles}" Margin="0,0,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllowedLinkBarToggleViewModel}">
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsEnabled}" Margin="0,0,12,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Min link dia. (mm, 0=auto)" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MinLinkDiameterMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Max link spacing (mm, 0=auto)" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MaxLinkSpacingMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Cross-tie threshold (mm)"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center" Width="165" />
                                <TextBox Text="{Binding CrossTieThresholdMm, StringFormat=F0, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" />
                            </StackPanel>

                            <!-- Layout type -->
                            <TextBlock Text="Layout type" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="All Sides Equal  (nTop = nLeft)"
                                      IsChecked="{Binding AllowAllSidesEqual}" Margin="0,0,0,4" />
                            <CheckBox Content="Sides Different Symmetric  (nTop ≠ nLeft)"
                                      IsChecked="{Binding AllowSidesDifferent}" Margin="0,0,0,8" />

                            <!-- Display -->
                            <TextBlock Text="Display" Style="{StaticResource SectionLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Max suggestions to show"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center" Width="165" />
                                <TextBox Text="{Binding MaxSuggestions, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Tab 2: Code / Detailing ── -->
                <TabItem Header="Code / Detailing">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">
                            <TextBlock Text="Code preset" Style="{StaticResource SectionLabelStyle}" />
                            <TextBox Text="EC2 (EN 1992-1-1)" IsReadOnly="True" Margin="0,0,0,8" />

                            <TextBlock Text="Reinforcement ratio" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check minimum ρ (EC2 §9.5.2)" IsChecked="{Binding CheckMinRho}"  Margin="0,0,0,4" />
                            <CheckBox Content="Check maximum ρ (EC2 §9.5.2)" IsChecked="{Binding CheckMaxRho}"  Margin="0,0,0,8" />

                            <TextBlock Text="Clear spacing" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check clear spacing" IsChecked="{Binding CheckClearSpacing}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Aggregate size (mm)"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center" Width="130" />
                                <TextBox Text="{Binding AggregateSize, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                            </StackPanel>

                            <TextBlock Text="Cover and link checks" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check bars inside link boundary" IsChecked="{Binding CheckBarInsideLink}" Margin="0,0,0,4" />
                            <CheckBox Content="Corner bars — always required (immutable)"
                                      IsChecked="{Binding RequireCornerBars}" IsEnabled="False"
                                      ToolTip="Corner bars are always present in the spacing-first algorithm."
                                      Margin="0,0,0,8" />

                            <TextBlock Text="Tie compatibility (EC2 §9.5.3)" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check tie diameter ≥ EC2 minimum"       IsChecked="{Binding CheckTieDiameter}"    Margin="0,0,0,4" />
                            <CheckBox Content="Check tie spacing ≤ EC2 maximum"         IsChecked="{Binding CheckTieSpacing}"     Margin="0,0,0,4" />
                            <CheckBox Content="Check unsupported bar distance"           IsChecked="{Binding CheckUnsupportedBar}" Margin="0,0,0,4" />
                            <CheckBox Content="Warn if internal links required"          IsChecked="{Binding WarnInternalLinks}"   Margin="0,0,0,4" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Tab 3: Design Summary ── -->
                <TabItem Header="Design Summary">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">

                            <TextBlock Text="Run Results" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding CandidateCountsText}" TextWrapping="Wrap" Margin="0,0,0,10" />

                            <!-- Best PMM Utilization -->
                            <TextBlock Text="Best PMM Utilization" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Highest PMM ratio while still ≤ target — most efficient use of section capacity."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <Grid Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Configuration"      Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BestPmmConfig}" FontWeight="SemiBold" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max PMM"             Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BestPmmValue}" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Steel ratio ρ"       Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BestPmmRho}"  Margin="0,0,0,3" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Shear link"           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BestPmmLink}" Margin="0,0,0,3" />
                            </Grid>

                            <Separator Margin="0,10,0,8" />

                            <!-- Lowest Rebar Ratio -->
                            <TextBlock Text="Lowest Rebar Ratio" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Least reinforcement while passing all constraints."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />
                            <Grid Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Configuration"        Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LowestRhoConfig}" FontWeight="SemiBold" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Steel ratio ρ"         Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LowestRhoValue}" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="PMM"                   Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LowestRhoPmm}"  Margin="0,0,0,3" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Shear link"             Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LowestRhoLink}" Margin="0,0,0,3" />
                            </Grid>

                            <Separator Margin="0,10,0,8" />
                            <TextBlock Text="Summary" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{DynamicResource DialogFooterBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" Margin="12,0"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="1" Style="{DynamicResource DialogActionPanelStyle}">
                    <Button Content="Auto"    Command="{Binding AutoCommand}"    Width="80"
                            Style="{DynamicResource PrimaryButtonStyle}"    Margin="0,0,6,0" />
                    <Button Content="Preview" Command="{Binding PreviewCommand}" Width="80"
                            Style="{DynamicResource SecondaryButtonStyle}"  Margin="0,0,6,0" />
                    <Button Content="Apply"   Command="{Binding ApplyCommand}"   Width="80"
                            Style="{DynamicResource PrimaryButtonStyle}"    Margin="0,0,6,0" />
                    <Button Content="Cancel"  Command="{Binding CancelCommand}"  Width="80"
                            IsCancel="True"
                            Style="{DynamicResource DialogActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
