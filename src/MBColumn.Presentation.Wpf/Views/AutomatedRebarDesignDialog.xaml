<Window x:Class="MBColumn.Presentation.Wpf.Views.AutomatedRebarDesignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels.AutomatedRebarDesign"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain"
        Title="Automated Rebar Design"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">

    <Window.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource DarkNavyBrush}" />
        </Style>
        <Style x:Key="StatusCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RebarSuggestionStatus.Failed}">
                    <Setter Property="Background" Value="#FFEBEE" />
                    <Setter Property="Foreground" Value="#C62828" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RebarSuggestionStatus.Warning}">
                    <Setter Property="Background" Value="#FFF8E1" />
                    <Setter Property="Foreground" Value="#E65100" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RebarSuggestionStatus.Valid}">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Setter Property="Foreground" Value="#2E7D32" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ConditionCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Condition}" Value="Changed">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Condition}" Value="Frozen">
                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CheckPassCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPassAfter}" Value="True">
                    <Setter Property="Foreground" Value="#2E7D32" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPassAfter}" Value="False">
                    <Setter Property="Foreground" Value="#C62828" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Automated Rebar Design"
                           Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Generate, evaluate, and apply optimised rebar layouts for the current section."
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <!-- Main body: left results + right constraints -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="4*" MinWidth="300" MaxWidth="420" />
            </Grid.ColumnDefinitions>

            <!-- ════════════════ LEFT PANEL ════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!-- Before / After Table -->
                <TextBlock Grid.Row="0" Text="Before / After"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="12,10,0,4" />

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ParameterRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserSortColumns="False"
                          CanUserResizeRows="False"
                          BorderThickness="0,1,0,0"
                          Margin="8,0,4,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="160" />
                        <DataGridTextColumn Header="Before"    Binding="{Binding Before}"    Width="80" />
                        <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="90"
                                            CellStyle="{StaticResource ConditionCellStyle}" />
                        <DataGridTextColumn Header="After"     Binding="{Binding After}"     Width="80" />
                        <DataGridTextColumn Header="Unit"      Binding="{Binding Unit}"      Width="50" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Check Summary -->
                <TextBlock Grid.Row="2" Text="Design Check Summary"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="12,4,0,4" />

                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding CheckRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserSortColumns="False"
                          CanUserResizeRows="False"
                          MaxHeight="200"
                          BorderThickness="0,1,0,0"
                          Margin="8,0,4,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Check"     Binding="{Binding CheckName}" Width="190" />
                        <DataGridTextColumn Header="Before"    Binding="{Binding Before}"    Width="65" />
                        <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="80"
                                            CellStyle="{StaticResource ConditionCellStyle}" />
                        <DataGridTextColumn Header="After"     Binding="{Binding After}"     Width="65"
                                            CellStyle="{StaticResource CheckPassCellStyle}" />
                        <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    Width="60"
                                            CellStyle="{StaticResource CheckPassCellStyle}" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Candidate Suggestions -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Candidate Suggestions"
                               Style="{StaticResource SectionLabelStyle}"
                               Margin="12,4,0,4" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CandidateRows}"
                              SelectedItem="{Binding SelectedCandidate}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              CanUserSortColumns="True"
                              CanUserResizeRows="False"
                              BorderThickness="0,1,0,0"
                              Margin="8,0,4,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"       Binding="{Binding Rank}"       Width="30" />
                            <DataGridTextColumn Header="Config"  Binding="{Binding Config}"     Width="70" />
                            <DataGridTextColumn Header="As mm²"  Binding="{Binding AsMm2Display}" Width="65" />
                            <DataGridTextColumn Header="ρ %"     Binding="{Binding RhoDisplay}"  Width="55" />
                            <DataGridTextColumn Header="PMM"     Binding="{Binding PmmDisplay}"  Width="50" />
                            <DataGridTextColumn Header="V max"   Binding="{Binding MaxShearDisplay}" Width="55" />
                            <DataGridTextColumn Header="Spacing" Binding="{Binding SpacingStatus}" Width="60" />
                            <DataGridTextColumn Header="Score"   Binding="{Binding ScoreDisplay}" Width="50" />
                            <DataGridTextColumn Header="Status"  Binding="{Binding StatusLabel}"  Width="65"
                                                CellStyle="{StaticResource StatusCellStyle}" />
                            <DataGridTextColumn Header="Reason"  Binding="{Binding Reason}"     Width="*" MinWidth="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderGreyBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- ════════════════ RIGHT PANEL ════════════════ -->
            <TabControl Grid.Column="2" Margin="4,8,8,4"
                        SelectedIndex="{Binding SelectedTabIndex}">

                <!-- Tab 0: Section Preview -->
                <TabItem Header="Section Preview">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <controls:SectionPreviewCanvas
                            Grid.Row="0"
                            SectionWidth="{Binding PreviewSectionWidthMm}"
                            SectionHeight="{Binding PreviewSectionHeightMm}"
                            Cover="{Binding PreviewCoverMm}"
                            UnitSystem="Metric"
                            Rebars="{Binding PreviewRebars}"
                            SectionLabel="{Binding PreviewSectionLabel}"
                            RebarLabel="{Binding PreviewRebarLabel}"
                            CoverLabel="{Binding PreviewCoverLabel}"
                            IsValid="{Binding PreviewIsValid}"
                            StirrupDiameterMm="{Binding PreviewStirrupDiameterMm}"
                            Margin="8,8,8,4" />

                        <TextBlock Grid.Row="1"
                                   Text="{Binding PreviewStatusText}"
                                   Margin="10,0,10,10"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Grid>
                </TabItem>

                <!-- Tab 1: Target -->
                <TabItem Header="Target">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">
                            <TextBlock Text="PMM Utilization Target"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Target" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding TargetPmm, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                    <TextBlock Text="Min acceptable" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MinPmm, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max acceptable" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MaxPmm, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Steel Ratio ρ Target"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Target %" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding TargetRho, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                    <TextBlock Text="Min preferred %" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MinPreferredRho, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max preferred %" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MaxPreferredRho, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Suggestion Intent"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <ComboBox ItemsSource="{Binding PresetOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Preset"
                                      SelectedValue="{Binding SelectedPreset}"
                                      Margin="0,0,0,8" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Max suggestions" Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Text="{Binding MaxSuggestions, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Show failed candidates"
                                      IsChecked="{Binding ShowFailed}"
                                      Margin="0,0,0,4" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Search Space -->
                <TabItem Header="Search Space">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">
                            <TextBlock Text="Allowed longitudinal bar sizes"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="Shear link / stirrup bars (T6, T8, T10) are set separately in the Stirrups section."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding AllowedBarToggles}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllowedBarToggleViewModel}">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsEnabled}"
                                                  Margin="0,0,12,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Shear link info (informational — not changed by auto-design) -->
                            <TextBlock Text="Shear link / stirrup bars"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding ShearLinkRangeText}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <TextBlock Text="Allowed bar counts" Style="{StaticResource SectionLabelStyle}" />
                            <ItemsControl ItemsSource="{Binding AllowedCountToggles}" Margin="0,0,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AllowedCountToggleViewModel}">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsEnabled}"
                                                  Margin="0,0,12,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Layout type" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="All Sides Equal  (nx = ny)"
                                      IsChecked="{Binding AllowAllSidesEqual}"
                                      Margin="0,0,0,4" />
                            <CheckBox Content="Sides Different  (nx ≠ ny)"
                                      IsChecked="{Binding AllowSidesDifferent}"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Auto-change permission" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Change bar diameter"       IsChecked="{Binding AllowChangeDiameter}" Margin="0,0,0,4" />
                            <CheckBox Content="Change number of bars"     IsChecked="{Binding AllowChangeCount}"    Margin="0,0,0,4" />
                            <CheckBox Content="Change side distribution"  IsChecked="{Binding AllowChangeSide}"     Margin="0,0,0,4" />
                            <CheckBox Content="Change tie spacing"        IsChecked="{Binding AllowChangeTie}"      Margin="0,0,0,4" />
                            <CheckBox Content="Change section size"       IsEnabled="False" Margin="0,0,0,4"
                                      ToolTip="Not available in current version" />
                            <CheckBox Content="Change material grade"     IsEnabled="False" Margin="0,0,0,4"
                                      ToolTip="Not available in current version" />
                            <CheckBox Content="Change cover"              IsEnabled="False" Margin="0,0,0,4"
                                      ToolTip="Not available in current version" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 3: Code / Detailing -->
                <TabItem Header="Code / Detailing">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">
                            <TextBlock Text="Code preset" Style="{StaticResource SectionLabelStyle}" />
                            <TextBox Text="EC2 (EN 1992-1-1)" IsReadOnly="True" Margin="0,0,0,8" />

                            <TextBlock Text="Reinforcement ratio" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check minimum ρ"   IsChecked="{Binding CheckMinRho}"   Margin="0,0,0,4" />
                            <CheckBox Content="Check maximum ρ"   IsChecked="{Binding CheckMaxRho}"   Margin="0,0,0,8" />

                            <TextBlock Text="Clear spacing" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check clear spacing" IsChecked="{Binding CheckClearSpacing}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Aggregate size (mm)" Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center" Width="130" />
                                <TextBox Text="{Binding AggregateSize, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" />
                            </StackPanel>

                            <TextBlock Text="Cover and link checks" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check bars inside link boundary" IsChecked="{Binding CheckBarInsideLink}" Margin="0,0,0,4" />
                            <CheckBox Content="Corner bars required"            IsChecked="{Binding RequireCornerBars}"   Margin="0,0,0,8" />

                            <TextBlock Text="Tie compatibility" Style="{StaticResource SectionLabelStyle}" />
                            <CheckBox Content="Check tie diameter"                      IsChecked="{Binding CheckTieDiameter}"    Margin="0,0,0,4" />
                            <CheckBox Content="Check tie spacing"                       IsChecked="{Binding CheckTieSpacing}"     Margin="0,0,0,4" />
                            <CheckBox Content="Check unsupported bar distance"          IsChecked="{Binding CheckUnsupportedBar}" Margin="0,0,0,4" />
                            <CheckBox Content="Warn if internal links are required"     IsChecked="{Binding WarnInternalLinks}"   Margin="0,0,0,4" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 4: Design Summary -->
                <TabItem Header="Design Summary">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,8">
                            <TextBlock Text="Run Results"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding CandidateCountsText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />

                            <TextBlock Text="Recommended Option"
                                       Style="{StaticResource SectionLabelStyle}" />

                            <Grid Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Configuration"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding RecommendedConfig}"
                                           FontWeight="SemiBold" Margin="0,0,0,4" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max PMM"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding RecommendedPmm}"
                                           Margin="0,0,0,4" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Steel ratio ρ"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding RecommendedRho}"
                                           Margin="0,0,0,4" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Total As"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Text="{Binding RecommendedAs}"
                                           Margin="0,0,0,4" />
                            </Grid>

                            <Separator Margin="0,10,0,8" />
                            <TextBlock Text="Reason / Notes"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding SummaryText}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{DynamicResource DialogFooterBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status message (left) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis" />

                <!-- Buttons (right) -->
                <StackPanel Grid.Column="1"
                            Style="{DynamicResource DialogActionPanelStyle}">
                    <Button Content="Auto"
                            Command="{Binding AutoCommand}"
                            Width="80"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="0,0,6,0" />
                    <Button Content="Preview"
                            Command="{Binding PreviewCommand}"
                            Width="80"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="0,0,6,0" />
                    <Button Content="Apply"
                            Command="{Binding ApplyCommand}"
                            Width="80"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="0,0,6,0" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Width="80"
                            IsCancel="True"
                            Style="{DynamicResource DialogActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
