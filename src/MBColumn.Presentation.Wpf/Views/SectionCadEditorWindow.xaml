<Window x:Class="MBColumn.Presentation.Wpf.Views.SectionCadEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAD Lite Section Editor"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource LightBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <DockPanel>
                <TextBlock Text="CAD Lite"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryNavyBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0" />
                <WrapPanel>
                    <Button Content="Select" Command="{Binding SelectCommand}" Style="{StaticResource CompactButtonStyle}" Margin="0,0,6,0" />
                    <Button Content="Pt" Command="{Binding AddBoundaryPointCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,6,0" ToolTip="Add boundary point" />
                    <Button Content="Rebar" Command="{Binding AddRebarCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,6,0" ToolTip="Place rebar" />
                    <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,12,0" />
                    <Separator Width="1" Margin="0,2,12,2" />
                    <Button Content="Rect" Command="{Binding RectangleCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Circle" Command="{Binding CircleCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="L" Command="{Binding LShapeCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,6,0" ToolTip="L-shape template" />
                    <Button Content="Perimeter Rebars" Command="{Binding PerimeterRebarsCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,6,0" />
                    <Button Content="Clear Rebars" Command="{Binding ClearRebarsCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" Margin="0,0,12,0" />
                    <Button Content="Fit" Click="Fit_Click" Style="{StaticResource SecondaryButtonStyle}" MinHeight="28" Padding="10,4" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Canvas x:Name="DrawingCanvas"
                        Background="#FBFCFE"
                        ClipToBounds="True"
                        MouseDown="DrawingCanvas_MouseDown"
                        MouseMove="DrawingCanvas_MouseMove"
                        MouseUp="DrawingCanvas_MouseUp"
                        MouseWheel="DrawingCanvas_MouseWheel"
                        SizeChanged="DrawingCanvas_SizeChanged" />
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Header="Boundary Coordinates">
                    <DataGrid ItemsSource="{Binding BoundaryPoints}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Width="*" />
                            <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Rebar Coordinates">
                    <DataGrid ItemsSource="{Binding Rebars}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Width="*" />
                            <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Width="*" />
                            <DataGridTextColumn Header="Size" Binding="{Binding BarSize, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Apply" Click="Apply_Click" Style="{StaticResource PrimaryButtonStyle}" MinWidth="90" Margin="0,0,8,0" />
                    <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
