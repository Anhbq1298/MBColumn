<UserControl x:Class="MBColumn.Presentation.Wpf.Views.RebarComplianceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,5" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource SidebarCardStyle}">
            <StackPanel>
                <TextBlock Text="Reinforcement Code Compliance in Details"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,4" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Padding="10,2" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AllPass}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource WarningAmberSoftBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusText}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AllPass}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningAmberBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="{Binding CodeRef, StringFormat='  {0}'}"
                               Style="{StaticResource MetricValueStyle}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FailCountText, StringFormat='  - {0}'}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource WarningAmberBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasFails, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Checks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding StatusText}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Top"
                                           Margin="0,1,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Fail}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningAmberBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="4,0,0,0">
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextDarkBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                               TextWrapping="Wrap"
                                               Margin="0,1,0,0">
                                        <Run Text="{Binding Provided, Mode=OneWay}" Foreground="{DynamicResource TextMutedBrush}" />
                                        <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                        <Run Text="{Binding Limit, Mode=OneWay}" Foreground="{DynamicResource TextMutedBrush}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Reference}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
