                                        <Run Text="0e" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text="| + M" />
                                        <Run Text="2" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=", M" />
                                        <Run Text="01" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" + 0.5M" />
                                        <Run Text="2" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=", and M" />
                                        <Run Text="min" BaselineAlignment="Subscript" FontSize="9" />
