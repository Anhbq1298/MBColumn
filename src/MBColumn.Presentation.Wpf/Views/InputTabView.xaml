<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.InputTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
    <UserControl.Resources>
        <Style x:Key="SideBarCountTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,0,8,6" />
            <Setter Property="Padding"
                    Value="7,5" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasBarCountWarning}"
                             Value="True">
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource AccentRedBrush}" />
                    <Setter Property="BorderThickness"
                            Value="2" />
                    <Setter Property="ToolTip"
                            Value="{Binding BarCountWarning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideReadOnlyTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,0,8,6" />
            <Setter Property="Padding"
                    Value="7,5" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="IsEnabled"
                    Value="False" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Background"
                    Value="{DynamicResource PanelBackgroundBrush}" />
        </Style>
        <Style x:Key="ColumnHeaderTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="HorizontalAlignment"
                    Value="Center" />
            <Setter Property="Margin"
                    Value="0,0,0,12" />
        </Style>
        <Style x:Key="PreviewPropertyLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>
        <Style x:Key="PreviewPropertyValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MutedValueTextStyle}">
            <Setter Property="Margin"
                    Value="0,0,0,4" />
            <Setter Property="TextWrapping"
                    Value="Wrap" />
        </Style>
        <Style x:Key="InputSubsectionTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource GroupTitleTextStyle}">
            <Setter Property="FontSize"
                    Value="{DynamicResource FontSizeHelper}" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>
        <Style x:Key="SectionShapeRadioStyle"
               TargetType="RadioButton">
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="FontSize"
                    Value="12.5" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Padding"
                    Value="14,6" />
            <Setter Property="Margin"
                    Value="12,0,0,0" />
            <Setter Property="MinWidth"
                    Value="110" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ShapeBorder"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="ShapeBorder"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter TargetName="ShapeBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ShapeBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver"
                                               Value="True" />
                                    <Condition Property="IsChecked"
                                               Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ShapeBorder"
                                        Property="Background"
                                        Value="{DynamicResource BorderSoftBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <TabControl>
        <TabItem Header="General Parameters + Load Inputs">
            <Grid Margin="4,6,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1.4*" MinWidth="320" />
                </Grid.ColumnDefinitions>
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <GroupBox Header="General"
                                  Background="White"
                                  Foreground="{DynamicResource DarkNavyBrush}"
                                  BorderBrush="{DynamicResource BorderGreyBrush}"
                                  Padding="14"
                                  Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Unit System"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <ComboBox ItemsSource="{Binding UnitSystems}"
                                          SelectedItem="{Binding UnitSystem}" />
                                <TextBlock Text="Design Code"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Margin="0,10,0,0" />
                                <ComboBox ItemsSource="{Binding DesignCodes}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          SelectedValue="{Binding SelectedDesignCode}" />
                                <TextBlock Text="Section Integration Method"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Margin="0,10,0,0" />
                                <ComboBox ItemsSource="{Binding SectionIntegrationMethodOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Method"
                                          SelectedValue="{Binding SelectedIntegrationMethod}">
                                    <ComboBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap"
                                                   MaxWidth="360"
                                                   Text="Fiber Integration: General numerical integration method recommended for circular sections and future arbitrary sections. Polygon Integration: Faster compression-zone clipping method useful for stress-block comparison." />
                                    </ComboBox.ToolTip>
                                </ComboBox>
                                <StackPanel Visibility="{Binding ShowAlphaCcOption, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Alpha cc"
                                               Style="{StaticResource FieldLabelTextStyle}"
                                               Margin="0,10,0,0" />
                                    <TextBox Text="{Binding AlphaCc, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Material"
                                  Background="White"
                                  Foreground="{DynamicResource DarkNavyBrush}"
                                  BorderBrush="{DynamicResource BorderGreyBrush}"
                                  Padding="14"
                                  Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Text="Library"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <ComboBox Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding MaterialLibraries}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Library"
                                          SelectedValue="{Binding SelectedMaterialLibrary}" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Text="Concrete Grade"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           IsEnabled="{Binding AreMaterialGradesEnabled}"
                                           Margin="0,8,0,0" />
                                <ComboBox Grid.Row="3"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding AvailableConcreteGrades}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding AreMaterialGradesEnabled}"
                                          SelectedItem="{Binding SelectedConcreteGrade}" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Text="Rebar Grade"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           IsEnabled="{Binding AreMaterialGradesEnabled}"
                                           Margin="0,8,0,0" />
                                <ComboBox Grid.Row="5"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding AvailableSteelGrades}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding AreMaterialGradesEnabled}"
                                          SelectedItem="{Binding SelectedSteelGrade}" />
                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Text="{Binding FcLabel}"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Margin="0,8,0,0" />
                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}"
                                           Margin="0,8,0,0" />
                                <TextBox Grid.Row="7"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         IsEnabled="{Binding AreMaterialInputsEnabled}"
                                         Text="{Binding Fc, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Text="{Binding FyLabel}"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="9"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         IsEnabled="{Binding AreMaterialInputsEnabled}"
                                         Text="{Binding Fy, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Text="Es"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="10"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="11"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         IsEnabled="{Binding AreMaterialInputsEnabled}"
                                         Text="{Binding Es, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
                <Grid Grid.Column="2">
                    <GroupBox Header="Demand Cases"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Moment sign convention diagram -->
                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6"
                                    VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Moment Sign Convention"
                                               Style="{StaticResource FieldLabelTextStyle}"
                                               Margin="0,0,0,4" />
                                    <Viewbox Stretch="Uniform"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Top">
                                        <Canvas Width="900" Height="940">
                                            <Canvas.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Arial, Helvetica, sans-serif"/>
                                                    <Setter Property="Foreground" Value="#0046d5"/>
                                                </Style>
                                            </Canvas.Resources>

                                            <Rectangle Width="900" Height="940" Fill="White"/>

                                            <!-- Column faces -->
                                            <Polygon Points="170.0,760.0 480.0,760.0 480.0,110.0 170.0,110.0" Fill="#dcecff" Opacity="0.45" />
                                            <Polygon Points="480.0,760.0 625.0,665.0 625.0,15.0 480.0,110.0" Fill="#dcecff" Opacity="0.65" />
                                            <Polygon Points="170.0,110.0 480.0,110.0 625.0,15.0 315.0,15.0" Fill="#dcecff" Opacity="0.55" />

                                            <!-- Main prism outline -->
                                            <Polyline Points="170.0,760.0 480.0,760.0 625.0,665.0 315.0,665.0 170.0,760.0" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                            <Polyline Points="170.0,110.0 480.0,110.0 625.0,15.0 315.0,15.0 170.0,110.0" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                            <Line X1="170" Y1="760" X2="170" Y2="110" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                            <Line X1="480" Y1="760" X2="480" Y2="110" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                            <Line X1="625" Y1="665" X2="625" Y2="15" Stroke="#0046d5" StrokeThickness="2.6" StrokeLineJoin="Round"/>
                                            <Line X1="315" Y1="665" X2="315" Y2="15" Stroke="#0046d5" StrokeThickness="1.6" StrokeDashArray="7 7"/>

                                            <!-- Mid section -->
                                            <Polygon Points="170.0,445.0 480.0,445.0 625.0,350.0 315.0,350.0" Fill="White" Opacity="0.45" Stroke="#0046d5" StrokeThickness="2.4"/>
                                            <Line X1="170" Y1="445" X2="625" Y2="350" Stroke="#0046d5" StrokeThickness="1.6" StrokeDashArray="7 7"/>
                                            <Line X1="480" Y1="445" X2="315" Y2="350" Stroke="#0046d5" StrokeThickness="1.6" StrokeDashArray="7 7"/>

                                            <!-- Centroid marker -->
                                            <Ellipse Canvas.Left="381.5" Canvas.Top="381.5" Width="32" Height="32" Fill="White" Stroke="#0046d5" StrokeThickness="2.2"/>
                                            <Ellipse Canvas.Left="392.5" Canvas.Top="392.5" Width="10" Height="10" Fill="#0046d5"/>

                                            <!-- Axial load P -->
                                            <Line X1="397.5" Y1="147.5" X2="397.5" Y2="373.5" Stroke="#0046d5" StrokeThickness="3" />
                                            <Polygon Points="382.5,343.5 397.5,373.5 412.5,343.5" Fill="#0046d5" />
                                            <TextBlock Canvas.Left="415.5" Canvas.Top="157" Text="P" FontSize="52" />

                                            <!-- MX -->
                                            <Line X1="397.5" Y1="397.5" X2="647.5" Y2="397.5" Stroke="#0046d5" StrokeThickness="3"/>
                                            <Path Data="M 642.5 384.5 L 669.5 397.5 L 642.5 410.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                            <Path Data="M 667.5 384.5 L 694.5 397.5 L 667.5 410.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                            <Rectangle Canvas.Left="712.5" Canvas.Top="371.5" Width="63" Height="46" Fill="White" Stroke="#0046d5" StrokeThickness="1.8"/>
                                            <TextBlock Canvas.Left="723" Canvas.Top="380" Text="MX" FontSize="52" />

                                            <!-- MY -->
                                            <Line X1="397.5" Y1="397.5" X2="517.5" Y2="304.5" Stroke="#0046d5" StrokeThickness="3"/>
                                            <Path Data="M 507.5 287.5 L 535.5 285.5 L 520.5 310.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                            <Path Data="M 528.5 270.5 L 556.5 268.5 L 541.5 293.5" Stroke="#0046d5" StrokeThickness="3" Fill="Transparent" />
                                            <Rectangle Canvas.Left="576.5" Canvas.Top="240.5" Width="63" Height="46" Fill="White" Stroke="#0046d5" StrokeThickness="1.8"/>
                                            <TextBlock Canvas.Left="587" Canvas.Top="249" Text="MY" FontSize="52" />

                                            <!-- Coordinate triad -->
                                            <Line X1="670" Y1="890" X2="815" Y2="890" Stroke="#0046d5" StrokeThickness="2.2" />
                                            <Path Data="M 793 879 L 815 890 L 793 901" Stroke="#0046d5" StrokeThickness="1.6" Fill="Transparent" />
                                            <Line X1="670" Y1="890" X2="765" Y2="815" Stroke="#0046d5" StrokeThickness="2.2" />
                                            <Path Data="M 754.8 837.2 L 765 815 L 741.2 820" Stroke="#0046d5" StrokeThickness="1.6" Fill="Transparent" />
                                            <Line X1="670" Y1="890" X2="670" Y2="750" Stroke="#0046d5" StrokeThickness="2.2" />
                                            <Path Data="M 659 772 L 670 750 L 681 772" Stroke="#0046d5" StrokeThickness="1.6" Fill="Transparent" />
                                            <Rectangle Canvas.Left="825" Canvas.Top="870" Width="34" Height="34" Fill="White" Stroke="#0046d5" StrokeThickness="1.8"/>
                                            <TextBlock Canvas.Left="834" Canvas.Top="875" Text="X" FontSize="24" />
                                            <Rectangle Canvas.Left="775" Canvas.Top="784" Width="34" Height="34" Fill="White" Stroke="#0046d5" StrokeThickness="1.8"/>
                                            <TextBlock Canvas.Left="784" Canvas.Top="788" Text="Y" FontSize="24" />
                                            <Rectangle Canvas.Left="653" Canvas.Top="705" Width="34" Height="34" Fill="White" Stroke="#0046d5" StrokeThickness="1.8"/>
                                            <TextBlock Canvas.Left="662" Canvas.Top="710" Text="Z" FontSize="24" />

                                            <!-- Title -->
                                            <TextBlock Canvas.Left="260" Canvas.Top="1050" Text="Positive Moment Loads" FontSize="38" FontWeight="SemiBold" />
                                        </Canvas>
                                    </Viewbox>
                                </StackPanel>
                            </Border>

                            <!-- Right: DataGrid + buttons -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                                    <Button Content="+ Add case"
                                            Command="{Binding AddLoadCaseCommand}"
                                            Style="{StaticResource CompactButtonStyle}"
                                            Margin="0,0,8,6" />
                                    <Button Content="Delete demand case"
                                            Command="{Binding DeleteSelectedLoadCasesCommand}"
                                            CommandParameter="{Binding SelectedItems, ElementName=LoadCasesGrid}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,4"
                                            FontSize="11.5"
                                            Margin="0,0,8,6" />
                                    <Button Content="Import from CSV"
                                            Command="{Binding ImportLoadCasesCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,4"
                                            FontSize="11.5"
                                            Margin="0,0,8,6" />
                                    <Button Content="Export to CSV"
                                            Command="{Binding ExportLoadCasesCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,4"
                                            FontSize="11.5"
                                            Margin="0,0,8,6" />
                                </WrapPanel>
                                <DataGrid x:Name="LoadCasesGrid"
                                          Grid.Row="1"
                                          ItemsSource="{Binding LoadCases}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeColumns="True"
                                          CanUserResizeRows="True"
                                          HeadersVisibility="Column"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Demand Case"
                                                      Command="{Binding Path=PlacementTarget.DataContext.AddLoadCaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove Selected Demand Case(s)"
                                                      Command="{Binding Path=PlacementTarget.DataContext.DeleteSelectedLoadCasesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Case Name"
                                                            Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                            Width="110"
                                                            MinWidth="80"
                                                            ElementStyle="{StaticResource LeftAlignText}" />
                                        <DataGridTextColumn Binding="{Binding Pu, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            MinWidth="64"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.DemandForceHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Mux, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            MinWidth="64"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.DemandMomentXHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Muy, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            MinWidth="64"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.DemandMomentYHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <!-- Shear demands — zero by default; only used when shear check is run -->
                                        <DataGridTextColumn Binding="{Binding Vux, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            MinWidth="60"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.ShearVuxHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vuy, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            MinWidth="60"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.ShearVuyHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Source"
                                                            Binding="{Binding Source, UpdateSourceTrigger=LostFocus}"
                                                            Width="75"
                                                            MinWidth="60"
                                                            ElementStyle="{StaticResource LeftAlignText}" />
                                        <DataGridCheckBoxColumn Header="Include"
                                                                Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="62"
                                                                MinWidth="50" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Grid>
        </TabItem>
        <TabItem Header="Section + Rebar">
            <Grid Margin="4,6,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" MinWidth="200" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <!-- ── Left: Section Preview (≈30%) ── -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Preview card -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Section Preview"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="SECTION PREVIEW"
                                           Style="{StaticResource OverlineTextStyle}"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="2D VIEW · GRID"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,0,0,4" />
                                <controls:SectionPreviewCanvas Height="240"
                                                               MinHeight="160"
                                                               HorizontalAlignment="Stretch"
                                                               SectionWidth="{Binding SectionWidth}"
                                                               SectionHeight="{Binding SectionHeight}"
                                                               Cover="{Binding Cover}"
                                                               UnitSystem="{Binding SelectedUnitSystem}"
                                                               SectionShape="{Binding SelectedSectionShape}"
                                                               Rebars="{Binding PreviewRebars}"
                                                               SectionLabel="{Binding SectionPreviewLabel}"
                                                               RebarLabel="{Binding RebarPreviewLabel}"
                                                               CoverLabel="{Binding CoverPreviewLabel}"
                                                               IsValid="{Binding IsSectionPreviewValid}"
                                                               ErrorMessage="{Binding SectionPreviewErrorMessage}"
                                                               BoundaryPoints="{Binding PreviewBoundaryPoints}"
                                                               StirrupDiameterMm="{Binding StirrupDiameterMm}"
                                                               InnerLegsX="{Binding InnerLegsX}"
                                                               InnerLegsY="{Binding InnerLegsY}" />
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,10">
                                    <Button Click="OpenCadEditor_Click"
                                            Style="{StaticResource CompactButtonStyle}"
                                            MinWidth="78"
                                            MinHeight="32"
                                            Padding="10,5"
                                            Margin="0,0,8,0"
                                            ToolTip="Open CAD Lite editor">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE70F;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{StaticResource FontSizeSection}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Edit"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ImportDxfCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="96"
                                            MinHeight="32"
                                            Padding="10,5"
                                            ToolTip="Import .DXF">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 6,3 L 15,3 L 20,8 L 20,21 L 6,21 Z M 15,3 L 15,8 L 20,8"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                    <Path Data="M 12,9 L 12,16 M 8.8,13 L 12,16.2 L 15.2,13"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Import .dxf" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Section properties (compact) -->
                                <Separator Background="{DynamicResource BorderGreyBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="SECTION PROPERTIES"
                                           Style="{StaticResource OverlineTextStyle}"
                                           Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Section" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewShapeSummaryText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Layout" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewRebarLayoutText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Cover" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CoverPreviewLabel}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="A" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewAreaText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Ixx" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PreviewIxxText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Iyy" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PreviewIyyText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="7" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Rebars" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding RebarPreviewLabel}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="ρ" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding PreviewRebarPercentageText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── Right: Section Geometry + Rebar Configuration (≈70%) ── -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Validation banners — only visible when there is something to show -->
                        <StackPanel Margin="0,0,0,8"
                                    Visibility="{Binding DataContext.IsCalculationOutdated, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Changes made, recalculation required."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DataContext.ValidationMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0"
                              Header="Section Geometry"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="0,0,7,14">
                        <StackPanel>
                            <!-- Section Shape -->
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Section Shape"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <ComboBox SelectedValue="{Binding SelectedSectionShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          VerticalAlignment="Center"
                                          Height="30">
                                    <ComboBoxItem Content="Rectangular"
                                                  Tag="{x:Static enums:SectionShapeType.Rectangular}" />
                                    <ComboBoxItem Content="Circular"
                                                  Tag="{x:Static enums:SectionShapeType.Circular}" />
                                    <ComboBoxItem Content="Irregular"
                                                  Tag="{x:Static enums:SectionShapeType.Irregular}" />
                                </ComboBox>
                            </DockPanel>

                            <!-- Clear cover -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="44" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Clear cover"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Cover}" />
                            </Grid>

                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Width b"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Width}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="3"
                                           Text="Height h"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="4"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Height}" />
                            </Grid>
                            <Grid Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Diameter D"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Diameter}" />
                            </Grid>

                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="Boundary Points (Clockwise)"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />
                            <!-- Editing UI only for Irregular Section -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <WrapPanel Margin="0,0,0,8">
                                    <Button ToolTip="Import..."
                                            Click="ImportBoundary_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0"
                                            Margin="0,0,8,0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,2 L 10,13 M 6,9 L 10,13 L 14,9"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                    <Button ToolTip="Export..."
                                            Click="ExportBoundary_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,14 L 10,3 M 6,7 L 10,3 L 14,7"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="{Binding IrregularInput.BoundaryValidationMessage}"
                                           Visibility="{Binding IrregularInput.HasBoundaryValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap" />
                                <DataGrid ItemsSource="{Binding IrregularInput.BoundaryPoints}"
                                          AutoGenerateColumns="False"
                                          MaxHeight="200">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Point"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.AddBoundaryRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove Selected Point(s)"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.DeleteBoundaryRowsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Pt"
                                                            Binding="{Binding PtIndex, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        <DataGridTextColumn Header="X"
                                                            Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        <DataGridTextColumn Header="Y"
                                                            Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            <!-- Preview for Rectangular/Circular — locked, greyed out -->
                            <DataGrid ItemsSource="{Binding PreviewBoundaryPoints}"
                                      Visibility="{Binding IsIrregularSection, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      IsEnabled="False"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pt" Binding="{Binding Index}" Width="*" />
                                    <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F2}" Width="*" />
                                    <DataGridTextColumn Header="Y" Binding="{Binding Y, StringFormat=F2}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Column="1"
                              Header="Rebar Configuration"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="7,0,0,14">
                        <StackPanel>
                            <TextBlock Text="1 — Longitudinal Reinforcement"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,8,0">
                                    <TextBlock Text="Rebar set library"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding RebarSetLibraries}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Library"
                                              SelectedValue="{Binding SelectedRebarSetLibrary}" />
                                </StackPanel>
                            </Grid>
                            <!-- 1. Algorithmic / Shape-Specific Top Panel (Visible for Rectangular/Circular) -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Grid Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Row 0: Layout Type ComboBox and standard inputs -->
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,8,0">
                                        <TextBlock Text="Layout Type"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding RebarLayoutTypes}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="LayoutType"
                                                  SelectedValue="{Binding SelectedRebarLayoutType}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding ShowTotalBarsInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Bar size"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableBars}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding BarSize}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="2"
                                                Visibility="{Binding ShowTotalBarsInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Total number of bars"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding BarCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Visibility="{Binding IsRectangularEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding LengthLabel, StringFormat=Bar spacing ({0})}"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding RectSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <!-- Row 1: Equal Spacing Layout Panel -->
                                    <Grid Grid.Row="1"
                                          Grid.ColumnSpan="3"
                                          Margin="0,8,0,0"
                                          Visibility="{Binding IsEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Bar size"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding AvailableBars}"
                                                      DisplayMemberPath="DisplayLabel"
                                                      SelectedValuePath="Name"
                                                      SelectedValue="{Binding BarSize}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Margin="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Spacing ("
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding LengthLabel}"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text=")"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding Spacing}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                <TextBlock Text="{Binding RebarLayoutWarning}"
                                           Visibility="{Binding HasRebarLayoutWarning, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Visibility="{Binding IsSidesDifferentLayout, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Margin="0,0,0,10">
                                    <Grid MinWidth="620">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="Top"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Bottom"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="3"
                                                   Text="Left"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="4"
                                                   Text="Right"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="No. of bars"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Bar size"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Clear cover"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                    </Grid>
                                </ScrollViewer>
                            </StackPanel>
                            <!-- 2. Irregular Section-Specific Spacing/Generate Panel (Visible only for Irregular Section) -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid DataContext="{Binding IrregularInput}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- Row 0: Layout Type Selector for Irregular -->
                                    <Grid Grid.Row="0"
                                          Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Layout Type"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding RebarModeOptions}"
                                                      SelectedValue="{Binding RebarMode}"
                                                      SelectedValuePath="Type"
                                                      DisplayMemberPath="DisplayName" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Row 1: Equal Spacing Inputs (Visible only when RebarMode is EqualSpacing) -->
                                    <Grid Grid.Row="1"
                                          Margin="0,0,0,12"
                                          Visibility="{Binding IsEqualSpacing, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Bar size"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding DataContext.AvailableBars, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="Name"
                                                      SelectedValue="{Binding BarSize}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Margin="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Spacing ("
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding DataContext.LengthLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text=")"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding Spacing}" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Row 2: Validation Messages -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding RebarValidationMessage}"
                                               Visibility="{Binding HasRebarValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                               Foreground="{DynamicResource AccentRedBrush}"
                                               Style="{StaticResource HelperTextStyle}"
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>

                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="Rebar Coordinates"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />
                            <!-- Editing UI only for Irregular Section with custom rebar coordinates -->
                            <StackPanel Visibility="{Binding IsRebarCoordinatesEditable, Converter={StaticResource BoolToVisibilityConverter}}">
                                <WrapPanel Margin="0,0,0,8">
                                    <Button ToolTip="Import..."
                                            Click="ImportRebar_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0"
                                            Margin="0,0,8,0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,2 L 10,13 M 6,9 L 10,13 L 14,9"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                    <Button ToolTip="Export..."
                                            Click="ExportRebar_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,14 L 10,3 M 6,7 L 10,3 L 14,7"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding IrregularInput.Rebars}"
                                          AutoGenerateColumns="False"
                                          MaxHeight="200">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Rebar"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.AddRebarRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove Selected Rebar(s)"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.DeleteRebarRowsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Index"
                                                            Binding="{Binding RebarIndex, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        <DataGridTextColumn Header="X"
                                                            Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        <DataGridTextColumn Header="Y"
                                                            Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        <DataGridTextColumn Header="Area"
                                                            Binding="{Binding AreaMm2, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        <DataGridTextColumn Header="Size"
                                                            Binding="{Binding BarSize, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            <!-- Preview UI for auto-generated rebars -->
                            <DataGrid ItemsSource="{Binding PreviewRebars}"
                                      Visibility="{Binding IsRebarCoordinatesEditable, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="*" />
                                    <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F2}" Width="*" />
                                    <DataGridTextColumn Header="Y" Binding="{Binding Y, StringFormat=F2}" Width="*" />
                                    <DataGridTextColumn Header="Size" Binding="{Binding Label}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- ── Section 2: Stirrups and Shear Links ── -->
                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="2 — Stirrups and Shear Links"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />

                            <!-- Stirrup Ø + Link spacing side by side — rectangular only -->
                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- Stirrup diameter -->
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Stirrup Ø"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding RebarDiameterUnitLabel}"
                                               Style="{StaticResource UnitTextStyle}" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding AvailableStirrupBars}"
                                              DisplayMemberPath="DisplayLabel"
                                              SelectedItem="{Binding SelectedStirrupBar}" />
                                </Grid>
                                <!-- Link spacing s -->
                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Link spacing s"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding LinkSpacingUnitLabel}"
                                               Style="{StaticResource UnitTextStyle}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             Grid.ColumnSpan="2"
                                             Text="{Binding LinkSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>

                            <!-- Inner legs X / Y — rectangular only -->
                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Inner legs X (‖ h)"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="Inner legs Y (‖ b)"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Text="{Binding InnerLegsX, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         Text="{Binding InnerLegsY, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,2,0,0">
                                    <TextBlock Text="Total: "
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding TotalLegsX}"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text=" legs"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            Margin="0,2,0,0">
                                    <TextBlock Text="Total: "
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding TotalLegsY}"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text=" legs"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                            </Grid>

                            <!-- EC2 §9.5.3 checks — rectangular only -->
                            <StackPanel Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,2,0,0">
                                <TextBlock Text="EC2 §9.5.3 Link Checks"
                                           Style="{StaticResource InputSubsectionTitleTextStyle}"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check1Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check1Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check1Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check2Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check2Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check2Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check3Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check3Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check3Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding Ec2AswsXText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="12,0,0,1" />
                                <TextBlock Text="{Binding Ec2AswsYText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="12,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
