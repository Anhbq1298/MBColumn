                                        <Run Text="Equivalent moment used with nominal curvature. M" />
                                        <Run Text="0e" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = max(0.6M" />
                                        <Run Text="02" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" + 0.4M" />
                                        <Run Text="01" BaselineAlignment="Subscript" FontSize="9" />
