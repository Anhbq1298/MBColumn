<UserControl x:Class="MBColumn.Presentation.Wpf.Views.InputTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls">
    <UserControl.Resources>
        <Style x:Key="SideBarCountTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,8,6" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasBarCountWarning}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentRedBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="ToolTip" Value="{Binding BarCountWarning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideReadOnlyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,8,6" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="Height" Value="32" />
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        </Style>
        <Style x:Key="ColumnHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SectionShapeRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ShapeBorder"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ShapeBorder" Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter TargetName="ShapeBorder" Property="BorderBrush" Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShapeBorder" Property="BorderBrush" Value="{DynamicResource PrimaryNavyBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ShapeBorder" Property="Background" Value="{DynamicResource BorderSoftBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*" MinWidth="220" />
            <ColumnDefinition Width="0.35*" MinWidth="300" />
            <ColumnDefinition Width="*" MinWidth="550" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,14,0">
            <StackPanel>
                <TextBlock Text="Project Settings" Style="{StaticResource ColumnHeaderTextStyle}" />

                <GroupBox Header="General" Background="White" Foreground="{DynamicResource DarkNavyBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Workflow" Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding UnitSystems}" SelectedItem="{Binding UnitSystem}" />
                        <TextBlock Text="Changing workflow resets defaults - values are not silently reinterpreted."
                                   Style="{StaticResource HelperTextStyle}" TextWrapping="Wrap" />

                        <TextBlock Text="Design Code" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding DesignCodes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{Binding SelectedDesignCode}" />

                        <TextBlock Text="Section Integration Method" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding SectionIntegrationMethodOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Method"
                                  SelectedValue="{Binding SelectedIntegrationMethod}">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap" MaxWidth="360"
                                           Text="Fiber Integration: General numerical integration method recommended for circular sections and future arbitrary sections. Polygon Integration: Faster compression-zone clipping method useful for stress-block comparison." />
                            </ComboBox.ToolTip>
                        </ComboBox>

                        <StackPanel Visibility="{Binding ShowAlphaCcOption, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Alpha cc" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                            <TextBox Text="{Binding AlphaCc, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Concrete strength coefficient (NDP). UK/Singapore standard = 0.85. Columns often use 0.80."
                                       Style="{StaticResource HelperTextStyle}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Material" Background="White" Foreground="{DynamicResource DarkNavyBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="76" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding FcLabel}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StressLabel}" Style="{StaticResource UnitTextStyle}" />
                        <TextBox  Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Fc, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding FyLabel}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StressLabel}" Style="{StaticResource UnitTextStyle}" />
                        <TextBox  Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Fy, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Es" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding StressLabel}" Style="{StaticResource UnitTextStyle}" />
                        <TextBox  Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Es, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,14,0">
            <StackPanel>
                <TextBlock Text="Load Case" Style="{StaticResource ColumnHeaderTextStyle}" />

                <GroupBox Header="Load Cases" Background="White" Foreground="{DynamicResource DarkNavyBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Moment Sign Convention"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Margin="0,0,0,8" />
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Margin="0,0,0,14">
                            <Image Source="/MBColumn;component/Resources/MomentSignConvention.png"
                                   Stretch="Uniform"
                                   MaxHeight="180"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8" TextWrapping="Wrap"
                                   Text="P: compression (+). Mx: moment about X-axis. My: moment about Y-axis." />

                        <DataGrid x:Name="LoadCasesGrid"
                                  ItemsSource="{Binding LoadCases}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="True"
                                  HeadersVisibility="Column"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  MinHeight="260"
                                  MaxHeight="460"
                                  Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Load&#x0a;Case" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="72" MinWidth="60" ElementStyle="{StaticResource LeftAlignText}" />
                                <DataGridTextColumn Header="P" Binding="{Binding Pu, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Width="*" MinWidth="64" ElementStyle="{StaticResource RightAlignText}" EditingElementStyle="{StaticResource RightAlignEditingTextBox}" />
                                <DataGridTextColumn Header="Mx" Binding="{Binding Mux, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Width="*" MinWidth="64" ElementStyle="{StaticResource RightAlignText}" EditingElementStyle="{StaticResource RightAlignEditingTextBox}" />
                                <DataGridTextColumn Header="My" Binding="{Binding Muy, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Width="*" MinWidth="64" ElementStyle="{StaticResource RightAlignText}" EditingElementStyle="{StaticResource RightAlignEditingTextBox}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <WrapPanel>
                            <Button Content="+ Add case" Command="{Binding AddLoadCaseCommand}"
                                    Style="{StaticResource CompactButtonStyle}" />
                            <Button Content="Delete load case"
                                    Command="{Binding DeleteSelectedLoadCasesCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=LoadCasesGrid}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,4" FontSize="11.5" Margin="8,0,0,0" />
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Section And Rebar Config" Style="{StaticResource ColumnHeaderTextStyle}" />

                <Border Style="{StaticResource CardBorderStyle}" Padding="18" MinHeight="240" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Section Preview" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}" Margin="0,0,0,4" />
                        <TextBlock Style="{StaticResource HelperTextStyle}" Margin="0,0,0,12" TextWrapping="Wrap"
                                   Text="Compression (+). Internal units: N, mm, MPa. Slenderness excluded." />

                        <controls:SectionPreviewCanvas Height="220" MinHeight="200"
                            HorizontalAlignment="Stretch"
                            SectionWidth="{Binding SectionWidth}"
                            SectionHeight="{Binding SectionHeight}"
                            Cover="{Binding Cover}"
                            UnitSystem="{Binding SelectedUnitSystem}"
                            SectionShape="{Binding SelectedSectionShape}"
                            Rebars="{Binding PreviewRebars}"
                            SectionLabel="{Binding SectionPreviewLabel}"
                            RebarLabel="{Binding RebarPreviewLabel}"
                            CoverLabel="{Binding CoverPreviewLabel}"
                            IsValid="{Binding IsSectionPreviewValid}"
                            ErrorMessage="{Binding SectionPreviewErrorMessage}"
                            BoundaryPoints="{Binding PreviewBoundaryPoints}" />
                    </StackPanel>
                </Border>

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button Content="Calculate PMM Capacity"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding DataContext.CalculateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            MinWidth="210" />
                    <TextBlock Text="Changes made, recalculation required."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentRedBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               Visibility="{Binding DataContext.IsCalculationOutdated, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding DataContext.ValidationMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentRedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Section Geometry" Background="White" Foreground="{DynamicResource DarkNavyBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" Padding="14" Margin="0,0,7,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <TextBlock Text="Section Shape" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ComboBox VerticalAlignment="Center" Height="30">
                                    <ComboBoxItem Content="Rectangular" IsSelected="{Binding IsRectangularSection}" />
                                    <ComboBoxItem Content="Circular" IsSelected="{Binding IsCircularSection}" />
                                    <ComboBoxItem Content="Irregular" IsSelected="{Binding IsIrregularSection}" />
                                </ComboBox>
                            </DockPanel>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LengthLabel, StringFormat=Clear cover ({0})}" Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LengthLabel}" Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Cover, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Width b" Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LengthLabel}" Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Height h" Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding LengthLabel}" Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Diameter D" Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LengthLabel}" Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Diameter, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid DataContext="{Binding IrregularInput}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="Boundary Points (Clockwise)" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4" TextWrapping="Wrap" />
                                    
                                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                                        <Button Content="C" ToolTip="Clear" Command="{Binding ClearBoundaryCommand}" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" Margin="0,0,8,0" />
                                        <Button Content="R" ToolTip="Reverse" Command="{Binding ReverseBoundaryCommand}" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" Margin="0,0,8,0" />
                                        <Button Content="I" ToolTip="Import..." Click="ImportBoundary_Click" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" Margin="0,0,8,0" />
                                        <Button Content="E" ToolTip="Export..." Click="ExportBoundary_Click" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" />
                                    </WrapPanel>

                                    <DataGrid Grid.Row="2" ItemsSource="{Binding BoundaryPoints}" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True" MaxHeight="200" Margin="0,0,0,8">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Pt" Binding="{Binding PtIndex, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Rebar Configuration" Background="White" Foreground="{DynamicResource DarkNavyBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" Padding="14" Margin="7,0,0,14">
                        <StackPanel>
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Layout Type" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding RebarLayoutTypes}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="LayoutType"
                                                  SelectedValue="{Binding SelectedRebarLayoutType}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Bar size" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableBars}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding BarSize}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Visibility="{Binding IsAllSidesEqualLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Total number of bars" Style="{StaticResource FieldLabelTextStyle}" TextWrapping="Wrap" />
                                        <TextBox Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Visibility="{Binding IsCircularEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Layout Type" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Text="Equal spacing" IsReadOnly="True" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Bar size" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableBars}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding BarSize}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Total number of bars" Style="{StaticResource FieldLabelTextStyle}" TextWrapping="Wrap" />
                                        <TextBox Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding RebarLayoutWarning}"
                                           Visibility="{Binding HasRebarLayoutWarning, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />

                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Visibility="{Binding IsSidesDifferentLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid MinWidth="620">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" MinWidth="110" />
                                            <ColumnDefinition Width="*" MinWidth="110" />
                                            <ColumnDefinition Width="*" MinWidth="110" />
                                            <ColumnDefinition Width="*" MinWidth="110" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Top" Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Bottom" Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Left" Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Right" Style="{StaticResource GroupTitleTextStyle}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="No. of bars" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1" Grid.Column="1" DataContext="{Binding RebarLayout.Top}" Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="2" DataContext="{Binding RebarLayout.Bottom}" Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="3" DataContext="{Binding RebarLayout.Left}" Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="4" DataContext="{Binding RebarLayout.Right}" Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SideBarCountTextBoxStyle}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Bar size" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="2" Grid.Column="1" DataContext="{Binding RebarLayout.Top}" Text="{Binding BarSize, Mode=OneWay}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2" Grid.Column="2" DataContext="{Binding RebarLayout.Bottom}" Text="{Binding BarSize, Mode=OneWay}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2" Grid.Column="3" DataContext="{Binding RebarLayout.Left}" Text="{Binding BarSize, Mode=OneWay}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2" Grid.Column="4" DataContext="{Binding RebarLayout.Right}" Text="{Binding BarSize, Mode=OneWay}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Clear cover" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3" Grid.Column="1" DataContext="{Binding RebarLayout.Top}" Text="{Binding Cover, Mode=OneWay, StringFormat=F3}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="2" DataContext="{Binding RebarLayout.Bottom}" Text="{Binding Cover, Mode=OneWay, StringFormat=F3}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="3" DataContext="{Binding RebarLayout.Left}" Text="{Binding Cover, Mode=OneWay, StringFormat=F3}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="4" DataContext="{Binding RebarLayout.Right}" Text="{Binding Cover, Mode=OneWay, StringFormat=F3}" Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                    </Grid>
                                </ScrollViewer>
                            </StackPanel>

                             <Grid Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                 <Grid DataContext="{Binding IrregularInput}">
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="*" />
                                     </Grid.RowDefinitions>

                                     <!-- Row 0: Layout Type Selector -->
                                     <Grid Grid.Row="0" Margin="0,0,0,8">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                             <TextBlock Text="Layout Type" Style="{StaticResource FieldLabelTextStyle}" />
                                             <ComboBox ItemsSource="{Binding RebarModeOptions}"
                                                       SelectedValue="{Binding RebarMode}"
                                                       SelectedValuePath="Type"
                                                       DisplayMemberPath="DisplayName" />
                                         </StackPanel>
                                     </Grid>

                                     <!-- Row 1: Equal Spacing Inputs (Visible only when RebarMode is EqualSpacing) -->
                                     <Grid Grid.Row="1" Margin="0,0,0,12" Visibility="{Binding IsEqualSpacing, Converter={StaticResource BoolToVisibilityConverter}}">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="Auto" />
                                         </Grid.ColumnDefinitions>
                                         
                                         <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                             <TextBlock Text="Bar size" Style="{StaticResource FieldLabelTextStyle}" />
                                             <ComboBox ItemsSource="{Binding DataContext.AvailableBars, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       DisplayMemberPath="Name" SelectedValuePath="Name"
                                                       SelectedValue="{Binding BarSize}" />
                                         </StackPanel>
                                         
                                         <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                             <StackPanel Orientation="Horizontal">
                                                 <TextBlock Text="Spacing (" Style="{StaticResource FieldLabelTextStyle}" />
                                                 <TextBlock Text="{Binding DataContext.LengthLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource FieldLabelTextStyle}" />
                                                 <TextBlock Text=")" Style="{StaticResource FieldLabelTextStyle}" />
                                             </StackPanel>
                                             <TextBox Text="{Binding Spacing, UpdateSourceTrigger=PropertyChanged}" />
                                         </StackPanel>
                                         
                                         <Button Grid.Column="2" Content="Generate" VerticalAlignment="Bottom" Height="32" Padding="12,0"
                                                 Style="{StaticResource PrimaryButtonStyle}"
                                                 Command="{Binding DataContext.GenerateIrregularRebarsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                     </Grid>

                                     <!-- Row 2: Validation Messages -->
                                     <TextBlock Grid.Row="2" Text="{Binding RebarValidationMessage}" Foreground="Red" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />

                                     <!-- Row 3: Rebar Coordinates Table -->
                                     <Grid Grid.Row="3">
                                         <Grid.RowDefinitions>
                                             <RowDefinition Height="Auto" />
                                             <RowDefinition Height="Auto" />
                                             <RowDefinition Height="*" />
                                         </Grid.RowDefinitions>
                                         
                                         <TextBlock Grid.Row="0" Text="Rebar Coordinates" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4" TextWrapping="Wrap" />
                                         
                                         <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                                             <Button Content="C" ToolTip="Clear" Command="{Binding ClearRebarsCommand}" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" Margin="0,0,8,0" />
                                             <Button Content="I" ToolTip="Import..." Click="ImportRebar_Click" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" Margin="0,0,8,0" />
                                             <Button Content="E" ToolTip="Export..." Click="ExportRebar_Click" Style="{StaticResource SecondaryButtonStyle}" Foreground="{DynamicResource PrimaryNavyBrush}" FontWeight="Bold" Width="26" Height="26" Padding="0" />
                                         </WrapPanel>
                                         
                                         <DataGrid Grid.Row="2" ItemsSource="{Binding Rebars}" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True" MaxHeight="200" Margin="0,0,0,8">
                                             <DataGrid.Columns>
                                                 <DataGridTextColumn Header="Index" Binding="{Binding RebarIndex, UpdateSourceTrigger=PropertyChanged}" />
                                                 <DataGridTextColumn Header="X" Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" />
                                                 <DataGridTextColumn Header="Y" Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" />
                                                 <DataGridTextColumn Header="Area" Binding="{Binding AreaMm2, UpdateSourceTrigger=PropertyChanged}" />
                                                 <DataGridTextColumn Header="Size" Binding="{Binding BarSize, UpdateSourceTrigger=PropertyChanged}" />
                                             </DataGrid.Columns>
                                         </DataGrid>
                                     </Grid>
                                 </Grid>
                             </Grid>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
