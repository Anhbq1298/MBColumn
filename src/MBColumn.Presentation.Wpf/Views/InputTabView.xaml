                                    <controls:SafeFormulaControl Formula="{Binding SlendernessCalculationLoadCase.MyCandM0ePlusM2Latex}" Scale="14" FormulaForeground="{DynamicResource TextDarkBrush}" Margin="0,4,0,0"
                                                                  Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <controls:SafeFormulaControl Formula="{Binding SlendernessCalculationLoadCase.MyCandM01Plus05M2Latex}" Scale="14" FormulaForeground="{DynamicResource TextDarkBrush}" Margin="0,4,0,0"
                                                                  Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <controls:SafeFormulaControl Formula="{Binding SlendernessCalculationLoadCase.MyCandMinimumMomentLatex}" Scale="14" FormulaForeground="{DynamicResource TextDarkBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
    </Grid>
</UserControl>
