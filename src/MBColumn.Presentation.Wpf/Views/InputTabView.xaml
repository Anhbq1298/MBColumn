                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- Right Column: Selected Load Case Editor & Slenderness Amplification -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,14">
                        
                        <!-- 1. Selected Load Case Editor -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedLoadCase.Name, StringFormat=Selected Load Case: {0}, TargetNullValue=Selected Load Case}"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,10" />
                                
