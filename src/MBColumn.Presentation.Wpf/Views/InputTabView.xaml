                                    </Canvas>
                                </Viewbox>
                            </StackPanel>
                        </Border>

                        <!-- Right: DataGrid + buttons -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,10">
