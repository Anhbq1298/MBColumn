<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.InputTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:views="clr-namespace:MBColumn.Presentation.Wpf.Views"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="InputViewResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="InputRoot">
    <TabControl>
        <TabItem Header="Section &amp; Rebar">
            <views:SectionRebarInputView />
        </TabItem>
        <TabItem Header="Loads">
            <views:LoadsInputView />
        </TabItem>
    </TabControl>

    <Border x:Name="SlendernessDetailsOverlay"
            Background="#990B1220"
            ClipToBounds="True"
            DataContext="{x:Null}"
            Visibility="Collapsed">
        <views:SlendernessCalculationDetailsView x:Name="SlendernessDetailsPanel" />
    </Border>
    </Grid>
</UserControl>

