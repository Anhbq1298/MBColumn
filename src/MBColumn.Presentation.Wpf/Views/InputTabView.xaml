                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.ShearVuyHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxTop, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxTopHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MxBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxBottomHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyTop, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyTopHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F1}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyBottomHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="λx"
                                                            Binding="{Binding LambdaX, TargetNullValue='-', StringFormat=F2}"
                                                            Width="60" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Header="λlim,x"
                                                            Binding="{Binding LambdaLimitX, TargetNullValue='-', StringFormat=F2}"
                                                            Width="72" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Header="λy"
                                                            Binding="{Binding LambdaY, TargetNullValue='-', StringFormat=F2}"
                                                            Width="60" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Header="λlim,y"
                                                            Binding="{Binding LambdaLimitY, TargetNullValue='-', StringFormat=F2}"
                                                            Width="72" IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}" />
                                        <DataGridTextColumn Binding="{Binding MxUsed, TargetNullValue=auto, StringFormat=F1}"
                                                            Width="*"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MxUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyUsed, TargetNullValue=auto, StringFormat=F1}"
                                                            Width="*"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.MyUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
                                                            Width="100"
                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource LeftAlignText}">
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                    <Setter Property="Background" Value="#EBEBEB" />
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- Buttons below DataGrid -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="+ Add case"
                                        Command="{Binding AddLoadCaseCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Delete demand case"
                                        Command="{Binding DeleteSelectedLoadCasesCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=LoadCasesGrid}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                                        Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <Button Content="Delete demand case"
                                        Command="{Binding DeleteSelectedLoadCasesCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=SlenderLoadCasesGrid}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0"
                                        Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Content="Import from CSV"
                                        Command="{Binding ImportLoadCasesCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" Margin="0,0,8,0" />
                                <Button Content="Export to CSV"
                                        Command="{Binding ExportLoadCasesCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,4" FontSize="{StaticResource FontSizeBody}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </GroupBox>
                <!-- Right Column: Selected Load Case Editor & Slenderness Amplification -->
                <ScrollViewer Grid.Column="2"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,14">
                        
                        <!-- 1. Selected Load Case Editor -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedLoadCase.Name, StringFormat=Selected Load Case: {0}, TargetNullValue=Selected Load Case}"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,10" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Pu / NEd -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <DockPanel>
                                            <TextBlock Text="NEd" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding ForceLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.NEd, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8"
                                                Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <DockPanel>
                                            <TextBlock Text="Mx" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.Mx, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"
                                                Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <DockPanel>
                                            <TextBlock Text="My" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.My, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <DockPanel>
                                            <TextBlock Text="Vx" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding ForceLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.Vx, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <DockPanel>
                                            <TextBlock Text="Vy" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding ForceLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.Vy, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,10,0,0"
                                      Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                               Text="Member End Moments"
                                               Style="{StaticResource InputSubsectionTitleTextStyle}" />
                                    
                                    <!-- Row 1: Mx End Moments -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4,0,8">
                                        <DockPanel>
                                            <TextBlock Text="Mx Top" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.MxTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,4,0,8">
                                        <DockPanel>
                                            <TextBlock Text="Mx Bottom" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.MxBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </StackPanel>

                                    <!-- Row 2: My End Moments -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,4">
                                        <DockPanel>
                                            <TextBlock Text="My Top" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.MyTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,4">
                                        <DockPanel>
                                            <TextBlock Text="My Bottom" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.MyBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="{Binding SelectedLoadCase.MxUsed, TargetNullValue='Mx Used auto', StringFormat='Mx Used {0:F1}'}"
                                               Style="{StaticResource HelperTextStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="2"
                                               Text="{Binding SelectedLoadCase.MyUsed, TargetNullValue='My Used auto', StringFormat='My Used {0:F1}'}"
                                               Style="{StaticResource HelperTextStyle}"
                                               Margin="0,8,0,0" />

                                    <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                            Background="White"
                                            BorderBrush="{DynamicResource BorderSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="4"
                                            Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Member End Moments Diagram"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,2" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- ===== Mx Diagram (left) - dynamic ===== -->
                                                <controls:MomentDiagramControl
                                                    Grid.Column="0"
                                                    Title="Mx"
                                                    DiagramColor="#c0392b"
                                                    MomentTop="{Binding SelectedLoadCase.MxTop}"
                                                    MomentBottom="{Binding SelectedLoadCase.MxBottom}"
                                                    Height="220" Margin="2,0" />

                                                <!-- Separator -->
                                                <Rectangle Grid.Column="1" Width="1" Fill="#D6DEE6" Margin="0,4" VerticalAlignment="Stretch" />

                                                <!-- ===== My Diagram (right) - dynamic ===== -->
                                                <controls:MomentDiagramControl
                                                    Grid.Column="2"
                                                    Title="My"
                                                    DiagramColor="#2471a3"
                                                    MomentTop="{Binding SelectedLoadCase.MyTop}"
                                                    MomentBottom="{Binding SelectedLoadCase.MyBottom}"
                                                    Height="220" Margin="2,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 2. EC2 Slenderness Settings -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="EC2 Slenderness Settings"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,8" />
                                
                                <CheckBox x:Name="EnableSlendernessCheck"
                                          Content="Include EC2 slenderness amplification"
                                          FontWeight="SemiBold"
                                          IsChecked="{Binding IncludeEc2Slenderness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />

                                <!-- Panel when Slenderness Check is Disabled -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=EnableSlendernessCheck, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <Border CornerRadius="4" Padding="10,8" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE946;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="15"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Status: Disabled - PMM uses original input moments"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Panel when Slenderness Check is Enabled -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=EnableSlendernessCheck, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Method" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBlock Text="EC2 Nominal Curvature" FontWeight="Bold" Foreground="{DynamicResource PrimaryNavyBrush}" HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center" />
                                    </DockPanel>

                                    <!-- Geometry Column Clear Height -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Member length L"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding MemberLengthLabel}"
                                                   Style="{StaticResource UnitTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                 Style="{StaticResource ComputedTextBoxStyle}"
                                                 Text="{Binding MemberLengthDisplay, Mode=OneWay, TargetNullValue=''}" />
                                    </Grid>

                                    <!-- Effective Length Mode & Coefficients -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Mode selection -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Text="Effective length mode"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   Margin="0,0,0,2" />
                                        <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" SelectedIndex="0" Margin="0,0,0,6">
                                            <ComboBoxItem Content="k &#x00D7; L (Manual factor)" />
                                            <ComboBoxItem Content="Calculate automatically from end stiffness" />
                                        </ComboBox>

                                        <!-- Factor inputs -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="kx" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding Kx, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="ky" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding Ky, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </Grid>

                                    <!-- Moment Shape Settings -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="l0x = kx &#x00D7; L" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource ComputedTextBoxStyle}" Text="{Binding L0xText, Mode=OneWay}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="l0y = ky &#x00D7; L" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource ComputedTextBoxStyle}" Text="{Binding L0yText, Mode=OneWay}" />
                                    </Grid>

                                    <!-- Moment Shape Settings -->
                                    <TextBlock Text="Moment shape mode" Style="{StaticResource FieldLabelTextStyle}" Margin="0,4,0,2" />
                                    <ComboBox x:Name="MomentShapeModeCombo" SelectedIndex="0" Margin="0,0,0,8">
                                        <ComboBoxItem Content="Simplified (User specified rm)" />
                                        <ComboBoxItem Content="Calculated from End Moments (Advanced)" />
                                    </ComboBox>

                                    <!-- Sub-items under Simplified shape mode -->
                                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=MomentShapeModeCombo, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=0}">
                                        <CheckBox x:Name="ApplySameRm"
                                                  Content="Apply same rm to both axes"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8" />
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Preset -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                       Text="Moment shape preset" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,2" />
                                            <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" SelectedIndex="0" Margin="0,0,0,6">
                                                <ComboBoxItem Content="Single curvature (rm = +1.0)" />
                                                <ComboBoxItem Content="Double curvature (rm = -1.0)" />
                                                <ComboBoxItem Content="Equal end moments (rm = +1.0)" />
                                                <ComboBoxItem Content="No first order moments / Imperfection only (rm = 1.0)" />
                                            </ComboBox>

                                            <!-- rm input value -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="rm (Mx)" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="3" Grid.Column="0" Text="1.00" />

                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="rm (My)" Style="{StaticResource FieldLabelTextStyle}" 
                                                       Visibility="{Binding IsChecked, ElementName=ApplySameRm, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                            <TextBox Grid.Row="3" Grid.Column="2" Text="1.00" 
                                                     Visibility="{Binding IsChecked, ElementName=ApplySameRm, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Advanced End Moments Panel (Visible when Moment Shape Mode is Calculated from End Moments) -->
                                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=MomentShapeModeCombo, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=1}">
                                        <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Background="{DynamicResource PanelBackgroundBrush}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Advanced End Moment Input" Style="{StaticResource FieldLabelTextStyle}" FontWeight="Bold" Margin="0,0,0,6" />
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Text="Mx End Moments" Style="{StaticResource FieldLabelTextStyle}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Mx Top" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding SelectedLoadCase.MxTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                    
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Mx Bottom" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedLoadCase.MxBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                    
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Text="My End Moments" Style="{StaticResource FieldLabelTextStyle}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" Margin="0,6,0,0"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="My Top" Style="{StaticResource FieldLabelTextStyle}"/>
