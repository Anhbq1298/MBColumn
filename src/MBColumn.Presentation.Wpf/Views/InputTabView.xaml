                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeColumns="True"
                                          HeadersVisibility="Column"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Include"
                                                                Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="70" />
                                        <DataGridTextColumn Header="Case Name"
                                                            Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                            Width="110"
                                                            ElementStyle="{StaticResource LeftAlignText}" />
                                        <DataGridTextColumn Binding="{Binding NEd, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.DemandForceHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vx, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.ShearVuxHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Vy, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.ShearVuyHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
