                                                            IsReadOnly="True"
                                                            ElementStyle="{StaticResource RightAlignText}">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.MyUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status"
                                                            Binding="{Binding Status}"
