                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.NEd, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8"
                                                Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <DockPanel>
                                            <TextBlock Text="Mx" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.Mx, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"
                                                Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <DockPanel>
                                            <TextBlock Text="My" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.My, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <DockPanel>
                                            <TextBlock Text="Vx" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding ForceLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.Vx, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <DockPanel>
                                            <TextBlock Text="Vy" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="{Binding ForceLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <TextBox Text="{Binding SelectedLoadCase.Vy, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,10,0,0"
                                      Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                               Text="Member End Moments"
                                               Style="{StaticResource InputSubsectionTitleTextStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding SelectedLoadCase.MxTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             ToolTip="Mx Top" />
                                    <TextBox Grid.Row="1" Grid.Column="2"
                                             Text="{Binding SelectedLoadCase.MxBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             ToolTip="Mx Bottom" />
                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding SelectedLoadCase.MyTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             ToolTip="My Top"
                                             Margin="0,8,0,0" />
                                    <TextBox Grid.Row="2" Grid.Column="2"
                                             Text="{Binding SelectedLoadCase.MyBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             ToolTip="My Bottom"
                                             Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="{Binding SelectedLoadCase.MxUsed, TargetNullValue='Mx Used auto', StringFormat='Mx Used {0:F2}'}"
                                               Style="{StaticResource HelperTextStyle}"
                                               Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="2"
                                               Text="{Binding SelectedLoadCase.MyUsed, TargetNullValue='My Used auto', StringFormat='My Used {0:F2}'}"
                                               Style="{StaticResource HelperTextStyle}"
                                               Margin="0,8,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 2. EC2 Slenderness Settings -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12"
                                Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="EC2 Slenderness Settings"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,8" />
                                
                                <CheckBox x:Name="EnableSlendernessCheck"
                                          Content="Include EC2 slenderness amplification"
                                          FontWeight="SemiBold"
                                          IsChecked="{Binding IncludeEc2Slenderness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,0,10" />

                                <!-- Panel when Slenderness Check is Disabled -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=EnableSlendernessCheck, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <Border CornerRadius="4" Padding="10,8" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE946;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="15"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Status: Disabled — PMM uses original input moments"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Panel when Slenderness Check is Enabled -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=EnableSlendernessCheck, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Method" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBlock Text="EC2 Nominal Curvature" FontWeight="Bold" Foreground="{DynamicResource PrimaryNavyBrush}" HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center" />
                                    </DockPanel>

                                    <!-- Geometry Column Clear Height -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Member length L"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding LengthLabel}"
                                                   Style="{StaticResource UnitTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                 IsReadOnly="True"
                                                 Text="{Binding MemberLengthL, TargetNullValue=''}" />
                                    </Grid>

                                    <!-- Effective Length Mode & Coefficients -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Mode selection -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Text="Effective length mode"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   Margin="0,0,0,2" />
                                        <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" SelectedIndex="0" Margin="0,0,0,6">
                                            <ComboBoxItem Content="k × l (Manual factor)" />
                                            <ComboBoxItem Content="Calculate automatically from end stiffness" />
                                        </ComboBox>

                                        <!-- Factor inputs -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="kx" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding Kx, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="ky" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding Ky, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                    </Grid>

                                    <!-- Moment Shape Settings -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="l0x = kx × L" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" IsReadOnly="True" Text="{Binding L0xText}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="l0y = ky × L" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="2" IsReadOnly="True" Text="{Binding L0yText}" />
                                    </Grid>

                                    <!-- Moment Shape Settings -->
                                    <TextBlock Text="Moment shape mode" Style="{StaticResource FieldLabelTextStyle}" Margin="0,4,0,2" />
                                    <ComboBox x:Name="MomentShapeModeCombo" SelectedIndex="0" Margin="0,0,0,8">
                                        <ComboBoxItem Content="Simplified (User specified rm)" />
                                        <ComboBoxItem Content="Calculated from End Moments (Advanced)" />
                                    </ComboBox>

                                    <!-- Sub-items under Simplified shape mode -->
                                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=MomentShapeModeCombo, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=0}">
                                        <CheckBox x:Name="ApplySameRm"
                                                  Content="Apply same rm to both axes"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8" />
                                        
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Preset -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                       Text="Moment shape preset" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,2" />
                                            <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" SelectedIndex="0" Margin="0,0,0,6">
                                                <ComboBoxItem Content="Single curvature (rm = +1.0)" />
                                                <ComboBoxItem Content="Double curvature (rm = -1.0)" />
                                                <ComboBoxItem Content="Equal end moments (rm = +1.0)" />
                                                <ComboBoxItem Content="No first order moments / Imperfection only (rm = 1.0)" />
                                            </ComboBox>

                                            <!-- rm input value -->
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="rm (Mx)" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="3" Grid.Column="0" Text="1.00" />

                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="rm (My)" Style="{StaticResource FieldLabelTextStyle}" 
                                                       Visibility="{Binding IsChecked, ElementName=ApplySameRm, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                            <TextBox Grid.Row="3" Grid.Column="2" Text="1.00" 
                                                     Visibility="{Binding IsChecked, ElementName=ApplySameRm, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Advanced End Moments Panel (Visible when Moment Shape Mode is Calculated from End Moments) -->
                                    <StackPanel Visibility="{Binding SelectedIndex, ElementName=MomentShapeModeCombo, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=1}">
                                        <Border BorderBrush="{DynamicResource BorderSoftBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Background="{DynamicResource PanelBackgroundBrush}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Advanced End Moment Input" Style="{StaticResource FieldLabelTextStyle}" FontWeight="Bold" Margin="0,0,0,6" />
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Text="Mx End Moments" Style="{StaticResource FieldLabelTextStyle}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Mx Top" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding SelectedLoadCase.MxTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                    
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Mx Bottom" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedLoadCase.MxBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                    
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Text="My End Moments" Style="{StaticResource FieldLabelTextStyle}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" Margin="0,6,0,0"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="My Top" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Grid.Row="5" Grid.Column="0" Text="{Binding SelectedLoadCase.MyTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                    
                                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="My Bottom" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding SelectedLoadCase.MyBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- EC2 Creep and Reinforcement Factors -->
                                    <Grid Margin="0,4,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Effective creep ratio φeff" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding PhiEff, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Reinforcement factor B" Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="2" IsEnabled="False" Text="Auto (from As)" />
                                    </Grid>

                                    <CheckBox Content="Use default A = 0.7 if φeff is unknown"
                                              IsChecked="{Binding UseDefaultAWhenPhiEffUnknown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,0,0,10" />

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Expander Header="Values Used from Current Section &amp; Rebar"
                                  IsExpanded="False"
                                  Margin="0,0,0,12"
                                  Visibility="{Binding IncludeEc2Slenderness, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource CardBorderStyle}" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding PreviewAreaText, StringFormat='Ac: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewAsTotalText, StringFormat='As,total: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding PreviewIxxText, StringFormat='Ixx: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewIyyText, StringFormat='Iyy: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding PreviewIxText, StringFormat='ix: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewIyText, StringFormat='iy: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding PreviewFcdText, StringFormat='fcd: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PreviewFydText, StringFormat='fyd: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Es, StringFormat='Es: {0:F0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewEcmText, StringFormat='Ecm: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding PreviewDxText, StringFormat='d_x for Mx curvature: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PreviewDyText, StringFormat='d_y for My curvature: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding PreviewOmegaText, StringFormat='ω: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PreviewNRatioText, StringFormat='n: {0}'}" Style="{StaticResource HelperTextStyle}" />
                                </Grid>
                            </Border>
                        </Expander>

                        <!-- 3. Amplified Moment Preview -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12"
                                Visibility="{Binding IsChecked, ElementName=EnableSlendernessCheck, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="EC2 Slenderness Preview"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,8" />
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.4*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="26" />
                                        <RowDefinition Height="26" />
                                        <RowDefinition Height="26" />
                                    </Grid.RowDefinitions>

                                    <!-- Table Header -->
                                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="Axis" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="l0 (mm)" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="λ" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="3" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="λlim" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="4" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="rm" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="5" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1">
                                        <TextBlock Text="M2 (kNm)" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="6" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,1,1">
                                        <TextBlock Text="Moment Used" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>

                                    <!-- Row 1: Mx -->
                                    <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="Mx" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding L0xText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="2" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" Foreground="#C62828" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="3" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="4" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="5" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="6" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.MxUsed, TargetNullValue=auto, StringFormat=F2}" FontWeight="Bold" Foreground="{DynamicResource DarkNavyBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>

                                    <!-- Row 2: My -->
                                    <Border Grid.Row="2" Grid.Column="0" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="My" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding L0yText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" Foreground="#2E7D32" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="3" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="4" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="5" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="calc" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="6" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.MyUsed, TargetNullValue=auto, StringFormat=F2}" FontWeight="Bold" Foreground="{DynamicResource DarkNavyBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11.5"/>
                                    </Border>
                                </Grid>
                                
                                <TextBlock Text="PMM demand source:" FontWeight="Bold" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                <TextBlock Text="Mx Used and My Used are passed to PMM when slenderness is enabled." FontSize="11.5" Foreground="{DynamicResource PrimaryNavyBrush}" Margin="4,0,0,2"/>
                                <TextBlock Text="Vx and Vy are not modified by slenderness amplification." FontSize="11.5" Foreground="{DynamicResource PrimaryNavyBrush}" Margin="4,0,0,8"/>
                                
                                <Separator Margin="0,4,0,8" />
                                
                                <Button Content="Recalculate Slenderness"
                                        Style="{StaticResource CompactButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        Height="32" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Warnings"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding SlendernessWarningText}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
