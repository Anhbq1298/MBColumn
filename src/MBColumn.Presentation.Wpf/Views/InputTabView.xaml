                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Equivalent first-order moment - M" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="0e" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" />
