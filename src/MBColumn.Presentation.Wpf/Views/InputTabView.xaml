<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.InputTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
    <UserControl.Resources>
        <Style x:Key="SideBarCountTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,0,8,6" />
            <Setter Property="Padding"
                    Value="7,5" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasBarCountWarning}"
                             Value="True">
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource AccentRedBrush}" />
                    <Setter Property="BorderThickness"
                            Value="2" />
                    <Setter Property="ToolTip"
                            Value="{Binding BarCountWarning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideReadOnlyTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,0,8,6" />
            <Setter Property="Padding"
                    Value="7,5" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="IsEnabled"
                    Value="False" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Background"
                    Value="{DynamicResource PanelBackgroundBrush}" />
        </Style>
        <Style x:Key="ColumnHeaderTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="HorizontalAlignment"
                    Value="Center" />
            <Setter Property="Margin"
                    Value="0,0,0,12" />
        </Style>
        <Style x:Key="PreviewPropertyLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin"
                    Value="0,0,0,4" />
        </Style>
        <Style x:Key="PreviewPropertyValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MutedValueTextStyle}">
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Margin"
                    Value="0,0,0,4" />
            <Setter Property="TextWrapping"
                    Value="Wrap" />
        </Style>
        <Style x:Key="InputSubsectionTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource GroupTitleTextStyle}">
            <Setter Property="FontSize"
                    Value="{DynamicResource FontSizeHelper}" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>
        <Style x:Key="MathEquationTextStyle"
               TargetType="TextBlock">
            <Setter Property="FontFamily"
                    Value="Cambria Math, Cambria, Segoe UI" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextWrapping"
                    Value="Wrap" />
        </Style>
        <Style x:Key="ParameterMeaningTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextWrapping"
                    Value="Wrap" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>
        <Style x:Key="SectionShapeRadioStyle"
               TargetType="RadioButton">
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="FontSize"
                    Value="12.5" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Padding"
                    Value="14,6" />
            <Setter Property="Margin"
                    Value="12,0,0,0" />
            <Setter Property="MinWidth"
                    Value="110" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ShapeBorder"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="ShapeBorder"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter TargetName="ShapeBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ShapeBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver"
                                               Value="True" />
                                    <Condition Property="IsChecked"
                                               Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ShapeBorder"
                                        Property="Background"
                                        Value="{DynamicResource BorderSoftBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComputedTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="#EBEBEB" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid x:Name="InputRoot">
    <TabControl>
        <TabItem Header="Section &amp; Rebar">
            <Grid Margin="4,6,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18*" MinWidth="200" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="32*" MinWidth="250" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="50*" MinWidth="400" />
                </Grid.ColumnDefinitions>

                <!-- Column 0: General & Material -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <GroupBox Header="General"
                                  Background="White"
                                  Foreground="{DynamicResource DarkNavyBrush}"
                                  BorderBrush="{DynamicResource BorderGreyBrush}"
                                  Padding="14"
                                  Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Unit System"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <ComboBox ItemsSource="{Binding UnitSystems}"
                                          SelectedItem="{Binding UnitSystem}" />
                                <TextBlock Text="Design Code"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Margin="0,10,0,0" />
                                <ComboBox ItemsSource="{Binding DesignCodes}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          SelectedValue="{Binding SelectedDesignCode}" />
                                <TextBlock Text="Section Integration Method"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Margin="0,10,0,0" />
                                <ComboBox ItemsSource="{Binding SectionIntegrationMethodOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Method"
                                          SelectedValue="{Binding SelectedIntegrationMethod}">
                                    <ComboBox.ToolTip>
                                        <TextBlock TextWrapping="Wrap"
                                                   MaxWidth="360"
                                                   Text="Fiber Integration: General numerical integration method recommended for circular sections and future arbitrary sections. Polygon Integration: Faster compression-zone clipping method useful for stress-block comparison." />
                                    </ComboBox.ToolTip>
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Member Geometry"
                                  Background="White"
                                  Foreground="{DynamicResource DarkNavyBrush}"
                                  BorderBrush="{DynamicResource BorderGreyBrush}"
                                  Padding="14"
                                  Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Column clear height / member length, L"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding MemberLengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding MemberLengthDisplay, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" />
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="Material"
                                  Background="White"
                                  Foreground="{DynamicResource DarkNavyBrush}"
                                  BorderBrush="{DynamicResource BorderGreyBrush}"
                                  Padding="14"
                                  Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Text="Library"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <ComboBox Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding MaterialLibraries}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Library"
                                          SelectedValue="{Binding SelectedMaterialLibrary}" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Text="Concrete Grade"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           IsEnabled="{Binding AreMaterialGradesEnabled}"
                                           Margin="0,8,0,0" />
                                <ComboBox Grid.Row="3"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding AvailableConcreteGrades}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding AreMaterialGradesEnabled}"
                                          SelectedItem="{Binding SelectedConcreteGrade}" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Text="Rebar Grade"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           IsEnabled="{Binding AreMaterialGradesEnabled}"
                                           Margin="0,8,0,0" />
                                <ComboBox Grid.Row="5"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding AvailableSteelGrades}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding AreMaterialGradesEnabled}"
                                          SelectedItem="{Binding SelectedSteelGrade}" />
                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                            Margin="0,8,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="True">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="f"/>
                                     <Run Text="ck" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBlock Grid.Row="6"
                                            Grid.Column="0"
                                            Margin="0,8,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="False">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="f'"/>
                                     <Run Text="c" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBlock Grid.Row="6"
                                            Grid.Column="1"
                                            Text="{Binding StressLabel}"
                                            Style="{StaticResource UnitTextStyle}"
                                            Margin="0,8,0,0" />
                                <TextBox Grid.Row="7"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         IsEnabled="{Binding AreMaterialInputsEnabled}"
                                         Text="{Binding Fc, UpdateSourceTrigger=PropertyChanged}" />
                                 <TextBlock Grid.Row="8"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}">
                                     <Run Text="gamma c (&#x03B3;"/>
                                     <Run Text="c" FontSize="9" BaselineAlignment="Subscript"/>
                                     <Run Text=")"/>
                                 </TextBlock>
                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Text=""
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="9"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding GammaC, UpdateSourceTrigger=PropertyChanged}" />
                                 <TextBlock Grid.Row="10"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}">
                                     <Run Text="alpha cc (&#x03B1;"/>
                                     <Run Text="cc" FontSize="9" BaselineAlignment="Subscript"/>
                                     <Run Text=")"/>
                                 </TextBlock>
                                <TextBox Grid.Row="11"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding AlphaCc, UpdateSourceTrigger=PropertyChanged}" />
                                 <TextBlock Grid.Row="12"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}">
                                     <Run Text="f"/>
                                     <Run Text="cd" FontSize="9" BaselineAlignment="Subscript"/>
                                     <Run Text=" = &#x03B1;"/>
                                     <Run Text="cc" FontSize="9" BaselineAlignment="Subscript"/>
                                     <Run Text=" f"/>
                                     <Run Text="ck" FontSize="9" BaselineAlignment="Subscript"/>
                                     <Run Text=" / &#x03B3;"/>
                                     <Run Text="c" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                <TextBlock Grid.Row="12"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="13"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource ComputedTextBoxStyle}"
                                         Text="{Binding FcdDisplayText, Mode=OneWay}" />

                                 <TextBlock Grid.Row="15"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}">
                                     <Run Text="E"/>
                                     <Run Text="cm" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                <TextBlock Grid.Row="15"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="16"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Style="{StaticResource ComputedTextBoxStyle}"
                                         Text="{Binding EcmDisplayText, Mode=OneWay}" />
                                <DockPanel Grid.Row="17"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding ShowEurocodeConcreteStrainProfileOption, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Strain model"
                                               Style="{StaticResource FieldLabelTextStyle}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <ComboBox ItemsSource="{Binding EurocodeConcreteStrainProfiles}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Profile"
                                              SelectedValue="{Binding SelectedEurocodeConcreteStrainProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              MinWidth="142"
                                              HorizontalAlignment="Right" />
                                </DockPanel>
                                 <TextBlock Grid.Row="18"
                                            Grid.Column="0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="True">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="f"/>
                                     <Run Text="yk" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBlock Grid.Row="18"
                                            Grid.Column="0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="False">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="f"/>
                                     <Run Text="y" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                <TextBlock Grid.Row="18"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="19"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         IsEnabled="{Binding AreMaterialInputsEnabled}"
                                         Text="{Binding Fy, UpdateSourceTrigger=PropertyChanged}" />
                                 <TextBlock Grid.Row="20"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}">
                                     <Run Text="E"/>
                                     <Run Text="s" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                <TextBlock Grid.Row="20"
                                           Grid.Column="1"
                                           Text="{Binding StressLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="21"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         IsEnabled="{Binding AreMaterialInputsEnabled}"
                                         Text="{Binding Es, UpdateSourceTrigger=PropertyChanged}" />
                            
                                 <!-- Concrete Ultimate Strain -->
                                 <TextBlock Grid.Row="22"
                                            Grid.Column="0"
                                            Margin="0,8,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="True">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="&#x03B5;" />
                                     <Run Text="{Binding ConcreteUltimateStrainSubscript, Mode=OneWay}" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBlock Grid.Row="22"
                                            Grid.Column="0"
                                            Margin="0,8,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="False">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="&#x03B5;" />
                                     <Run Text="cu" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBox Grid.Row="23"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Style="{StaticResource ComputedTextBoxStyle}"
                                          Text="{Binding EpsilonCu2, Mode=OneWay, StringFormat=F5}" />

                                 <!-- Concrete Peak Strain -->
                                 <TextBlock Grid.Row="24"
                                            Grid.Column="0"
                                            Margin="0,8,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="True">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="&#x03B5;" />
                                     <Run Text="{Binding ConcretePeakStrainSubscript, Mode=OneWay}" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBlock Grid.Row="24"
                                            Grid.Column="0"
                                            Margin="0,8,0,0">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
                                             <Setter Property="Visibility" Value="Collapsed"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsEc2}" Value="False">
                                                     <Setter Property="Visibility" Value="Visible"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                     <Run Text="&#x03B5;" />
                                     <Run Text="c0" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBox Grid.Row="25"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Style="{StaticResource ComputedTextBoxStyle}"
                                          Text="{Binding EpsilonC2, Mode=OneWay, StringFormat=F5}" />

                                 <!-- Steel Yield Strain -->
                                 <TextBlock Grid.Row="26"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}"
                                            Margin="0,8,0,0">
                                     <Run Text="&#x03B5;" />
                                     <Run Text="yd" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBox Grid.Row="27"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Style="{StaticResource ComputedTextBoxStyle}"
                                          Text="{Binding EpsilonYd, Mode=OneWay, StringFormat=F5}" />

                                 <!-- Steel Ultimate Strain -->
                                 <TextBlock Grid.Row="28"
                                            Grid.Column="0"
                                            Style="{StaticResource FieldLabelTextStyle}"
                                            Margin="0,8,0,0">
                                     <Run Text="&#x03B5;" />
                                     <Run Text="ud" FontSize="9" BaselineAlignment="Subscript"/>
                                 </TextBlock>
                                 <TextBox Grid.Row="29"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Style="{StaticResource ComputedTextBoxStyle}"
                                          Text="{Binding EpsilonUd, Mode=OneWay, StringFormat=F5}" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>


                <!-- Column 2: Section Preview -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Preview card -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Section Preview"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="SECTION PREVIEW"
                                           Style="{StaticResource OverlineTextStyle}"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="2D VIEW &#x00B7; GRID"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Margin="0,0,0,4" />
                                <controls:SectionPreviewCanvas Height="240"
                                                               MinHeight="160"
                                                               HorizontalAlignment="Stretch"
                                                               SectionWidth="{Binding SectionWidth}"
                                                               SectionHeight="{Binding SectionHeight}"
                                                               Cover="{Binding Cover}"
                                                               UnitSystem="{Binding SelectedUnitSystem}"
                                                               SectionShape="{Binding SelectedSectionShape}"
                                                               Rebars="{Binding PreviewRebars}"
                                                               SectionLabel="{Binding SectionPreviewLabel}"
                                                               RebarLabel="{Binding RebarPreviewLabel}"
                                                               CoverLabel="{Binding CoverPreviewLabel}"
                                                               IsValid="{Binding IsSectionPreviewValid}"
                                                               ErrorMessage="{Binding SectionPreviewErrorMessage}"
                                                               BoundaryPoints="{Binding PreviewBoundaryPoints}"
                                                               StirrupDiameterMm="{Binding StirrupDiameterMm}"
                                                               InnerLegsX="{Binding InnerLegsX}"
                                                               InnerLegsY="{Binding InnerLegsY}" />
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,10">
                                    <Button Click="OpenCadEditor_Click"
                                            Style="{StaticResource CompactButtonStyle}"
                                            MinWidth="78"
                                            MinHeight="32"
                                            Padding="10,5"
                                            Margin="0,0,8,0"
                                            ToolTip="Open CAD Lite editor"
                                            Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE70F;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{StaticResource FontSizeSection}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Edit"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ImportDxfCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="96"
                                            MinHeight="32"
                                            Padding="10,5"
                                            Margin="0,0,8,0"
                                            ToolTip="Import .DXF">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 6,3 L 15,3 L 20,8 L 20,21 L 6,21 Z M 15,3 L 15,8 L 20,8"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                    <Path Data="M 12,9 L 12,16 M 8.8,13 L 12,16.2 L 15.2,13"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Import .dxf" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ExportDxfCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="96"
                                            MinHeight="32"
                                            Padding="10,5"
                                            ToolTip="Export current section as .DXF">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,6,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 6,3 L 15,3 L 20,8 L 20,21 L 6,21 Z M 15,3 L 15,8 L 20,8"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                    <Path Data="M 12,14 L 12,7 M 8.8,10 L 12,6.8 L 15.2,10"
                                                          Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Export .dxf" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Section properties (compact) -->
                                <Separator Background="{DynamicResource BorderGreyBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="SECTION PROPERTIES"
                                           Style="{StaticResource OverlineTextStyle}"
                                           Margin="0,0,0,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Section" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewShapeSummaryText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Layout" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewRebarLayoutText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Cover" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CoverPreviewLabel}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="A" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewAreaText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Ixx" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PreviewIxxText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Iyy" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PreviewIyyText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource PreviewPropertyLabelTextStyle}">
                                        <Run Text="r"/>
                                        <Run Text="x" FontSize="9" BaselineAlignment="Subscript"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PreviewIxText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource PreviewPropertyLabelTextStyle}">
                                        <Run Text="r"/>
                                        <Run Text="y" FontSize="9" BaselineAlignment="Subscript"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding PreviewIyText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="9" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Rebars" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding RebarPreviewLabel}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="rho (&#x03C1;)" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding PreviewRebarPercentageText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <Separator Grid.Row="12" Grid.ColumnSpan="2" Background="{DynamicResource BorderGreyBrush}" Margin="0,2,0,6"/>
                                    <TextBlock Grid.Row="13" Grid.Column="0" Text="Concrete" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding PreviewConcreteQuantityText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                    <TextBlock Grid.Row="14" Grid.Column="0" Text="Steel" Style="{StaticResource PreviewPropertyLabelTextStyle}"/>
                                    <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding PreviewSteelQuantityText}" Style="{StaticResource PreviewPropertyValueTextStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>


                <!-- Column 4: Section Geometry & Rebar Configuration -->
                <ScrollViewer Grid.Column="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Validation banners - only visible when there is something to show -->
                        <StackPanel Margin="0,0,0,8"
                                    Visibility="{Binding DataContext.IsCalculationOutdated, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Changes made, recalculation required."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DataContext.ValidationMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40*" />
                            <ColumnDefinition Width="60*" />
                        </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0"
                              Header="Section Geometry"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="0,0,7,14">
                        <StackPanel>
                            <!-- Section Shape -->
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Section Shape"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <ComboBox SelectedValue="{Binding SelectedSectionShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          VerticalAlignment="Center"
                                          Height="30">
                                    <ComboBoxItem Content="Rectangular"
                                                  Tag="{x:Static enums:SectionShapeType.Rectangular}" />
                                    <ComboBoxItem Content="Circular"
                                                  Tag="{x:Static enums:SectionShapeType.Circular}" />
                                    <ComboBoxItem Content="Irregular"
                                                  Tag="{x:Static enums:SectionShapeType.Irregular}" />
                                </ComboBox>
                            </DockPanel>

                            <!-- Clear cover -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="44" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Clear cover"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Cover}" />
                            </Grid>

                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Width b"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Width}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="3"
                                           Text="Height h"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="4"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Height}" />
                            </Grid>
                            <Grid Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Diameter D"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Diameter}" />
                            </Grid>

                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="Boundary Points (Clockwise)"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />
                            <!-- Editing UI only for Irregular Section -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <WrapPanel Margin="0,0,0,8">
                                    <Button ToolTip="Import..."
                                            Click="ImportBoundary_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0"
                                            Margin="0,0,8,0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,2 L 10,13 M 6,9 L 10,13 L 14,9"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                    <Button ToolTip="Export..."
                                            Click="ExportBoundary_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,14 L 10,3 M 6,7 L 10,3 L 14,7"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="{Binding IrregularInput.BoundaryValidationMessage}"
                                           Visibility="{Binding IrregularInput.HasBoundaryValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap" />
                                <DataGrid ItemsSource="{Binding IrregularInput.BoundaryPoints}"
                                          AutoGenerateColumns="False"
                                          MaxHeight="200">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Point"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.AddBoundaryRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove Selected Point(s)"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.DeleteBoundaryRowsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Pt"
                                                            Binding="{Binding PtIndex, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="50" />
                                        <DataGridTextColumn Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="90">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="X"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="90">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="Y"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            <!-- Preview for Rectangular/Circular - locked, greyed out -->
                            <DataGrid ItemsSource="{Binding PreviewBoundaryPoints}"
                                      Visibility="{Binding IsIrregularSection, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      IsEnabled="False"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pt" Binding="{Binding Index}" Width="Auto" MinWidth="50" />
                                    <DataGridTextColumn Binding="{Binding X, StringFormat=F2}" Width="Auto" MinWidth="90">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="X"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Y, StringFormat=F2}" Width="*" MinWidth="90">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="Y"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Column="1"
                              Header="Rebar Configuration"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="7,0,0,14">
                        <StackPanel>
                            <!-- Auto Design Rebar button — rectangular section only -->
                            <Button Command="{Binding AutoDesignRebarCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Padding="14,6"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                    ToolTip="Open Automated Rebar Design dialog to generate and evaluate candidate rebar configurations.">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Auto Design Rebar..."
                                               Margin="7,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="1 - Longitudinal Reinforcement"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,8,0">
                                    <TextBlock Text="Rebar set library"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding RebarSetLibraries}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Library"
                                              SelectedValue="{Binding SelectedRebarSetLibrary}" />
                                </StackPanel>
                            </Grid>
                            <!-- 1. Algorithmic / Shape-Specific Top Panel (Visible for Rectangular/Circular) -->
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Row 0: Layout Type ComboBox and standard inputs -->
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,8,0">
                                        <TextBlock Text="Layout Type"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding RebarLayoutTypes}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="LayoutType"
                                                  SelectedValue="{Binding SelectedRebarLayoutType}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding ShowTotalBarsInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Bar size"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableBars}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding BarSize}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="2"
                                                Visibility="{Binding ShowTotalBarsInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Total number of bars"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding BarCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Visibility="{Binding IsRectangularEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding LengthLabel, StringFormat=Bar spacing ({0})}"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding RectSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <!-- Row 1: Equal Spacing Layout Panel -->
                                    <Grid Grid.Row="1"
                                          Grid.ColumnSpan="3"
                                          Margin="0,8,0,0"
                                          Visibility="{Binding IsEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Bar size"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding AvailableBars}"
                                                      DisplayMemberPath="DisplayLabel"
                                                      SelectedValuePath="Name"
                                                      SelectedValue="{Binding BarSize}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Margin="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Spacing ("
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding LengthLabel}"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text=")"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding Spacing}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                <TextBlock Text="{Binding RebarLayoutWarning}"
                                           Visibility="{Binding HasRebarLayoutWarning, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Visibility="{Binding IsSidesDifferentLayout, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Margin="0,0,0,10">
                                    <Grid MinWidth="620">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="Top"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Bottom"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="3"
                                                   Text="Left"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="4"
                                                   Text="Right"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="No. of bars"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Bar size"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Clear cover"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                    </Grid>
                                </ScrollViewer>
                            </StackPanel>
                            <!-- 2. Irregular Section Validation Messages -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock DataContext="{Binding IrregularInput}"
                                           Text="{Binding RebarValidationMessage}"
                                           Visibility="{Binding HasRebarValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="Rebar Coordinates"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />
                            <!-- Editing UI only for Irregular Section with custom rebar coordinates -->
                            <StackPanel Visibility="{Binding IsRebarCoordinatesEditable, Converter={StaticResource BoolToVisibilityConverter}}">
                                <WrapPanel Margin="0,0,0,8">
                                    <Button ToolTip="Import..."
                                            Click="ImportRebar_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0"
                                            Margin="0,0,8,0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,2 L 10,13 M 6,9 L 10,13 L 14,9"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                    <Button ToolTip="Export..."
                                            Click="ExportRebar_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Foreground="{DynamicResource PrimaryNavyBrush}"
                                            Width="26"
                                            Height="26"
                                            Padding="0">
                                        <Viewbox Width="14"
                                                 Height="14">
                                            <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,14 L 10,3 M 6,7 L 10,3 L 14,7"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                    </Button>
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding IrregularInput.Rebars}"
                                          AutoGenerateColumns="False"
                                          MaxHeight="200">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Add Rebar"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.AddRebarRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove Selected Rebar(s)"
                                                      Command="{Binding Path=PlacementTarget.DataContext.IrregularInput.DeleteRebarRowsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Index"
                                                            Binding="{Binding RebarIndex, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="55" />
                                        <DataGridTextColumn Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="75">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="X"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="75">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="Y"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding AreaMm2, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="85">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="Bar Area"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.AreaLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding BarSize, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="90">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center">Bar<LineBreak/>Marking</TextBlock>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                            <!-- Preview UI for auto-generated rebars -->
                            <DataGrid ItemsSource="{Binding PreviewRebars}"
                                      Visibility="{Binding IsRebarCoordinatesEditable, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="Auto" MinWidth="55" />
                                    <DataGridTextColumn Binding="{Binding X, StringFormat=F2}" Width="Auto" MinWidth="75">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="X"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Y, StringFormat=F2}" Width="Auto" MinWidth="75">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="Y"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.LengthLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Area, StringFormat=F1}" Width="Auto" MinWidth="85">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock TextAlignment="Center" HorizontalAlignment="Center"><Run Text="Bar Area"/><LineBreak/><Run Text="("/><Run Text="{Binding DataContext.AreaLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"/><Run Text=")"/></TextBlock>
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Label}" Width="*" MinWidth="90">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock TextAlignment="Center" HorizontalAlignment="Center">Bar<LineBreak/>Marking</TextBlock>
                                            </DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Section 2: Stirrups and Shear Links -->
                            <Separator Margin="0,12,0,10" />
                            <TextBlock Text="2 - Stirrups and Shear Links"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}" />

                            <!-- Stirrup diameter and link spacing side by side - rectangular only -->
                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- Stirrup diameter -->
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Stirrup &#x00D8;"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding RebarDiameterUnitLabel}"
                                               Style="{StaticResource UnitTextStyle}" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              ItemsSource="{Binding AvailableStirrupBars}"
                                              DisplayMemberPath="DisplayLabel"
                                              SelectedItem="{Binding SelectedStirrupBar}" />
                                </Grid>
                                <!-- Link spacing s -->
                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Link spacing s"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding LinkSpacingUnitLabel}"
                                               Style="{StaticResource UnitTextStyle}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             Grid.ColumnSpan="2"
                                             Text="{Binding LinkSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>

                            <!-- Circular shear reinforcement -->
                            <TextBlock Text="Circular Shear Reinforcement"
                                       Style="{StaticResource InputSubsectionTitleTextStyle}"
                                       Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="0,0,0,6" />
                            <Grid Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hoop diameter"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RebarDiameterUnitLabel}"
                                               Style="{StaticResource UnitTextStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                              ItemsSource="{Binding AvailableStirrupBars}"
                                              DisplayMemberPath="DisplayLabel"
                                              SelectedItem="{Binding SelectedStirrupBar}" />
                                </Grid>
                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hoop spacing"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LinkSpacingUnitLabel}"
                                               Style="{StaticResource UnitTextStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                             Text="{Binding LinkSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>

                            <StackPanel Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,8">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Hoop type"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox Grid.Row="1"
                                                  ItemsSource="{Binding CircularHoopTypes}"
                                                  SelectedItem="{Binding SelectedCircularHoopType}" />
                                    </Grid>
                                    <Grid Grid.Column="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="D' to hoop centreline"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LinkSpacingUnitLabel}"
                                                   Style="{StaticResource UnitTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                 Text="{Binding CircularHoopCentrelineDiameterText, Mode=OneWay}"
                                                 IsReadOnly="True" />
                                    </Grid>
                                </Grid>
                            </StackPanel>

                            <!-- Inner legs X / Y - rectangular only -->
                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Inner legs X (? h)"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="Inner legs Y (? b)"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Text="{Binding InnerLegsX, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         Text="{Binding InnerLegsY, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,2,0,0">
                                    <TextBlock Text="Total: "
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding TotalLegsX}"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text=" legs"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            Margin="0,2,0,0">
                                    <TextBlock Text="Total: "
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding TotalLegsY}"
                                               FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text=" legs"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                            </Grid>

                            <!-- EC2 9.5.3 checks - circular only -->
                            <StackPanel Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,2,0,0">
                                <TextBlock Text="EC2 &#x00A7;9.5.3 Link Checks"
                                           Style="{StaticResource InputSubsectionTitleTextStyle}"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check1Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check1Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check1Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check2Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check2Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check2Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding Ec2AswsXText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="12,2,0,2" />
                            </StackPanel>

                            <!-- EC2 9.5.3 checks - rectangular only -->
                            <StackPanel Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,2,0,0">
                                <TextBlock Text="EC2 &#x00A7;9.5.3 Link Checks"
                                           Style="{StaticResource InputSubsectionTitleTextStyle}"
                                           Margin="0,0,0,4" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check1Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check1Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check1Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check2Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check2Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check2Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,2">
                                    <Border Width="7" Height="7" CornerRadius="3.5" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check3Pass}" Value="False">
                                                        <Setter Property="Background" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding Ec2Check3Text}" FontSize="10" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Ec2Check3Pass}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding Ec2AswsXText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"
