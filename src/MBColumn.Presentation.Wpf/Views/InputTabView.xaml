                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="{Binding DataContext.MxUsedHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyUsed, TargetNullValue=auto, StringFormat=F2}"
