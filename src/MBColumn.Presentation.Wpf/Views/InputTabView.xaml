<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.InputTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:enums="clr-namespace:MBColumn.Domain.Enums;assembly=MBColumn.Domain">
    <UserControl.Resources>
        <Style x:Key="SideBarCountTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,0,8,6" />
            <Setter Property="Padding"
                    Value="7,5" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasBarCountWarning}"
                             Value="True">
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource AccentRedBrush}" />
                    <Setter Property="BorderThickness"
                            Value="2" />
                    <Setter Property="ToolTip"
                            Value="{Binding BarCountWarning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideReadOnlyTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,0,8,6" />
            <Setter Property="Padding"
                    Value="7,5" />
            <Setter Property="Height"
                    Value="32" />
            <Setter Property="IsEnabled"
                    Value="False" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Background"
                    Value="{DynamicResource PanelBackgroundBrush}" />
        </Style>
        <Style x:Key="ColumnHeaderTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="HorizontalAlignment"
                    Value="Center" />
            <Setter Property="Margin"
                    Value="0,0,0,12" />
        </Style>
        <Style x:Key="SectionShapeRadioStyle"
               TargetType="RadioButton">
            <Setter Property="Foreground"
                    Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="FontSize"
                    Value="12.5" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Padding"
                    Value="14,6" />
            <Setter Property="Margin"
                    Value="12,0,0,0" />
            <Setter Property="MinWidth"
                    Value="110" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ShapeBorder"
                                Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="ShapeBorder"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter TargetName="ShapeBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter Property="Foreground"
                                        Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ShapeBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryNavyBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver"
                                               Value="True" />
                                    <Condition Property="IsChecked"
                                               Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ShapeBorder"
                                        Property="Background"
                                        Value="{DynamicResource BorderSoftBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*"
                              MinWidth="220" />
            <ColumnDefinition Width="0.35*"
                              MinWidth="300" />
            <ColumnDefinition Width="*"
                              MinWidth="550" />
        </Grid.ColumnDefinitions>
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,14,0">
            <StackPanel>
                <TextBlock Text="Project Settings"
                           Style="{StaticResource ColumnHeaderTextStyle}" />
                <GroupBox Header="General"
                          Background="White"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="14"
                          Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Workflow"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding UnitSystems}"
                                  SelectedItem="{Binding UnitSystem}" />
                        <TextBlock Text="Changing workflow resets defaults - values are not silently reinterpreted."
                                   Style="{StaticResource HelperTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Design Code"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding DesignCodes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{Binding SelectedDesignCode}" />
                        <TextBlock Text="Section Integration Method"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Margin="0,10,0,0" />
                        <ComboBox ItemsSource="{Binding SectionIntegrationMethodOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Method"
                                  SelectedValue="{Binding SelectedIntegrationMethod}">
                            <ComboBox.ToolTip>
                                <TextBlock TextWrapping="Wrap"
                                           MaxWidth="360"
                                           Text="Fiber Integration: General numerical integration method recommended for circular sections and future arbitrary sections. Polygon Integration: Faster compression-zone clipping method useful for stress-block comparison." />
                            </ComboBox.ToolTip>
                        </ComboBox>
                        <StackPanel Visibility="{Binding ShowAlphaCcOption, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Alpha cc"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,10,0,0" />
                            <TextBox Text="{Binding AlphaCc, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Concrete strength coefficient (NDP). UK/Singapore standard = 0.85. Columns often use 0.80."
                                       Style="{StaticResource HelperTextStyle}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="Material"
                          Background="White"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="14"
                          Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="76" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding FcLabel}"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Text="{Binding StressLabel}"
                                   Style="{StaticResource UnitTextStyle}" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding Fc, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="{Binding FyLabel}"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding StressLabel}"
                                   Style="{StaticResource UnitTextStyle}" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding Fy, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="Es"
                                   Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Text="{Binding StressLabel}"
                                   Style="{StaticResource UnitTextStyle}" />
                        <TextBox Grid.Row="5"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding Es, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,14,0">
            <StackPanel>
                <TextBlock Text="Load Case"
                           Style="{StaticResource ColumnHeaderTextStyle}" />
                <GroupBox Header="Load Cases"
                          Background="White"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="14"
                          Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Moment Sign Convention"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Margin="0,0,0,8" />
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Margin="0,0,0,14">
                            <Image Source="/MBColumn;component/Resources/MomentSignConvention.png"
                                   Stretch="Uniform"
                                   MaxHeight="180"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Style="{StaticResource HelperTextStyle}"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"
                                   Text="P: compression (+). Mx: moment about X-axis. My: moment about Y-axis." />
                        <DataGrid x:Name="LoadCasesGrid"
                                  ItemsSource="{Binding LoadCases}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="True"
                                  HeadersVisibility="Column"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  MinHeight="260"
                                  MaxHeight="460"
                                  Margin="0,0,0,8">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add Load Case"
                                              Command="{Binding Path=PlacementTarget.DataContext.AddLoadCaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Remove Selected Load Case(s)"
                                              Command="{Binding Path=PlacementTarget.DataContext.DeleteSelectedLoadCasesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Load&#xA;Case"
                                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="72"
                                                    MinWidth="60"
                                                    ElementStyle="{StaticResource LeftAlignText}" />
                                <DataGridTextColumn Header="P"
                                                    Binding="{Binding Pu, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                    Width="*"
                                                    MinWidth="64"
                                                    ElementStyle="{StaticResource RightAlignText}"
                                                    EditingElementStyle="{StaticResource RightAlignEditingTextBox}" />
                                <DataGridTextColumn Header="Mx"
                                                    Binding="{Binding Mux, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                    Width="*"
                                                    MinWidth="64"
                                                    ElementStyle="{StaticResource RightAlignText}"
                                                    EditingElementStyle="{StaticResource RightAlignEditingTextBox}" />
                                <DataGridTextColumn Header="My"
                                                    Binding="{Binding Muy, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                    Width="*"
                                                    MinWidth="64"
                                                    ElementStyle="{StaticResource RightAlignText}"
                                                    EditingElementStyle="{StaticResource RightAlignEditingTextBox}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel>
                            <Button Content="+ Add case"
                                    Command="{Binding AddLoadCaseCommand}"
                                    Style="{StaticResource CompactButtonStyle}" />
                            <Button Content="Delete load case"
                                    Command="{Binding DeleteSelectedLoadCasesCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=LoadCasesGrid}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,4"
                                    FontSize="11.5"
                                    Margin="8,0,0,0" />
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Section And Rebar Config"
                           Style="{StaticResource ColumnHeaderTextStyle}" />
                <Border Style="{StaticResource CardBorderStyle}"
                        Padding="18"
                        MinHeight="240"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Section Preview"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           Margin="0,0,0,4" />
                                <TextBlock Style="{StaticResource HelperTextStyle}"
                                           TextWrapping="Wrap"
                                           Text="Compression (+). Internal units: N, mm, MPa. Slenderness excluded." />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding ImportDxfCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="58"
                                    Height="54"
                                    Padding="4"
                                    Margin="12,0,0,0"
                                    ToolTip="Import .DXF">
                                <StackPanel HorizontalAlignment="Center">
                                    <Viewbox Width="22"
                                             Height="22"
                                             Margin="0,1,0,2">
                                        <Canvas Width="24"
                                                Height="24">
                                            <Path Data="M 6,3 L 15,3 L 20,8 L 20,21 L 6,21 Z M 15,3 L 15,8 L 20,8"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                            <Path Data="M 12,9 L 12,16 M 8.8,13 L 12,16.2 L 15.2,13"
                                                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="1.9"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text=".dxf"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <controls:SectionPreviewCanvas Height="220"
                                                       MinHeight="200"
                                                       HorizontalAlignment="Stretch"
                                                       SectionWidth="{Binding SectionWidth}"
                                                       SectionHeight="{Binding SectionHeight}"
                                                       Cover="{Binding Cover}"
                                                       UnitSystem="{Binding SelectedUnitSystem}"
                                                       SectionShape="{Binding SelectedSectionShape}"
                                                       Rebars="{Binding PreviewRebars}"
                                                       SectionLabel="{Binding SectionPreviewLabel}"
                                                       RebarLabel="{Binding RebarPreviewLabel}"
                                                       CoverLabel="{Binding CoverPreviewLabel}"
                                                       IsValid="{Binding IsSectionPreviewValid}"
                                                       ErrorMessage="{Binding SectionPreviewErrorMessage}"
                                                       BoundaryPoints="{Binding PreviewBoundaryPoints}" />
                    </StackPanel>
                </Border>
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                    <TextBlock Text="Changes made, recalculation required."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentRedBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               Visibility="{Binding DataContext.IsCalculationOutdated, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding DataContext.ValidationMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentRedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0"
                              Header="Section Geometry"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="0,0,7,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <TextBlock Text="Section Shape"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <ComboBox SelectedValue="{Binding SelectedSectionShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          VerticalAlignment="Center"
                                          Height="30">
                                    <ComboBoxItem Content="Rectangular"
                                                  Tag="{x:Static enums:SectionShapeType.Rectangular}" />
                                    <ComboBoxItem Content="Circular"
                                                  Tag="{x:Static enums:SectionShapeType.Circular}" />
                                    <ComboBoxItem Content="Irregular"
                                                  Tag="{x:Static enums:SectionShapeType.Irregular}" />
                                </ComboBox>
                            </DockPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="{Binding LengthLabel, StringFormat=Clear cover ({0})}"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Cover}" />
                            </Grid>
                            <Grid Visibility="{Binding IsRectangularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Width b"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Width}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="3"
                                           Text="Height h"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="4"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Height}" />
                            </Grid>
                            <Grid Visibility="{Binding IsCircularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Diameter D"
                                           Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="{Binding LengthLabel}"
                                           Style="{StaticResource UnitTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Diameter}" />
                            </Grid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Column="1"
                              Header="Rebar Configuration"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="7,0,0,14">
                        <StackPanel>
                            <!-- 1. Algorithmic / Shape-Specific Top Panel (Visible for Rectangular/Circular) -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Grid Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Row 0: Layout Type ComboBox and standard inputs -->
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,8,0">
                                        <TextBlock Text="Layout Type"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding RebarLayoutTypes}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="LayoutType"
                                                  SelectedValue="{Binding SelectedRebarLayoutType}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding ShowTotalBarsInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Bar size"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableBars}"
                                                  DisplayMemberPath="DisplayLabel"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding BarSize}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="2"
                                                Visibility="{Binding ShowTotalBarsInput, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Total number of bars"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding BarCount}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Visibility="{Binding IsRectangularEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding LengthLabel, StringFormat=Bar spacing ({0})}"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding RectSpacing, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <!-- Row 1: Equal Spacing Layout Panel -->
                                    <Grid Grid.Row="1"
                                          Grid.ColumnSpan="3"
                                          Margin="0,8,0,0"
                                          Visibility="{Binding IsEqualSpacingLayout, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Bar size"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding AvailableBars}"
                                                      DisplayMemberPath="DisplayLabel"
                                                      SelectedValuePath="Name"
                                                      SelectedValue="{Binding BarSize}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Margin="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Spacing ("
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding LengthLabel}"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text=")"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding Spacing}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                <TextBlock Text="{Binding RebarLayoutWarning}"
                                           Visibility="{Binding HasRebarLayoutWarning, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{DynamicResource AccentRedBrush}"
                                           Style="{StaticResource HelperTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Visibility="{Binding IsSidesDifferentLayout, Converter={StaticResource BoolToVisibilityConverter}}"
                                              Margin="0,0,0,10">
                                    <Grid MinWidth="620">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="110" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="Top"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Bottom"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="3"
                                                   Text="Left"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="4"
                                                   Text="Right"
                                                   Style="{StaticResource GroupTitleTextStyle}" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="No. of bars"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource SideBarCountTextBoxStyle}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Bar size"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding BarSize, Mode=OneWay}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Clear cover"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 DataContext="{Binding RebarLayout.Top}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="2"
                                                 DataContext="{Binding RebarLayout.Bottom}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="3"
                                                 DataContext="{Binding RebarLayout.Left}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="4"
                                                 DataContext="{Binding RebarLayout.Right}"
                                                 Text="{Binding Cover, Mode=OneWay, StringFormat=F3}"
                                                 Style="{StaticResource SideReadOnlyTextBoxStyle}" />
                                    </Grid>
                                </ScrollViewer>
                            </StackPanel>
                            <!-- 2. Irregular Section-Specific Spacing/Generate Panel (Visible only for Irregular Section) -->
                            <StackPanel Visibility="{Binding IsIrregularSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid DataContext="{Binding IrregularInput}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- Row 0: Layout Type Selector for Irregular -->
                                    <Grid Grid.Row="0"
                                          Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Layout Type"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding RebarModeOptions}"
                                                      SelectedValue="{Binding RebarMode}"
                                                      SelectedValuePath="Type"
                                                      DisplayMemberPath="DisplayName" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Row 1: Equal Spacing Inputs (Visible only when RebarMode is EqualSpacing) -->
                                    <Grid Grid.Row="1"
                                          Margin="0,0,0,12"
                                          Visibility="{Binding IsEqualSpacing, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="Bar size"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding DataContext.AvailableBars, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="Name"
                                                      SelectedValue="{Binding BarSize}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Margin="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Spacing ("
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding DataContext.LengthLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text=")"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding Spacing}" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Row 2: Validation Messages -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding RebarValidationMessage}"
                                               Visibility="{Binding HasRebarValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                               Foreground="Red"
                                               FontSize="11"
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </Grid>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0"
                              Header="Boundary Points (Clockwise)"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="0,0,7,0">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIrregularSection}"
                                                 Value="False">
                                        <Setter Property="Opacity"
                                                Value="0.45" />
                                        <Setter Property="IsEnabled"
                                                Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel DataContext="{Binding IrregularInput}">
                            <WrapPanel Margin="0,0,0,8">
                                <Button ToolTip="Import..."
                                        Click="ImportBoundary_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Foreground="{DynamicResource PrimaryNavyBrush}"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="0,0,8,0">
                                    <Viewbox Width="14"
                                             Height="14">
                                        <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,2 L 10,13 M 6,9 L 10,13 L 14,9"
                                              Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Viewbox>
                                </Button>
                                <Button ToolTip="Export..."
                                        Click="ExportBoundary_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Foreground="{DynamicResource PrimaryNavyBrush}"
                                        Width="26"
                                        Height="26"
                                        Padding="0">
                                    <Viewbox Width="14"
                                             Height="14">
                                        <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,14 L 10,3 M 6,7 L 10,3 L 14,7"
                                              Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Viewbox>
                                </Button>
                            </WrapPanel>
                            <TextBlock Text="{Binding BoundaryValidationMessage}"
                                       Visibility="{Binding HasBoundaryValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Foreground="Red"
                                       FontSize="11"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap" />
                            <DataGrid ItemsSource="{Binding BoundaryPoints}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="True"
                                      CanUserDeleteRows="True"
                                      MaxHeight="200">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Add Point"
                                                  Command="{Binding Path=PlacementTarget.DataContext.AddBoundaryRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Remove Selected Point(s)"
                                                  Command="{Binding Path=PlacementTarget.DataContext.DeleteBoundaryRowsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pt"
                                                        Binding="{Binding PtIndex, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="X"
                                                        Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Y"
                                                        Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Column="1"
                              Header="Rebar Coordinates"
                              Background="White"
                              Foreground="{DynamicResource DarkNavyBrush}"
                              BorderBrush="{DynamicResource BorderGreyBrush}"
                              Padding="14"
                              Margin="7,0,0,0">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRebarCoordinatesEditable}"
                                                 Value="False">
                                        <Setter Property="Opacity"
                                                Value="0.45" />
                                        <Setter Property="IsEnabled"
                                                Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel DataContext="{Binding IrregularInput}">
                            <WrapPanel Margin="0,0,0,8">
                                <Button ToolTip="Import..."
                                        Click="ImportRebar_Click"
                                        IsEnabled="{Binding IsCustomCoordinates}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Foreground="{DynamicResource PrimaryNavyBrush}"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="0,0,8,0">
                                    <Viewbox Width="14"
                                             Height="14">
                                        <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,2 L 10,13 M 6,9 L 10,13 L 14,9"
                                              Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Viewbox>
                                </Button>
                                <Button ToolTip="Export..."
                                        Click="ExportRebar_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Foreground="{DynamicResource PrimaryNavyBrush}"
                                        Width="26"
                                        Height="26"
                                        Padding="0">
                                    <Viewbox Width="14"
                                             Height="14">
                                        <Path Data="M 2,12 L 2,16 C 2,17 3,18 4,18 L 16,18 C 17,18 18,17 18,16 L 18,12 M 10,14 L 10,3 M 6,7 L 10,3 L 14,7"
                                              Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Viewbox>
                                </Button>
                            </WrapPanel>
                            <DataGrid ItemsSource="{Binding Rebars}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="{Binding IsCustomCoordinates}"
                                      CanUserDeleteRows="{Binding IsCustomCoordinates}"
                                      IsReadOnly="{Binding IsAlgorithmicCoordinates}"
                                      MaxHeight="200">
                                <DataGrid.Style>
                                    <Style TargetType="DataGrid"
                                           BasedOn="{StaticResource {x:Type DataGrid}}">
                                        <Style.Triggers>
                                            <Trigger Property="IsReadOnly"
                                                     Value="True">
                                                <Setter Property="Opacity"
                                                        Value="0.65" />
                                                <Setter Property="Background"
                                                        Value="#F2F2F2" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Add Rebar"
                                                  Command="{Binding Path=PlacementTarget.DataContext.AddRebarRowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  IsEnabled="{Binding Path=PlacementTarget.DataContext.IsCustomCoordinates, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Remove Selected Rebar(s)"
                                                  Command="{Binding Path=PlacementTarget.DataContext.DeleteRebarRowsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding Path=PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  IsEnabled="{Binding Path=PlacementTarget.DataContext.IsCustomCoordinates, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Index"
                                                        Binding="{Binding RebarIndex, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="X"
                                                        Binding="{Binding X, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Y"
                                                        Binding="{Binding Y, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Area"
                                                        Binding="{Binding AreaMm2, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Size"
                                                        Binding="{Binding BarSize, UpdateSourceTrigger=PropertyChanged}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
