                                <Border BorderThickness="0"
                                        CornerRadius="0"
                                        Padding="0"
                                        Margin="0,0,0,12"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Effective length - L: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Clear column length from Section &amp; Rebar. It is the base length before applying kx or ky." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Effective length factors - kx, ky: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="User-defined restraint factors. The app calculates l" />
                                        <Run Text="0x" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = kx &#x00D7; L and l" />
                                        <Run Text="0y" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = ky &#x00D7; L." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Slenderness ratio - &#x03BB;: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Measures effective length against section stiffness radius. &#x03BB;x = l" />
                                        <Run Text="0x" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" / ix and &#x03BB;y = l" />
                                        <Run Text="0y" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" / iy." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Axial load ratio - n: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Compression demand level. n = N" />
                                        <Run Text="Ed" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" / (Ac &#x00D7; fcd)." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Creep factor - A: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Reduces &#x03BB;lim for creep. A = 1 / (1 + 0.2&#x03C6;eff), or A = 0.7 when the default option is used." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Reinforcement factor - B: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Increases &#x03BB;lim based on longitudinal steel. B = &#x221A;(1 + 2&#x03C9;), with &#x03C9; = A" />
                                        <Run Text="s,total" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" &#x00D7; fyd / (Ac &#x00D7; fcd)." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Moment shape factor - C: " Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="Accounts for the first-order moment diagram between top and bottom. C = 1.7 - r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="9" /><Run Text=", where r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="9" /><Run Text=" = M" /><Run Text="01" BaselineAlignment="Subscript" FontSize="9" /><Run Text=" / M" /><Run Text="02" BaselineAlignment="Subscript" FontSize="9" /><Run Text=". The sign is preserved: positive r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="9" /><Run Text=" means same-curvature bending, negative r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="9" /><Run Text=" means reverse-curvature bending. Smaller C lowers &#x03BB;lim; larger C raises &#x03BB;lim." /></TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Slenderness limit - &#x03BB;lim: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Limit used to decide whether second-order moment is required. &#x03BB;lim = 20ABC / &#x221A;n." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="End moments - M" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="01" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text=" and M" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="02" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="First-order end moments including imperfection. M" />
                                        <Run Text="02" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" is the larger design end moment; M" />
                                        <Run Text="01" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" is the smaller signed companion." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Branch - stocky/slender: " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="If &#x03BB; &lt; &#x03BB;lim, second-order moment is not required and M" />
                                        <Run Text="2" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = 0. If &#x03BB; &#x2265; &#x03BB;lim, the nominal curvature method is applied." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Kr factor - K" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="r" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Corrects curvature for axial load level. K" />
                                        <Run Text="r" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = (n" />
                                        <Run Text="u" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" - n) / (n" />
                                        <Run Text="u" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" - 0.4), limited to 1, with n" />
                                        <Run Text="u" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = 1 + &#x03C9;." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Creep curvature factor - K" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="&#x03C6;" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Amplifies curvature for creep. K" />
                                        <Run Text="&#x03C6;" BaselineAlignment="Subscript" FontSize="9" />
                                        <Run Text=" = max(1, 1 + &#x03B2;&#x03C6;eff), where &#x03B2; = 0.35 + fck / 200 - &#x03BB; / 150." />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                        <Run Text="Second-order moment - M" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="2" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                        <Run Text="Additional moment from nominal curvature when &#x03BB; &#x2265; &#x03BB;lim. If &#x03BB; &lt; &#x03BB;lim, M" />
