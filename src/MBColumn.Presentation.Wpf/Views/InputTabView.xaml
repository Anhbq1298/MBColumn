                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding MyBottom, UpdateSourceTrigger=LostFocus, TargetNullValue='', StringFormat=F2}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource RightAlignText}"
                                                            EditingElementStyle="{StaticResource RightAlignEditingTextBox}">
