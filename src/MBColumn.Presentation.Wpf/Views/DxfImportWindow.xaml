<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.DxfImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import DXF"
        Width="640"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Padding="18">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="DXF Import"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryNavyBrush}"
                       Margin="0,0,0,14" />

            <!-- File path row -->
            <TextBlock Text="DXF file"
                       Style="{StaticResource FieldLabelTextStyle}" />
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding FilePath, UpdateSourceTrigger=LostFocus}" />
                <Button Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowseFileCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="4"
                        Content="Refresh Layers"
                        Command="{Binding RefreshLayersCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>

            <!-- Two-panel: Layers | Options -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Layers -->
                <GroupBox Grid.Column="0"
                          Header="Layers"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="12">
                    <StackPanel>
                        <TextBlock Text="Layer(s) to import the section from"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Boundary shape(s)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LayerNames}"
                                      SelectedItem="{Binding SelectedBoundaryLayerName}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bar(s)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LayerNames}"
                                      SelectedItem="{Binding SelectedRebarLayerName}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Right: Options -->
                <GroupBox Grid.Column="2"
                          Header="Options"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Import scale"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScaleFactor, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <CheckBox Content="Override rebar diameter"
                                  IsChecked="{Binding OverrideRebarDiameter}"
                                  Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Diameter (mm)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RebarDiameterMm, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsRebarDiameterInputEnabled}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Summary area -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,8">
                <TextBlock Text="{Binding SummaryText}"
                           TextWrapping="Wrap"
                           FontSize="12" />
            </Border>

            <!-- Message (error or status) -->
            <TextBlock Text="{Binding Message}"
                       Visibility="{Binding HasMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground"
                                Value="{DynamicResource AccentRedBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasErrors}"
                                         Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextMutedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="Import"
                        Command="{Binding ImportCommand}"
                        IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
