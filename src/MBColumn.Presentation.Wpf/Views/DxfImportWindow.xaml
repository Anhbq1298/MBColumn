<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.DxfImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import DXF"
        Width="640"
        SizeToContent="Height"
        Style="{DynamicResource DialogWindowStyle}">
    <Grid Style="{DynamicResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="DXF Import" Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Map DXF layers, preview geometry, then import the section."
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource DialogBodyBorderStyle}">
        <StackPanel>
            <!-- File path row -->
            <TextBlock Text="DXF file"
                       Style="{StaticResource FieldLabelTextStyle}" />
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding FilePath, UpdateSourceTrigger=LostFocus}" />
                <Button Grid.Column="2"
                        Content="Browse..."
                        Command="{Binding BrowseFileCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="4"
                        Content="Refresh Layers"
                        Command="{Binding RefreshLayersCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>

            <!-- Two-panel: Layers | Options -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Layers -->
                <GroupBox Grid.Column="0"
                          Header="Layers"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="12">
                    <StackPanel>
                        <TextBlock Text="Layer(s) to import the section from"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Boundary shape(s)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LayerNames}"
                                      SelectedItem="{Binding SelectedBoundaryLayerName}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bar(s)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LayerNames}"
                                      SelectedItem="{Binding SelectedRebarLayerName}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Right: Options -->
                <GroupBox Grid.Column="2"
                          Header="Options"
                          Foreground="{DynamicResource DarkNavyBrush}"
                          BorderBrush="{DynamicResource BorderGreyBrush}"
                          Padding="12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Import scale"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding ScaleFactor, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <CheckBox Content="Override rebar diameter"
                                  IsChecked="{Binding OverrideRebarDiameter}"
                                  Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Diameter (mm)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Margin="0,0,8,0" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding RebarDiameterMm, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsRebarDiameterInputEnabled}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Preview canvas -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,8">
                <Canvas Width="580"
                        Height="160"
                        HorizontalAlignment="Center"
                        ClipToBounds="True">
                    <Polygon Points="{Binding PreviewBoundaryPoints}"
                             Stroke="{DynamicResource PrimaryNavyBrush}"
                             StrokeThickness="1.5"
                             Fill="#1A3A5C8C" />
                    <ItemsControl ItemsSource="{Binding PreviewRebars}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left"
                                        Value="{Binding Left}" />
                                <Setter Property="Canvas.Top"
                                        Value="{Binding Top}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Ellipse Width="{Binding Size}"
                                         Height="{Binding Size}"
                                         Fill="{DynamicResource PrimaryNavyBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </Border>

            <!-- Summary area -->
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,8">
                <TextBlock Text="{Binding SummaryText}"
                           TextWrapping="Wrap"
                           FontSize="12" />
            </Border>

            <!-- Message (error or status) -->
            <TextBlock Text="{Binding Message}"
                       Visibility="{Binding HasMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground"
                                Value="{DynamicResource AccentRedBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasErrors}"
                                         Value="False">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextMutedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource DialogFooterBarStyle}">
            <StackPanel Style="{DynamicResource DialogActionPanelStyle}">
                <Button Content="Cancel"
                        IsCancel="True"
                        Style="{DynamicResource DialogActionButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Content="Import"
                        Command="{Binding ImportCommand}"
                        IsDefault="True"
                        MinWidth="88"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
