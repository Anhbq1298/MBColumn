<Window x:Class="MBColumn.Presentation.Wpf.Views.SelectSectionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Existing Sections" Height="400" Width="300"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">
    <Grid Style="{DynamicResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Add Existing Sections" Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Choose sections to include in the selected group."
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <ListBox x:Name="SectionsListBox"
                 Grid.Row="1"
                 Margin="12"
                 Background="{DynamicResource PanelBackgroundBrush}"
                 BorderBrush="{DynamicResource BorderGreyBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}"
                              IsChecked="{Binding IsSelected}"
                              Foreground="{DynamicResource TextDarkBrush}"
                              Margin="2" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Style="{DynamicResource DialogFooterBarStyle}">
            <StackPanel Style="{DynamicResource DialogActionPanelStyle}">
                <Button Content="Cancel"
                        IsCancel="True"
                        Width="88"
                        Margin="0,0,8,0"
                        Style="{DynamicResource DialogActionButtonStyle}" />
                <Button Content="Add"
                        IsDefault="True"
                        Click="OkButton_Click"
                        Width="88"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
