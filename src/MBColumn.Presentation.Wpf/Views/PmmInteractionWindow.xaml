<UserControl x:Class="MBColumn.Presentation.Wpf.Views.PmmInteractionWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
             Background="{DynamicResource LightBackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,5" />
        </Style>
        <Style x:Key="ResultChartCardStyle" TargetType="Border" BasedOn="{StaticResource ChartCardStyle}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinHeight" Value="180" />
        </Style>
        <Style x:Key="ChartInlineSettingsStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="4,0,4,0" />
        </Style>
        <Style x:Key="ChartConfigCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style x:Key="ChartConfigLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="CenterCellTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style x:Key="LeftCellTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="CenterColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="ChartConfigInputStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="54" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>
        <Style x:Key="SettingsSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <!-- Local font overrides — smaller/consistent for this compact view -->
        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="PmmSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
        </Style>
        <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="UnitTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Chart icon toolbar styles — muted/subtle -->
        <Style x:Key="ChartIconHintStyle" TargetType="Border">
            <Setter Property="Background" Value="#B8FFFFFF" />
            <Setter Property="BorderBrush" Value="#30000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
        <Style x:Key="ChartIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#80505050" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#20000000" />
                                <Setter Property="Foreground" Value="#C0303030" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#35000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChartIconToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#80505050" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#20000000" />
                                <Setter Property="Foreground" Value="#C0303030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChartToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="ChartToolbarToggleStyle" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryNavyBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryNavyBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- 3-column grid: col0=2D MM/section-info, col1=2D PM/tables, col2=3D PMM/tables -->
    <Grid Margin="4" TextElement.FontSize="{StaticResource FontSizeBody}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" MinHeight="140" />
            <RowDefinition Height="5*" MinHeight="180" />
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Header ═══ -->
        <!-- ═══ ROW 3: Charts ═══ -->

        <!-- Col 0: 2D MM (Mx-My diagram) -->
        <Border Grid.Row="1" Grid.Column="0"
                Style="{StaticResource ResultChartCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding MmDiagramTitle}"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,4" />
                <Grid Grid.Row="1" x:Name="MmChartArea">
                    <controls:DiagramCanvas2D x:Name="MmCanvas" ShowInteractionHint="True" Points="{Binding MxMyPoints}"
                                              XAxisLabel="{Binding MM.XAxisLabel}"
                                              YAxisLabel="{Binding MM.YAxisLabel}"
                                              ShowGrid="{Binding MM.ShowGrid}"
                                              ShowLabels="{Binding MM.ShowLabels}"
                                              ShowSpecialPoints="{Binding ShowCpLabels}"
                                              ShowCpLabels="{Binding ShowCpLabels}"
                                              ShowDemandPoint="True"
                                              ShowDemandLabel="False"
                                              ShowNominalCurve="{Binding ShowNominalCurve}"
                                              UseEqualAspect="{Binding UseEqualAspectForMM}"
                                              XGridStep="{Binding MStepX}"
                                              YGridStep="{Binding MStepY}"
                                              SelectedPoint="{Binding SelectedChartPoint}"
                                              HighlightedDemandLabel="{Binding HighlightedDemandLabel}"
                                              Ratio="{Binding MM.Ratio}"
                                              ResetVersion="{Binding MM.ResetVersion}" />
                    <!-- Icon toolbar — left side -->
                    <Border VerticalAlignment="Center" HorizontalAlignment="Left"
                            Margin="6,0,0,0"
                            Style="{StaticResource ChartIconHintStyle}">
                        <StackPanel Orientation="Vertical" Margin="0,2">
                            <Button Style="{StaticResource ChartIconButtonStyle}" ToolTip="Reset view"
                                    Click="ResetMmChart_Click">
                                <TextBlock Text="↺" FontSize="15" />
                            </Button>
                            <Separator Margin="2,3" Background="#20000000" Height="1" />
                            <ToggleButton Style="{StaticResource ChartIconToggleStyle}" ToolTip="Show grid"
                                          IsChecked="{Binding MM.ShowGrid}">
                                <TextBlock Text="▦" FontSize="14" />
                            </ToggleButton>
                            <ToggleButton Style="{StaticResource ChartIconToggleStyle}" ToolTip="Show axes labels"
                                          IsChecked="{Binding MM.ShowLabels}"
                                          Margin="0,2,0,0">
                                <TextBlock Text="┼" FontSize="13" FontWeight="SemiBold" />
                            </ToggleButton>
                            <Separator Margin="2,3" Background="#20000000" Height="1" />
                            <ToggleButton Style="{StaticResource ChartIconToggleStyle}" ToolTip="Toggle control points"
                                          IsChecked="{Binding ShowCpLabels}"
                                          Visibility="Collapsed">
                                <TextBlock Text="🎯" FontSize="14" />
                            </ToggleButton>
                            <Button Style="{StaticResource ChartIconButtonStyle}" ToolTip="Export PNG"
                                    Margin="0,2,0,0" Click="ExportMmChart_Click">
                                <TextBlock Text="📷" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- X/Y step overlay — bottom-left -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="6,0,0,6"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSoftBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="5,3">
                        <WrapPanel>
                            <TextBlock Text="Mx step" Style="{StaticResource ChartConfigLabelStyle}" />
                            <TextBox Text="{Binding MStepX, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                     Style="{StaticResource ChartConfigInputStyle}" />
                            <TextBlock Text="My step" Style="{StaticResource ChartConfigLabelStyle}" Margin="4,0,4,0" />
                            <TextBox Text="{Binding MStepY, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                     Style="{StaticResource ChartConfigInputStyle}" />
                        </WrapPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Col 1: 2D PM (PM-angle diagram) -->
        <Border Grid.Row="1" Grid.Column="1"
                Style="{StaticResource ResultChartCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding PM.DiagramTitle}"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,4"
                           ToolTip="{Binding PM.DiagramTitle}" />
                <Grid Grid.Row="1" x:Name="PmChartArea">
                    <controls:DiagramCanvas2D x:Name="PmCanvas" ShowInteractionHint="True" Points="{Binding PmAnglePoints}"
                                              ReferenceLines="{Binding PmReferenceLines}"
                                              XAxisLabel="{Binding PM.XAxisLabel}"
                                              YAxisLabel="{Binding PM.YAxisLabel}"
                                              ShowGrid="{Binding PM.ShowGrid}"
                                              ShowLabels="{Binding PM.ShowLabels}"
                                              ShowSpecialPoints="{Binding ShowCpLabels}"
                                              ShowCpLabels="{Binding ShowCpLabels}"
                                              ShowDemandPoint="True"
                                              ShowDemandLabel="False"
                                              ShowReferenceLines="{Binding ShowPmaxPmin}"
                                              ShowNominalCurve="{Binding ShowNominalCurve}"
                                              XGridStep="{Binding MStep}"
                                              YGridStep="{Binding PStep}"
                                              BoundsOverride="{Binding SharedPmBounds}"
                                              SelectedPoint="{Binding SelectedChartPoint}"
                                              HighlightedDemandLabel="{Binding HighlightedDemandLabel}"
                                              Ratio="{Binding PM.Ratio}"
                                              ResetVersion="{Binding PM.ResetVersion}" />
                    <!-- Icon toolbar — left side -->
                    <Border VerticalAlignment="Center" HorizontalAlignment="Left"
                            Margin="6,0,0,0"
                            Style="{StaticResource ChartIconHintStyle}">
                        <StackPanel Orientation="Vertical" Margin="0,2">
                            <Button Style="{StaticResource ChartIconButtonStyle}" ToolTip="Reset view"
                                    Click="ResetPmChart_Click">
                                <TextBlock Text="↺" FontSize="15" />
                            </Button>
                            <Separator Margin="2,3" Background="#20000000" Height="1" />
                            <Button Style="{StaticResource ChartIconButtonStyle}" ToolTip="PM at θ = 0°"
                                    Command="{Binding SetTheta0Command}">
                                <TextBlock Text="0°" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" />
                            </Button>
                            <Button Style="{StaticResource ChartIconButtonStyle}" ToolTip="PM at θ = 90°"
                                    Margin="0,2,0,0" Command="{Binding SetTheta90Command}">
                                <TextBlock Text="90°" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" />
                            </Button>
                            <Separator Margin="2,3" Background="#20000000" Height="1" />
                            <ToggleButton Style="{StaticResource ChartIconToggleStyle}" ToolTip="Show grid"
                                          IsChecked="{Binding PM.ShowGrid}">
                                <TextBlock Text="▦" FontSize="14" />
                            </ToggleButton>
                            <ToggleButton Style="{StaticResource ChartIconToggleStyle}" ToolTip="Show axes labels"
                                          IsChecked="{Binding PM.ShowLabels}"
                                          Margin="0,2,0,0">
                                <TextBlock Text="┼" FontSize="13" FontWeight="SemiBold" />
                            </ToggleButton>
                            <Separator Margin="2,3" Background="#20000000" Height="1" />
                            <ToggleButton Style="{StaticResource ChartIconToggleStyle}" ToolTip="Toggle control points"
                                          IsChecked="{Binding ShowCpLabels}">
                                <TextBlock Text="🎯" FontSize="14" />
                            </ToggleButton>
                            <Button Style="{StaticResource ChartIconButtonStyle}" ToolTip="Export PNG"
                                    Margin="0,2,0,0" Click="ExportPmChart_Click">
                                <TextBlock Text="📷" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- P/M step overlay — bottom-left corner of chart -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="6,0,0,6"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSoftBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="5,3">
                        <WrapPanel>
                            <CheckBox Content="P max/min" IsChecked="{Binding ShowPmaxPmin}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <TextBlock Text="P step" Style="{StaticResource ChartConfigLabelStyle}" Margin="4,0,4,0" />
                            <TextBox Text="{Binding PStep, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                     Style="{StaticResource ChartConfigInputStyle}" />
                            <TextBlock Text="M step" Style="{StaticResource ChartConfigLabelStyle}" Margin="4,0,4,0" />
                            <TextBox Text="{Binding MStep, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                     Style="{StaticResource ChartConfigInputStyle}" />
                        </WrapPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Col 2: 3D PMM -->
        <Border Grid.Row="1" Grid.Column="2"
                Style="{StaticResource ResultChartCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="3D PMM View"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,4" />
                <Grid Grid.Row="1">
                    <controls:InteractionViewport3D Points="{Binding PM3D.SurfacePoints}"
                                                   DemandPoint="{Binding PM3D.DemandPoint}"
                                                   DemandPoints="{Binding PM3D.DemandPoints}"
                                                   ShowGrid="True"
                                                   ShowWireframe="True"
                                                   ShowSurface="True"
                                                   ShowLabels="True"
                                                   ShowDemandPoint="True"
                                                   UnitLabels="{Binding PM3D.UnitLabels}"
                                                   SelectedPmAngle="{Binding PM3D.SelectedPmAngle}"
                                                   SelectedAxialLoad="{Binding PM3D.SelectedAxialLoad}"
                                                   ShowSlicePlane="True"
                                                   ShowAxialLoadSlice="True"
                                                   SpecialCapacityPoints="{Binding PM3D.SpecialCapacityPoints}"
                                                   ShowCpLabels="{Binding ShowCpLabels}"
                                                   ResetVersion="{Binding PM3D.ResetVersion}" />
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ ROW 1: Info / Tables ═══ -->

        <!-- Col 0: Section preview (left) + θ Slice / P Level controls (right) -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Section canvas -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource BorderSoftBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Section + Rebar"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               Style="{StaticResource PmmSectionHeaderStyle}"
                               Margin="0,0,0,6" />
                    <controls:SectionStateInsetCanvas Grid.Row="1"
                                                      InsetFigure="{Binding PmChartInset}" />
                </Grid>
            </Border>

            <!-- Right: θ Slice + P Level -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="0,4,0,0">

                <!-- θ Slice -->
                <TextBlock Text="θ Slice"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryNavyBrush}"
                           Style="{StaticResource PmmSectionHeaderStyle}"
                           Margin="0,0,0,6" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Angle θ"
                               Style="{StaticResource FieldLabelTextStyle}"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedSliceAngleDegrees, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                             HorizontalContentAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="deg"
                               Style="{StaticResource UnitTextStyle}"
                               Margin="4,0,0,0" />
                </Grid>
                <TextBlock Text="{Binding PmSliceLabel}"
                           Style="{StaticResource HelperTextStyle}"
                           Margin="0,0,0,16" />

                <!-- P Level -->
                <TextBlock Text="P Level"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryNavyBrush}"
                           Style="{StaticResource PmmSectionHeaderStyle}"
                           Margin="0,0,0,6" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Axial load"
                               Style="{StaticResource FieldLabelTextStyle}"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedAxialLoad, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                             HorizontalContentAlignment="Right" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding ForceUnitLabel}"
                               Style="{StaticResource UnitTextStyle}"
                               Margin="4,0,0,0" />
                </Grid>
                <TextBlock Text="{Binding MxMySliceLabel}"
                           Style="{StaticResource HelperTextStyle}" />

                <!-- Legend Card -->
                <TextBlock Text="Legends"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryNavyBrush}"
                           Style="{StaticResource PmmSectionHeaderStyle}"
                           Margin="0,16,0,6" />
                <Border BorderBrush="{DynamicResource BorderSoftBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="8"
                        Background="{DynamicResource PanelBackgroundBrush}">
                    <StackPanel>
                        <!-- Active Loadcase & Angle Info -->
                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,6">
                            <Run Text="{Binding SelectedLoadCaseRow.Name, FallbackValue='', Mode=OneWay}" />
                            <Run Text=" θ = " />
                            <Run Text="{Binding SelectedSliceAngleDegrees, StringFormat=F1, Mode=OneWay}" />
                            <Run Text="°" />
                        </TextBlock>

                        <!-- Concrete in Compression -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="12" Height="12" CornerRadius="2"
                                    Background="#5CF59E0B"
                                    BorderBrush="#A0475569" BorderThickness="0.5"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Concrete in compression"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Concrete in Tension (ignored) -->
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="12" Height="12" CornerRadius="2"
                                    Background="#3A64748B"
                                    BorderBrush="#A0475569" BorderThickness="0.5"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Concrete in tension (ignored)"
                                       Style="{StaticResource HelperTextStyle}"
                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>

        <!-- Col 1: Special Control Points -->
        <Border Grid.Row="0" Grid.Column="1"
                Style="{StaticResource ChartCardStyle}"
                Padding="8" Margin="4,4,2,4"
                Visibility="{Binding HasSevenPointValidation, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right"
                            Content="Export CtrlPts"
                            Style="{StaticResource CompactButtonStyle}"
                            Padding="8,2"
                            MinHeight="22"
                            FontSize="{StaticResource FontSizeCaption}"
                            Command="{Binding ExportAllPointsCommand}" />
                    <TextBlock Text="Special Control Points (7 Points)"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               Style="{StaticResource PmmSectionHeaderStyle}"
                               VerticalAlignment="Center" />
                </DockPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SevenPointValidationRows}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="True"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          ColumnWidth="Auto"
                          HeadersVisibility="Column"
                          HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Point" Binding="{Binding UniqueName}" Width="Auto"
                                            ElementStyle="{StaticResource CenterCellTextStyle}"
                                            HeaderStyle="{StaticResource CenterColumnHeaderStyle}" />
                        <DataGridTextColumn Header="Description" Binding="{Binding PointName}" Width="*"
                                            ElementStyle="{StaticResource LeftCellTextStyle}" />
                        <DataGridTextColumn Header="c (mm)" Binding="{Binding CDisplay}" Width="Auto"
                                            ElementStyle="{StaticResource CenterCellTextStyle}"
                                            HeaderStyle="{StaticResource CenterColumnHeaderStyle}" />
                        <DataGridTextColumn Binding="{Binding PnSolverDisplay}" Width="Auto"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextAlignment="Center">
                                        <Run Text="P" />
                                        <LineBreak />
                                        <Run Text="(" />
                                        <Run Text="{Binding DataContext.ForceUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding MNegDisplay}" Width="Auto"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextAlignment="Center">
                                        <Run Text="Mθ(-)" />
                                        <LineBreak />
                                        <Run Text="(" />
                                        <Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding MPosDisplay}" Width="Auto"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextAlignment="Center">
                                        <Run Text="Mθ(+)" />
                                        <LineBreak />
                                        <Run Text="(" />
                                        <Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Col 2: Demand / Capacity Summary Table -->
        <Border Grid.Row="0" Grid.Column="2"
                Style="{StaticResource ChartCardStyle}"
                Padding="8" Margin="2,4,4,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Demand / Capacity Summary"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryNavyBrush}"
                           Style="{StaticResource PmmSectionHeaderStyle}"
                           Margin="0,0,0,6" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding LoadCaseRows}"
                          SelectedItem="{Binding SelectedLoadCaseRow}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="True"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          IsReadOnly="True"
                          ColumnWidth="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WarningAmberSoftBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFailing}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Index}"
                                            Width="28"
                                            ElementStyle="{StaticResource CenterCellTextStyle}"
                                            HeaderStyle="{StaticResource CenterColumnHeaderStyle}" />
                        <DataGridTextColumn Header="LC Name" Binding="{Binding Name}"
                                            Width="*" MinWidth="80"
                                            ElementStyle="{StaticResource LeftCellTextStyle}" />
                        <DataGridTextColumn Binding="{Binding PDisplay}"
                                            Width="Auto" MinWidth="45"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap" TextAlignment="Center">
                                        <Run Text="P" /><LineBreak />
                                        <Run Text="(" /><Run Text="{Binding DataContext.ForceUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" /><Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding MxDisplay}"
                                            Width="Auto" MinWidth="45"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap" TextAlignment="Center">
                                        <Run Text="Mx" /><LineBreak />
                                        <Run Text="(" /><Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" /><Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding MyDisplay}"
                                            Width="Auto" MinWidth="45"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap" TextAlignment="Center">
                                        <Run Text="My" /><LineBreak />
                                        <Run Text="(" /><Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" /><Run Text=")" />
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding UtilizationDisplay}"
                                            Width="Auto" MinWidth="40"
                                            ElementStyle="{StaticResource CenterCellTextStyle}">
                            <DataGridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap" TextAlignment="Center">UR</TextBlock>
                                </DataTemplate>
                            </DataGridTextColumn.HeaderTemplate>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}"
                                            Width="Auto" MinWidth="50"
                                            ElementStyle="{StaticResource CenterCellTextStyle}"
                                            HeaderStyle="{StaticResource CenterColumnHeaderStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
