<Window x:Class="MBColumn.Presentation.Wpf.Views.PmmInteractionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="PMM Interaction Details"
        Width="1400" Height="900"
        MinWidth="1100" MinHeight="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource LightBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,5" />
        </Style>
        <Style x:Key="ResultChartCardStyle" TargetType="Border" BasedOn="{StaticResource ChartCardStyle}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinHeight" Value="220" />
        </Style>
        <Style x:Key="ChartInlineSettingsStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="ChartConfigCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style x:Key="ChartConfigLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="ChartConfigInputStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="54" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" MinWidth="380" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" MinWidth="560" />
        </Grid.ColumnDefinitions>

        <!-- Left: PMM Details sidebar -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Style="{StaticResource SidebarCardStyle}">
                <StackPanel>
                    <!-- Header -->
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right"
                                Content="Export PMM CtrlPts"
                                Style="{StaticResource CompactButtonStyle}"
                                Command="{Binding ExportAllPointsCommand}" />
                        <TextBlock Text="PMM Check in Details"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Diagram Viewports -->
                    <TextBlock Text="Diagram Viewports"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="0,4,0,4" />
                    <TextBlock Text="{Binding ViewportDropdownText}"
                               Style="{StaticResource HelperTextStyle}"
                               Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding ViewportOptions}" Margin="0,0,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected}"
                                          MinWidth="92"
                                          Margin="0,2,10,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,0,0,10" Background="{DynamicResource BorderSoftBrush}" />

                    <!-- Slice Navigation -->
                    <TextBlock Text="Slice Navigation"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Angle theta (Mx, My)"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SelectedSliceAngleDegrees, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                 HorizontalContentAlignment="Right" />
                        <TextBlock Grid.Column="2" Text="deg"
                                   Style="{StaticResource UnitTextStyle}"
                                   Margin="6,0,0,10" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Axial load"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SelectedAxialLoad, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                 HorizontalContentAlignment="Right" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ForceUnitLabel}"
                                   Style="{StaticResource UnitTextStyle}"
                                   Margin="6,0,0,10" />
                    </Grid>
                    <TextBlock Text="{Binding PmSliceLabel}" Style="{StaticResource HelperTextStyle}" />
                    <TextBlock Text="{Binding MxMySliceLabel}" Style="{StaticResource HelperTextStyle}" Margin="0,2,0,0" />
                    <controls:SectionStateInsetCanvas
                        InsetFigure="{Binding PmChartInset}"
                        Height="190"
                        Margin="0,10,0,10" />

                    <Separator Margin="0,0,0,10" Background="{DynamicResource BorderSoftBrush}" />

                    <!-- Demand Source -->
                    <TextBlock Text="Demand Source"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding DemandSourceSummary}" Style="{StaticResource HelperTextStyle}" />
                    <TextBlock Text="{Binding DemandSourceDetail}" Style="{StaticResource HelperTextStyle}" Margin="0,2,0,10" />

                    <!-- 7 Special Capacity Points -->
                    <StackPanel Margin="0,0,0,10"
                                Visibility="{Binding HasSevenPointValidation, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="7 Capacity Points (Current Slice)"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Margin="0,0,0,6" />
                        <DataGrid ItemsSource="{Binding SevenPointValidationRows}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="False"
                                  ColumnWidth="Auto"
                                  HeadersVisibility="Column"
                                  MaxHeight="250"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Point" Binding="{Binding UniqueName}" Width="Auto" />
                                <DataGridTextColumn Header="Description" Binding="{Binding PointName}" Width="*" />
                                <DataGridTextColumn Header="c (mm)" Binding="{Binding CDisplay}" Width="Auto" />
                                <DataGridTextColumn Binding="{Binding PnSolverDisplay}" Width="Auto">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="P (" />
                                                <Run Text="{Binding DataContext.ForceUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding MnSolverDisplay}" Width="Auto">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="M (" />
                                                <Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                <Run Text=")" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Load Case PMM Utilization -->
                    <TextBlock Text="Load Case PMM Utilization"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               Margin="0,0,0,6" />
                    <DataGrid ItemsSource="{Binding LoadCaseRows}"
                              SelectedItem="{Binding SelectedLoadCaseRow}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeColumns="True"
                              CanUserResizeRows="False"
                              CanUserSortColumns="False"
                              IsReadOnly="True"
                              ColumnWidth="Auto"
                              MinHeight="126"
                              MaxHeight="300"
                              HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFailing}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Load Case" Binding="{Binding Name}"
                                                Width="*" MinWidth="80"
                                                ElementStyle="{StaticResource WrapLeftAlignText}" />
                            <DataGridTextColumn Binding="{Binding PDisplay}"
                                                Width="Auto" MinWidth="45"
                                                ElementStyle="{StaticResource WrapRightAlignText}">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" TextAlignment="Right">
                                            <Run Text="P" /><LineBreak />
                                            <Run Text="(" /><Run Text="{Binding DataContext.ForceUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" /><Run Text=")" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding MxDisplay}"
                                                Width="Auto" MinWidth="45"
                                                ElementStyle="{StaticResource WrapRightAlignText}">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" TextAlignment="Right">
                                            <Run Text="Mx" /><LineBreak />
                                            <Run Text="(" /><Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" /><Run Text=")" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding MyDisplay}"
                                                Width="Auto" MinWidth="45"
                                                ElementStyle="{StaticResource WrapRightAlignText}">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" TextAlignment="Right">
                                            <Run Text="My" /><LineBreak />
                                            <Run Text="(" /><Run Text="{Binding DataContext.MomentUnitLabel, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" /><Run Text=")" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding UtilizationDisplay}"
                                                Width="Auto" MinWidth="60"
                                                ElementStyle="{StaticResource WrapRightAlignText}">
                                <DataGridTextColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" TextAlignment="Right">Utilization<LineBreak />Ratio</TextBlock>
                                    </DataTemplate>
                                </DataGridTextColumn.HeaderTemplate>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}"
                                                Width="Auto" MinWidth="50"
                                                ElementStyle="{StaticResource WrapLeftAlignText}" />
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <GridSplitter Grid.Column="1"
                      Width="10"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource LightBackgroundBrush}" />

        <!-- Right: Charts area (65% 2D + 35% 3D) -->
        <Grid Grid.Column="2" Margin="8,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="35*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: PM 2D + Mx-My 2D stacked -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{Binding ShowPM, Converter={StaticResource BoolToGridLengthConverter}}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{Binding ShowMxMy, Converter={StaticResource BoolToGridLengthConverter}}" />
                </Grid.RowDefinitions>

                <!-- PM 2D chart -->
                <Border Grid.Row="0"
                        Style="{StaticResource ResultChartCardStyle}"
                        Visibility="{Binding ShowPM, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8" MinHeight="28">
                            <Button DockPanel.Dock="Right"
                                    Content="x"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Close viewport"
                                    Command="{Binding CloseViewportCommand}"
                                    CommandParameter="{x:Static vm:DiagramViewportType.PM2D}" />
                            <TextBlock Text="{Binding PM.DiagramTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       VerticalAlignment="Center"
                                       ToolTip="{Binding PM.DiagramTitle}" />
                        </DockPanel>
                        <Border Grid.Row="1" Style="{StaticResource ChartInlineSettingsStyle}">
                            <WrapPanel>
                                <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Labels" IsChecked="{Binding ShowLabels}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Legend" IsChecked="{Binding ShowLegend}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Demand" IsChecked="{Binding ShowDemandPoint}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="P max/min" IsChecked="{Binding ShowPmaxPmin}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Nominal" IsChecked="{Binding ShowNominalCurve}"
                                          Style="{StaticResource ChartConfigCheckBoxStyle}"
                                          Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="P step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding PStep, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                         Style="{StaticResource ChartConfigInputStyle}" />
                                <TextBlock Text="M step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding MStep, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                         Style="{StaticResource ChartConfigInputStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding ShowLegend, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="14" Height="3" Background="{DynamicResource PrimaryNavyBrush}" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="Design" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Border Width="14" Height="3" Background="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" Margin="0,0,4,2"
                                            Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Nominal" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2"
                                               Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Red" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-01" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Orange" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-02" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Gold" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-03" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Green" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-04" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Blue" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-05" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Indigo" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-06" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Path Data="M 0,-5.5 L 5.5,5 L -5.5,5 Z" Fill="Violet" Stroke="Black" StrokeThickness="1" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="CP-07" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <controls:DiagramCanvas2D Grid.Row="2"
                                                  MinHeight="220"
                                                  Points="{Binding PmAnglePoints}"
                                                  ReferenceLines="{Binding PmReferenceLines}"
                                                  XAxisLabel="{Binding PM.XAxisLabel}"
                                                  YAxisLabel="{Binding PM.YAxisLabel}"
                                                  ShowGrid="{Binding ShowGrid}"
                                                  ShowLabels="{Binding ShowLabels}"
                                                  ShowDemandPoint="{Binding ShowDemandPoint}"
                                                  ShowDemandLabel="False"
                                                  ShowReferenceLines="{Binding ShowPmaxPmin}"
                                                  ShowNominalCurve="{Binding ShowNominalCurve}"
                                                  XGridStep="{Binding MStep}"
                                                  YGridStep="{Binding PStep}"
                                                  BoundsOverride="{Binding SharedPmBounds}"
                                                  SelectedPoint="{Binding SelectedChartPoint}"
                                                  HighlightedDemandLabel="{Binding HighlightedDemandLabel}"
                                                  Ratio="{Binding PM.Ratio}"
                                                  ResetVersion="{Binding PM.ResetVersion}" />
                    </Grid>
                </Border>

                <!-- Spacer between PM and Mx-My -->
                <Border Grid.Row="1" Height="8"
                        Visibility="{Binding ShowMxMy, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Mx-My 2D chart -->
                <Border Grid.Row="2"
                        Style="{StaticResource ResultChartCardStyle}"
                        Visibility="{Binding ShowMxMy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8" MinHeight="28">
                            <Button DockPanel.Dock="Right"
                                    Content="x"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Close viewport"
                                    Command="{Binding CloseViewportCommand}"
                                    CommandParameter="{x:Static vm:DiagramViewportType.MxMy2D}" />
                            <TextBlock Text="Mx-My Diagram"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Grid.Row="1" Style="{StaticResource ChartInlineSettingsStyle}">
                            <WrapPanel>
                                <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Labels" IsChecked="{Binding ShowLabels}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Legend" IsChecked="{Binding ShowLegend}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Demand" IsChecked="{Binding ShowDemandPoint}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Nominal" IsChecked="{Binding ShowNominalCurve}"
                                          Style="{StaticResource ChartConfigCheckBoxStyle}"
                                          Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <CheckBox Content="Equal aspect" IsChecked="{Binding UseEqualAspectForMM}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <TextBlock Text="X step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding MStepX, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                         Style="{StaticResource ChartConfigInputStyle}" />
                                <TextBlock Text="Y step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding MStepY, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}"
                                         Style="{StaticResource ChartConfigInputStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding ShowLegend, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="14" Height="3" Background="{DynamicResource PrimaryNavyBrush}" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="Design" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Border Width="14" Height="3" Background="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" Margin="0,0,4,2"
                                            Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Nominal" Style="{StaticResource ChartConfigLabelStyle}"
                                               Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <controls:DiagramCanvas2D Grid.Row="2"
                                                  MinHeight="220"
                                                  Points="{Binding MxMyPoints}"
                                                  XAxisLabel="{Binding MM.XAxisLabel}"
                                                  YAxisLabel="{Binding MM.YAxisLabel}"
                                                  ShowGrid="{Binding ShowGrid}"
                                                  ShowLabels="{Binding ShowLabels}"
                                                  ShowDemandPoint="{Binding ShowDemandPoint}"
                                                  ShowDemandLabel="False"
                                                  ShowNominalCurve="{Binding ShowNominalCurve}"
                                                  UseEqualAspect="{Binding UseEqualAspectForMM}"
                                                  XGridStep="{Binding MStepX}"
                                                  YGridStep="{Binding MStepY}"
                                                  SelectedPoint="{Binding SelectedChartPoint}"
                                                  HighlightedDemandLabel="{Binding HighlightedDemandLabel}"
                                                  Ratio="{Binding MM.Ratio}"
                                                  ResetVersion="{Binding MM.ResetVersion}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Right column: 3D PMM chart -->
            <Border Grid.Column="2"
                    Style="{StaticResource ResultChartCardStyle}"
                    Visibility="{Binding ShowPmm3D, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8" MinHeight="28">
                        <Button DockPanel.Dock="Right"
                                Content="x"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Close viewport"
                                Command="{Binding CloseViewportCommand}"
                                CommandParameter="{x:Static vm:DiagramViewportType.Pmm3D}" />
                        <TextBlock Text="3D PMM View"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <Border Grid.Row="1" Style="{StaticResource ChartInlineSettingsStyle}">
                        <WrapPanel>
                            <CheckBox Content="Surface" IsChecked="{Binding ShowSurface3D}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Wire" IsChecked="{Binding ShowWireframe3D}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Demand" IsChecked="{Binding ShowDemandPoint}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Grid" IsChecked="{Binding PM3D.ShowGrid}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Labels" IsChecked="{Binding PM3D.ShowLabels}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Theta slice" IsChecked="{Binding PM3D.ShowSlicePlane}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="P slice" IsChecked="{Binding PM3D.ShowAxialLoadSlice}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <Button Content="Reset"
                                    Command="{Binding PM3D.ResetCameraCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    MinHeight="24"
                                    Padding="8,2"
                                    Margin="0,0,8,2" />
                            <TextBlock Text="{Binding PM3D.SelectedPmAngleLabel}"
                                       Style="{StaticResource ChartConfigLabelStyle}"
                                       Margin="0,0,8,2" />
                            <TextBlock Text="{Binding PM3D.SelectedAxialLoadLabel}"
                                       Style="{StaticResource ChartConfigLabelStyle}" />
                        </WrapPanel>
                    </Border>
                    <controls:InteractionViewport3D Grid.Row="2"
                                                   MinHeight="220"
                                                   Points="{Binding PM3D.SurfacePoints}"
                                                   DemandPoint="{Binding PM3D.DemandPoint}"
