<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.AutoGroupColumnsByTierView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ag="clr-namespace:MBColumn.Application.DTOs.Etabs.AutoGrouping;assembly=MBColumn.Application"
        Title="{StaticResource AutoGrouping_DialogTitle}"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindowStyle}">
    <Window.Resources>
        <Style x:Key="AutoGroupingSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSection}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource DarkNavyBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AutoGroupingStepNumberStyle" TargetType="Border">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="AutoGroupingStepTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AutoGroupingMessageSeverityStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static ag:AutoGroupingValidationSeverity.Warning}">
                    <Setter Property="Foreground" Value="{DynamicResource WarningAmberBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static ag:AutoGroupingValidationSeverity.Error}">
                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Style="{StaticResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{StaticResource AutoGrouping_CloseButton}"
                        Command="{Binding CancelCommand}"
                        Width="30"
                        Height="26"
                        Padding="0"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <TextBlock Text="{StaticResource AutoGrouping_DialogTitle}"
                           Style="{StaticResource DialogHeaderTitleTextStyle}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DialogBodyBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource DialogPanelBorderStyle}"
                        Padding="12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <Border DockPanel.Dock="Left">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AutoGroupingStepNumberStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTierDefinitionsStep}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTierDefinitionsStep}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="{StaticResource AutoGrouping_TierDefinitionsHeader}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource AutoGroupingStepTitleStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTierDefinitionsStep}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource DarkNavyBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>

                        <Border Grid.Column="1"
                                Height="1"
                                Background="{DynamicResource BorderGreyBrush}"
                                VerticalAlignment="Center"
                                Margin="8,0" />

                        <DockPanel Grid.Column="2">
                            <Border DockPanel.Dock="Left">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AutoGroupingStepNumberStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGroupingPreviewStep}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBlueBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGroupingPreviewStep}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="{StaticResource AutoGrouping_PreviewHeader}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource AutoGroupingStepTitleStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGroupingPreviewStep}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource DarkNavyBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource DialogPanelBorderStyle}"
                        Visibility="{Binding IsTierDefinitionsStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="{StaticResource AutoGrouping_AddTierButton}"
                                            Command="{Binding AddTierCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinHeight="28"
                                            Padding="10,4" />
                                    <Button Content="{StaticResource AutoGrouping_RemoveTierButton}"
                                            Command="{Binding RemoveTierCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinHeight="28"
                                            Padding="10,4"
                                            Margin="6,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{StaticResource AutoGrouping_AssignedTiersHeader}"
                                           Style="{StaticResource AutoGroupingSectionTitleStyle}" />
                            </DockPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Tiers}"
                                     SelectedItem="{Binding SelectedTier, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                CornerRadius="4"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBox Grid.Row="0"
                                                         Text="{Binding TierName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         FontWeight="SemiBold" />

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{StaticResource AutoGrouping_LabelFilterColumn}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding LabelFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="{StaticResource AutoGrouping_LabelFilterToolTip}" />
                                                </Grid>

                                                <TextBlock Grid.Row="4"
                                                           Text="{StaticResource AutoGrouping_AssignedStoriesHeader}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource DarkNavyBrush}" />

                                                <TextBlock Grid.Row="6"
                                                           Text="{StaticResource AutoGrouping_NoAssignedStories}"
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AssignedStories.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <ItemsControl Grid.Row="6" ItemsSource="{Binding AssignedStories}">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AssignedStories.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Background="{DynamicResource LightBackgroundBrush}"
                                                                        BorderBrush="{DynamicResource BorderSoftBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="4"
                                                                        Padding="8,4">
                                                                    <TextBlock Text="{Binding StoryName}" />
                                                                </Border>
                                                                <Button Grid.Column="1"
                                                                        Content="X"
                                                                        Command="{Binding DataContext.RemoveStoryFromTierCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                                        Width="26"
                                                                        Height="24"
                                                                        Padding="0"
                                                                        Margin="6,0,0,0" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <ItemsControl Grid.Row="8" ItemsSource="{Binding WarningMessages}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="{DynamicResource WarningAmberBrush}"
                                                                       FontSize="{StaticResource FontSizeCaption}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,0,0,2" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Border Grid.Column="2"
                                BorderBrush="{DynamicResource BorderGreyBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Background="{DynamicResource PanelBackgroundBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{StaticResource AutoGrouping_AvailableStoriesHeader}"
                                           Style="{StaticResource AutoGroupingSectionTitleStyle}" />

                                <TextBlock Grid.Row="2"
                                           Text="{StaticResource AutoGrouping_NoAvailableStories}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAvailableStories}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ListBox x:Name="AvailableStoriesListBox"
                                         Grid.Row="2"
                                         ItemsSource="{Binding AvailableStories}"
                                         SelectionMode="Extended"
                                         SelectionChanged="OnAvailableStoriesSelectionChanged"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <ListBox.Style>
                                        <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAvailableStories}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.Style>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,5"
                                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock Text="{Binding StoryName}" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="4"
                                        Content="{StaticResource AutoGrouping_AssignToTierButton}"
                                        Command="{Binding AssignSelectedStoriesCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        MinHeight="30"
                                        Padding="12,5"
                                        HorizontalAlignment="Stretch" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Visibility="{Binding IsGroupingPreviewStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="128" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource DialogPanelBorderStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{StaticResource AutoGrouping_TierSummaryHeader}"
                                       Style="{StaticResource AutoGroupingSectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{StaticResource AutoGrouping_NoTierSummaryRows}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasTierSummaryRows}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <DataGrid ItemsSource="{Binding TierSummaryRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      IsReadOnly="True"
                                      MaxHeight="108"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Style>
                                    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasTierSummaryRows}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{StaticResource AutoGrouping_SummaryTierColumn}"
                                                        Binding="{Binding TierName}"
                                                        Width="1*" />
                                    <DataGridTextColumn Header="{StaticResource AutoGrouping_SummaryStoryRangeColumn}"
                                                        Binding="{Binding StoryRange}"
                                                        Width="1*" />
                                    <DataGridTextColumn Header="{StaticResource AutoGrouping_SummarySectionCountColumn}"
                                                        Binding="{Binding ColumnSectionCount}"
                                                        Width="90"
                                                        ElementStyle="{StaticResource RightAlignText}" />
                                    <DataGridTextColumn Header="{StaticResource AutoGrouping_SummaryObjectCountColumn}"
                                                        Binding="{Binding ObjectCount}"
                                                        Width="90"
                                                        ElementStyle="{StaticResource RightAlignText}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource DialogPanelBorderStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{StaticResource AutoGrouping_PreviewHeader}"
                                       Style="{StaticResource AutoGroupingSectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{StaticResource AutoGrouping_NoPreviewRows}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasColumnPreviewGroups}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ColumnPreviewGroups}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasColumnPreviewGroups}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderGreyBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,0,0,10"
                                                    Margin="0,0,0,10">
                                                <DockPanel>
                                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.2*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding ColumnLabel}"
                                                                   FontSize="{StaticResource FontSizeSection}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource DarkNavyBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding TiersDisplayText}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding SectionCount, StringFormat={}{0} sections}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   Margin="16,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding TotalObjects, StringFormat={}{0} objects}"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   Margin="16,0,0,0"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <DataGrid ItemsSource="{Binding Items}"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              CanUserReorderColumns="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              EnableRowVirtualization="True"
                                                              VirtualizingPanel.IsVirtualizing="True"
                                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="{StaticResource AutoGrouping_PreviewTierColumn}"
                                                                                Binding="{Binding TierName}"
                                                                                Width="1*" />
                                                            <DataGridTextColumn Header="{StaticResource AutoGrouping_PreviewStoryRangeColumn}"
                                                                                Binding="{Binding StoryRange}"
                                                                                Width="105" />
                                                            <DataGridTextColumn Header="{StaticResource AutoGrouping_PreviewMbSectionColumn}"
                                                                                Binding="{Binding MbColumnSectionName}"
                                                                                Width="1.2*" />
                                                            <DataGridTextColumn Header="{StaticResource AutoGrouping_PreviewCountColumn}"
                                                                                Binding="{Binding Count}"
                                                                                Width="78"
                                                                                ElementStyle="{StaticResource RightAlignText}" />
                                                            <DataGridTextColumn Header="{StaticResource AutoGrouping_PreviewEtabsSectionsColumn}"
                                                                                Binding="{Binding EtabsSectionsDisplayText}"
                                                                                Width="1.3*" />
                                                            <DataGridTextColumn Header="{StaticResource AutoGrouping_PreviewMaterialsColumn}"
                                                                                Binding="{Binding MaterialsDisplayText}"
                                                                                Width="1*" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource DialogPanelBorderStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{StaticResource AutoGrouping_ValidationHeader}"
                                       Style="{StaticResource AutoGroupingSectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{StaticResource AutoGrouping_NoValidationMessages}"
                                       Foreground="{DynamicResource TextMutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasValidationMessages}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ValidationMessages}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasValidationMessages}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding SeverityDisplayText}"
                                                           Style="{StaticResource AutoGroupingMessageSeverityStyle}"
                                                           MinWidth="64" />
                                                <TextBlock Text="{Binding Message}"
                                                           Foreground="{DynamicResource TextDarkBrush}"
                                                           TextWrapping="Wrap" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterBarStyle}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{StaticResource AutoGrouping_CancelButton}"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinHeight="32"
                            Padding="14,6" />
                    <Button Content="{StaticResource AutoGrouping_BackButton}"
                            Command="{Binding BackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinHeight="32"
                            Padding="14,6"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsGroupingPreviewStep, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="{StaticResource AutoGrouping_PreviewButton}"
                            Command="{Binding PreviewCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinHeight="32"
                            Padding="16,6"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsTierDefinitionsStep, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="{StaticResource AutoGrouping_ApplyButton}"
                            Command="{Binding ApplyCommand}"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinHeight="32"
                            Padding="16,6"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsGroupingPreviewStep, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
