<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="MBColumn.Presentation.Wpf.Views.SlendernessCalculationDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls">
        <Border
                Background="#FAFCFF"
                Padding="22"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="0,0,0,14"
                           Background="Transparent">
                    <TextBlock Text="Determine Design Moment - EC2"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryNavyBrush}" />
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Background="White">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="2.4*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SlendernessCalculationLoadCase.Name, StringFormat='Selected Load Case: {0}', TargetNullValue='Selected Load Case'}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Margin="0,0,0,10"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="NEd"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding SlendernessCalculationLoadCase.NEd, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="kN"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   FontSize="{StaticResource FontSizeBody}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="6,0">
                                <StackPanel>
                                    <TextBlock Text="Member End Moments"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                            <TextBlock Text="Mx Top" Style="{StaticResource FieldLabelTextStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding SlendernessCalculationLoadCase.MxTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                <TextBlock Grid.Column="1" Text="kNÂ·m" VerticalAlignment="Center" TextAlignment="Right" FontSize="{StaticResource FontSizeBody}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="Mx Bottom" Style="{StaticResource FieldLabelTextStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding SlendernessCalculationLoadCase.MxBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                <TextBlock Grid.Column="1" Text="kNÂ·m" VerticalAlignment="Center" TextAlignment="Right" FontSize="{StaticResource FontSizeBody}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="My Top" Style="{StaticResource FieldLabelTextStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding SlendernessCalculationLoadCase.MyTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                <TextBlock Grid.Column="1" Text="kNÂ·m" VerticalAlignment="Center" TextAlignment="Right" FontSize="{StaticResource FontSizeBody}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2">
                                            <TextBlock Text="My Bottom" Style="{StaticResource FieldLabelTextStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding SlendernessCalculationLoadCase.MyBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                                <TextBlock Grid.Column="1" Text="kNÂ·m" VerticalAlignment="Center" TextAlignment="Right" FontSize="{StaticResource FontSizeBody}" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SlendernessCalculationLoadCase.MxUsed, TargetNullValue='Mx Used auto', StringFormat='Mx Used {0:F1} kNÂ·m'}"
                                                   Style="{StaticResource HelperTextStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SlendernessCalculationLoadCase.MyUsed, TargetNullValue='My Used auto', StringFormat='My Used {0:F1} kNÂ·m'}"
                                                   Style="{StaticResource HelperTextStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Section Properties"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Margin="0,0,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Concrete gross area - A" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="c" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewAreaText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Total longitudinal rebar area - A" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="s,total" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewAsTotalText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Second moment of area about x-axis - I" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="xx" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewIxxText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Second moment of area about y-axis - I" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="yy" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewIyyText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Radius of gyration for x slenderness - i" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="x" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewIxText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}" Margin="0"><Run Text="Radius of gyration for y slenderness - i" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="y" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewIyText, Mode=OneWay}" /></TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Steel elastic modulus - E" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="s" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding Es, Mode=OneWay, StringFormat=F0}" /><Run Text=" MPa" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Concrete secant modulus from EC2 - E" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="cm" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewEcmText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Effective depth used for M" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="x" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=" curvature - d" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="x" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewDxText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Effective depth used for M" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="y" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=" curvature - d" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="y" BaselineAlignment="Subscript" FontSize="9" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewDyText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Mechanical reinforcement ratio - " Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="Ï‰" Foreground="{DynamicResource AccentBlueBrush}" /><Run Text=": " /><Run Text="{Binding PreviewOmegaText, Mode=OneWay}" /></TextBlock>
                                            <TextBlock Style="{StaticResource ParameterMeaningTextStyle}" Margin="0"><Run Text="Axial load ratio for selected case - n: " Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="{Binding PreviewNRatioText, Mode=OneWay}" /></TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="White"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.72*" />
                                    <ColumnDefinition Width="1.72*" />
                                    <ColumnDefinition Width="1.95*" />
                                    <ColumnDefinition Width="1.95*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.ColumnSpan="4"
                                           Text="Member End Moments Diagram"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Margin="0,0,0,4" />
                                <controls:MomentDiagramControl Grid.Row="1"
                                                               Grid.Column="2"
                                                               Title="Mx"
                                                               DiagramColor="#c0392b"
                                                               MomentTop="{Binding SlendernessCalculationLoadCase.MxTop}"
                                                               MomentBottom="{Binding SlendernessCalculationLoadCase.MxBottom}"
                                                               Height="110"
                                                               Margin="2,0,8,0" />
                                <Rectangle Grid.Row="1"
                                           Grid.Column="2"
                                           Fill="#D6DEE6"
                                           Width="1"
                                           HorizontalAlignment="Right"
                                           Margin="0,4,0,4" />
                                <controls:MomentDiagramControl Grid.Row="1"
                                                               Grid.Column="3"
                                                               Title="My"
                                                               DiagramColor="#2471a3"
                                                               MomentTop="{Binding SlendernessCalculationLoadCase.MyTop}"
                                                               MomentBottom="{Binding SlendernessCalculationLoadCase.MyBottom}"
                                                               Height="110"
                                                               Margin="8,0,2,0" />
                            </Grid>
                        </Border>

                            <StackPanel Margin="0,0,0,12" Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                                <DockPanel>
                                                    <TextBlock Text="NEd" Style="{StaticResource FieldLabelTextStyle}" />
                                                    <TextBlock Text="{Binding ForceLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBox Text="{Binding SlendernessCalculationLoadCase.NEd, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" />
                                            </StackPanel>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                       Text="Member End Moments"
                                                       Style="{StaticResource InputSubsectionTitleTextStyle}"
                                                       Margin="0,2,0,6" />

                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
                                                <DockPanel>
                                                    <TextBlock Text="Mx Top" Style="{StaticResource FieldLabelTextStyle}" />
                                                    <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBox Text="{Binding SlendernessCalculationLoadCase.MxTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
                                                <DockPanel>
                                                    <TextBlock Text="Mx Bottom" Style="{StaticResource FieldLabelTextStyle}" />
                                                    <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBox Text="{Binding SlendernessCalculationLoadCase.MxBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="3" Grid.Column="0">
                                                <DockPanel>
                                                    <TextBlock Text="My Top" Style="{StaticResource FieldLabelTextStyle}" />
                                                    <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBox Text="{Binding SlendernessCalculationLoadCase.MyTop, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="3" Grid.Column="2">
                                                <DockPanel>
                                                    <TextBlock Text="My Bottom" Style="{StaticResource FieldLabelTextStyle}" />
                                                    <TextBlock Text="{Binding MomentLabel}" Style="{StaticResource UnitTextStyle}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBox Text="{Binding SlendernessCalculationLoadCase.MyBottom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SlendernessCalculationLoadCase.MxUsed, TargetNullValue='Mx Used auto', StringFormat='Mx Used {0:F1}'}"
                                                       Style="{StaticResource HelperTextStyle}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SlendernessCalculationLoadCase.MyUsed, TargetNullValue='My Used auto', StringFormat='My Used {0:F1}'}"
                                                       Style="{StaticResource HelperTextStyle}" />
                                        </Grid>
                                    </StackPanel>

                                    <Border Grid.Row="1"
                                            Background="White"
                                            BorderBrush="{DynamicResource BorderSoftBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="6"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Member End Moments Diagram"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="1" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <controls:MomentDiagramControl Grid.Column="0"
                                                                               Title="Mx"
                                                                               DiagramColor="#c0392b"
                                                                               MomentTop="{Binding SlendernessCalculationLoadCase.MxTop}"
                                                                               MomentBottom="{Binding SlendernessCalculationLoadCase.MxBottom}"
                                                                               Height="300"
                                                                               Margin="2,0" />
                                                <Rectangle Grid.Column="1" Fill="#D6DEE6" Margin="0,4" />
                                                <controls:MomentDiagramControl Grid.Column="2"
                                                                               Title="My"
                                                                               DiagramColor="#2471a3"
                                                                               MomentTop="{Binding SlendernessCalculationLoadCase.MyTop}"
                                                                               MomentBottom="{Binding SlendernessCalculationLoadCase.MyBottom}"
                                                                               Height="300"
                                                                               Margin="2,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                        <Border Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="1. Section properties"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Concrete gross area - A" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="c" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewAreaText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Total longitudinal rebar area - A" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="s,total" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewAsTotalText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Second moment of area about x-axis - I" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="xx" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewIxxText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Second moment of area about y-axis - I" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="yy" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewIyyText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Radius of gyration for x slenderness - i" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="x" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewIxText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Radius of gyration for y slenderness - i" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="y" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewIyText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Concrete design strength - f" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="cd" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewFcdText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Steel design yield strength - f" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="yd" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewFydText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Steel elastic modulus - E" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="s" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding Es, Mode=OneWay, StringFormat=F0}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Concrete secant modulus from EC2 - E" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="cm" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewEcmText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Effective depth used for M" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="x" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=" curvature - d" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="x" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewDxText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Effective depth used for M" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="y" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=" curvature - d" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="y" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text=": " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewDyText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}">
                                    <Run Text="Mechanical reinforcement ratio - &#x03C9;: " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewOmegaText, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource ParameterMeaningTextStyle}" Margin="0">
                                    <Run Text="Axial load ratio for selected case - n: " Foreground="{DynamicResource AccentBlueBrush}" />
                                    <Run Text="{Binding PreviewNRatioText, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="2. Detailed calculation"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           Margin="0,0,0,8"
                                           Visibility="Collapsed" />
                                <Border Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="0"
                                        Padding="0"
                                        Margin="0,0,0,12"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Member End Moments Diagram"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="1" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

