                                    </TextBlock>
                                    <TextBlock Style="{StaticResource ParameterMeaningTextStyle}"><Run Text="Moment shape factor - C: " Foreground="{DynamicResource AccentBlueBrush}" /><Run Text="Accounts for the first-order moment diagram between top and bottom. C = 1.7 - r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=", where r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=" = M" /><Run Text="01" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=" / M" /><Run Text="02" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=". The sign is preserved: positive r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=" means same-curvature bending, negative r" /><Run Text="m" BaselineAlignment="Subscript" FontSize="{StaticResource FontSizeSubscript}" /><Run Text=" means reverse-curvature bending. Smaller C lowers &#x03BB;lim; larger C raises &#x03BB;lim." /></TextBlock>
