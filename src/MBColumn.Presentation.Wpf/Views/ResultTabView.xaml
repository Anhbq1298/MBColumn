<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ResultTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels">
    <UserControl.Resources>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,5" />
        </Style>

        <Style x:Key="ResultChartCardStyle" TargetType="Border" BasedOn="{StaticResource ChartCardStyle}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinHeight" Value="220" />
        </Style>

        <Style x:Key="ChartInlineSettingsStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="ChartConfigCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="ChartConfigLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <Style x:Key="ChartConfigInputStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="54" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource LightBackgroundBrush}">
        <Grid.Resources>
            <Style x:Key="WrapRightAlignText" TargetType="TextBlock" BasedOn="{StaticResource RightAlignText}">
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="WrapLeftAlignText" TargetType="TextBlock" BasedOn="{StaticResource LeftAlignText}">
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="520" MinWidth="480" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" MinWidth="560" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- 1st: Results Summary (PMM, Shear, Compliance Overview)      -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Border Style="{StaticResource SidebarCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Results Summary"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Margin="0,0,0,12" />

                        <!-- Overall Column Status Badge -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Overall Column Status" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentBlueSoftBrush}"
                                    BorderBrush="{DynamicResource BorderGreyBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,4"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="{Binding StatusText}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource PrimaryNavyBrush}" />
                            </Border>
                        </Grid>

                        <Separator Margin="0,0,0,12" Background="{DynamicResource BorderSoftBrush}" />

                        <!-- Row-by-row Check Summaries -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="100" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- PMM Check Summary -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="PMM Interaction" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11.5" />
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Max Util.: " Style="{StaticResource MetricLabelStyle}" Margin="0" />
                                    <TextBlock Text="{Binding MaxUtilization, StringFormat={}{0:F3}}" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" />
                                    <TextBlock Text=" | Critical LC: " Style="{StaticResource MetricLabelStyle}" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding CriticalLoadCaseName}" TextTrimming="CharacterEllipsis" MaxWidth="150" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="8,2" CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="FAIL">
                                                <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusText}" FontWeight="Bold" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="FAIL">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Shear Check Summary -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,12" DataContext="{Binding Shear}">
                                <TextBlock Text="Shear Capacity" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11.5" />
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Max Util.: " Style="{StaticResource MetricLabelStyle}" Margin="0" />
                                    <TextBlock Text="{Binding GoverningUtilText}" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" />
                                    <TextBlock Text=" (EC2 §6.2)" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="8,2" CornerRadius="6" DataContext="{Binding Shear}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDemand}" Value="True">
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasDemand}" Value="True" />
                                                    <Condition Binding="{Binding IsGoverningPass}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontWeight="Bold" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="NO DEMAND" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDemand}" Value="True">
                                                    <Setter Property="Text" Value="{Binding GoverningStatusText}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasDemand}" Value="True" />
                                                        <Condition Binding="{Binding IsGoverningPass}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Reinforcement Compliance Summary -->
                            <StackPanel Grid.Row="2" Margin="0,0,0,4" DataContext="{Binding RebarCompliance}">
                                <TextBlock Text="Reinforcement Compliance" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11.5" />
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding CodeRef}" Style="{StaticResource MetricLabelStyle}" Margin="0" />
                                    <TextBlock Text=" - " Style="{StaticResource MetricLabelStyle}" Margin="0" Visibility="{Binding HasFails, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding FailCountText}" FontSize="10" Foreground="{DynamicResource AccentRedBrush}" Visibility="{Binding HasFails, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="All checks conforming" FontSize="10" Foreground="{DynamicResource SuccessGreenBrush}" Visibility="{Binding HasFails, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="8,2" CornerRadius="6" DataContext="{Binding RebarCompliance}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AllPass}" Value="False">
                                                <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusText}" FontWeight="Bold" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AllPass}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- 2nd: Reinforcement Code Compliance in Details              -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Border Style="{StaticResource SidebarCardStyle}"
                        DataContext="{Binding RebarCompliance}"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Reinforcement Code Compliance in Details"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Margin="0,0,0,4" />

                        <!-- Overall status badge -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Padding="10,2" CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AllPass}" Value="False">
                                                <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusText}" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AllPass}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="{Binding CodeRef, StringFormat='  {0}'}"
                                       Style="{StaticResource MetricValueStyle}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FailCountText, StringFormat='  - {0}'}"
                                       FontSize="10" Foreground="{DynamicResource AccentRedBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasFails, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>

                        <!-- Per-check list -->
                        <ItemsControl ItemsSource="{Binding Checks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Fail}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Margin="4,0,0,0">
                                            <TextBlock Text="{Binding Description}" FontSize="10.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextDarkBrush}" TextWrapping="Wrap" />
                                            <TextBlock FontSize="9.5" TextWrapping="Wrap" Margin="0,1,0,0">
                                                <Run Text="{Binding Provided, Mode=OneWay}" Foreground="{DynamicResource TextMutedBrush}" />
                                                <Run Text=" / " Foreground="{DynamicResource TextMutedBrush}" />
                                                <Run Text="{Binding Limit, Mode=OneWay}" Foreground="{DynamicResource TextMutedBrush}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding Reference}" FontSize="9"
                                                       Foreground="{DynamicResource TextMutedBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- 3rd: PMM Check in Details                                  -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Border Style="{StaticResource SidebarCardStyle}">
                    <StackPanel>
                        <!-- Header with Export PMM CtrlPts button -->
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Content="Export PMM CtrlPts"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Command="{Binding ExportAllPointsCommand}" />
                            <TextBlock Text="PMM Check in Details"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Diagram Viewports -->
                        <TextBlock Text="Diagram Viewports" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11" Margin="0,4,0,4" />
                        <TextBlock Text="{Binding ViewportDropdownText}" Style="{StaticResource HelperTextStyle}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding ViewportOptions}" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsSelected}"
                                              MinWidth="92"
                                              Margin="0,2,10,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,0,0,10" Background="{DynamicResource BorderSoftBrush}" />

                        <!-- Slice Navigation -->
                        <TextBlock Text="Slice Navigation" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Angle theta (Mx, My)" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedSliceAngleDegrees, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                     HorizontalContentAlignment="Right" />
                            <TextBlock Grid.Column="2" Text="deg" Style="{StaticResource UnitTextStyle}" Margin="6,0,0,10" />
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Axial load" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SelectedAxialLoad, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                     HorizontalContentAlignment="Right" />
                            <TextBlock Grid.Column="2" Text="{Binding ForceUnitLabel}" Style="{StaticResource UnitTextStyle}" Margin="6,0,0,10" />
                        </Grid>
                        <TextBlock Text="{Binding PmSliceLabel}" Style="{StaticResource HelperTextStyle}" />
                        <TextBlock Text="{Binding MxMySliceLabel}" Style="{StaticResource HelperTextStyle}" Margin="0,2,0,0" />
                        <controls:SectionStateInsetCanvas
                            InsetFigure="{Binding PmChartInset}"
                            Height="190"
                            Margin="0,10,0,10" />

                        <Separator Margin="0,0,0,10" Background="{DynamicResource BorderSoftBrush}" />

                        <TextBlock Text="Demand Source" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding DemandSourceSummary}" Style="{StaticResource HelperTextStyle}" />
                        <TextBlock Text="{Binding DemandSourceDetail}" Style="{StaticResource HelperTextStyle}" Margin="0,2,0,10" />

                        <!-- Load Case Demands & PMM Utilization -->
                        <TextBlock Text="Load Case PMM Utilization" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryNavyBrush}" FontSize="11" Margin="0,0,0,6" />
                        <DataGrid ItemsSource="{Binding LoadCaseRows}"
                                  SelectedItem="{Binding SelectedLoadCaseRow}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="False"
                                  IsReadOnly="True"
                                  ColumnWidth="SizeToCells"
                                  MinHeight="126"
                                  MaxHeight="240"
                                  HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFailing}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Load Case" Binding="{Binding Name}" Width="120" MinWidth="90" ElementStyle="{StaticResource WrapLeftAlignText}" />
                                <DataGridTextColumn Header="P" Binding="{Binding PDisplay}" Width="60" MinWidth="50" ElementStyle="{StaticResource WrapRightAlignText}" />
                                <DataGridTextColumn Header="Mx" Binding="{Binding MxDisplay}" Width="60" MinWidth="50" ElementStyle="{StaticResource WrapRightAlignText}" />
                                <DataGridTextColumn Header="My" Binding="{Binding MyDisplay}" Width="60" MinWidth="50" ElementStyle="{StaticResource WrapRightAlignText}" />
                                <DataGridTextColumn Header="Utilization Ratio" Binding="{Binding UtilizationDisplay}" Width="120" MinWidth="100" ElementStyle="{StaticResource WrapRightAlignText}" />
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="75" MinWidth="65" ElementStyle="{StaticResource WrapLeftAlignText}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- 4th: Shear Check in Details (EC2 §6.2)                      -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <Border Style="{StaticResource SidebarCardStyle}"
                        DataContext="{Binding Shear}"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Shear Check in Details (EC2 §6.2)"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Margin="0,0,0,4" />

                        <!-- Overall status badge (only when demand is non-zero) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding HasDemand, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Padding="10,2" CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGoverningPass}" Value="False">
                                                <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding GoverningStatusText}" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGoverningPass}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="{Binding GoverningUtilText, StringFormat='  UR = {0}'}"
                                       Style="{StaticResource MetricValueStyle}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Helper text when no demand -->
                        <TextBlock FontSize="10" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding HasDemand, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            No shear demand entered - capacity shown for reference.
                            Enter Vux / Vuy in the load case table.
                        </TextBlock>

                        <!-- Step 1 — Concrete capacity without links -->
                        <TextBlock Text="Step 1 - Without Reinforcement (VRd,c)"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   Margin="0,4,0,6" />

                        <!-- Circular section diagram + note (visible for circular only) -->
                        <Border Visibility="Collapsed"
                                Background="#F4F7FB" BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <!-- Canvas diagram -->
                                <Canvas Width="160" Height="130" Margin="0,0,12,0">
                                    <!-- Concrete section fill -->
                                    <Ellipse Canvas.Left="20" Canvas.Top="5" Width="120" Height="120"
                                             Fill="#DCE8F5" Stroke="#4A6FA5" StrokeThickness="2"/>
                                    <!-- Cover dashed circle (r≈50) -->
                                    <Ellipse Canvas.Left="34" Canvas.Top="19" Width="92" Height="92"
                                             Fill="Transparent" Stroke="#7A9FD4"
                                             StrokeThickness="1" StrokeDashArray="4 3"/>
                                    <!-- 8 rebar dots evenly on cover circle (r=46, center 80,65) -->
                                    <Ellipse Canvas.Left="76" Canvas.Top="15" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="108" Canvas.Top="28" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="122" Canvas.Top="61" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="108" Canvas.Top="93" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="76" Canvas.Top="106" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="44" Canvas.Top="93" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="30" Canvas.Top="61" Width="8" Height="8" Fill="#C0392B"/>
                                    <Ellipse Canvas.Left="44" Canvas.Top="28" Width="8" Height="8" Fill="#C0392B"/>
                                    <!-- bw = 0.8D chord at center y=65, half-width=48 (0.8×60) -->
                                    <Line X1="32" Y1="65" X2="128" Y2="65"
                                          Stroke="#E67E22" StrokeThickness="2.5"/>
                                    <TextBlock Canvas.Left="50" Canvas.Top="67"
                                               Text="bw = 0.8D" FontSize="8.5"
                                               Foreground="#E67E22" FontWeight="SemiBold"/>
                                    <!-- d: from top (y=5) to tension steel centroid (y=110) -->
                                    <Line X1="12" Y1="5" X2="12" Y2="110"
                                          Stroke="#1A3A5C" StrokeThickness="1.5"/>
                                    <Polygon Points="12,5 8,14 16,14" Fill="#1A3A5C"/>
                                    <Polygon Points="12,110 8,101 16,101" Fill="#1A3A5C"/>
                                    <TextBlock Canvas.Left="2" Canvas.Top="52"
                                               Text="d" FontSize="10" FontWeight="Bold"
                                               Foreground="#1A3A5C"/>
                                    <!-- D diameter bracket -->
                                    <Line X1="20" Y1="126" X2="140" Y2="126"
                                          Stroke="#666" StrokeThickness="1.5"/>
                                    <Polygon Points="20,126 28,122 28,130" Fill="#666"/>
                                    <Polygon Points="140,126 132,122 132,130" Fill="#666"/>
                                    <TextBlock Canvas.Left="76" Canvas.Top="128"
                                               Text="D" FontSize="9" FontWeight="Bold"
                                               Foreground="#666"/>
                                </Canvas>
                                <!-- Text notes -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Circular — EC2 §6.2.2(5)"
                                               FontWeight="SemiBold" FontSize="10"
                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                               Margin="0,0,0,5"/>
                                    <TextBlock FontSize="9.5" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,2">
                                        <Run Text="D = "/><Run Text="{Binding DiameterText, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock FontSize="9.5" Foreground="#E67E22" Margin="0,0,0,2" FontWeight="SemiBold">
                                        <Run Text="bw = 0.8D = "/><Run Text="{Binding BwXText, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="9.5" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,2">
                                        <Run Text="d (X) = "/><Run Text="{Binding DEffXText, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock FontSize="9.5" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,4">
                                        <Run Text="d (Y) = "/><Run Text="{Binding DEffYText, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock Text="Symmetric: X = Y"
                                               FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="64" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="X dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Y dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="bw (mm)" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BwXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BwYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="d (mm)" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DEffXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DEffYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="k" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding KFactorXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding KFactorYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="VRd,c" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding VRdcXText}" Style="{StaticResource MetricValueStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding VRdcYText}" Style="{StaticResource MetricValueStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Links?" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LinksReqXText}" FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLinksReqX}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding LinksReqYText}" FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLinksReqY}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Step 2 — Capacity with links -->
                        <Border Background="#FAFCFF"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8"
                                Margin="0,6,0,8">
                            <StackPanel>
                                <TextBlock Text="Concrete shear capacity"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           Margin="0,0,0,4" />
                                <controls:SafeFormulaControl Formula="{Binding ConcreteFormulaLatex}"
                                                             Scale="14"
                                                             FormulaForeground="{DynamicResource TextDarkBrush}"
                                                             Margin="0,0,0,4" />
                                <controls:SafeFormulaControl Formula="{Binding ConcreteXSubLatex}"
                                                             Scale="12"
                                                             FormulaForeground="#1E64C8"
                                                             Margin="0,1,0,0" />
                                <controls:SafeFormulaControl Formula="{Binding ConcreteYSubLatex}"
                                                             Scale="12"
                                                             FormulaForeground="#1E64C8"
                                                             Margin="0,1,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Step 2 - With Reinforcement (VRd,s / VRd,max)"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   Margin="0,8,0,4" />
                        <TextBlock Text="No link data provided."
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                   Visibility="{Binding HasLinks, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                        <Grid Visibility="{Binding HasLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="64" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="X dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Y dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Asw/s" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AswSXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding AswSYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="cot θ" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CotThetaXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding CotThetaYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="VRd,s" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding VRdsXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding VRdsYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="VRd,max" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding VRdMaxXText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding VRdMaxYText}" Style="{StaticResource MetricValueStyle}" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="VRd" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding VRdXText}" Style="{StaticResource MetricValueStyle}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding VRdYText}" Style="{StaticResource MetricValueStyle}" FontWeight="SemiBold" />
                        </Grid>

                        <Border Background="#FAFCFF"
                                BorderBrush="{DynamicResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8"
                                Margin="0,6,0,8"
                                Visibility="{Binding HasLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Shear reinforcement capacity"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           Margin="0,0,0,4" />
                                <controls:SafeFormulaControl Formula="{Binding LinkAreaLatex}"
                                                             Scale="13"
                                                             FormulaForeground="{DynamicResource TextDarkBrush}" />
                                <controls:SafeFormulaControl Formula="{Binding LinkAreaSubLatex}"
                                                             Scale="12"
                                                             FormulaForeground="{DynamicResource TextMutedBrush}" />
                                <controls:SafeFormulaControl Formula="{Binding LinkSteelSubLatex}"
                                                             Scale="12"
                                                             FormulaForeground="{DynamicResource TextMutedBrush}"
                                                             Margin="0,0,0,6" />

                                <StackPanel Visibility="{Binding IsCircularHoop, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Circular hoop model - Orr-Bath"
                                               FontSize="9.5"
                                               FontWeight="SemiBold"
                                               Foreground="#1E64C8" />
                                    <controls:SafeFormulaControl Formula="{Binding CircularHoopFormulaLatex}"
                                                                 Scale="13"
                                                                 FormulaForeground="{DynamicResource TextDarkBrush}" />
                                    <controls:SafeFormulaControl Formula="{Binding CircularHoopXSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8" />
                                    <controls:SafeFormulaControl Formula="{Binding CircularHoopYSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8"
                                                                 Margin="0,0,0,6" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding IsCircularHoop, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="Rectangular leg-count model"
                                               FontSize="9.5"
                                               FontWeight="SemiBold"
                                               Foreground="#1E64C8" />
                                    <controls:SafeFormulaControl Formula="{Binding RectangularLinkFormulaLatex}"
                                                                 Scale="13"
                                                                 FormulaForeground="{DynamicResource TextDarkBrush}" />
                                    <controls:SafeFormulaControl Formula="{Binding RectangularLinkXSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8" />
                                    <controls:SafeFormulaControl Formula="{Binding RectangularLinkYSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8"
                                                                 Margin="0,0,0,6" />
                                </StackPanel>

                                <TextBlock Text="Strut limit"
                                           FontSize="9.5"
                                           FontWeight="SemiBold"
                                           Foreground="#1E64C8" />
                                <controls:SafeFormulaControl Formula="{Binding VRdMaxFormulaLatex}"
                                                             Scale="13"
                                                             FormulaForeground="{DynamicResource TextDarkBrush}" />
                                <controls:SafeFormulaControl Formula="{Binding VRdMaxXSubLatex}"
                                                             Scale="12"
                                                             FormulaForeground="#1E64C8" />
                                <controls:SafeFormulaControl Formula="{Binding VRdMaxYSubLatex}"
                                                             Scale="12"
                                                             FormulaForeground="#1E64C8" />
                            </StackPanel>
                        </Border>

                        <!-- Strut-crushing warning -->
                        <TextBlock TextWrapping="Wrap" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentRedBrush}"
                                   Margin="0,4,0,2"
                                   Text="{Binding StruttingWarningText}"
                                   Visibility="{Binding AnyStruttingCritical, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- §9.2.2(5) minimum Asw/s check -->
                        <StackPanel Visibility="{Binding HasLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Min. Asw/s  (§9.2.2(5))"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryNavyBrush}"
                                       Margin="0,6,0,3" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="X dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Y dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Prov." Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AswSXText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding AswSYText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Reqd." Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AswSMinReqdXText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding AswSMinReqdYText}" Style="{StaticResource MetricValueStyle}" />
                            </Grid>
                            <Border Background="#FAFCFF"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,6,0,4">
                                <StackPanel>
                                    <TextBlock Text="Minimum reinforcement equations"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                               Margin="0,0,0,4" />
                                    <controls:SafeFormulaControl Formula="{Binding MinAswFormulaLatex}"
                                                                 Scale="13"
                                                                 FormulaForeground="{DynamicResource TextDarkBrush}" />
                                    <controls:SafeFormulaControl Formula="{Binding MinAswXSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8" />
                                    <controls:SafeFormulaControl Formula="{Binding MinAswYSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8" />
                                </StackPanel>
                            </Border>
                            <!-- Pass / fail badges -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock FontSize="10" Margin="0,0,10,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="X: ✓ OK" />
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AswSMinPassX}" Value="False">
                                                    <Setter Property="Text" Value="X: ✗ FAIL" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Y: ✓ OK" />
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AswSMinPassY}" Value="False">
                                                    <Setter Property="Text" Value="Y: ✗ FAIL" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Utilisation (only when demand is non-zero) -->
                        <StackPanel Visibility="{Binding HasDemand, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Utilisation"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryNavyBrush}"
                                       Margin="0,8,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="X dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Y dir." FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="VEd" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VEdXText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding VEdYText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="UR" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UtilXText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding UtilYText}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Status" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StatusXText}" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsXPass}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding StatusYText}" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsYPass}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Border Background="#FAFCFF"
                                    BorderBrush="{DynamicResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="Demand check equations"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryNavyBrush}"
                                               Margin="0,0,0,4" />
                                    <controls:SafeFormulaControl Formula="{Binding UtilFormulaLatex}"
                                                                 Scale="13"
                                                                 FormulaForeground="{DynamicResource TextDarkBrush}" />
                                    <controls:SafeFormulaControl Formula="{Binding UtilXSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8" />
                                    <controls:SafeFormulaControl Formula="{Binding UtilYSubLatex}"
                                                                 Scale="12"
                                                                 FormulaForeground="#1E64C8" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Row="0"
                      Grid.RowSpan="2"
                      Grid.Column="1"
                      Width="10"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource LightBackgroundBrush}" />

        <!-- Chart area: 65% 2D charts | 35% 3D chart -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Margin="8,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="35*" />
            </Grid.ColumnDefinitions>

            <!-- Left column (65%): PM 2D + Mx-My 2D stacked -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{Binding ShowPM,   Converter={StaticResource BoolToGridLengthConverter}}" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="{Binding ShowMxMy, Converter={StaticResource BoolToGridLengthConverter}}" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ResultChartCardStyle}"
                        Visibility="{Binding ShowPM, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8" MinHeight="28">
                            <Button DockPanel.Dock="Right"
                                    Content="x"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Close viewport"
                                    Command="{Binding CloseViewportCommand}"
                                    CommandParameter="{x:Static vm:DiagramViewportType.PM2D}" />
                            <TextBlock Text="{Binding PM.DiagramTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       VerticalAlignment="Center"
                                       ToolTip="{Binding PM.DiagramTitle}" />
                        </DockPanel>
                        <Border Grid.Row="1" Style="{StaticResource ChartInlineSettingsStyle}">
                            <WrapPanel>
                                <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Labels" IsChecked="{Binding ShowLabels}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Legend" IsChecked="{Binding ShowLegend}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Demand" IsChecked="{Binding ShowDemandPoint}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="P max/min" IsChecked="{Binding ShowPmaxPmin}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Nominal" IsChecked="{Binding ShowNominalCurve}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <TextBlock Text="P step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding PStep, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}" Style="{StaticResource ChartConfigInputStyle}" />
                                <TextBlock Text="M step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding MStep, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}" Style="{StaticResource ChartConfigInputStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding ShowLegend, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="14" Height="3" Background="{DynamicResource PrimaryNavyBrush}" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="Design" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Border Width="14" Height="3" Background="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" Margin="0,0,4,2"
                                            Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Nominal"
                                               Style="{StaticResource ChartConfigLabelStyle}"
                                               Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <controls:DiagramCanvas2D Grid.Row="2"
                                                  MinHeight="220"
                                                  Points="{Binding PmAnglePoints}"
                                                  ReferenceLines="{Binding PmReferenceLines}"
                                                  XAxisLabel="{Binding PM.XAxisLabel}"
                                                  YAxisLabel="{Binding PM.YAxisLabel}"
                                                  ShowGrid="{Binding ShowGrid}"
                                                  ShowLabels="{Binding ShowLabels}"
                                                  ShowDemandPoint="{Binding ShowDemandPoint}"
                                                  ShowDemandLabel="False"
                                                  ShowReferenceLines="{Binding ShowPmaxPmin}"
                                                  ShowNominalCurve="{Binding ShowNominalCurve}"
                                                  XGridStep="{Binding MStep}"
                                                  YGridStep="{Binding PStep}"
                                                  BoundsOverride="{Binding SharedPmBounds}"
                                                  SelectedPoint="{Binding SelectedChartPoint}"
                                                  HighlightedDemandLabel="{Binding HighlightedDemandLabel}"
                                                  Ratio="{Binding PM.Ratio}"
                                                  ResetVersion="{Binding PM.ResetVersion}" />
                    </Grid>
                </Border>

                <!-- Spacer between PM and Mx-My (only takes space when both are visible) -->
                <Border Grid.Row="1"
                        Height="8"
                        Visibility="{Binding ShowMxMy, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Border Grid.Row="2"
                        Style="{StaticResource ResultChartCardStyle}"
                        Visibility="{Binding ShowMxMy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8" MinHeight="28">
                            <Button DockPanel.Dock="Right"
                                    Content="x"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Close viewport"
                                    Command="{Binding CloseViewportCommand}"
                                    CommandParameter="{x:Static vm:DiagramViewportType.MxMy2D}" />
                            <TextBlock Text="Mx-My Diagram"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <Border Grid.Row="1" Style="{StaticResource ChartInlineSettingsStyle}">
                            <WrapPanel>
                                <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Labels" IsChecked="{Binding ShowLabels}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Legend" IsChecked="{Binding ShowLegend}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Demand" IsChecked="{Binding ShowDemandPoint}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Nominal" IsChecked="{Binding ShowNominalCurve}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <CheckBox Content="Equal aspect" IsChecked="{Binding UseEqualAspectForMM}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                                <TextBlock Text="X step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding MStepX, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}" Style="{StaticResource ChartConfigInputStyle}" />
                                <TextBlock Text="Y step" Style="{StaticResource ChartConfigLabelStyle}" />
                                <TextBox Text="{Binding MStepY, UpdateSourceTrigger=PropertyChanged, Delay=500, StringFormat=F2}" Style="{StaticResource ChartConfigInputStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding ShowLegend, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border Width="14" Height="3" Background="{DynamicResource PrimaryNavyBrush}" VerticalAlignment="Center" Margin="0,0,4,2" />
                                    <TextBlock Text="Design" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                                    <Border Width="14" Height="3" Background="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" Margin="0,0,4,2"
                                            Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Nominal"
                                               Style="{StaticResource ChartConfigLabelStyle}"
                                               Visibility="{Binding IsAciCode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <controls:DiagramCanvas2D Grid.Row="2"
                                                  MinHeight="220"
                                                  Points="{Binding MxMyPoints}"
                                                  XAxisLabel="{Binding MM.XAxisLabel}"
                                                  YAxisLabel="{Binding MM.YAxisLabel}"
                                                  ShowGrid="{Binding ShowGrid}"
                                                  ShowLabels="{Binding ShowLabels}"
                                                  ShowDemandPoint="{Binding ShowDemandPoint}"
                                                  ShowDemandLabel="False"
                                                  ShowNominalCurve="{Binding ShowNominalCurve}"
                                                  UseEqualAspect="{Binding UseEqualAspectForMM}"
                                                  XGridStep="{Binding MStepX}"
                                                  YGridStep="{Binding MStepY}"
                                                  SelectedPoint="{Binding SelectedChartPoint}"
                                                  HighlightedDemandLabel="{Binding HighlightedDemandLabel}"
                                                  Ratio="{Binding MM.Ratio}"
                                                  ResetVersion="{Binding MM.ResetVersion}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Right column (35%): 3D PMM chart -->
            <Border Grid.Column="2"
                    Style="{StaticResource ResultChartCardStyle}"
                    Visibility="{Binding ShowPmm3D, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8" MinHeight="28">
                        <Button DockPanel.Dock="Right"
                                Content="x"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Close viewport"
                                Command="{Binding CloseViewportCommand}"
                                CommandParameter="{x:Static vm:DiagramViewportType.Pmm3D}" />
                        <TextBlock Text="3D PMM View"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <Border Grid.Row="1" Style="{StaticResource ChartInlineSettingsStyle}">
                        <WrapPanel>
                            <CheckBox Content="Surface" IsChecked="{Binding ShowSurface3D}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Wire" IsChecked="{Binding ShowWireframe3D}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Demand" IsChecked="{Binding ShowDemandPoint}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Grid" IsChecked="{Binding PM3D.ShowGrid}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Labels" IsChecked="{Binding PM3D.ShowLabels}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="Theta slice" IsChecked="{Binding PM3D.ShowSlicePlane}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <CheckBox Content="P slice" IsChecked="{Binding PM3D.ShowAxialLoadSlice}" Style="{StaticResource ChartConfigCheckBoxStyle}" />
                            <Button Content="Reset"
                                    Command="{Binding PM3D.ResetCameraCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    MinHeight="24"
                                    Padding="8,2"
                                    Margin="0,0,8,2" />
                            <TextBlock Text="{Binding PM3D.SelectedPmAngleLabel}" Style="{StaticResource ChartConfigLabelStyle}" Margin="0,0,8,2" />
                            <TextBlock Text="{Binding PM3D.SelectedAxialLoadLabel}" Style="{StaticResource ChartConfigLabelStyle}" />
                        </WrapPanel>
                    </Border>
                    <controls:InteractionViewport3D Grid.Row="2"
                                                   MinHeight="220"
                                                   Points="{Binding PM3D.SurfacePoints}"
                                                   DemandPoint="{Binding PM3D.DemandPoint}"
                                                   DemandPoints="{Binding PM3D.DemandPoints}"
                                                   ShowGrid="{Binding PM3D.ShowGrid}"
                                                   ShowWireframe="{Binding ShowWireframe3D}"
                                                   ShowSurface="{Binding ShowSurface3D}"
                                                   ShowLabels="{Binding PM3D.ShowLabels}"
                                                   ShowDemandPoint="{Binding ShowDemandPoint}"
                                                   UnitLabels="{Binding PM3D.UnitLabels}"
                                                   SelectedPmAngle="{Binding PM3D.SelectedPmAngle}"
                                                   SelectedAxialLoad="{Binding PM3D.SelectedAxialLoad}"
                                                   ShowSlicePlane="{Binding PM3D.ShowSlicePlane}"
                                                   ShowAxialLoadSlice="{Binding PM3D.ShowAxialLoadSlice}"
                                                   SpecialCapacityPoints="{Binding PM3D.SpecialCapacityPoints}"
                                                   ResetVersion="{Binding PM3D.ResetVersion}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
