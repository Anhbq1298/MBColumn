<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ResultTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MBColumn.Presentation.Wpf.Views"
             xmlns:converters="clr-namespace:MBColumn.Presentation.Wpf.Converters">
    <UserControl.Resources>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,5" />
        </Style>
        <Style x:Key="DetailEllipsisButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTip" Value="Open details" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="ResultRoot">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource LightBackgroundBrush}">
        <StackPanel>
            <!-- Results Summary -->
            <Border Style="{StaticResource SidebarCardStyle}">
                <StackPanel>
                    <TextBlock Text="Results Summary"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Margin="0,0,0,12" />

                    <!-- Overall Column Status Badge -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Overall Column Status"
                                   Style="{StaticResource MetricLabelStyle}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                        <Border Grid.Column="1" CornerRadius="10" Padding="12,3" HorizontalAlignment="Right">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOverallWarning}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WarningAmberSoftBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOverallFail}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding OverallStatusText}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeBody}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOverallWarning}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource WarningAmberBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOverallFail}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <Separator Margin="0,0,0,12" Background="{DynamicResource BorderSoftBrush}" />

                    <!-- Check summaries -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" MinWidth="90" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- PMM Interaction -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PMM Interaction"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           VerticalAlignment="Center" />
                                <Button Content="View Details"
                                        Style="{StaticResource DetailEllipsisButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding OpenPmmDetailsCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Max Util.: " Style="{StaticResource MetricLabelStyle}" Margin="0" />
                                <TextBlock Text="{Binding MaxUtilization, StringFormat={}{0:F3}}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDarkBrush}" />
                                <TextBlock Text=" | Critical LC: "
                                           Style="{StaticResource MetricLabelStyle}"
                                           Margin="8,0,0,0" />
                                <TextBlock Text="{Binding CriticalLoadCaseName}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="150"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDarkBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Row="0" Grid.Column="1"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Padding="8,2" CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusText}" Value="FAIL">
                                            <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusText}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeBody}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="FAIL">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Shear Capacity -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,12" DataContext="{Binding Shear}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Shear Capacity"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           VerticalAlignment="Center" />
                                <Button Content="View Details"
                                        Style="{StaticResource DetailEllipsisButtonStyle}"
                                        IsEnabled="{Binding HasResult}"
                                        Margin="8,0,0,0"
                                        Click="OpenShearDetails_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Max Util.: " Style="{StaticResource MetricLabelStyle}" Margin="0" />
                                <TextBlock Text="{Binding GoverningUtilText}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextDarkBrush}" />
                                <TextBlock Text=" | Critical LC: "
                                           Style="{StaticResource MetricLabelStyle}"
                                           Margin="8,0,0,0"
                                           Visibility="{Binding HasEnvelopeSummary, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="{Binding GoverningCaseName}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="150"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}"
                                           Visibility="{Binding HasEnvelopeSummary, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text=" (EC2 §6.2)"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Row="1" Grid.Column="1"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Padding="8,2" CornerRadius="6"
                                DataContext="{Binding Shear}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDemand}" Value="True">
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasDemand}" Value="True" />
                                                <Condition Binding="{Binding IsGoverningPass}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontWeight="Bold" FontSize="{StaticResource FontSizeBody}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="NO DEMAND" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDemand}" Value="True">
                                                <Setter Property="Text" Value="{Binding GoverningStatusText}" />
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasDemand}" Value="True" />
                                                    <Condition Binding="{Binding IsGoverningPass}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Reinforcement Compliance -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,4" DataContext="{Binding RebarCompliance}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Reinforcement Compliance"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           VerticalAlignment="Center" />
                                <Button Content="View Details"
                                        Style="{StaticResource DetailEllipsisButtonStyle}"
                                        IsEnabled="{Binding HasResult}"
                                        Margin="8,0,0,0"
                                        Click="OpenRebarComplianceDetails_Click" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding CodeRef}" Style="{StaticResource MetricLabelStyle}" Margin="0" />
                                <TextBlock Text=" – " Style="{StaticResource MetricLabelStyle}" Margin="0"
                                           Visibility="{Binding HasFails, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="{Binding FailCountText}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource WarningAmberBrush}"
                                           Visibility="{Binding HasFails, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="All checks conforming"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource SuccessGreenBrush}"
                                           Visibility="{Binding HasFails, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Row="2" Grid.Column="1"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Padding="8,2" CornerRadius="6"
                                DataContext="{Binding RebarCompliance}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AllPass}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource WarningAmberSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusText}"
                                       FontWeight="Bold"
                                       FontSize="{StaticResource FontSizeBody}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AllPass}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource WarningAmberBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    </Grid>
</UserControl>
