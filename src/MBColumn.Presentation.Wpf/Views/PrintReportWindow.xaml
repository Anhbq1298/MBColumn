<Window x:Class="MBColumn.Presentation.Wpf.Views.PrintReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Print Report"
        Width="860" Height="580"
        MinWidth="700" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource DialogWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Print Report" Style="{DynamicResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Select sections, choose an output folder, and pick a print mode."
                           Style="{DynamicResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <!-- Body: Left explorer + Right settings -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Section Explorer -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Explorer header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource PrimaryNavyBrush}"
                            Padding="10,7">
                        <TextBlock Text="Select Sections"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Select / Deselect All -->
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="8,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Select All"
                                    Command="{Binding SelectAllCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinHeight="24" Padding="8,2"
                                    FontSize="{StaticResource FontSizeBody}"
                                    Margin="0,0,6,0" />
                            <Button Content="Deselect All"
                                    Command="{Binding DeselectAllCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinHeight="24" Padding="8,2"
                                    FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Border>

                    <!-- Tree -->
                    <TreeView ItemsSource="{Binding ExplorerNodes}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.Resources>
                            <!-- Group template -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:PrintGroupNode}"
                                                      ItemsSource="{Binding Columns}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0" />
                                    <TextBlock Text="📁 " VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- Column template -->
                            <DataTemplate DataType="{x:Type vm:PrintColumnNode}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              IsThreeState="False"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0" />
                                    <TextBlock Text="📄 " VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <Border Margin="6,0,0,0" VerticalAlignment="Center"
                                            Padding="5,1"
                                            CornerRadius="6" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessGreenBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasResult}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextDarkBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Calculated" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasResult}" Value="False">
                                                            <Setter Property="Text" Value="No result" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=True}" />
                                <Setter Property="Padding" Value="4,3" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{DynamicResource BorderGreyBrush}" />

            <!-- Right: Output Settings -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,20,24,8">
                <StackPanel>

                    <!-- Output folder -->
                    <TextBlock Text="Output Folder"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Margin="0,0,0,6" />

                    <TextBlock Text="Save reports to:"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Margin="0,0,0,4" />

                    <DockPanel Margin="0,0,0,24">
                        <Button DockPanel.Dock="Right"
                                Content="Browse…"
                                Command="{Binding BrowseOutputFolderCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinHeight="30" Padding="10,4"
                                Margin="8,0,0,0" />
                        <TextBox Text="{Binding OutputFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="30"
                                 VerticalContentAlignment="Center"
                                 Padding="6,0" />
                    </DockPanel>

                    <!-- Print mode -->
                    <TextBlock Text="Print Mode"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Margin="0,0,0,10" />

                    <!-- Option 1: Individual files -->
                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,12" Margin="0,0,0,8">
                        <StackPanel>
                            <RadioButton IsChecked="{Binding IsPrintModeIndividual, Mode=TwoWay}"
                                         GroupName="PrintMode"
                                         FontWeight="SemiBold"
                                         FontSize="{StaticResource FontSizeBody}"
                                         Foreground="{DynamicResource TextDarkBrush}">
                                Print to individual files
                            </RadioButton>
                            <TextBlock Text="Each selected section is saved as a separate PDF. Every PDF has flat bookmarks for its report sections."
                                       Style="{StaticResource HelperTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="20,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Option 2: Mirror folder structure -->
                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,12" Margin="0,0,0,8">
                        <StackPanel>
                            <RadioButton IsChecked="{Binding IsPrintModeMirror, Mode=TwoWay}"
                                         GroupName="PrintMode"
                                         FontWeight="SemiBold"
                                         FontSize="{StaticResource FontSizeBody}"
                                         Foreground="{DynamicResource TextDarkBrush}">
                                Keep folder structure (mirror project explorer)
                            </RadioButton>
                            <TextBlock Text="Same as individual files, but group names become sub-folders that mirror the project explorer hierarchy."
                                       Style="{StaticResource HelperTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="20,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Option 3: Combined report -->
                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderGreyBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton IsChecked="{Binding IsPrintModeCombined, Mode=TwoWay}"
                                         GroupName="PrintMode"
                                         FontWeight="SemiBold"
                                         FontSize="{StaticResource FontSizeBody}"
                                         Foreground="{DynamicResource TextDarkBrush}">
                                Compile combined report
                            </RadioButton>
                            <TextBlock Text="All sections are merged into a single PDF. The bookmark panel shows a nested tree: Group → Section → Report sub-section."
                                       Style="{StaticResource HelperTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="20,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Progress -->
                    <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,12">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource TextDarkBrush}"
                                   Margin="0,0,0,6" />
                        <ProgressBar Height="10"
                                     Minimum="0"
                                     Maximum="{Binding ProgressMax}"
                                     Value="{Binding ProgressValue}"
                                     Foreground="{DynamicResource ActionBlueBrush}"
                                     Background="{DynamicResource PanelBackgroundBrush}"
                                     BorderThickness="0" />
                    </StackPanel>

                    <!-- Status text (idle) -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                               Margin="0,0,0,16" />

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{DynamicResource DialogFooterBarStyle}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Print Report"
                        Command="{Binding PrintCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinHeight="32" Padding="18,6">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE749;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <TextBlock Text="  Print Report"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <Button Content="Close"
                        IsCancel="True"
                        Click="CloseButton_Click"
                        Style="{StaticResource DialogActionButtonStyle}"
                        MinHeight="32" Padding="14,6"
                        Margin="0,0,8,0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
