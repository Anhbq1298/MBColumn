<Window x:Class="MBColumn.Presentation.Wpf.Views.AppNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MBColumn"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource BorderGreyBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource CardElevationEffect}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryNavyBrush}"
                    CornerRadius="8,8,0,0"
                    Padding="16,10">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Click="CloseButton_Click"
                            Width="24"
                            Height="24"
                            MinHeight="0"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTip="Close">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="{StaticResource IconFontFamily}"
                                   FontSize="10"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <TextBlock x:Name="TitleTextBlock"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeSection}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18,18,18,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="IconCircle"
                        Width="42"
                        Height="42"
                        CornerRadius="21"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="IconTextBlock"
                               FontFamily="{StaticResource IconFontFamily}"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="MessageTextBlock"
                           Grid.Column="1"
                           Margin="14,0,0,0"
                           Foreground="{DynamicResource TextDarkBrush}"
                           FontSize="{StaticResource FontSizeBody}"
                           TextWrapping="Wrap"
                           LineHeight="18"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource LightBackgroundBrush}"
                    CornerRadius="0,0,8,8"
                    BorderBrush="{DynamicResource BorderGreyBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="NoButton"
                            Content="No"
                            Click="NoButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="88"
                            MinHeight="30"
                            Padding="14,5"
                            Margin="0,0,8,0" />
                    <Button x:Name="YesButton"
                            Content="Yes"
                            Click="YesButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="88"
                            MinHeight="30"
                            Padding="14,5"
                            Margin="0,0,8,0" />
                    <Button x:Name="OkButton"
                            Content="OK"
                            Click="OkButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="88"
                            MinHeight="30"
                            Padding="14,5" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
