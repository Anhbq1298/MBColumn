<Window x:Class="MBColumn.Presentation.Wpf.Views.ResultDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Result Details"
        Width="760"
        Height="820"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource LightBackgroundBrush}">
    <Grid Margin="10">
        <ContentControl x:Name="DetailHost"
                        Opacity="0" />

        <Border x:Name="LoadingOverlay"
                Background="{DynamicResource LightBackgroundBrush}"
                BorderBrush="{DynamicResource BorderSoftBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="260">
            <StackPanel>
                <TextBlock Text="Rendering equations..."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryNavyBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />
                <ProgressBar Height="6"
                             IsIndeterminate="True"
                             MinWidth="220" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
