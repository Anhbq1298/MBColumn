<UserControl x:Class="MBColumn.Presentation.Wpf.Views.ShearDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MBColumn.Presentation.Wpf.Controls"
             FontFamily="{StaticResource AppFontFamily}">
    <UserControl.Resources>
        <!--
            LOCAL STYLES — all font sizes reference Theme.Tokens.xaml keys.
            New views should follow this pattern: never hardcode numeric sizes.

            Body text   → FontSizeBody    (12)
            Headers     → FontSizeSection (14)
            Formulas    → FontSizeFormula (12)  ← SafeFormulaControl Scale attribute
        -->
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,5" />
        </Style>

        <Style x:Key="FormulaPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LightBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,6,0,10" />
        </Style>

        <Style x:Key="DetailSubheadStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeSection}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,8,0,6" />
        </Style>

        <Style x:Key="DirectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource SidebarCardStyle}">
            <StackPanel>
                <TextBlock Text="Shear Check in Details (EC2 &#x00A7;6.2)"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="0,0,0,4" />

                <!-- Envelope Summary -->
                <TextBlock Text="Envelope Summary"
                           Style="{StaticResource DetailSubheadStyle}"
                           Visibility="{Binding HasEnvelopeSummary, Converter={StaticResource BoolToVisibilityConverter}}" />

                <DataGrid ItemsSource="{Binding EnvelopeSummaryRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          RowHeaderWidth="0"
                          Margin="0,0,0,8"
                          MinHeight="82"
                          MaxHeight="120"
                          Visibility="{Binding HasEnvelopeSummary, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGoverning}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Envelope" Binding="{Binding Direction}" Width="1.1*" />
                        <DataGridTextColumn Header="Combo" Binding="{Binding CaseName}" Width="1.2*" />
                        <DataGridTextColumn Header="Demand" Binding="{Binding DemandText}" Width="*" />
                        <DataGridTextColumn Header="Capacity" Binding="{Binding CapacityText}" Width="*" />
                        <DataGridTextColumn Header="Ratio" Binding="{Binding RatioText}" Width="0.8*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="0.8*" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasDemand, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Padding="10,2" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessGreenSoftBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGoverningPass}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource DangerRedSoftBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding GoverningStatusText}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGoverningPass}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentRedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="{Binding GoverningUtilText, StringFormat='  Governing ratio = {0}'}"
                               Style="{StaticResource MetricValueStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock FontSize="{StaticResource FontSizeBody}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,8">
                    The summary uses the envelope shear demand from all included combinations. Detailed checks below use the governing envelope.
                </TextBlock>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- Step 1 - Without Reinforcement (VRd,c)                    -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <TextBlock Text="Step 1 - Without Reinforcement (VRd,c)" Style="{StaticResource DetailSubheadStyle}" />
                <Border Style="{StaticResource FormulaPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Concrete shear capacity" Style="{StaticResource DetailSubheadStyle}" Margin="0,0,0,5" />
                        <!-- Shared formula shown once -->
                        <controls:SafeFormulaControl Formula="{Binding ConcreteFormulaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource PrimaryNavyBrush}"
                                                     Margin="0,0,0,8" />

                        <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" />
                        <controls:SafeFormulaControl Formula="{Binding ConcreteXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource TextDarkBrush}"
                                                     Margin="10,0,0,0" />

                        <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                        <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                        <controls:SafeFormulaControl Formula="{Binding ConcreteYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource TextDarkBrush}"
                                                     Margin="10,0,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding HasDemand, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource FormulaPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" Margin="0,0,0,2" />
                            <controls:SafeFormulaControl Formula="{Binding Step1UtilXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                            <TextBlock Text="&#x2714; Shear reinforcement not required"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessGreenBrush}"
                                       Margin="10,5,0,0"
                                       Visibility="{Binding ShowLinksNotRequiredX, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Text="&#x26A0; Links required"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="10,5,0,0"
                                       Visibility="{Binding ShowLinksRequiredX, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                            <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding Step1UtilYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                            <TextBlock Text="&#x2714; Shear reinforcement not required"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessGreenBrush}"
                                       Margin="10,5,0,0"
                                       Visibility="{Binding ShowLinksNotRequiredY, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Text="&#x26A0; Links required"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="10,5,0,0"
                                       Visibility="{Binding ShowLinksRequiredY, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- Step 2 - With Reinforcement (VRd,s / VRd,max)             -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <TextBlock Text="Step 2 - With Reinforcement (VRd,s / VRd,max)" Style="{StaticResource DetailSubheadStyle}" />
                <TextBlock Text="No link data provided."
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Visibility="{Binding HasLinks, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                <Border Style="{StaticResource FormulaPanelStyle}"
                        Visibility="{Binding HasLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Shear reinforcement capacity" Style="{StaticResource DetailSubheadStyle}" Margin="0,0,0,5" />

                        <!-- Shared: circular hoop area (if applicable) -->
                        <StackPanel Visibility="{Binding IsCircularHoop, Converter={StaticResource BoolToVisibilityConverter}}">
                            <controls:SafeFormulaControl Formula="{Binding LinkAreaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource PrimaryNavyBrush}" />
                            <controls:SafeFormulaControl Formula="{Binding LinkAreaSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}" />
                        </StackPanel>

                        <!-- Shared: steel properties -->
                        <controls:SafeFormulaControl Formula="{Binding LinkSteelSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource TextDarkBrush}"
                                                     Margin="0,0,0,8" />

                        <!-- Circular hoop model -->
                        <StackPanel Visibility="{Binding IsCircularHoop, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Circular hoop model - Orr-Bath"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryNavyBrush}" />
                            <!-- Shared formula once -->
                            <controls:SafeFormulaControl Formula="{Binding CircularHoopFormulaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource PrimaryNavyBrush}"
                                                         Margin="0,2,0,6" />

                            <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding CircularHoopXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />

                            <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                            <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding CircularHoopYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,6" />
                        </StackPanel>

                        <!-- Rectangular leg-count model -->
                        <StackPanel Visibility="{Binding IsCircularHoop, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="Rectangular leg-count model"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryNavyBrush}" />
                            <!-- Shared formula once -->
                            <controls:SafeFormulaControl Formula="{Binding RectangularLinkFormulaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource PrimaryNavyBrush}"
                                                         Margin="0,2,0,6" />

                            <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding RectangularLinkInputXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                            <controls:SafeFormulaControl Formula="{Binding RectangularLinkXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />

                            <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                            <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding RectangularLinkInputYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                            <controls:SafeFormulaControl Formula="{Binding RectangularLinkYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,6" />
                        </StackPanel>

                        <!-- Strut limit: shared formula, X/Y subs -->
                        <TextBlock Text="Strut limit"
                                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryNavyBrush}"
                                   Margin="0,8,0,2" />
                        <controls:SafeFormulaControl Formula="{Binding VRdMaxFormulaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource PrimaryNavyBrush}"
                                                     Margin="0,0,0,6" />

                        <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" />
                        <controls:SafeFormulaControl Formula="{Binding VRdMaxXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource TextDarkBrush}"
                                                     Margin="10,0,0,0" />

                        <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                        <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                        <controls:SafeFormulaControl Formula="{Binding VRdMaxYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                     FormulaForeground="{DynamicResource TextDarkBrush}"
                                                     Margin="10,0,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding HasLinksAndDemand, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource FormulaPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" Margin="0,0,0,2" />
                            <controls:SafeFormulaControl Formula="{Binding Step2UtilXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                            <TextBlock Text="&#x26A0; Section fails in shear"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="10,5,0,0"
                                       Visibility="{Binding ShowStep2FailX, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                            <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding Step2UtilYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                            <TextBlock Text="&#x26A0; Section fails in shear"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       Margin="10,5,0,0"
                                       Visibility="{Binding ShowStep2FailY, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- Minimum Asw/s (§9.2.2(5))                                 -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <StackPanel Visibility="{Binding HasLinks, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Minimum Asw/s  (&#x00A7;9.2.2(5))" Style="{StaticResource DetailSubheadStyle}" />
                    <Border Style="{StaticResource FormulaPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Minimum reinforcement equations" Style="{StaticResource DetailSubheadStyle}" Margin="0,0,0,5" />
                            <!-- Shared formula once -->
                            <controls:SafeFormulaControl Formula="{Binding MinAswFormulaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource PrimaryNavyBrush}"
                                                         Margin="0,0,0,8" />

                            <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding MinAswXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />

                            <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                            <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding MinAswYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- Utilisation                                                -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <StackPanel Visibility="{Binding ShowUtilisationPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Utilisation" Style="{StaticResource DetailSubheadStyle}" />
                    <Border Style="{StaticResource FormulaPanelStyle}">
                        <StackPanel>
                            <!-- Shared formula once -->
                            <controls:SafeFormulaControl Formula="{Binding UtilFormulaLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource PrimaryNavyBrush}"
                                                         Margin="0,0,0,8" />

                            <TextBlock Text="X direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding UtilXSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />

                            <Separator Margin="0,10,0,6" Background="{DynamicResource BorderSoftBrush}" />

                            <TextBlock Text="Y direction" Style="{StaticResource DirectionLabelStyle}" />
                            <controls:SafeFormulaControl Formula="{Binding UtilYSubLatex}" Scale="{StaticResource FontSizeFormula}"
                                                         FormulaForeground="{DynamicResource TextDarkBrush}"
                                                         Margin="10,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
