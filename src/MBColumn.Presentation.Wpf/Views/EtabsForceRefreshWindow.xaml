<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsForceRefreshWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Refresh Forces from ETABS"
        Width="900"
        Height="700"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryNavyBrush}"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="Refresh Forces from ETABS"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Text="Pull latest forces from ETABS into MBColumn. ETABS model geometry and loads are never modified."
                           FontSize="11"
                           Foreground="#BBCCE0"
                           Margin="0,3,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Main content with step panels -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left sidebar: steps + connection + settings -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                <!-- Connection status -->
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="ETABS Connection" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,6" />
                        <Button Content="Connect to ETABS"
                                Command="{Binding ConnectCommand}"
                                Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Linked sections summary -->
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="ETABS-Linked Sections" Style="{StaticResource SectionHeaderStyle}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding LinkedSectionCount}" Style="{StaticResource ValueStyle}" />
                            <TextBlock Text=" sections" Style="{StaticResource LabelStyle}" Margin="4,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SelectedComboCount}" Style="{StaticResource ValueStyle}" />
                            <TextBlock Text=" combos selected" Style="{StaticResource LabelStyle}" Margin="4,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Force source -->
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Force Source" Style="{StaticResource SectionHeaderStyle}" />
                        <RadioButton Content="Design Forces"
                                     IsChecked="{Binding UseDesignForces}"
                                     Margin="0,0,0,4" />
                        <RadioButton Content="Element Forces"
                                     IsChecked="{Binding UseElementForces}" />
                        <TextBlock Text="Design Forces are ETABS design table forces. Element Forces are analysis output forces."
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Locations -->
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Locations" Style="{StaticResource SectionHeaderStyle}" />
                        <CheckBox Content="Top" IsChecked="{Binding ImportTop}" Margin="0,0,0,4" />
                        <CheckBox Content="Bottom" IsChecked="{Binding ImportBottom}" />
                    </StackPanel>
                </Border>

                <!-- Scope -->
                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Scope" Style="{StaticResource SectionHeaderStyle}" />
                        <RadioButton Content="All linked sections"
                                     IsChecked="{Binding RefreshAllSections}"
                                     Margin="0,0,0,4" />
                        <RadioButton Content="Selected sections only"
                                     IsChecked="{Binding RefreshSelectedSectionsOnly}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right main area -->
            <Grid Grid.Column="1">
                <!-- Step 2: Combination selection (visible when not in preview step) -->
                <Grid Visibility="{Binding IsStep3, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Select Load Combinations" Style="{StaticResource SectionHeaderStyle}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Select All"
                                    Command="{Binding SelectAllCombosCommand}"
                                    Padding="8,3" Margin="0,0,6,0" />
                            <Button Content="Clear All"
                                    Command="{Binding ClearAllCombosCommand}"
                                    Padding="8,3" />
                        </StackPanel>
                        <TextBox Text="{Binding LoadComboFilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Search combinations..."
                                 Margin="0,0,0,4" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LoadCombinations}"
                             SelectionMode="Extended"
                             Name="ComboListBox"
                             SelectionChanged="OnComboListBoxSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="2" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Text="{Binding StatusMessage}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,6,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToCollapsedConverter}}" />
                </Grid>

                <!-- Step 3: Preview -->
                <Grid Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Summary cards -->
                    <Border Grid.Row="0"
                            Style="{StaticResource PanelBorderStyle}"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Force Refresh Preview" Style="{StaticResource SectionHeaderStyle}" />
                            <UniformGrid Columns="4" Margin="0,6,0,0">
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="{Binding PreviewSectionsAffected}" Style="{StaticResource ValueStyle}" />
                                    <TextBlock Text="Sections affected" Style="{StaticResource LabelStyle}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="{Binding PreviewNewRows}" Style="{StaticResource ValueStyle}" />
                                    <TextBlock Text="New load rows" Style="{StaticResource LabelStyle}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="{Binding PreviewChangedRows}" Style="{StaticResource ValueStyle}" />
                                    <TextBlock Text="Changed rows" Style="{StaticResource LabelStyle}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding PreviewAddedRows}" Style="{StaticResource ValueStyle}" />
                                    <TextBlock Text="Added rows" Style="{StaticResource LabelStyle}" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Warning banner -->
                    <Border Grid.Row="1"
                            Background="#FFF8E1"
                            BorderBrush="#FFC107"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="10,6"
                            Margin="0,0,0,8"
                            Visibility="{Binding PreviewHasWarnings, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="#7B5800" />
                    </Border>

                    <!-- Per-section table -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding SectionRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="160" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120" />
                            <DataGridTextColumn Header="Old Rows" Binding="{Binding OldRows}" Width="70" />
                            <DataGridTextColumn Header="New Rows" Binding="{Binding NewRows}" Width="70" />
                            <DataGridTextColumn Header="Changed" Binding="{Binding ChangedRows}" Width="70" />
                            <DataGridTextColumn Header="Added" Binding="{Binding AddedRows}" Width="60" />
                            <DataGridTextColumn Header="Removed" Binding="{Binding RemovedRows}" Width="70" />
                            <DataGridTextColumn Header="Action" Binding="{Binding ActionText}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Footer buttons -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderGreyBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Busy indicator -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding BusyText}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Preview Refresh"
                            Command="{Binding BuildPreviewCommand}"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsStep3, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <Button Content="Apply Refresh"
                            Command="{Binding ApplyCommand}"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="Back"
                            Padding="10,6"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibilityConverter}}"
                            Click="OnBackClick" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Padding="10,6" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
