<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="MBColumn.Presentation.Wpf.Views.EtabsForceRefreshWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MBColumn.Presentation.Wpf.ViewModels"
        Title="Re-import ETABS Forces"
        Width="820"
        Height="620"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindowStyle}">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryNavyBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="WarningPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WarningAmberSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource WarningAmberBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
    </Window.Resources>

    <Grid Style="{StaticResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource DialogHeaderBorderStyle}">
            <StackPanel>
                <TextBlock Text="Re-import ETABS Forces" Style="{StaticResource DialogHeaderTitleTextStyle}" />
                <TextBlock Text="Pull latest analytical forces from ETABS into the current MB Column Section." 
                           Style="{StaticResource DialogHeaderSubtitleTextStyle}" />
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="14" Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- ETABS Connection Panel -->
                <RowDefinition Height="Auto" /> <!-- Source Mapping Panel -->
                <RowDefinition Height="*" />    <!-- Split settings / selection list -->
            </Grid.RowDefinitions>

            <!-- ETABS Connection Panel -->
            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ETABS Connection" Style="{StaticResource SectionHeaderStyle}" Grid.Column="0" />
                        <Button Content="Reconnect ETABS" Command="{Binding ConnectCommand}" 
                                Grid.Column="1" 
                                Padding="8,2" 
                                FontSize="11" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <!-- Connected Layout -->
                    <Grid Margin="0,4,0,0" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="ConnLabel" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="ConnLabel2" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Status:" FontWeight="SemiBold" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessGreenBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="Connected" FontWeight="SemiBold" Foreground="{DynamicResource SuccessGreenBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="Model:" FontWeight="SemiBold" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ModelName}" TextTrimming="CharacterEllipsis" Grid.Row="0" Grid.Column="5" VerticalAlignment="Center" ToolTip="{Binding ModelPath}" />

                        <TextBlock Text="Units:" FontWeight="SemiBold" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PresentUnits}" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />

                        <TextBlock Text="Current MB Section:" FontWeight="SemiBold" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentSectionName}" Grid.Row="2" Grid.Column="5" VerticalAlignment="Center" />

                        <TextBlock Text="Source Metadata ID:" FontWeight="SemiBold" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MetadataId}" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="4" VerticalAlignment="Center" />
                    </Grid>
                    <!-- Model Mismatch Warning -->
                    <Border Style="{StaticResource WarningPanelStyle}"
                            Visibility="{Binding HasModelMismatchWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="!" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold" Foreground="{DynamicResource WarningAmberBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ModelMismatchWarning}" Foreground="{DynamicResource WarningAmberBrush}" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" Grid.Column="1" VerticalAlignment="Center" />
                            </Grid>
                            <CheckBox Content="I confirm this is the intended ETABS source model for this section."
                                      IsChecked="{Binding IsSourceModelConfirmed}"
                                      Margin="22,6,0,0"
                                      FontSize="{StaticResource FontSizeCaption}" />
                        </StackPanel>
                    </Border>

                    <!-- Disconnected Layout -->
                    <Grid Margin="0,4,0,0" Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <TextBlock Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding ConnectionStatusText}" FontWeight="SemiBold" Foreground="{DynamicResource AccentRedBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Please connect to the original ETABS model before re-importing forces." 
                                       Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="Connect / Reconnect ETABS" Command="{Binding ConnectCommand}" 
                                    Style="{StaticResource PrimaryButtonStyle}" Padding="10,4" Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Source Mapping Panel -->
            <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Source Mapping" Style="{StaticResource SectionHeaderStyle}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="MapLabel" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="MapLabel2" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Imported from ETABS:" FontWeight="SemiBold" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ImportedFromEtabs}" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" />

                        <TextBlock Text="Metadata ID:" FontWeight="SemiBold" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MetadataId}" Grid.Row="0" Grid.Column="5" VerticalAlignment="Center" />

                        <TextBlock Text="Column/Pier label:" FontWeight="SemiBold" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ColumnLabel}" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />

                        <TextBlock Text="Story range:" FontWeight="SemiBold" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StoryRange}" Grid.Row="2" Grid.Column="5" VerticalAlignment="Center" />

                        <TextBlock Text="Source story:" FontWeight="SemiBold" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SourceStory}" Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding SourceStory}" />

                        <TextBlock Text="Filter mode:" FontWeight="SemiBold" Grid.Row="4" Grid.Column="3" VerticalAlignment="Center" />
                        <TextBlock Text="Metadata-based" Grid.Row="4" Grid.Column="5" VerticalAlignment="Center" />

                        <TextBlock Text="ETABS Object Unique Names:" FontWeight="SemiBold" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding EtabsObjectIds}" Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="4" VerticalAlignment="Center" TextWrapping="Wrap" ToolTip="{Binding EtabsObjectIdsToolTip}" />

                        <TextBlock Text="{Binding SourceMappingMessage}"
                                   Grid.Row="8"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="6"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasSourceMappingMessage, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                    <Border Style="{StaticResource WarningPanelStyle}"
                            Visibility="{Binding HasMultipleFallbackCandidates, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Multiple ETABS objects match the stored XY location and story range. Please select the intended source object."
                                       Foreground="{DynamicResource WarningAmberBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding FallbackCandidates}"
                                      SelectedItem="{Binding SelectedFallbackCandidate}"
                                      DisplayMemberPath="DisplayText"
                                      MinHeight="24" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Split settings / selection list -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left Settings Column -->
                <StackPanel Grid.Column="0">
                    <!-- Force Source -->
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Force Source" Style="{StaticResource SectionHeaderStyle}" />
                            <RadioButton Content="Use Design Forces" IsChecked="{Binding UseDesignForces}" Margin="0,4" />
                            <RadioButton Content="Use Element Forces" IsChecked="{Binding UseElementForces}" Margin="0,4" />
                        </StackPanel>
                    </Border>
                    <!-- Import Behavior -->
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Import Behavior" Style="{StaticResource SectionHeaderStyle}" />
                            <RadioButton Content="Replace existing ETABS loads" IsChecked="{Binding BehaviorReplace}" Margin="0,4" />
                            <RadioButton Content="Append as new loads" IsChecked="{Binding BehaviorAppend}" Margin="0,4" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Selection List Column -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Load Selection" Style="{StaticResource SectionHeaderStyle}" />
                        
                        <!-- Load Source selection directly in Load Selection panel -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                            <CheckBox Content="Load Combinations" IsChecked="{Binding LoadCombinationsSelected}" Margin="0,0,16,0" VerticalAlignment="Center" />
                            <CheckBox Content="Load Cases" IsChecked="{Binding LoadCasesSelected}" VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid Margin="0,2,0,4">
                            <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding LoadComboFilterText, UpdateSourceTrigger=PropertyChanged}" 
                                     Tag="Search combinations and cases..." Grid.Column="0" Height="26" />
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="8,0,0,0">
                                <Button Content="Select All" Command="{Binding SelectAllCombosCommand}" Padding="8,3" Margin="0,0,4,0" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Clear All" Command="{Binding ClearAllCombosCommand}" Padding="8,3" Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Virtualizing ListBox for combinations/cases -->
                    <Border Grid.Row="1" BorderThickness="1" BorderBrush="{DynamicResource BorderGreyBrush}" CornerRadius="4">
                        <ListBox ItemsSource="{Binding LoadCombinations}"
                                 SelectionMode="Extended"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource PanelBackgroundBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="2" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Style="{StaticResource DialogFooterBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status / Progress -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="120"
                                 Height="8"
                                 Margin="0,0,12,0"
                                 Foreground="{DynamicResource AccentBlueBrush}"
                                 Background="{DynamicResource PanelBackgroundBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding BusyText}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}" Foreground="{DynamicResource AccentRedBrush}" TextWrapping="Wrap" MaxWidth="400" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Import" Command="{Binding ImportCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="16,6" Margin="0,0,8,0" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="16,6" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
