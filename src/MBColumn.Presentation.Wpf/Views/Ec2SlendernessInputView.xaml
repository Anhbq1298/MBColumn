                                    </Border>

                                    <!-- Row 1: Mx -->
                                    <Border Grid.Row="1" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="Mx" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding L0xText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.LambdaX, TargetNullValue=-, StringFormat=F2}" Foreground="#C62828" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.LambdaLimitX, TargetNullValue=-, StringFormat=F2}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="4" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.RmX, TargetNullValue=-, StringFormat=F2}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="5" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.M2x, TargetNullValue=-, StringFormat=F2}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="6" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.MxUsed, TargetNullValue=auto, StringFormat=F2}" FontWeight="Bold" Foreground="{DynamicResource DarkNavyBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>

                                    <!-- Row 2: My -->
                                    <Border Grid.Row="2" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="My" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
