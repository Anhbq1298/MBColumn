                                        <Border Grid.Row="6" Grid.Column="2" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcCurvX" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="6" Grid.Column="3" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcCurvY" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>

                                        <Border Grid.Row="7" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <TextBlock Text="7. Moment used" TextWrapping="Wrap" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Grid.Row="7" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcMomentUsedFormula" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="7" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcMxUsed" Formula="" Scale="12" FormulaForeground="{DynamicResource DarkNavyBrush}" />
                                        </Border>
                                        <Border Grid.Row="7" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcMyUsed" Formula="" Scale="12" FormulaForeground="{DynamicResource DarkNavyBrush}" />
                                        </Border>
                                    </Grid>
                                </Expander>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.55*" />
                                        <ColumnDefinition Width="1.45*" />
                                        <ColumnDefinition Width="1.35*" />
                                        <ColumnDefinition Width="1.5*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1" Padding="4">
                                        <TextBlock Text="Axis" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1" Padding="4">
                                        <TextBlock Text="First-order end moments" TextWrapping="Wrap" TextAlignment="Center" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1" Padding="4">
                                        <TextBlock Text="Slenderness check" TextWrapping="Wrap" TextAlignment="Center" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="3" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,1,1" Padding="4">
                                        <TextBlock Text="Amplified demand" TextWrapping="Wrap" TextAlignment="Center" FontWeight="SemiBold" />
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                        <TextBlock Text="Mx" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                        <StackPanel>
                                            <controls:SafeFormulaControl x:Name="SumRmX" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                        <StackPanel>
                                            <controls:SafeFormulaControl x:Name="SumLambdaX" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                            <controls:SafeFormulaControl x:Name="SumLimitX" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" Margin="0,2,0,0" />
                                            <controls:SafeFormulaControl x:Name="SumBranchX" Formula="" Scale="11" FormulaForeground="{DynamicResource PrimaryNavyBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                        <StackPanel>
                                            <controls:SafeFormulaControl x:Name="SumCurvX" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                            <controls:SafeFormulaControl x:Name="SumMxUsed" Formula="" Scale="11" FormulaForeground="{DynamicResource DarkNavyBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                        <TextBlock Text="My" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                        <StackPanel>
                                            <controls:SafeFormulaControl x:Name="SumRmY" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                        <StackPanel>
                                            <controls:SafeFormulaControl x:Name="SumLambdaY" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                            <controls:SafeFormulaControl x:Name="SumLimitY" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" Margin="0,2,0,0" />
                                            <controls:SafeFormulaControl x:Name="SumBranchY" Formula="" Scale="11" FormulaForeground="{DynamicResource PrimaryNavyBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                        <StackPanel>
                                            <controls:SafeFormulaControl x:Name="SumCurvY" Formula="" Scale="11" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                            <controls:SafeFormulaControl x:Name="SumMyUsed" Formula="" Scale="11" FormulaForeground="{DynamicResource DarkNavyBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
</UserControl>
