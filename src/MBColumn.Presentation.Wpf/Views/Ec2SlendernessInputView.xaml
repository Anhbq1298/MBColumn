                                        <TextBlock Text="{Binding L0yText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.LambdaY, TargetNullValue=-, StringFormat=F2}" Foreground="#2E7D32" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.LambdaLimitY, TargetNullValue=-, StringFormat=F2}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="4" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.RmY, TargetNullValue=-, StringFormat=F2}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
