                                    <Border Grid.Row="2" Grid.Column="5" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.M2y, TargetNullValue=-, StringFormat=F2}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="6" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1">
                                        <TextBlock Text="{Binding SelectedLoadCase.MyUsed, TargetNullValue=auto, StringFormat=F2}" FontWeight="Bold" Foreground="{DynamicResource DarkNavyBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                </Grid>

                                <TextBlock Text="EC2 calculation details"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryNavyBrush}"
                                           Margin="0,2,0,6" />
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Flow"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,0,0,2" />
                                    <controls:SafeFormulaControl Formula="l_0=kL,\quad \lambda=\frac{l_0}{i},\quad \lambda&lt;\lambda_{lim}\Rightarrow M_2=0,\quad \lambda\geq\lambda_{lim}\Rightarrow \mathrm{nominal\;curvature}"
                                                                 Scale="12"
                                                                 FormulaForeground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="Moment Used is passed to PMM."
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <Expander Header="Step-by-step equations"
                                          IsExpanded="True"
                                          Margin="0,0,0,10">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="1.25*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1" Padding="4">
                                            <TextBlock Text="Step" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1" Padding="4">
                                            <TextBlock Text="Equation" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,0,1" Padding="4">
                                            <TextBlock Text="Mx axis" FontWeight="SemiBold" TextAlignment="Center" />
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="3" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,1,1,1" Padding="4">
                                            <TextBlock Text="My axis" FontWeight="SemiBold" TextAlignment="Center" />
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <TextBlock Text="Effective length" TextWrapping="Wrap" />
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl Formula="l_0=kL" Scale="13" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcL0x" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcL0y" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <TextBlock Text="Slenderness ratio" TextWrapping="Wrap" />
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcLambdaFormula" Formula="" Scale="13" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcLambdaX" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcLambdaY" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>

                                        <Border Grid.Row="3" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <TextBlock Text="Slenderness limit" TextWrapping="Wrap" />
                                        </Border>
                                        <Border Grid.Row="3" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcLimitFormula" Formula="" Scale="13" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="3" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcLimitX" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="3" Grid.Column="3" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,1,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcLimitY" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>

                                        <Border Grid.Row="4" Grid.Column="0" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <TextBlock Text="4. Moment ratio" TextWrapping="Wrap" />
                                        </Border>
                                        <Border Grid.Row="4" Grid.Column="1" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcRmFormula" Formula="" Scale="13" FormulaForeground="{DynamicResource TextDarkBrush}" />
                                        </Border>
                                        <Border Grid.Row="4" Grid.Column="2" Visibility="{Binding SlendernessCalculationLoadCase.IsAnyAxisSlender, Converter={StaticResource BoolToVisibilityConverter}}" BorderBrush="{DynamicResource BorderGreyBrush}" BorderThickness="1,0,0,1" Padding="4">
                                            <controls:SafeFormulaControl x:Name="CalcRmX" Formula="" Scale="12" FormulaForeground="{DynamicResource TextDarkBrush}" />
