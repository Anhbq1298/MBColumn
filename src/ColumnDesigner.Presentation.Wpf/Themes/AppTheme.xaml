                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:ColumnDesigner.Presentation.Wpf.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.Colors.xaml" />
        <ResourceDictionary Source="Theme.Typography.xaml" />
        <ResourceDictionary Source="Theme.Controls.xaml" />
        <ResourceDictionary Source="Theme.DataGrid.xaml" />
        <ResourceDictionary Source="Theme.Cards.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
</ResourceDictionary>
