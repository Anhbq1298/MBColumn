<Window x:Class="ColumnDesigner.Presentation.Wpf.ControlPointsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control Points"
        Icon="Resources/desktop-icon.png"
        Width="820" Height="560"
        MinWidth="600" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="RightAlignText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Padding" Value="0,0,4,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14" Background="{DynamicResource LightBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="ControlPointsGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAxisHeader}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderGreyBrush}" />
                            <Setter Property="BorderThickness" Value="0,1,0,0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColAboutPoint" Header="About Point"
                                    Binding="{Binding AboutPoint}" Width="130" />
                <DataGridTextColumn x:Name="ColP"          Header="P"
                                    Binding="{Binding P}" Width="90" ElementStyle="{StaticResource RightAlignText}" />
                <DataGridTextColumn x:Name="ColMx"         Header="X-Moment"
                                    Binding="{Binding Mx}" Width="90" ElementStyle="{StaticResource RightAlignText}" />
                <DataGridTextColumn x:Name="ColMy"         Header="Y-Moment"
                                    Binding="{Binding My}" Width="90" ElementStyle="{StaticResource RightAlignText}" />
                <DataGridTextColumn x:Name="ColNaDepth"    Header="NA Depth"
                                    Binding="{Binding NaDepth}" Width="90" ElementStyle="{StaticResource RightAlignText}" />
                <DataGridTextColumn x:Name="ColDtDepth"    Header="dt Depth"
                                    Binding="{Binding DtDepth}" Width="90" ElementStyle="{StaticResource RightAlignText}" />
                <DataGridTextColumn x:Name="ColEpsilonT"   Header="Îµt"
                                    Binding="{Binding EpsilonT}" Width="80" ElementStyle="{StaticResource RightAlignText}" />
                <DataGridTextColumn x:Name="ColPhi"        Header="Ï†"
                                    Binding="{Binding Phi}" Width="60" ElementStyle="{StaticResource RightAlignText}" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="1"
                Content="Close"
                Width="90"
                Margin="0,10,0,0"
                HorizontalAlignment="Right"
                Click="CloseButton_Click" />
    </Grid>
</Window>
